class PutUserHook(MethodHook):
    def __init__(self, p): self.p = weakref.ref(p)
    @safe
    def before_hooked_method(self, param):
        if not (p := self.p()) or not param.args or not (user := param.args[0]): return
        uid = getattr(user, 'id', None)
        if uid and uid in p.faked_users:
            flags = p.faked_users[uid]
            user.verified = flags.get('verified', user.verified)
            user.premium = flags.get('premium', user.premium)
            user.scam = flags.get('scam', False)
            user.fake = flags.get('fake', False)
            if flags.get('emoji_status_id'):
                try:
                    es = TLRPC.TL_emojiStatus()
                    es.document_id = jlong(int(flags['emoji_status_id']))
                    user.emoji_status = es
                except: pass

class AdminRankHook(MethodHook):
    def __init__(self, p): self.p = weakref.ref(p)
    @safe
    def after_hooked_method(self, param):
        p = self.p()
        if not p or not param.args: return
        uid = param.args[0]
        if uid in p.faked_users:
            rank = p.faked_users[uid].get('admin_title')
            if rank:
                param.setResult(rank)

class LocalRenderHook(MethodHook):
    def __init__(self, p): self.p = weakref.ref(p)
    @safe
    def before_hooked_method(self, param):
        if not (p := self.p()) or not param.args or not (m := param.args[0]): return
        if not (c := p.localChanges.get(m.getId())): return
        is_service = isinstance(m.messageOwner, TLRPC.TL_messageService)
        ents = c.get('entities') or ArrayList()
        m.messageOwner.entities = ents
        if ents.size() > 0: m.messageOwner.flags |= MsgFlags.ENTITIES
        else: m.messageOwner.flags &= ~MsgFlags.ENTITIES
        if is_service:
            m.messageText = j.android_text_SpannableStringBuilder(c.get('text', ""))
        else:
            m.messageOwner.message = c.get('text', "")
        if (f_id := c.get('from_id')):
            m.messageOwner.from_id = f_id
            m.messageOwner.flags |= MsgFlags.FROM_ID

        sender_flags = c.get('sender_flags', {})
        if sender_flags:
            acc = UserConfig.selectedAccount
            mc = MessagesController.getInstance(acc)
            from_id = c.get('from_id')
            if from_id:
                uid = getattr(from_id, 'user_id', None)
                if uid:
                    user = mc.getUser(jlong(uid))
                    if user:
                        user.verified = sender_flags.get('verified', user.verified)
                        user.premium = sender_flags.get('premium', user.premium)
                        user.scam = sender_flags.get('scam', False)
                        user.fake = sender_flags.get('fake', False)
                        if sender_flags.get('emoji_status_id'):
                            try:
                                es = TLRPC.TL_emojiStatus()
                                es.document_id = jlong(int(sender_flags['emoji_status_id']))
                                user.emoji_status = es
                            except: pass
                        mc.putUser(user, False)

                admin_title = sender_flags.get('admin_title')
                if admin_title:
                    _set_field(m.messageOwner, 'post_author', admin_title)
                    m.messageOwner.flags |= MsgFlags.POST_AUTHOR
                else:
                    _set_field(m.messageOwner, 'post_author', "")
                    m.messageOwner.flags &= ~MsgFlags.POST_AUTHOR

            admin_title = sender_flags.get('admin_title')
            if admin_title:
                _set_field(m.messageOwner, 'post_author', admin_title)
                m.messageOwner.flags |= MsgFlags.POST_AUTHOR
            else:
                _set_field(m.messageOwner, 'post_author', "")
                m.messageOwner.flags &= ~MsgFlags.POST_AUTHOR

        m.messageOwner.out = c.get('out', False)
        if m.messageOwner.out: m.messageOwner.flags |= MsgFlags.OUT
        else: m.messageOwner.flags &= ~MsgFlags.OUT

        via_bot = c.get('via_bot_name', '')
        if via_bot:
            try:
                m.messageOwner.flags |= MsgFlags.VIA_BOT_ID
                m.messageOwner.via_bot_id = int(c.get('via_bot_id', 123456))
            except: pass

        if (media := c.get('media')):
            m.messageOwner.media = media
            m.messageOwner.flags |= MsgFlags.MEDIA
            m.type = c.get('msg_type', 0)
            if (path := c.get('attach_path')): m.messageOwner.attachPath = path
            m.setType(); m.generateThumbs(False); m.createMediaThumbs(); m.checkMediaExistance()
        else:
            m.messageOwner.media = TLRPC.TL_messageMediaEmpty()
            if not is_service: m.type = 0
            m.messageOwner.flags &= ~MsgFlags.MEDIA
            m.messageOwner.attachPath = ""
            m.setType()

        custom_reply = c.get('custom_reply')
        clear_reply = c.get('clear_reply')
        if custom_reply:
            rep_tl = TLRPC.TL_message(); rep_tl.message = custom_reply.get('text', ''); rep_tl.id = 8888888; rep_tl.date = int(time.time())
            rep_peer = TLRPC.TL_peerUser(); rep_peer.user_id = 8888888; rep_tl.from_id = rep_peer
            fake_user = TLRPC.TL_user(); fake_user.id = 8888888; fake_user.first_name = custom_reply.get('name', 'Имя')
            MessagesController.getInstance(UserConfig.selectedAccount).putUser(fake_user, False)
            m.messageOwner.flags |= MsgFlags.REPLY
            header = TLRPC.TL_messageReplyHeader(); header.reply_to_msg_id = rep_tl.id; m.messageOwner.reply_to = header
            m.replyMessageObject = MessageObject(UserConfig.selectedAccount, rep_tl, False, False)
        elif clear_reply:
            m.messageOwner.flags &= ~MsgFlags.REPLY; m.messageOwner.reply_to = None; m.replyMessageObject = None

        if c.get('date'): m.messageOwner.date = c['date']
        if c.get('views'): m.messageOwner.views = c['views']; m.messageOwner.flags |= MsgFlags.VIEWS

        apply_reactions_to_mo(m.messageOwner, c.get('reactions',[]))
        if not is_service: m.applyNewText(m.messageOwner.message)
        m.resetLayout(); m.forceUpdate = True


class FakeEditor(BasePlugin):
    def __init__(self):  
        super().__init__()
        self.localChanges = {}
        self.faked_users = {}
        self.current_ps = None
        self.editingId = None
        self.editingItem = None
        self.current_sheet = None
        self.frag = None
        self.peer = None
        self._originOut = False
        self._edit_watcher = None
        self._gw_state = {'qty': '50', 'val': '12', 'hours': '24', 'txt': '', 'is_stars': False}
        self._temp_giveaway_channels =[]

    def on_plugin_load(self):
        self.add_menu_item(MenuItemData(MenuItemType.MESSAGE_CONTEXT_MENU, "Редактор", self.open_editor_sheet, "msg_edit"))
        self.add_menu_item(MenuItemData(MenuItemType.CHAT_ACTION_MENU, "Создать фейк", self.open_creator_sheet, "msg_edit"))
        if (cls := j.org_telegram_ui_Cells_ChatMessageCell):
            self.hook_all_methods(cls, "setMessageContent", LocalRenderHook(self))
        if (mc_cls := j.org_telegram_messenger_MessagesController):
            self.hook_all_methods(mc_cls, "putUser", PutUserHook(self))
        if (ca_cls := j.org_telegram_ui_ChatActivity):
            self.hook_all_methods(ca_cls, "getAdminRank", AdminRankHook(self))
        logcat(f"[{__name__}] Loaded successfully.")

    @on_ui
    def refresh_ui(self):
        if isinstance(f := get_last_fragment(), ChatActivity):
            if (lv := f.getChatListView()):
                for i in range(lv.getChildCount()):
                    if (v := lv.getChildAt(i)): v.invalidate()
                if (ad := lv.getAdapter()): ad.notifyDataSetChanged()

    def _get_ripple_drawable(self, bg_color, corner_radius_dp=0, stroke_color=None, stroke_width_dp=1):
        is_dark = Theme.isCurrentThemeDark()
        ripple_color = _ji(0x1AFFFFFF if is_dark else 0x1A000000)
        bg = GradientDrawable()
        bg.setColor(_ji(bg_color))
        if corner_radius_dp > 0:
            bg.setCornerRadius(float(dp(corner_radius_dp)))
        if stroke_color is not None:
            bg.setStroke(dp(stroke_width_dp), _ji(stroke_color))
        return RippleDrawable(ColorStateList.valueOf(ripple_color), bg, None)

    def _add_press_anim(self, view):
        class PressAnim(dynamic_proxy(View.OnTouchListener)):
            def onTouch(self, v, event):
                action = event.getAction()
                if action == MotionEvent.ACTION_DOWN:
                    v.animate().scaleX(0.96).scaleY(0.96).setDuration(100).start()
                elif action in[MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL]:
                    v.animate().scaleX(1.0).scaleY(1.0).setDuration(100).start()
                return False
        view.setOnTouchListener(PressAnim())

    def _create_dialog_input(self, ctx, hint, default_text="", input_type=1):
        try: primary_text = Theme.getColor(Theme.key_dialogTextBlack)
        except: primary_text = 0xFFFFFFFF
        try: hint_text = Theme.getColor(Theme.key_dialogTextHint)
        except: hint_text = 0xFF9CA3AF
        try: card_bg = Theme.getColor(Theme.key_windowBackgroundWhite)
        except: card_bg = 0xFF233041
        try: divider_color = Theme.getColor(Theme.key_divider)
        except: divider_color = 0x1AFFFFFF if Theme.isCurrentThemeDark() else 0x1A000000
        et = EditText(ctx)
        et.setHint(hint)
        et.setText(str(default_text))
        et.setInputType(input_type)
        et.setTextColor(_ji(primary_text))
        et.setHintTextColor(_ji(hint_text))
        bg = GradientDrawable()
        bg.setColor(_ji(card_bg))
        bg.setCornerRadius(float(dp(6)))
        bg.setStroke(dp(1), _ji(divider_color))
        et.setBackground(bg)
        et.setPadding(dp(12), dp(12), dp(12), dp(12))
        return et

    @staticmethod
    def _build_msg_obj(base_obj, ps):
        mo = clone_message_owner(base_obj.messageOwner)
        mo.out = ps.get('out', False)
        if mo.out: mo.flags |= MsgFlags.OUT
        else: mo.flags &= ~MsgFlags.OUT
        if ps.get('date'): mo.date = ps['date']
        if ps.get('views'): mo.views = ps['views']; mo.flags |= MsgFlags.VIEWS
        if ps.get('from_id'):
            mo.from_id = ps['from_id']; mo.flags |= MsgFlags.FROM_ID

        sender_flags = ps.get('sender_flags', {})
        if sender_flags and ps.get('from_id'):
            uid = getattr(ps['from_id'], 'user_id', None)
            if uid:
                mc = MessagesController.getInstance(UserConfig.selectedAccount)
                user = mc.getUser(jlong(uid))
                if user:
                    user.verified = sender_flags.get('verified', user.verified)
                    user.premium = sender_flags.get('premium', user.premium)
                    user.scam = sender_flags.get('scam', False)
                    user.fake = sender_flags.get('fake', False)
                    if sender_flags.get('emoji_status_id'):
                        try:
                            es = TLRPC.TL_emojiStatus()
                            es.document_id = jlong(int(sender_flags['emoji_status_id']))
                            user.emoji_status = es
                        except: pass
                    mc.putUser(user, False)

            admin_title = sender_flags.get('admin_title')
            if admin_title:
                _set_field(mo, 'post_author', admin_title)
                mo.flags |= MsgFlags.POST_AUTHOR
            else:
                _set_field(mo, 'post_author', "")
                mo.flags &= ~MsgFlags.POST_AUTHOR

        via_bot_name = ps.get('via_bot_name', '')
        if via_bot_name:
            try:
                mo.flags |= MsgFlags.VIA_BOT_ID
                mo.via_bot_id = int(ps.get('via_bot_id', 123456))
                via_user = TLRPC.TL_user()
                via_user.id = int(ps.get('via_bot_id', 123456))
                via_user.username = via_bot_name.lstrip('@')
                via_user.first_name = via_bot_name.lstrip('@')
                via_user.bot = True
                MessagesController.getInstance(UserConfig.selectedAccount).putUser(via_user, False)
            except: pass
        else:
            mo.flags &= ~MsgFlags.VIA_BOT_ID

        obj = MessageObject(UserConfig.selectedAccount, mo, True, True)
        custom_reply = ps.get('custom_reply')
        clear_reply = ps.get('clear_reply')
        if custom_reply:
            rep_tl = TLRPC.TL_message(); rep_tl.message = custom_reply['text']; rep_tl.id = 8888888; rep_tl.date = int(time.time())
            p_rep = TLRPC.TL_peerUser(); p_rep.user_id = int(8888888); rep_tl.from_id = p_rep
            fu = TLRPC.TL_user(); fu.id = int(8888888); fu.first_name = custom_reply['name']
            MessagesController.getInstance(UserConfig.selectedAccount).putUser(fu, False)
            mo.flags |= MsgFlags.REPLY
            hdr = TLRPC.TL_messageReplyHeader(); hdr.reply_to_msg_id = rep_tl.id; mo.reply_to = hdr
            obj.replyMessageObject = MessageObject(UserConfig.selectedAccount, rep_tl, False, False)
        elif not clear_reply and base_obj.replyMessageObject:
            obj.replyMessageObject = base_obj.replyMessageObject
            mo.flags |= MsgFlags.REPLY
            if not mo.reply_to:
                hdr = TLRPC.TL_messageReplyHeader(); hdr.reply_to_msg_id = base_obj.replyMessageObject.getId(); mo.reply_to = hdr
        else:
            mo.flags &= ~MsgFlags.REPLY; mo.reply_to = None; obj.replyMessageObject = None

        display_text = ps.get('text', "")
        if not ps.get('reactions') and not ps.get('media'): display_text += "\n\n\u200b"
        mo.message = display_text
        ents = ps.get('entities') or ArrayList(); mo.entities = ents
        if ents.size() > 0: mo.flags |= MsgFlags.ENTITIES
        else: mo.flags &= ~MsgFlags.ENTITIES
        if ps.get('media'):
            mo.media = ps['media']; mo.flags |= MsgFlags.MEDIA
            if ps.get('attach_path'): mo.attachPath = ps['attach_path']
        else:
            mo.media = TLRPC.TL_messageMediaEmpty(); mo.flags &= ~MsgFlags.MEDIA; mo.attachPath = ""
        apply_reactions_to_mo(mo, ps.get('reactions',[]))
        if ps.get('msg_type') is not None: obj.type = ps['msg_type']
        obj.resetLayout(); obj.generateThumbs(False); obj.createMediaThumbs()
        return obj

    @on_ui
    @safe
    def open_editor_sheet(self, ctx_data):
        origin = ctx_data.get("message")
        self.frag = get_last_fragment()
        if not origin or not self.frag: return
        self.peer = self.frag.getDialogId()
        self._show_sheet(origin)

    @on_ui
    @safe
    def open_creator_sheet(self, ctx_data):
        self.frag = get_last_fragment()
        if not self.frag: return
        self.peer = self.frag.getDialogId()
        self._show_sheet(None)

    def _show_sheet(self, origin):
        activity = self.frag.getParentActivity()
        if not activity: return

        acc = UserConfig.selectedAccount
        is_creation_mode = origin is None

        if is_creation_mode:
            self.editingId = None
            self._originOut = False
            
            dummy_msg = TLRPC.TL_message()
            dummy_msg.id = UserConfig.getInstance(acc).getNewMessageId()
            dummy_msg.dialog_id = self.peer
            dummy_msg.date = int(time.time())
            dummy_msg.message = ""
            dummy_msg.flags = MsgFlags.FROM_ID
            dummy_msg.out = False
            dummy_msg.peer_id = self._make_peer()
            dummy_msg.from_id = self._make_peer()
            
            origin_to_use = MessageObject(acc, dummy_msg, False, True)
            
            self.current_ps = {
                'text': "",
                'entities': ArrayList(),
                'media': None,
                'msg_type': 0,
                'from_id': dummy_msg.from_id,
                'out': False,
                '_sender_changed': True,
                'attach_path': None,
                'custom_reply': None,
                'clear_reply': False,
                'reactions':[],
                'date': dummy_msg.date,
                'views': 0,
                'sender_flags': {},
                'via_bot_name': '',
                'via_bot_id': 0,
            }
        else:
            origin_to_use = origin
            self.editingId = origin.getId()
            self._originOut = origin.isOutOwner()

            prev = self.localChanges.get(self.editingId)
            if prev:
                self.current_ps = prev.copy()
            else:
                mo = origin.messageOwner
                has_media = mo.media is not None and not isinstance(mo.media, TLRPC.TL_messageMediaEmpty)
                init_media = mo.media if has_media else None
                init_type = origin.type if has_media else 0
                init_text = str(origin.messageText).replace('\u200b', '').strip() if origin.messageText else ""
                init_path = getattr(mo, 'attachPath', None)
                if not init_path:
                    try: init_path = getattr(origin, 'attachPath', None)
                    except: pass
                my_id = UserConfig.getInstance(acc).getClientUserId()
                if origin.isOutOwner():
                    my_peer = TLRPC.TL_peerUser()
                    my_peer.user_id = int(my_id)
                    init_from_id = my_peer
                else:
                    init_from_id = mo.from_id

                existing_reactions =[]
                if mo.reactions and mo.reactions.results:
                    mc = MessagesController.getInstance(acc)
                    real_users_by_emo = {}
                    if mo.reactions.recent_reactions:
                        for rr_idx in range(mo.reactions.recent_reactions.size()):
                            pr = mo.reactions.recent_reactions.get(rr_idx)
                            if not pr or not pr.reaction or not pr.peer_id: continue
                            if isinstance(pr.reaction, TLRPC.TL_reactionEmoji):
                                emo_key = pr.reaction.emoticon
                            elif isinstance(pr.reaction, TLRPC.TL_reactionPaid):
                                emo_key = "⭐PAID"
                            else:
                                emo_key = str(pr.reaction.document_id)
                            uid = getattr(pr.peer_id, 'user_id', None)
                            if uid:
                                real_users_by_emo.setdefault(emo_key,[]).append(int(uid))
                                real_user = mc.getUser(jlong(uid))
                                if not real_user:
                                    try: mc.loadUser(jlong(uid), 0, True)
                                    except: pass
                    for rc_idx in range(mo.reactions.results.size()):
                        rc = mo.reactions.results.get(rc_idx)
                        if isinstance(rc.reaction, TLRPC.TL_reactionEmoji):
                            emo = rc.reaction.emoticon
                        elif isinstance(rc.reaction, TLRPC.TL_reactionPaid):
                            emo = "⭐PAID"
                        else:
                            emo = str(rc.reaction.document_id)
                        real_uids = real_users_by_emo.get(emo,[])[:3]
                        existing_reactions.append({'emoticon': emo, 'users': real_uids, 'display_count': rc.count})

                self.current_ps = {
                    'text': init_text,
                    'entities': mo.entities or ArrayList(),
                    'media': init_media,
                    'msg_type': init_type,
                    'from_id': init_from_id,
                    'out': False,
                    '_sender_changed': True,
                    'attach_path': init_path,
                    'custom_reply': None,
                    'clear_reply': False,
                    'reactions': existing_reactions,
                    'date': mo.date,
                    'views': getattr(mo, 'views', 0),
                    'sender_flags': {},
                    'via_bot_name': '',
                    'via_bot_id': 0,
                }

        self.editingItem = self._build_msg_obj(origin_to_use, self.current_ps)

        is_dark = Theme.isCurrentThemeDark()
        try: bg_color = Theme.getColor(Theme.key_dialogBackground)
        except: bg_color = 0xFF1F2937
        try: primary_text = Theme.getColor(Theme.key_dialogTextBlack)
        except: primary_text = 0xFFFFFFFF
        try: secondary_text = Theme.getColor(Theme.key_dialogTextGray3)
        except: secondary_text = 0xFF9CA3AF
        try: card_bg = Theme.getColor(Theme.key_windowBackgroundWhite)
        except: card_bg = 0xFF233041
        try: icon_color = Theme.getColor(Theme.key_windowBackgroundWhiteBlueIcon)
        except: icon_color = 0xFF3B82F6
        try: divider_color = Theme.getColor(Theme.key_divider)
        except: divider_color = 0x1AFFFFFF if is_dark else 0x1A000000
        tab_outline_color = _ji(0x33FFFFFF if is_dark else 0x33000000)
        active_tab_bg = _ji(blend_colors(_ji(bg_color), 0xFFFFFFFF if is_dark else 0xFF000000, 0.12))
        active_tab_text = primary_text

        sheet = BottomSheet(activity, True)
        self.current_sheet = sheet
        try: sheet.setApplyBottomPadding(False)
        except: pass
        try: sheet.getWindow().setSoftInputMode(16)
        except: pass

        root = LinearLayout(activity)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(dp(16), dp(16), dp(16), dp(16))
        root_bg = GradientDrawable()
        root_bg.setColor(_ji(bg_color))
        root_bg.setCornerRadius(float(dp(16)))
        root.setBackground(root_bg)

        header = LinearLayout(activity)
        header.setOrientation(LinearLayout.HORIZONTAL)
        header.setGravity(Gravity.CENTER_VERTICAL)
        title = TextView(activity)
        title.setText("Fake Creator" if is_creation_mode else "Fake Editor")
        title.setTextColor(_ji(primary_text))
        title.setTextSize(1, 20.0)
        title.setTypeface(AndroidUtilities.bold())
        header.addView(title, LayoutHelper.createLinear(0, -2, 1.0))
        close_btn = ImageView(activity)
        close_btn.setImageResource(get_icon_id("ic_close_white", "ic_close"))
        close_btn.setColorFilter(_ji(secondary_text))
        try: close_btn.setBackground(Theme.createSelectorDrawable(_ji(Theme.getColor(Theme.key_listSelector)), 1))
        except: pass
        close_btn.setPadding(dp(8), dp(8), dp(8), dp(8))
        close_btn.setOnClickListener(OnClickListener(lambda v: sheet.dismiss()))
        self._add_press_anim(close_btn)
        header.addView(close_btn, LayoutHelper.createLinear(36, 36))
        root.addView(header, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 16))

        tabs_container = LinearLayout(activity)
        tabs_container.setOrientation(LinearLayout.HORIZONTAL)
        tabs_bg = GradientDrawable()
        tabs_bg.setColor(0)
        tabs_bg.setCornerRadius(float(dp(24)))
        tabs_bg.setStroke(dp(1), tab_outline_color)
        tabs_container.setBackground(tabs_bg)
        tabs_container.setPadding(dp(4), dp(4), dp(4), dp(4))

        tab_views = {}
        content_views = {}
        tab_keys =["editor", "generator", "data"]
        current_tab = [None]

        def switch_tab(active_key):
            if current_tab[0] == active_key: return
            curr_idx = tab_keys.index(current_tab[0]) if current_tab[0] else -1
            new_idx = tab_keys.index(active_key)
            direction = 1 if new_idx > curr_idx else -1
            width = AndroidUtilities.displaySize.x
            for key, tv in tab_views.items():
                if key == active_key:
                    tv.setTextColor(_ji(active_tab_text))
                    active_bg = GradientDrawable()
                    active_bg.setColor(_ji(active_tab_bg))
                    active_bg.setCornerRadius(float(dp(20)))
                    tv.setBackground(active_bg)
                else:
                    tv.setTextColor(_ji(secondary_text))
                    tv.setBackground(None)
            for key, view in content_views.items():
                if key == active_key:
                    view.setVisibility(View.VISIBLE)
                    if current_tab[0] is not None:
                        view.setTranslationX(width * direction)
                        view.setAlpha(0.0)
                        view.animate().translationX(0).alpha(1.0).setDuration(250).setInterpolator(find_class("android.view.animation.DecelerateInterpolator")()).setListener(None).start()
                elif key == current_tab[0]:
                    class AnimEnd(dynamic_proxy(Runnable)):
                        def __init__(self, v): super().__init__(); self.v = v
                        def run(self): self.v.setVisibility(View.GONE)
                    view.animate().translationX(-width * direction).alpha(0.0).setDuration(250).setInterpolator(find_class("android.view.animation.DecelerateInterpolator")()).withEndAction(AnimEnd(view)).start()
                else:
                    view.setVisibility(View.GONE)
            current_tab[0] = active_key

        def create_tab(key, text):
            tv = TextView(activity)
            tv.setText(text)
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(1, 14.0)
            tv.setTypeface(AndroidUtilities.bold())
            tv.setPadding(0, dp(8), 0, dp(8))
            tv.setOnClickListener(OnClickListener(lambda v: switch_tab(key)))
            self._add_press_anim(tv)
            tab_views[key] = tv
            tabs_container.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))

        create_tab("editor", "Создатель" if is_creation_mode else "Редактор")
        create_tab("generator", "Генератор")
        create_tab("data", "Данные")
        root.addView(tabs_container, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 16))

        scroll = ScrollView(activity)
        scroll.setFillViewport(True)
        content_wrapper = FrameLayout(activity)

        def create_action_row(icon_names, title_text, subtitle_text, click_action, is_destructive=False):
            row = LinearLayout(activity)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(dp(16), dp(12), dp(16), dp(12))
            row.setBackground(self._get_ripple_drawable(0x00000000, 0))
            try: red_color = Theme.getColor(Theme.key_text_RedRegular)
            except: red_color = 0xFFE53935
            final_icon_color = red_color if is_destructive else icon_color
            icon_frame = FrameLayout(activity)
            icon_bg = GradientDrawable()
            icon_bg.setCornerRadius(float(dp(10)))
            icon_bg.setColor(_ji(final_icon_color & 0x00FFFFFF | 0x1A000000))
            icon_frame.setBackground(icon_bg)
            icon = ImageView(activity)
            res_id = get_icon_id(*icon_names)
            if res_id: icon.setImageResource(res_id)
            icon.setColorFilter(_ji(final_icon_color))
            icon_frame.addView(icon, LayoutHelper.createFrame(20, 20, Gravity.CENTER))
            row.addView(icon_frame, LayoutHelper.createLinear(36, 36, 0, 0, 16, 0))
            text_layout = LinearLayout(activity)
            text_layout.setOrientation(LinearLayout.VERTICAL)
            t_title = TextView(activity)
            t_title.setText(title_text)
            t_title.setTextColor(_ji(red_color if is_destructive else primary_text))
            t_title.setTextSize(1, 16.0)
            t_title.setTypeface(AndroidUtilities.bold())
            text_layout.addView(t_title, LayoutHelper.createLinear(-1, -2))
            if subtitle_text:
                t_sub = TextView(activity)
                t_sub.setText(subtitle_text)
                t_sub.setTextColor(_ji(secondary_text))
                t_sub.setTextSize(1, 13.0)
                text_layout.addView(t_sub, LayoutHelper.createLinear(-1, -2, 0, 2, 0, 0))
            row.addView(text_layout, LayoutHelper.createLinear(0, -2, 1.0))
            chevron = ImageView(activity)
            chevron.setImageResource(get_icon_id("arrow_right", "msg_arrowright", "ic_chevron_right"))
            chevron.setColorFilter(_ji(secondary_text))
            row.addView(chevron, LayoutHelper.createLinear(24, 24, Gravity.CENTER_VERTICAL))
            row.setOnClickListener(OnClickListener(click_action))
            self._add_press_anim(row)
            return row

        def create_section(rows):
            section = LinearLayout(activity)
            section.setOrientation(LinearLayout.VERTICAL)
            bg = GradientDrawable()
            bg.setColor(_ji(card_bg))
            bg.setCornerRadius(float(dp(14)))
            section.setBackground(bg)
            try: section.setClipToOutline(True)
            except: pass
            for i, row in enumerate(rows):
                section.addView(row, LayoutHelper.createLinear(-1, -2))
                if i < len(rows) - 1:
                    div = View(activity)
                    div.setBackgroundColor(_ji(divider_color))
                    div_lp = LayoutHelper.createLinear(-1, 1)
                    div_lp.leftMargin = dp(68)
                    section.addView(div, div_lp)
            wrapper = LinearLayout(activity)
            wrapper.setPadding(0, 0, 0, dp(16))
            wrapper.addView(section, LayoutHelper.createLinear(-1, -2))
            return wrapper

        tab_editor = LinearLayout(activity)
        tab_editor.setOrientation(LinearLayout.VERTICAL)

        bubble_frame = FrameLayout(activity)
        bubble_frame.setPadding(0, 0, 0, dp(4))

        res = get_private_field(self.frag, "sharedResources")
        thm = get_private_field(self.frag, "themeDelegate")
        cell = j.org_telegram_ui_Cells_ChatMessageCell(activity, UserConfig.selectedAccount, True, res, thm)

        stub = lambda s, *a, **kw: None
        stub_f = lambda s, *a, **kw: False
        stub_t = lambda s, *a, **kw: True

        cell.setDelegate(ProxyF.create("org.telegram.ui.Cells.ChatMessageCell$ChatMessageCellDelegate",
            getDialogId=lambda s: self.frag.getDialogId(), getSharedResources=lambda s: res, getResourcesProvider=lambda s: thm,
            getChatActivity=lambda s: self.frag, getChatMode=lambda s: 1, isChat=stub_t, canDrawOutboundsContent=stub_t,
            getProgressToNext=lambda s, c: jfloat(1.0), getProgressToPrev=lambda s, c: jfloat(1.0),
            shouldRepeatSticker=stub_t, doNotShowLoadingReply=stub_t, getTopicId=lambda s: 0, isPinnedMessage=lambda s, m: False,
            getThreadMessage=stub, getTopPinnedMessage=stub, getBottomPinnedMessage=stub, getChatStyle=stub,
            getInstantVideoPlayer=stub, getPinchToZoomHelper=stub, getPhotoPreviewPinchToZoomHelper=stub,
            getFlickerLoadingView=stub, getChatListView=stub, getPatternProvider=stub, getAdminRank=lambda s, *a: self.current_ps.get('sender_flags', {}).get('admin_title') if self.current_ps else None,
            getTextSelectionHelper=stub, getProgressLoadingBotButtonUrl=stub, getProgressLoadingLink=stub,
            didPressUrl=stub, didLongPress=stub, didPressImage=stub, videoTimerReached=stub, onDiceFinished=stub,
            didPressBotButton=stub, didPressReaction=stub, canPerformReply=stub_f, canPerformActions=stub_f,
            isTopPinnedMessageVisible=stub_f, isBottomPinnedMessageVisible=stub_f, isFirstMessage=stub_f,
            isLastMessage=stub_f, shouldShowTopicButton=stub_f, shouldShowDialogButton=stub_f, isProgressLoading=stub_f, isReplyOrSelf=stub_f, isOwner=stub_f
        ))
        cell.isChat = True
        cell.setMessageObject(self.editingItem, None, False, False, False)
        bubble_frame.addView(cell, LayoutHelper.createFrame(-1, -2))

        edit = EditText(activity)
        edit.setTextSize(1, SharedConfig.fontSize)
        edit.setTextColor(Color.TRANSPARENT)
        edit.setCursorVisible(True); edit.setBackground(None)
        edit.setGravity(Gravity.LEFT | Gravity.TOP)
        edit.setIncludeFontPadding(False)
        edit.setInputType(131073)
        edit.setFocusable(True)
        edit.setFocusableInTouchMode(True)

        class EditTouch(dynamic_proxy(View.OnTouchListener)):
            def onTouch(self, v, event):
                if event.getAction() == MotionEvent.ACTION_UP:
                    v.requestFocus()
                    run_on_ui_thread(lambda: AndroidUtilities.showKeyboard(v), 200)
                return False
        edit.setOnTouchListener(EditTouch())

        def update_edit_padding():
            has_reply = self.current_ps.get('custom_reply') is not None or (not self.current_ps.get('clear_reply') and origin_to_use.replyMessageObject is not None)
            top_padding = 75 if has_reply else 25
            is_out = self.current_ps.get('out', False)
            left_pad = 20 if is_out else 72
            right_pad = 72 if is_out else 20
            edit.setPadding(dp(left_pad), dp(top_padding), dp(right_pad), dp(10))

        update_edit_padding()

        def reconstruct_spans(txt, entities, paint):
            ssb = SpannableStringBuilder("\u200b" + txt)
            if entities:
                for i in range(entities.size()):
                    e = entities.get(i)
                    if isinstance(e, TLRPC.TL_messageEntityCustomEmoji):
                        try:
                            span = AnimatedEmojiSpan(e.document_id, paint.getFontMetricsInt())
                            ssb.setSpan(span, e.offset + 1, e.offset + 1 + e.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
                        except: pass
            return ssb

        edit.setText(reconstruct_spans(self.current_ps['text'], self.current_ps['entities'], edit.getPaint()))
        bubble_frame.addView(edit, LayoutHelper.createFrame(-1, -2))
        tab_editor.addView(bubble_frame, LayoutHelper.createLinear(-1, -2))

        fmt_scroll = HorizontalScrollView(activity)
        fmt_scroll.setHorizontalScrollBarEnabled(False)
        fmt_scroll.setPadding(dp(16), dp(4), dp(16), dp(4))
        
        fmt_layout = LinearLayout(activity)
        fmt_layout.setOrientation(LinearLayout.HORIZONTAL)
        fmt_layout.setGravity(Gravity.CENTER_VERTICAL)
        
        fmt_layout_bg = GradientDrawable()
        fmt_layout_bg.setColor(_ji(card_bg))
        fmt_layout_bg.setCornerRadius(float(dp(16)))
        fmt_layout_bg.setStroke(dp(1), _ji(divider_color))
        fmt_layout.setBackground(fmt_layout_bg)
        fmt_layout.setPadding(dp(4), dp(4), dp(4), dp(4))
        
        fmt_scroll.addView(fmt_layout, LayoutHelper.createFrame(-2, -2))

        FORMAT_TYPES =[
            ("B", "bold", TLRPC.TL_messageEntityBold),
            ("I", "italic", TLRPC.TL_messageEntityItalic),
            ("U", "underline", TLRPC.TL_messageEntityUnderline),
            ("S", "strike", TLRPC.TL_messageEntityStrike),
            ("M", "mono", TLRPC.TL_messageEntityCode),
            ("</>", "code", TLRPC.TL_messageEntityPre),
            ("||", "spoiler", TLRPC.TL_messageEntitySpoiler),
            ("🔗", "link", None),
        ]

        def apply_format(fmt_type, entity_cls):
            try:
                start = edit.getSelectionStart()
                end = edit.getSelectionEnd()
                if start < 0 or end <= start: return
                real_start = max(0, start - 1)
                real_end = max(0, end - 1)
                length = real_end - real_start
                if length <= 0: return

                def apply_and_update(ents):
                    self.current_ps['entities'] = ents
                    clean_text = edit.getText().toString().replace('\u200b', '')
                    self.current_ps['text'] = clean_text
                    mo = self.editingItem.messageOwner
                    mo.entities = ents
                    if ents.size() > 0: mo.flags |= MsgFlags.ENTITIES
                    else: mo.flags &= ~MsgFlags.ENTITIES
                    self.editingItem.applyNewText(clean_text)
                    self.editingItem.resetLayout()
                    self.editingItem.forceUpdate = True
                    cell.setMessageObject(self.editingItem, None, False, False, False)
                    cell.requestLayout()
                    cell.invalidate()

                if fmt_type == "link":
                    b2 = AlertDialogBuilder(activity)
                    b2.set_title("Вставить ссылку")
                    ll = LinearLayout(activity); ll.setOrientation(1); ll.setPadding(dp(20), dp(8), dp(20), dp(8))
                    et_url = self._create_dialog_input(activity, "https://...")
                    ll.addView(et_url, LayoutHelper.createLinear(-1, -2))
                    b2.set_view(ll)
                    def on_link_ok(d, w):
                        url = et_url.getText().toString().strip()
                        if url:
                            ent = TLRPC.TL_messageEntityTextUrl()
                            ent.offset = real_start; ent.length = length; ent.url = url
                            ents = self.current_ps.get('entities') or ArrayList()
                            ents.add(ent)
                            apply_and_update(ents)
                        d.dismiss()
                    b2.set_positive_button("ОК", on_link_ok)
                    b2.set_negative_button("Отмена", lambda d, w: d.dismiss())
                    b2.show()
                    return

                ent = entity_cls()
                ent.offset = real_start
                ent.length = length
                ents = self.current_ps.get('entities') or ArrayList()
                ents.add(ent)
                apply_and_update(ents)
            except: logcat(traceback.format_exc())

        def clear_format(v):
            self.current_ps['entities'] = ArrayList()
            clean_text = edit.getText().toString().replace('\u200b', '')
            self.current_ps['text'] = clean_text
            mo = self.editingItem.messageOwner
            mo.entities = self.current_ps['entities']
            mo.flags &= ~MsgFlags.ENTITIES
            self.editingItem.applyNewText(clean_text)
            self.editingItem.resetLayout()
            self.editingItem.forceUpdate = True
            cell.setMessageObject(self.editingItem, None, False, False, False)
            cell.requestLayout()
            cell.invalidate()

        for (label, fmt_type, entity_cls) in FORMAT_TYPES:
            btn = TextView(activity)
            btn.setText(label)
            btn.setTextSize(1, 14.0)
            btn.setTypeface(AndroidUtilities.bold())
            btn.setGravity(Gravity.CENTER)
            btn.setTextColor(_ji(primary_text))
            btn.setBackground(self._get_ripple_drawable(0x00000000, 12))
            btn.setPadding(dp(12), dp(8), dp(12), dp(8))
            btn.setOnClickListener(OnClickListener(lambda v, ft=fmt_type, ec=entity_cls: apply_format(ft, ec)))
            self._add_press_anim(btn)
            fmt_layout.addView(btn, LayoutHelper.createLinear(-2, -2))

        btn_clear_fmt = TextView(activity)
        btn_clear_fmt.setText("✕")
        btn_clear_fmt.setTextSize(1, 14.0)
        btn_clear_fmt.setTypeface(AndroidUtilities.bold())
        btn_clear_fmt.setGravity(Gravity.CENTER)
        try: btn_clear_fmt.setTextColor(_ji(Theme.getColor(Theme.key_text_RedRegular)))
        except: btn_clear_fmt.setTextColor(_ji(0xFFE53935))
        btn_clear_fmt.setBackground(self._get_ripple_drawable(0x00000000, 12))
        btn_clear_fmt.setPadding(dp(12), dp(8), dp(12), dp(8))
        btn_clear_fmt.setOnClickListener(OnClickListener(clear_format))
        self._add_press_anim(btn_clear_fmt)
        fmt_layout.addView(btn_clear_fmt, LayoutHelper.createLinear(-2, -2))

        tab_editor.addView(fmt_scroll, LayoutHelper.createLinear(-1, -2))

        dialog_ref = [None]

        def manage_reaction_dialog(r_idx):
            r_data = self.current_ps['reactions'][r_idx]
            emo = r_data['emoticon']
            users = r_data['users']
            display_count = r_data.get('display_count', len(users))
            builder = AlertDialogBuilder(activity)
            builder.set_title("Управление реакцией")
            scroll_mgr = ScrollView(activity)
            list_layout = LinearLayout(activity)
            list_layout.setOrientation(LinearLayout.VERTICAL)
            list_layout.setPadding(dp(16), dp(8), dp(16), dp(8))
            header_r = LinearLayout(activity)
            header_r.setOrientation(LinearLayout.HORIZONTAL)
            header_r.setGravity(Gravity.CENTER_VERTICAL)
            header_r.setPadding(0, dp(8), 0, dp(16))
            emo_display = emo if not emo.startswith("⭐PAID") else "⭐"
            emo_view = _create_emoji_view(activity, emo_display)
            header_r.addView(emo_view, LayoutHelper.createLinear(28, 28))
            tv_label = TextView(activity)
            tv_label.setText("  Показывать: ")
            tv_label.setTextColor(_ji(primary_text))
            tv_label.setTextSize(1, 15.0)
            header_r.addView(tv_label, LayoutHelper.createLinear(-2, -2))
            et_count = self._create_dialog_input(activity, "Кол-во", str(display_count), 2)
            et_count.setTextSize(1, 15.0)
            header_r.addView(et_count, LayoutHelper.createLinear(110, -2))
            list_layout.addView(header_r, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))
            tv_avatars_label = TextView(activity)
            tv_avatars_label.setText("Аватарки в реакции (до 3х User ID):")
            tv_avatars_label.setTextColor(_ji(secondary_text))
            tv_avatars_label.setTextSize(1, 13.0)
            list_layout.addView(tv_avatars_label, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
            user_edits =[]
            for u_idx, uid in enumerate(users):
                row = LinearLayout(activity)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(0, 0, 0, dp(8))
                et = self._create_dialog_input(activity, "User ID", str(uid), 2)
                user_edits.append((u_idx, et))
                row.addView(et, LayoutHelper.createLinear(0, -2, 1.0))
                del_btn = ImageView(activity)
                del_btn.setImageResource(get_icon_id("msg_close", "ic_close"))
                try: red_color = Theme.getColor(Theme.key_text_RedRegular)
                except: red_color = 0xFFE53935
                del_btn.setColorFilter(_ji(red_color))
                del_btn.setPadding(dp(8), dp(8), dp(8), dp(8))
                del_btn.setBackground(self._get_ripple_drawable(card_bg, 20, divider_color, 1))
                def make_del_click(r_i, u_i):
                    def on_click(v):
                        for ui, edit_v in user_edits:
                            try: self.current_ps['reactions'][r_i]['users'][ui] = int(edit_v.getText().toString())
                            except: pass
                        self.current_ps['reactions'][r_i]['users'].pop(u_i)
                        if not self.current_ps['reactions'][r_i]['users']:
                            dc = self.current_ps['reactions'][r_i].get('display_count', 0)
                            if dc <= 0: self.current_ps['reactions'].pop(r_i)
                        if dialog_ref[0]: dialog_ref[0].dismiss()
                        rebuild_and_show()
                        if self.current_ps['reactions'] and r_i < len(self.current_ps['reactions']):
                            manage_reaction_dialog(r_i)
                    return OnClickListener(on_click)
                del_btn.setOnClickListener(make_del_click(r_idx, u_idx))
                self._add_press_anim(del_btn)
                row.addView(del_btn, LayoutHelper.createLinear(40, 40, 0, 0, 8, 0))
                list_layout.addView(row, LayoutHelper.createLinear(-1, -2))
            if len(users) < 3:
                btn_add_user = TextView(activity)
                btn_add_user.setText("+ Добавить User ID")
                btn_add_user.setTextColor(_ji(icon_color))
                btn_add_user.setTextSize(1, 14.0)
                btn_add_user.setTypeface(AndroidUtilities.bold())
                btn_add_user.setPadding(0, dp(12), 0, dp(4))
                btn_add_user.setBackground(self._get_ripple_drawable(0x00000000, 8))
                def on_add_user(v):
                    mc = MessagesController.getInstance(UserConfig.selectedAccount)
                    for ui, edit_v in user_edits:
                        try:
                            new_uid = int(edit_v.getText().toString())
                            self.current_ps['reactions'][r_idx]['users'][ui] = new_uid
                            if not mc.getUser(jlong(new_uid)):
                                try: mc.loadUser(jlong(new_uid), 0, True)
                                except: pass
                        except: pass
                    self.current_ps['reactions'][r_idx]['users'].append(random.randint(10000000, 99999999))
                    if dialog_ref[0]: dialog_ref[0].dismiss()
                    manage_reaction_dialog(r_idx)
                btn_add_user.setOnClickListener(OnClickListener(on_add_user))
                self._add_press_anim(btn_add_user)
                list_layout.addView(btn_add_user, LayoutHelper.createLinear(-1, -2, 0, 4, 0, 0))
            tv_hint = TextView(activity)
            tv_hint.setText("💡 Аватарки видны в бабле до 3 человек.\nЧисло «Показывать» — счётчик на кнопке реакции.")
            tv_hint.setTextColor(_ji(secondary_text))
            tv_hint.setTextSize(1, 12.0)
            tv_hint.setPadding(0, dp(12), 0, dp(4))
            list_layout.addView(tv_hint, LayoutHelper.createLinear(-1, -2))
            scroll_mgr.addView(list_layout)
            builder.set_view(scroll_mgr)
            def on_done(d, w):
                try:
                    new_count = int(et_count.getText().toString())
                    if new_count < 0: new_count = 0
                    self.current_ps['reactions'][r_idx]['display_count'] = new_count
                except: pass
                mc = MessagesController.getInstance(UserConfig.selectedAccount)
                for ui, edit_v in user_edits:
                    try:
                        new_uid = int(edit_v.getText().toString())
                        self.current_ps['reactions'][r_idx]['users'][ui] = new_uid
                        uid_long = jlong(new_uid)
                        if not mc.getUser(uid_long):
                            stub_user = TLRPC.TL_user()
                            stub_user.id = new_uid
                            stub_user.first_name = f"id{new_uid}"
                            mc.putUser(stub_user, False)
                            try: mc.loadUser(uid_long, 0, True)
                            except: pass
                    except: pass
                rebuild_and_show()
                run_on_ui_thread(lambda: rebuild_and_show(), 1200)
                d.dismiss()
            def on_delete_reaction(d, w):
                self.current_ps['reactions'].pop(r_idx)
                rebuild_and_show()
                d.dismiss()
            builder.set_positive_button("Готово", on_done)
            builder.set_neutral_button("Удалить реакцию", on_delete_reaction)
            builder.set_negative_button("Отмена", lambda d, w: d.dismiss())
            dialog_ref[0] = builder.show()

        def open_reaction_picker(v):
            try:
                try: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False)
                except: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False, False)
                bs = BottomSheet(activity, True)
                bs.setCustomView(ev)
                def show_reaction_count_dialog(emo_val):
                    builder = AlertDialogBuilder(activity)
                    builder.set_title("Реакция выбрана!")
                    layout = LinearLayout(activity)
                    layout.setPadding(dp(20), dp(10), dp(20), dp(10))
                    input_count = self._create_dialog_input(activity, "Введите количество (например, 15)", "1", 2)
                    layout.addView(input_count, LayoutHelper.createLinear(-1, -2))
                    builder.set_view(layout)
                    def on_ok(d, w):
                        try: count = int(input_count.getText().toString().strip())
                        except: count = 1
                        if count > 0:
                            users =[random.randint(10000000, 99999999) for _ in range(min(count, 3))]
                            self.current_ps['reactions'].append({'emoticon': str(emo_val), 'users': users, 'display_count': count})
                            rebuild_and_show()
                        d.dismiss()
                    builder.set_positive_button("Добавить", on_ok)
                    builder.set_negative_button("Отмена", lambda d, w: d.dismiss())
                    builder.show()
                def on_custom_reaction(s, doc_id, doc, emo, r):
                    bs.dismiss(); show_reaction_count_dialog(str(doc_id)); return None
                def on_regular_reaction(s, e):
                    bs.dismiss(); show_reaction_count_dialog(e); return None
                ev.setDelegate(ProxyF.create("org.telegram.ui.Components.EmojiView$EmojiViewDelegate",
                    onEmojiSelected=on_regular_reaction, onCustomEmojiSelected=on_custom_reaction,
                    onStickerSelected=stub, onGifSelected=stub, onBackspace=stub_t,
                    getProgressToSearchOpened=lambda s: jfloat(0.0), isSearchOpened=stub_f, isExpanded=stub_f,
                    getDialogId=lambda s: jlong(0), getThreadId=lambda s: 0, canSchedule=stub_f, isInScheduleMode=stub_f,
                    onStickersSettingsClick=stub, onEmojiSettingsClick=stub, onStickersGroupClick=stub, onTabOpened=stub,
                    onClearEmojiRecent=stub, onShowStickerSet=stub, onStickerSetAdd=stub, onStickerSetRemove=stub,
                    onSearchOpenClose=stub, onAnimatedEmojiUnlockClick=stub, showTrendingStickersAlert=stub, invalidateEnterView=stub, isUserSelf=stub_f
                ))
                bs.show()
            except: logcat(traceback.format_exc())

        def rebuild_and_show():
            self.editingItem = self._build_msg_obj(origin_to_use, self.current_ps)
            cell.setMessageObject(self.editingItem, None, False, False, False)
            update_edit_padding()
            for i in range(tab_editor.getChildCount()):
                if tab_editor.getChildAt(i).getTag() == "__reactions_scroll__":
                    tab_editor.removeViewAt(i)
                    break
            reactions_scroll = HorizontalScrollView(activity)
            reactions_scroll.setTag("__reactions_scroll__")
            reactions_scroll.setHorizontalScrollBarEnabled(False)
            reactions_scroll.setPadding(dp(16), dp(4), dp(16), dp(8))
            reactions_layout = LinearLayout(activity)
            reactions_layout.setOrientation(LinearLayout.HORIZONTAL)
            reactions_layout.setGravity(Gravity.CENTER_VERTICAL)
            reactions_scroll.addView(reactions_layout, LayoutHelper.createFrame(-2, -2))
            for r_idx, r_data in enumerate(self.current_ps.get('reactions',[])):
                pill = LinearLayout(activity)
                pill.setOrientation(LinearLayout.HORIZONTAL)
                pill.setGravity(Gravity.CENTER_VERTICAL)
                pill.setBackground(self._get_ripple_drawable(card_bg, 16, divider_color, 1))
                pill.setPadding(dp(8), dp(4), dp(8), dp(4))
                emo_display = r_data['emoticon'] if not r_data['emoticon'].startswith("⭐PAID") else "⭐"
                emo_view = _create_emoji_view(activity, emo_display)
                pill.addView(emo_view, LayoutHelper.createLinear(20, 20))
                tv_count = TextView(activity)
                tv_count.setText(str(r_data.get('display_count', len(r_data['users']))))
                tv_count.setTextColor(_ji(primary_text))
                tv_count.setTextSize(1, 13.0)
                tv_count.setTypeface(AndroidUtilities.bold())
                tv_count.setPadding(dp(6), 0, 0, 0)
                pill.addView(tv_count, LayoutHelper.createLinear(-2, -2))
                class PillLongClick(dynamic_proxy(View.OnLongClickListener)):
                    def __init__(self, idx): super().__init__(); self.idx = idx
                    def onLongClick(self, v): manage_reaction_dialog(self.idx); return True
                pill.setOnLongClickListener(PillLongClick(r_idx))
                self._add_press_anim(pill)
                reactions_layout.addView(pill, LayoutHelper.createLinear(-2, -2, 0, 0, 8, 0))

            btn_paid = TextView(activity)
            btn_paid.setText("⭐")
            btn_paid.setTextSize(1, 18.0)
            btn_paid.setGravity(Gravity.CENTER)
            btn_paid.setBackground(self._get_ripple_drawable(card_bg, 16, divider_color, 1))
            btn_paid.setPadding(dp(6), dp(4), dp(6), dp(4))
            def on_add_paid(v):
                builder_paid = AlertDialogBuilder(activity)
                builder_paid.set_title("Платная реакция ⭐")
                layout_paid = LinearLayout(activity)
                layout_paid.setPadding(dp(20), dp(10), dp(20), dp(10))
                input_paid = self._create_dialog_input(activity, "Количество звёзд (например 8000)", "100", 2)
                layout_paid.addView(input_paid, LayoutHelper.createLinear(-1, -2))
                builder_paid.set_view(layout_paid)
                def on_ok_paid(d, w):
                    try: count_paid = int(input_paid.getText().toString().strip())
                    except: count_paid = 100
                    if count_paid > 0:
                        self.current_ps['reactions'].append({'emoticon': '⭐PAID', 'users':[], 'display_count': count_paid})
                        rebuild_and_show()
                    d.dismiss()
                builder_paid.set_positive_button("Добавить", on_ok_paid)
                builder_paid.set_negative_button("Отмена", lambda d, w: d.dismiss())
                builder_paid.show()
            btn_paid.setOnClickListener(OnClickListener(on_add_paid))
            self._add_press_anim(btn_paid)
            reactions_layout.addView(btn_paid, LayoutHelper.createLinear(32, 32, 0, 0, 4, 0))
            btn_add = ImageView(activity)
            btn_add.setImageResource(get_icon_id("msg_add"))
            btn_add.setColorFilter(_ji(icon_color))
            btn_add.setBackground(self._get_ripple_drawable(card_bg, 16, divider_color, 1))
            btn_add.setPadding(dp(6), dp(6), dp(6), dp(6))
            btn_add.setOnClickListener(OnClickListener(open_reaction_picker))
            self._add_press_anim(btn_add)
            reactions_layout.addView(btn_add, LayoutHelper.createLinear(32, 32))
            tab_editor.addView(reactions_scroll, 2, LayoutHelper.createLinear(-1, -2))
            cell.requestLayout(); cell.invalidate()

        rebuild_and_show()

        def txt_sync(tw_s, s):
            try:
                if not s or s.length() == 0: return
                if s.charAt(0) != '\u200b':
                    s.insert(0, "\u200b"); return
                raw_spans = s.getSpans(0, s.length(), AnimatedEmojiSpan)
                py_spans = sorted([(s.getSpanStart(sp), sp) for sp in raw_spans], key=lambda x: x[0])
                ents = self.current_ps.get('entities') or ArrayList()
                new_ents = ArrayList()
                for ei in range(ents.size()):
                    e = ents.get(ei)
                    if not isinstance(e, TLRPC.TL_messageEntityCustomEmoji):
                        new_ents.add(e)
                last_start = -1
                for start, span in py_spans:
                    if start == last_start: continue
                    last_start = start
                    en = TLRPC.TL_messageEntityCustomEmoji()
                    en.offset = start - 1
                    en.length = s.getSpanEnd(span) - start
                    en.document_id = span.getDocumentId()
                    new_ents.add(en)
                clean_text = s.toString().replace('\u200b', '')
                self.current_ps['text'] = clean_text
                self.current_ps['entities'] = new_ents
                mo = self.editingItem.messageOwner
                mo.message = clean_text
                mo.entities = new_ents
                if new_ents.size() > 0: mo.flags |= MsgFlags.ENTITIES
                else: mo.flags &= ~MsgFlags.ENTITIES
                self.editingItem.applyNewText(clean_text)
                self.editingItem.resetLayout()
                self.editingItem.forceUpdate = True
                cell.setMessageObject(self.editingItem, None, False, False, False)
                cell.requestLayout(); cell.invalidate()
            except: logcat(traceback.format_exc())

        self._edit_watcher = ProxyF.create("android.text.TextWatcher", beforeTextChanged=stub, onTextChanged=stub, afterTextChanged=txt_sync)
        edit.addTextChangedListener(self._edit_watcher)

        def change_sender_dialog(v):
            try:
                builder = AlertDialogBuilder(activity)
                builder.set_title("ID Отправителя")
                layout = LinearLayout(activity)
                layout.setOrientation(LinearLayout.VERTICAL)
                layout.setPadding(dp(24), dp(8), dp(24), dp(8))
                input_field = self._create_dialog_input(activity, "Введите User ID", "", 2)
                layout.addView(input_field, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
                cb_out = CheckBox(activity)
                cb_out.setText("Исходящее (от меня)")
                cb_out.setTextColor(_ji(primary_text))
                cb_out.setChecked(self.current_ps.get('out', False))
                layout.addView(cb_out)
                builder.set_view(layout)
                def on_ok(d, w):
                    try:
                        val = input_field.getText().toString().strip()
                        if val:
                            new_id = int(val)
                            peer = TLRPC.TL_peerUser(); peer.user_id = new_id
                            self.current_ps['from_id'] = peer
                        self.current_ps['out'] = cb_out.isChecked()
                        self.current_ps['_sender_changed'] = True
                        rebuild_and_show()
                    except: pass
                    d.dismiss()
                builder.set_positive_button("ОК", on_ok)
                builder.set_negative_button("Отмена", lambda d, w: d.dismiss())
                builder.show()
            except: logcat(traceback.format_exc())

        def sender_status_dialog(v):
            try:
                sf = self.current_ps.get('sender_flags', {}).copy()
                builder = AlertDialogBuilder(activity)
                builder.set_title("Статусы отправителя")
                layout = LinearLayout(activity)
                layout.setOrientation(LinearLayout.VERTICAL)
                layout.setPadding(dp(16), dp(8), dp(16), dp(8))
                
                try: red_color = Theme.getColor(Theme.key_text_RedRegular)
                except: red_color = 0xFFE53935

                def create_toggle(icon_name, text, key, color_val):
                    row = LinearLayout(activity)
                    row.setOrientation(LinearLayout.HORIZONTAL)
                    row.setGravity(Gravity.CENTER_VERTICAL)
                    row.setPadding(dp(8), dp(12), dp(8), dp(12))
                    
                    icon = ImageView(activity)
                    icon.setImageResource(get_icon_id(icon_name))
                    icon.setColorFilter(_ji(color_val))
                    row.addView(icon, LayoutHelper.createLinear(24, 24, 0, 0, 16, 0))
                    
                    tv = TextView(activity)
                    tv.setText(text)
                    tv.setTextColor(_ji(primary_text))
                    tv.setTextSize(1, 15.0)
                    row.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))
                    
                    cb = CheckBox(activity)
                    cb.setChecked(sf.get(key, False))
                    row.addView(cb, LayoutHelper.createLinear(-2, -2))
                    
                    def on_click(v):
                        cb.setChecked(not cb.isChecked())
                        sf[key] = cb.isChecked()
                    row.setOnClickListener(OnClickListener(on_click))
                    self._add_press_anim(row)
                    return row

                layout.addView(create_toggle("menu_verification", "Верификация", "verified", icon_color))
                layout.addView(create_toggle("msg_premium_badge", "Premium", "premium", 0xFFF6A531))
                layout.addView(create_toggle("msg_block2_solar", "Scam", "scam", red_color))
                layout.addView(create_toggle("left_status_profile", "Fake", "fake", red_color))

                emo_row = LinearLayout(activity)
                emo_row.setOrientation(LinearLayout.HORIZONTAL)
                emo_row.setGravity(Gravity.CENTER_VERTICAL)
                emo_row.setPadding(dp(8), dp(12), dp(8), dp(12))
                
                emo_icon = ImageView(activity)
                emo_icon.setImageResource(get_icon_id("msg_smile"))
                emo_icon.setColorFilter(_ji(icon_color))
                emo_row.addView(emo_icon, LayoutHelper.createLinear(24, 24, 0, 0, 16, 0))
                
                tv_emo = TextView(activity)
                tv_emo.setText("Эмодзи-статус")
                tv_emo.setTextColor(_ji(primary_text))
                tv_emo.setTextSize(1, 15.0)
                emo_row.addView(tv_emo, LayoutHelper.createLinear(0, -2, 1.0))
                
                emo_val_view = FrameLayout(activity)
                if sf.get('emoji_status_id'):
                    emo_val_view.addView(_create_emoji_view(activity, sf['emoji_status_id']), LayoutHelper.createFrame(24, 24))
                else:
