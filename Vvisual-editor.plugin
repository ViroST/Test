        et_dur = self._create_dialog_input(activity, "Например 120", "60", 2); layout.addView(et_dur, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
        cb_out = CheckBox(activity); cb_out.setText("Исходящий звонок"); cb_out.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack))); layout.addView(cb_out)
        cb_missed = CheckBox(activity); cb_missed.setText("Пропущенный"); cb_missed.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack))); layout.addView(cb_missed)
        builder = AlertDialogBuilder(activity); builder.set_title("Fake Call"); builder.set_view(layout)
        def on_ok(d, w):
            try: dur = int(et_dur.getText().toString())
            except: dur = 60
            self._execute_fake_call(dur, cb_out.isChecked(), cb_missed.isChecked())
