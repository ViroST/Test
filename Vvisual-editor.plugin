    def _execute_fake_bot_msg(self, text, btns_raw, bot_input, has_inline):
        acc = UserConfig.selectedAccount
        try:
            p = self._make_peer()

            try:
                bot_id = int(bot_input)
            except ValueError:
                bot_name = bot_input.lstrip('@')
                bot_id = abs(hash(bot_name)) % 999999999 if bot_name else 123456
                bot_user = TLRPC.TL_user()
                bot_user.id = int(bot_id)
                bot_user.username = bot_name
                bot_user.first_name = bot_name
                bot_user.bot = True
                MessagesController.getInstance(acc).putUser(bot_user, False)

            msg = TLRPC.TL_message(); msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            bot_peer = TLRPC.TL_peerUser(); bot_peer.user_id = int(bot_id)
            msg.peer_id = p; msg.dialog_id = int(self.peer); msg.date = int(time.time())
            msg.message = text; msg.flags = MsgFlags.FROM_ID
            msg.from_id = bot_peer
            msg.out = False; msg.unread = True

            if has_inline and btns_raw:
                markup = TLRPC.TL_replyInlineMarkup()
                markup.rows = ArrayList()
                for row_raw in btns_raw:
                    if not row_raw.strip(): continue
                    row = TLRPC.TL_keyboardButtonRow()
                    row.buttons = ArrayList()
                    for btn_txt in row_raw.split('|'):
                        btn = TLRPC.TL_keyboardButtonCallback()
                        btn.text = btn_txt.strip()
                        btn.data = bytes(btn_txt.strip(), 'utf-8')
                        row.buttons.add(btn)
                    markup.rows.add(row)
                msg.reply_markup = markup
                msg.flags |= MsgFlags.REPLY_MARKUP

            obj = MessageObject(acc, msg, False, True); lm = ArrayList(); lm.add(msg); lo = ArrayList(); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except: logcat(traceback.format_exc())

    def _giveaway_form(self, activity, sheet):
        layout = LinearLayout(activity); layout.setOrientation(1); layout.setPadding(dp(20), dp(10), dp(20), dp(10))
        ui_fields = {}
        cb_is_stars = CheckBox(activity)
        cb_is_stars.setText("Разыгрываем Звёзды (а не Premium)")
        cb_is_stars.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
        cb_is_stars.setChecked(self._gw_state['is_stars'])
        layout.addView(cb_is_stars)
        def add_input(key, label):
            tv = TextView(activity); tv.setText(label); tv.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText))); tv.setPadding(0, dp(12), 0, dp(4)); layout.addView(tv)
            et = self._create_dialog_input(activity, "", str(self._gw_state.get(key, '')), 1)
            layout.addView(et, LayoutHelper.createLinear(-1, -2)); ui_fields[key] = et
        add_input('qty', 'Количество победителей:')
        add_input('val', 'Срок Premium (мес) / Кол-во Звезд:')
        add_input('hours', 'Итоги через (часов):')
        add_input('txt', 'Доп. текст к розыгрышу:')
        btn_channels = TextView(activity)
        btn_channels.setText(f"Выбрать каналы ({len(self._temp_giveaway_channels)})")
        btn_channels.setGravity(Gravity.CENTER)
        btn_channels.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)))
        btn_channels.setPadding(0, dp(16), 0, dp(16))
        layout.addView(btn_channels, LayoutHelper.createLinear(-1, -2))
        builder = AlertDialogBuilder(activity); builder.set_title("Сгенерировать Розыгрыш"); builder.set_view(layout)
        dialog_ref = [None]
        def save_state():
            for k, v in ui_fields.items(): self._gw_state[k] = v.getText().toString()
            self._gw_state['is_stars'] = cb_is_stars.isChecked()
        def on_channels_click(v):
            save_state(); dialog_ref[0].dismiss(); sheet.dismiss()
            args = Bundle(); args.putBoolean("onlySelect", True); args.putBoolean("checkCanWrite", False); args.putInt("dialogsType", 3)
            da = DialogsActivity(args)
            def on_select(proxy, frag, dids, *args_catch):
                frag.finishFragment()
                channels =[]
                if dids:
                    for i in range(dids.size()):
                        item = dids.get(i)
                        cid = getattr(item, 'dialogId', item)
                        try: channels.append(int(cid))
                        except: pass
                self._temp_giveaway_channels = channels
                run_on_ui_thread(lambda: (self.current_sheet.show(), self._giveaway_form(activity, sheet)))
                return True
            da.setDelegate(ProxyF.create("org.telegram.ui.DialogsActivity$DialogsActivityDelegate", didSelectDialogs=on_select))
            self.frag.presentFragment(da)
        btn_channels.setOnClickListener(OnClickListener(on_channels_click))
        def on_ok(d, w):
            save_state(); self._execute_giveaway_bubble(); d.dismiss(); sheet.dismiss()
            BulletinHelper.show_success("Розыгрыш отправлен в чат!")
        builder.set_positive_button("Создать", on_ok); builder.show()
        dialog_ref[0] = builder.show()

    def _execute_giveaway_bubble(self):
        acc = UserConfig.selectedAccount
        try:
            is_stars = self._gw_state['is_stars']
            qty = int(self._gw_state.get('qty', '50'))
            val = int(self._gw_state.get('val', '12'))
            hours = int(self._gw_state.get('hours', '24'))
            lm = ArrayList(); lo = ArrayList()
            p = self._make_peer()
            svc_msg = TLRPC.TL_messageService(); svc_msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(svc_msg.id, self.peer)
            svc_msg.dialog_id = int(self.peer); svc_msg.date = int(time.time()); svc_msg.unread = True
            svc_msg.flags = MsgFlags.FROM_ID; svc_msg.peer_id = p; svc_msg.from_id = p
            svc_action = TLRPC.TL_messageActionGiveawayLaunch()
            if is_stars:
                svc_action.stars = jlong(int(val))
                svc_action.flags |= 1
            svc_msg.action = svc_action
            lm.add(svc_msg); lo.add(MessageObject(acc, svc_msg, False, True))
            media = TLRPC.TL_messageMediaGiveaway(); media.channels = ArrayList()
            for cid in self._temp_giveaway_channels: media.channels.add(jlong(abs(cid)))
            media.quantity = qty
            if is_stars:
                media.stars = jlong(int(val))
                media.flags |= 32
            else:
                media.months = int(val)
                media.flags |= 16
            media.until_date = int(time.time()) + (hours * 3600)
            msg = TLRPC.TL_message(); msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            msg.dialog_id = int(self.peer); msg.date = int(time.time()); msg.unread = True
            msg.out = False; msg.flags = MsgFlags.FROM_ID | MsgFlags.MEDIA
            msg.peer_id = p; msg.from_id = p
            msg.media = media; msg.message = self._gw_state.get('txt', ""); msg.entities = ArrayList()
            obj = MessageObject(acc, msg, False, True); obj.generateThumbs(False)
            lm.add(msg); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except: logcat(traceback.format_exc())