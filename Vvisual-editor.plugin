        tv_b = TextView(activity); tv_b.setText("Кнопки (каждая с новой строки, | = разделитель в ряду):"); tv_b.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText))); tv_b.setPadding(0, 0, 0, dp(4)); btns_container.addView(tv_b)
        et_btns = self._create_dialog_input(activity, "Кнопка 1|Кнопка 2\nКнопка 3"); et_btns.setMinLines(2); btns_container.addView(et_btns, LayoutHelper.createLinear(-1, -2))
        layout.addView(btns_container, LayoutHelper.createLinear(-1, -2))
        
        def on_cb_inline_click(v):
            btns_container.setVisibility(View.VISIBLE if cb_inline.isChecked() else View.GONE)
