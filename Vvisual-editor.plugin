class MsgFlags:
    OUT = 2
    REPLY = 8
    REPLY_MARKUP = 64
    ENTITIES = 128
    FROM_ID = 256
    MEDIA = 512
    VIEWS = 1024
    VIA_BOT_ID = 2048
    POST_AUTHOR = 65536
    HAS_REACTIONS = 1048576

class J:
    _c = {}
    def __getattr__(self, n):
        if n not in self._c: self._c[n] = find_class(n.replace('_', '.'))
        return self._c[n]
j = J()

def safe(f):
    @wraps(f)
    def w(*a, **kw):
        try: return f(*a, **kw)
        except Exception as e: logcat(f"Error in {f.__name__}: {e}\n{traceback.format_exc()}")
    return w

def on_ui(f):
    @wraps(f)
    def w(*a, **kw): run_on_ui_thread(lambda: f(*a, **kw))
    return w

def to_s32(n): return (n & 0xFFFFFFFF) - (0x100000000 if n > 0x7FFFFFFF else 0)
def dp(value): return AndroidUtilities.dp(value)
def _ji(color_val):
    c = int(color_val) & 0xFFFFFFFF
    return c - 0x100000000 if c >= 0x80000000 else c

def blend_colors(c1, c2, ratio):
    a1, r1, g1, b1 = (c1 >> 24) & 0xFF, (c1 >> 16) & 0xFF, (c1 >> 8) & 0xFF, c1 & 0xFF
    a2, r2, g2, b2 = (c2 >> 24) & 0xFF, (c2 >> 16) & 0xFF, (c2 >> 8) & 0xFF, c2 & 0xFF
    a = int(a1 + (a2 - a1) * ratio) & 0xFF
    r = int(r1 + (r2 - r1) * ratio) & 0xFF
    g = int(g1 + (g2 - g1) * ratio) & 0xFF
    b = int(b1 + (b2 - b1) * ratio) & 0xFF
    return (a << 24) | (r << 16) | (g << 8) | b

def get_val(obj, name, default=None):
    if obj is None: return default
    try: return getattr(obj, name)
    except: pass
    try:
        f = obj.getClass().getField(name)
        f.setAccessible(True)
        return f.get(obj)
    except: pass
    try:
        f = obj.getClass().getDeclaredField(name)
        f.setAccessible(True)
        return f.get(obj)
    except: pass
    return default

def _set_field(obj, field_name, value):
    if obj is None: return False
    try:
        setattr(obj, field_name, value)
        return True
    except: pass
    try:
        f = obj.getClass().getField(field_name)
        f.setAccessible(True)
        t_name = f.getType().getName()
        if t_name == "int": f.setInt(obj, int(value))
        elif t_name == "long": f.setLong(obj, int(value))
        elif t_name == "boolean": f.setBoolean(obj, bool(value))
        else: f.set(obj, value)
        return True
    except: pass
    try:
        f = obj.getClass().getDeclaredField(field_name)
        f.setAccessible(True)
        t_name = f.getType().getName()
        if t_name == "int": f.setInt(obj, int(value))
        elif t_name == "long": f.setLong(obj, int(value))
        elif t_name == "boolean": f.setBoolean(obj, bool(value))
        else: f.set(obj, value)
        return True
    except: return False

class ProxyF:
    @staticmethod
    def create(path, **methods):
        base = dynamic_proxy(j.__getattr__(path.replace('.', '_')))
        class Proxy(base):
            def __init__(self): super().__init__(); self._m = methods
            def __getattribute__(self, name):
                try:
                    m = object.__getattribute__(self, '_m')
                    if name in m: return lambda *a, **kw: m[name](self, *a, **kw)
                except: pass
                return super().__getattribute__(name)
        return Proxy()

def get_icon_id(*names):
    ctx = ApplicationLoader.applicationContext
    for n in names:
        res = ctx.getResources().getIdentifier(n, "drawable", ctx.getPackageName())
        if res: return res
    return 0

def clone_message_owner(owner):
    try:
        data = SerializedData(owner.getObjectSize())
        owner.serializeToStream(data)
        stream = SerializedData(data.toByteArray())
        magic = stream.readInt32(True)
        return TLRPC.Message.TLdeserialize(stream, magic, True)
    except Exception as e:
        m = TLRPC.TL_message()
        m.id = owner.id
        m.from_id = owner.from_id
        m.peer_id = owner.peer_id
        m.date = owner.date
        m.message = owner.message
        m.media = owner.media
        m.flags = owner.flags
        m.out = owner.out
        m.reply_to = owner.reply_to
        m.entities = owner.entities
        m.via_bot_id = getattr(owner, 'via_bot_id', 0)
        m.post_author = getattr(owner, 'post_author', "")
        m.views = getattr(owner, 'views', 0)
        return m

def apply_reactions_to_mo(mo, reactions_data):
    if not reactions_data:
        mo.flags &= ~MsgFlags.HAS_REACTIONS; mo.reactions = None; return
    mo.flags |= MsgFlags.HAS_REACTIONS
    tl_reactions = TLRPC.TL_messageReactions()
    tl_reactions.flags = 3
    tl_reactions.results = ArrayList()
    tl_reactions.recent_reactions = ArrayList()
    mc = MessagesController.getInstance(UserConfig.selectedAccount)
    for i, r_data in enumerate(reactions_data):
        emo = r_data['emoticon']
        users = r_data.get('users',[])
        count = r_data.get('display_count', len(users))
        if count == 0 and len(users) == 0: continue
        if emo.startswith("⭐PAID"):
            reaction = TLRPC.TL_reactionPaid()
        elif emo.isdigit():
            reaction = TLRPC.TL_reactionCustomEmoji()
            try: reaction.document_id = jlong(int(emo))
            except: reaction.document_id = int(emo)
        else:
            reaction = TLRPC.TL_reactionEmoji()
            reaction.emoticon = emo
        rc = TLRPC.TL_reactionCount()
        rc.reaction = reaction
        rc.count = count
        tl_reactions.results.add(rc)
        for uid in users[:3]:
            uid_long = jlong(uid)
            real_user = mc.getUser(uid_long)
            if not real_user:
                stub_user = TLRPC.TL_user()
                stub_user.id = uid
                stub_user.first_name = f"id{uid}"
                mc.putUser(stub_user, False)
                try: mc.loadUser(uid_long, 0, True)
                except: pass
            peer_react = TLRPC.TL_messagePeerReaction()
            peer_react.flags = 1
            peer_react.peer_id = TLRPC.TL_peerUser()
            peer_react.peer_id.user_id = uid
            peer_react.reaction = reaction
            tl_reactions.recent_reactions.add(peer_react)
    mo.reactions = tl_reactions

def _create_emoji_view(ctx, emo_str):
    if emo_str.startswith("⭐PAID") or emo_str == "⭐":
        tv = TextView(ctx)
        tv.setText("⭐")
        tv.setTextSize(1, 16.0)
        tv.setGravity(Gravity.CENTER)
        return tv
    if emo_str.isdigit():
        try:
            TextViewEmojis = find_class("org.telegram.ui.Components.AnimatedEmojiSpan$TextViewEmojis")
            if TextViewEmojis:
                tv = TextViewEmojis(ctx)
                tv.setTextSize(1, 16.0)
                tv.setGravity(Gravity.CENTER)
                ssb = SpannableStringBuilder(" ")
                span = AnimatedEmojiSpan(jlong(int(emo_str)), tv.getPaint().getFontMetricsInt())
                ssb.setSpan(span, 0, 1, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
                tv.setText(ssb)
                return tv
        except Exception as e: pass
        try:
            biv = find_class("org.telegram.ui.Components.BackupImageView")(ctx)
            AnimatedEmojiDrawable = find_class("org.telegram.ui.Components.AnimatedEmojiDrawable")
            doc = AnimatedEmojiDrawable.findDocument(UserConfig.selectedAccount, jlong(int(emo_str)))
            if doc:
                ImageLocation = find_class("org.telegram.messenger.ImageLocation")
                biv.setImage(ImageLocation.getForDocument(doc), "50_50", None, None, doc)
                return biv
        except Exception as e: pass
        try:
            AnimatedEmojiDrawable = find_class("org.telegram.ui.Components.AnimatedEmojiDrawable")
            drawable = AnimatedEmojiDrawable.make(UserConfig.selectedAccount, 0, jlong(int(emo_str)))
            iv = ImageView(ctx)
            iv.setImageDrawable(drawable)
            try: drawable.addView(iv)
            except: pass
            return iv
        except Exception as e: pass
        tv = TextView(ctx)
        tv.setText("?")
        tv.setTextSize(1, 16.0)
        tv.setGravity(Gravity.CENTER)
        return tv
    else:
        tv = TextView(ctx)
        tv.setText(emo_str)
        tv.setTextSize(1, 16.0)
        tv.setGravity(Gravity.CENTER)
        return tv

def get_media_info_and_thumb(path, is_video):
    w, h, duration, thumb_bytes = 0, 0, 0, None
    try:
        bitmap = None
        if is_video:
            mmr = MediaMetadataRetriever(); mmr.setDataSource(path)
            w = int(mmr.extractMetadata(18) or 0); h = int(mmr.extractMetadata(19) or 0)
            dur_ms = int(mmr.extractMetadata(9) or 0); duration = int(dur_ms / 1000)
            rotation = int(mmr.extractMetadata(24) or 0)
            if rotation in[90, 270]: w, h = h, w
            if dur_ms > 0: bitmap = mmr.getFrameAtTime(jlong(random.randint(0, dur_ms) * 1000), 2)
            if not bitmap: bitmap = mmr.getFrameAtTime()
            mmr.release()
        else:
            opts = BitmapFactory.Options(); opts.inJustDecodeBounds = True
            BitmapFactory.decodeFile(path, opts); w, h = opts.outWidth, opts.outHeight
            opts.inJustDecodeBounds = False; opts.inSampleSize = 4; bitmap = BitmapFactory.decodeFile(path, opts)
        if bitmap:
            aspect = float(w) / float(h) if h > 0 else 1.0
            thumb_w = 90 if w < h else int(90 * aspect); thumb_h = int(90 / aspect) if w < h else 90
            scaled = Bitmap.createScaledBitmap(bitmap, thumb_w, thumb_h, True)
            stream = ByteArrayOutputStream(); scaled.compress(Bitmap.CompressFormat.JPEG, 55, stream)
            thumb_bytes = stream.toByteArray()
            if scaled != bitmap: scaled.recycle()
            bitmap.recycle(); stream.close()
    except: pass
    return w or 800, h or 800, duration, thumb_bytes

