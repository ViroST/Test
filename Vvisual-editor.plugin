                    tv_none.setText("Нет")
                    tv_none.setTextColor(_ji(secondary_text))
                    emo_val_view.addView(tv_none, LayoutHelper.createFrame(-2, -2))
                emo_row.addView(emo_val_view, LayoutHelper.createLinear(-2, -2))

                def open_emoji_status_picker(v):
                    try:
                        try: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False)
                        except: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False, False)
                        bs = BottomSheet(activity, True)
                        bs.setCustomView(ev)
                        def on_custom_emoji(s, doc_id, doc, emo, r):
                            sf['emoji_status_id'] = str(doc_id)
                            self.current_ps['sender_flags'] = sf
                            rebuild_and_show()
                            bs.dismiss()
                            if dialog_ref[0]: dialog_ref[0].dismiss()
                            sender_status_dialog(None)
                            return None
                        def on_clear(s):
                            sf['emoji_status_id'] = ""
                            self.current_ps['sender_flags'] = sf
                            rebuild_and_show()
                            bs.dismiss()
                            if dialog_ref[0]: dialog_ref[0].dismiss()
                            sender_status_dialog(None)
                            return True
                        ev.setDelegate(ProxyF.create("org.telegram.ui.Components.EmojiView$EmojiViewDelegate",
                            onEmojiSelected=stub, onCustomEmojiSelected=on_custom_emoji,
                            onStickerSelected=stub, onGifSelected=stub, onBackspace=on_clear,
                            getProgressToSearchOpened=lambda s: jfloat(0.0), isSearchOpened=stub_f, isExpanded=stub_f,
                            getDialogId=lambda s: jlong(0), getThreadId=lambda s: 0, canSchedule=stub_f, isInScheduleMode=stub_f,
                            onStickersSettingsClick=stub, onEmojiSettingsClick=stub, onStickersGroupClick=stub, onTabOpened=stub,
                            onClearEmojiRecent=stub, onShowStickerSet=stub, onStickerSetAdd=stub, onStickerSetRemove=stub,
                            onSearchOpenClose=stub, onAnimatedEmojiUnlockClick=stub, showTrendingStickersAlert=stub, invalidateEnterView=stub, isUserSelf=stub_f
                        ))
                        bs.show()
                    except: logcat(traceback.format_exc())
                
                emo_row.setOnClickListener(OnClickListener(open_emoji_status_picker))
                self._add_press_anim(emo_row)
                layout.addView(emo_row)

                admin_row = LinearLayout(activity)
                admin_row.setOrientation(LinearLayout.HORIZONTAL)
                admin_row.setGravity(Gravity.CENTER_VERTICAL)
                admin_row.setPadding(dp(8), dp(12), dp(8), dp(12))
                
                admin_icon = ImageView(activity)
                admin_icon.setImageResource(get_icon_id("filled_rating_crown"))
                admin_icon.setColorFilter(_ji(0xFFF6A531))
                admin_row.addView(admin_icon, LayoutHelper.createLinear(24, 24, 0, 0, 16, 0))
                
                tv_admin = TextView(activity)
                tv_admin.setText("Должность (Админ)")
                tv_admin.setTextColor(_ji(primary_text))
                tv_admin.setTextSize(1, 15.0)
                admin_row.addView(tv_admin, LayoutHelper.createLinear(0, -2, 1.0))
                
                tv_admin_val = TextView(activity)
                tv_admin_val.setText(sf.get('admin_title', "Нет"))
                tv_admin_val.setTextColor(_ji(secondary_text))
                admin_row.addView(tv_admin_val, LayoutHelper.createLinear(-2, -2))

                def open_admin_dialog(v):
                    b2 = AlertDialogBuilder(activity)
                    b2.set_title("Должность")
                    ll = LinearLayout(activity); ll.setOrientation(1); ll.setPadding(dp(20), dp(8), dp(20), dp(8))
                    et_admin = self._create_dialog_input(activity, "Например: Администратор", sf.get('admin_title', ''))
                    ll.addView(et_admin, LayoutHelper.createLinear(-1, -2))
                    b2.set_view(ll)
                    def on_ok(d, w):
                        sf['admin_title'] = et_admin.getText().toString().strip()
                        self.current_ps['sender_flags'] = sf
                        rebuild_and_show()
                        d.dismiss()
                        if dialog_ref[0]: dialog_ref[0].dismiss()
                        sender_status_dialog(None)
                    def on_clear(d, w):
                        sf['admin_title'] = ""
                        self.current_ps['sender_flags'] = sf
                        rebuild_and_show()
                        d.dismiss()
                        if dialog_ref[0]: dialog_ref[0].dismiss()
                        sender_status_dialog(None)
                    b2.set_positive_button("ОК", on_ok)
                    b2.set_neutral_button("Убрать", on_clear)
                    b2.set_negative_button("Отмена", lambda d, w: d.dismiss())
                    b2.show()

                admin_row.setOnClickListener(OnClickListener(open_admin_dialog))
                self._add_press_anim(admin_row)
                layout.addView(admin_row)

                builder.set_view(layout)
                def on_apply(d, w):
                    self.current_ps['sender_flags'] = sf
                    rebuild_and_show()
                    d.dismiss()
                builder.set_positive_button("Применить", on_apply)
                builder.set_negative_button("Отмена", lambda d, w: d.dismiss())
                dialog_ref[0] = builder.show()
            except: logcat(traceback.format_exc())

        def change_reply_dialog(v):
            try:
                builder = AlertDialogBuilder(activity)
                builder.set_title("Изменить ответ")
                container = LinearLayout(activity); container.setOrientation(1); container.setPadding(dp(24), 0, dp(24), 0)
                input_name = self._create_dialog_input(activity, "Имя автора ответа", self.current_ps.get('custom_reply', {}).get('name', '') if self.current_ps.get('custom_reply') else '')
                input_text = self._create_dialog_input(activity, "Текст ответа", self.current_ps.get('custom_reply', {}).get('text', '') if self.current_ps.get('custom_reply') else '')
                container.addView(input_name, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
                container.addView(input_text, LayoutHelper.createLinear(-1, -2))
                builder.set_view(container)
                def on_ok(d, w):
                    name = input_name.getText().toString(); text = input_text.getText().toString()
                    if name or text:
                        self.current_ps['custom_reply'] = {'name': name, 'text': text}
                        self.current_ps['clear_reply'] = False
                    else:
                        self.current_ps['custom_reply'] = None
                        self.current_ps['clear_reply'] = True
                    rebuild_and_show(); d.dismiss()
                def on_clear(d, w):
                    self.current_ps['custom_reply'] = None; self.current_ps['clear_reply'] = True; rebuild_and_show(); d.dismiss()
                builder.set_positive_button("Применить", on_ok)
                builder.set_neutral_button("Сбросить", on_clear)
                builder.set_negative_button("Отмена", lambda d, w: d.dismiss()); builder.show()
            except: logcat(traceback.format_exc())

        def via_bot_dialog(v):
            try:
                builder = AlertDialogBuilder(activity)
                builder.set_title("Via Bot")
                layout = LinearLayout(activity); layout.setPadding(dp(24), dp(8), dp(24), dp(8))
                et = self._create_dialog_input(activity, "@username бота", self.current_ps.get('via_bot_name', ''))
                layout.addView(et, LayoutHelper.createLinear(-1, -2))
                builder.set_view(layout)
                def on_ok(d, w):
                    val = et.getText().toString().strip()
                    self.current_ps['via_bot_name'] = val
                    self.current_ps['via_bot_id'] = abs(hash(val)) % 999999999 if val else 0
                    rebuild_and_show(); d.dismiss()
                def on_clear(d, w):
                    self.current_ps['via_bot_name'] = ''; self.current_ps['via_bot_id'] = 0; rebuild_and_show(); d.dismiss()
                builder.set_positive_button("Применить", on_ok)
                builder.set_neutral_button("Убрать", on_clear)
                builder.set_negative_button("Отмена", lambda d, w: d.dismiss()); builder.show()
            except: logcat(traceback.format_exc())

        def _apply_document_media(doc, is_gif):
            try:
                media = TLRPC.TL_messageMediaDocument()
                media.document = doc
                self.current_ps['media'] = media
                self.current_ps['msg_type'] = 8 if is_gif else 13
                self.current_ps['attach_path'] = ""
                self.current_ps['text'] = ""
                self.current_ps['entities'] = ArrayList()
                rebuild_and_show()
            except: logcat(traceback.format_exc())

        def open_media_picker(v):
            try:
                try: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False)
                except: ev = EmojiView(self.frag, True, True, True, activity, True, None, None, True, thm, False, False)
                bs = BottomSheet(activity, True)
                bs.setCustomView(ev)
                def on_emoji(s, e):
                    start = edit.getSelectionStart(); end = edit.getSelectionEnd()
                    if start < 0: start = end = edit.length()
                    edit.getText().replace(min(start, end), max(start, end), e); return None
                def on_custom_emoji(s, d, doc, emo, r):
                    span = AnimatedEmojiSpan(d, edit.getPaint().getFontMetricsInt())
                    ss = SpannableString(" ")
                    ss.setSpan(span, 0, 1, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
                    start = edit.getSelectionStart(); end = edit.getSelectionEnd()
                    if start < 0: start = end = edit.length()
                    edit.getText().replace(min(start, end), max(start, end), ss); return None
                def on_sticker(s, *a):
                    for arg in a:
                        if isinstance(arg, TLRPC.Document):
                            _apply_document_media(arg, False); bs.dismiss(); return None
                    return None
                def on_gif(s, *a):
                    for arg in a:
                        doc = arg if isinstance(arg, TLRPC.Document) else getattr(arg, "document", None)
                        if doc: _apply_document_media(doc, True); bs.dismiss(); return None
                    return None
                ev.setDelegate(ProxyF.create("org.telegram.ui.Components.EmojiView$EmojiViewDelegate",
                    onEmojiSelected=on_emoji, onCustomEmojiSelected=on_custom_emoji,
                    onStickerSelected=on_sticker, onGifSelected=on_gif, onBackspace=lambda s: edit.dispatchKeyEvent(KeyEvent(0, 67)) or True,
                    getProgressToSearchOpened=lambda s: jfloat(0.0), isSearchOpened=stub_f, isExpanded=stub_f,
                    getDialogId=lambda s: jlong(0), getThreadId=lambda s: 0, canSchedule=stub_f, isInScheduleMode=stub_f,
                    onStickersSettingsClick=stub, onEmojiSettingsClick=stub, onStickersGroupClick=stub, onTabOpened=stub,
                    onClearEmojiRecent=stub, onShowStickerSet=stub, onStickerSetAdd=stub, onStickerSetRemove=stub,
                    onSearchOpenClose=stub, onAnimatedEmojiUnlockClick=stub, showTrendingStickersAlert=stub, invalidateEnterView=stub, isUserSelf=stub_f
                ))
                bs.show()
            except: logcat(traceback.format_exc())

        def open_gallery(v):
            try:
                sheet.dismiss()
                picker = PhotoAlbumPickerActivity(0, False, False, self.frag)
                def on_media(s, photos, notify, schedule):
                    if not photos or photos.isEmpty(): return
                    item = photos.get(0)
                    path = getattr(item, 'path', None) or (AndroidUtilities.getPath(item.uri) if getattr(item, 'uri', None) else None)
                    if not path or not File(path).exists(): return
                    is_video = getattr(item, 'isVideo', False)
                    run_on_ui_thread(lambda: self._apply_media_ui_internal(path, is_video, rebuild_and_show))
                picker.setDelegate(ProxyF.create("org.telegram.ui.PhotoAlbumPickerActivity$PhotoAlbumPickerActivityDelegate", didSelectPhotos=on_media, startPhotoSelectActivity=stub))
                self.frag.presentFragment(picker)
            except: logcat(traceback.format_exc())

        def reset_changes(v):
            if self.editingId in self.localChanges:
                changes = self.localChanges[self.editingId]
                if changes.get('sender_flags') and changes.get('from_id'):
                    uid = getattr(changes['from_id'], 'user_id', None)
                    if uid:
                        try: MessagesController.getInstance(UserConfig.selectedAccount).loadUser(jlong(uid), 0, True)
                        except: pass

            self.localChanges.pop(self.editingId, None)
            sheet.dismiss()
            self.refresh_ui()
            BulletinHelper.show_success("Изменения сброшены")

        sender_rows = [
            create_action_row(["msg_filled_menu_users_solar", "msg_user", "contact_id"], "Сменить отправителя", "Сделать исходящим/входящим", change_sender_dialog),
            create_action_row(["menu_verification", "msg_verified"], "Статусы отправителя", "Verified, Premium, Scam, Эмодзи...", sender_status_dialog),
        ]
        tab_editor.addView(create_section(sender_rows), LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0))

        msg_rows = [
            create_action_row(["msg_reply_solar", "msg_reply_remix", "ic_reply"], "Добавить реплай", "Фейковый ответ на сообщение", change_reply_dialog),
            create_action_row(["msg_bots_solar", "msg_bots"], "Via Bot", "Приписка «via @bot»", via_bot_dialog),
            create_action_row(["menu_sticker_add_solar", "msg_smile", "ic_smile"], "Эмодзи, стикеры, GIF", "Вставить в текст или прикрепить", open_media_picker),
            create_action_row(["files_folder_solar", "msg_attach", "ic_ab_attach", "msg_photo"], "Прикрепить из галереи", "Фото или видео", open_gallery),
        ]
        tab_editor.addView(create_section(msg_rows), LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0))

        if not is_creation_mode:
            reset_row =[
                create_action_row(["msg_delete", "ic_delete"], "Сбросить текущее", "Вернуть оригинал сообщения", reset_changes, is_destructive=True)
            ]
            tab_editor.addView(create_section(reset_row), LayoutHelper.createLinear(-1, -2))

        content_views["editor"] = tab_editor
        content_wrapper.addView(tab_editor, LayoutHelper.createFrame(-1, -2))

        tab_generator = self._build_generator_tab(activity, sheet, create_action_row, create_section)
        content_views["generator"] = tab_generator
        content_wrapper.addView(tab_generator, LayoutHelper.createFrame(-1, -2))
        tab_generator.setVisibility(View.GONE)

        tab_data = self._build_data_tab(activity, sheet, rebuild_and_show, create_action_row, create_section)
        content_views["data"] = tab_data
        content_wrapper.addView(tab_data, LayoutHelper.createFrame(-1, -2))
        tab_data.setVisibility(View.GONE)

        scroll.addView(content_wrapper, LayoutHelper.createFrame(-1, -2))
        root.addView(scroll, LayoutHelper.createLinear(-1, 0, 1.0))

        save_layout = LinearLayout(activity)
        save_layout.setOrientation(LinearLayout.HORIZONTAL)
        save_layout.setGravity(Gravity.CENTER)
        save_layout.setBackground(self._get_ripple_drawable(Theme.getColor(Theme.key_featuredStickers_addButton), 12))
        check_icon = ImageView(activity)
        check_icon.setImageResource(get_icon_id("input_done", "msg_check", "ic_done"))
        check_icon.setColorFilter(_ji(Theme.getColor(Theme.key_featuredStickers_buttonText)))
        save_layout.addView(check_icon, LayoutHelper.createLinear(20, 20, Gravity.CENTER_VERTICAL, 0, 0, 8, 0))
        save_btn = TextView(activity)
        save_btn.setText("Создать сообщение" if is_creation_mode else "Применить изменения")
        save_btn.setTextColor(_ji(Theme.getColor(Theme.key_featuredStickers_buttonText)))
        save_btn.setTextSize(1, 15.0)
        save_btn.setTypeface(AndroidUtilities.bold())
        save_layout.addView(save_btn, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL))
        save_layout.setPadding(0, dp(14), 0, dp(14))

        class SaveClick(dynamic_proxy(View.OnClickListener)):
            def onClick(self_obj, v):
                if is_creation_mode:
                    self._execute_create_message(self.current_ps)
                    BulletinHelper.show_success("Сообщение создано!")
                elif self.editingId and self.current_ps:
                    sender_changed = self.current_ps.get('_sender_changed', False)
                    final_out = self.current_ps['out'] if sender_changed else self._originOut
                    self.current_ps['out'] = final_out
                    self.localChanges[self.editingId] = self.current_ps.copy()
                    
                    sf = self.current_ps.get('sender_flags')
                    from_id = self.current_ps.get('from_id')
                    if sf and from_id:
                        uid = getattr(from_id, 'user_id', None)
                        if uid:
                            self.faked_users[int(uid)] = sf
                            
                    self.refresh_ui()
                    BulletinHelper.show_success("Изменения применены!")
                sheet.dismiss()

        save_layout.setOnClickListener(SaveClick())
        self._add_press_anim(save_layout)
        root.addView(save_layout, LayoutHelper.createLinear(-1, -2, 0, 16, 0, 0))

        switch_tab("editor")
        sheet.setCustomView(root)
        run_on_ui_thread(lambda: rebuild_and_show(), 1500)
        sheet.show()

    def _build_generator_tab(self, activity, sheet, create_action_row, create_section):
        tab_generator = LinearLayout(activity)
        tab_generator.setOrientation(LinearLayout.VERTICAL)
        gen_rows =[
            create_action_row(["msg_emoji_gem", "ic_gift"], "Создать NFT (Star Gift)", "Выбрать модель, узор и фон", lambda v: self._open_catalog_nft_sheet(activity, sheet)),
            create_action_row(["filled_earn_stars", "msg_star"], "Telegram Stars", "Фейковые звезды", lambda v: self._fake_gift_form(GiftType.STARS, activity, sheet)),
            create_action_row(["msg_payment_card", "msg_wallet"], "Fake Payment", "Чек об оплате", lambda v: self._fake_gift_form(GiftType.PAYMENT, activity, sheet)),
            create_action_row(["menu_premium_away", "msg_giveaway"], "Создать Розыгрыш", "Фейковый Giveaway", lambda v: self._giveaway_form(activity, sheet)),
            create_action_row(["msg_unvote_solar", "msg_polls"], "Fake Vote", "Опрос с нужными процентами", lambda v: self._fake_vote_form(activity, sheet)),
            create_action_row(["call_solar", "ic_call"], "Fake Call", "Входящий/исходящий звонок", lambda v: self._fake_call_form(activity, sheet)),
            create_action_row(["msg_screencast_solar", "msg_screenshot"], "Fake Screenshot", "Сервисное сообщение о скриншоте", lambda v: self._fake_screenshot(activity, sheet)),
            create_action_row(["msg_invited_solar", "msg_addcontact"], "Fake Invite", "Сообщение о добавлении в группу", lambda v: self._fake_invite_form(activity, sheet)),
            create_action_row(["filled_premium_bots", "msg_bots"], "Fake Bot Message", "Сообщение с инлайн-кнопками", lambda v: self._fake_bot_msg_form(activity, sheet)),
        ]
        tab_generator.addView(create_section(gen_rows), LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0))
        return tab_generator

    def _build_data_tab(self, activity, sheet, rebuild_and_show_cb, create_action_row, create_section):
        tab_data = LinearLayout(activity)
        tab_data.setOrientation(LinearLayout.VERTICAL)

        def change_time_dialog(v):
            builder = AlertDialogBuilder(activity)
            builder.set_title("Сменить время")
            layout = LinearLayout(activity)
            layout.setPadding(dp(24), dp(8), dp(24), dp(8))
            et = self._create_dialog_input(activity, "Время (Например 15:30)")
            layout.addView(et, LayoutHelper.createLinear(-1, -2))
            builder.set_view(layout)
            def on_ok(d, w):
                val = et.getText().toString()
                try:
                    if ":" in val:
                        h, m = map(int, val.split(':'))
                        t = time.localtime()
                        new_t = (t.tm_year, t.tm_mon, t.tm_mday, h, m, 0, t.tm_wday, t.tm_yday, t.tm_isdst)
                        self.current_ps['date'] = int(time.mktime(new_t))
                        rebuild_and_show_cb()
                except: pass
                d.dismiss()
            builder.set_positive_button("ОК", on_ok)
            builder.set_negative_button("Отмена", lambda d, w: d.dismiss()); builder.show()

        def change_views_dialog(v):
            builder = AlertDialogBuilder(activity)
            builder.set_title("Изменить просмотры")
            layout = LinearLayout(activity)
            layout.setPadding(dp(24), dp(8), dp(24), dp(8))
            et = self._create_dialog_input(activity, "Количество (Например 15000)", str(self.current_ps.get('views', 0) or ''), 2)
            layout.addView(et, LayoutHelper.createLinear(-1, -2))
            builder.set_view(layout)
            def on_ok(d, w):
                try:
                    self.current_ps['views'] = int(et.getText().toString())
                    rebuild_and_show_cb()
                except: pass
                d.dismiss()
            builder.set_positive_button("ОК", on_ok)
            builder.set_negative_button("Отмена", lambda d, w: d.dismiss()); builder.show()

        def reset_all_everywhere(v):
            acc = UserConfig.selectedAccount
            mc = MessagesController.getInstance(acc)

            for changes in self.localChanges.values():
                if changes.get('sender_flags') and changes.get('from_id'):
                    uid = getattr(changes['from_id'], 'user_id', None)
                    if uid:
                        try: mc.loadUser(jlong(uid), 0, True)
                        except: pass

            self.localChanges.clear()
            gen = self.get_setting('generated_msgs',[])
            
            from collections import defaultdict
            by_channel = defaultdict(list)
            by_chat = list()
            
            for item in gen:
                peer = item.get('peer', 0)
                mid = item.get('id', 0)
                if mid == 0: continue
                if peer <= -1000000000000:
                    by_channel[abs(peer) - 1000000000000].append(mid)
                else:
                    by_chat.append(mid)
                    
            for channel_id, mids in by_channel.items():
                arr = ArrayList()
                for mid in mids: arr.add(jint(mid))
                try: mc.deleteMessages(arr, None, None, int(channel_id), 0, True, 0)
                except: pass
                
            if by_chat:
                arr = ArrayList()
                for mid in by_chat: arr.add(jint(mid))
                try: mc.deleteMessages(arr, None, None, int(0), 0, True, 0)
                except: pass
                
            self.set_setting('generated_msgs',[])
            sheet.dismiss()
            self.refresh_ui()
            BulletinHelper.show_success("Все изменения и фейки удалены!")

        data_rows =[
            create_action_row(["timeline", "msg_clock"], "Изменить время", "Например: 15:30", change_time_dialog),
            create_action_row(["msg_views", "ic_views"], "Изменить просмотры", "Для постов из каналов", change_views_dialog),
        ]
        tab_data.addView(create_section(data_rows), LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0))
        reset_all_row =[
            create_action_row(["msg_delete", "ic_delete"], "Сбросить ВСЁ везде", "Удалить все фейки и правки", reset_all_everywhere, is_destructive=True)
        ]
        tab_data.addView(create_section(reset_all_row), LayoutHelper.createLinear(-1, -2))
        return tab_data

    def _execute_create_message(self, ps):
        acc = UserConfig.selectedAccount
        try:
            msg = TLRPC.TL_message()
            msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            
            p = self._make_peer()
            msg.peer_id = p
            msg.dialog_id = int(self.peer)
            msg.date = ps.get('date', int(time.time()))
            msg.message = ps.get('text', '')
            msg.entities = ps.get('entities') or ArrayList()
            msg.flags = MsgFlags.FROM_ID | (MsgFlags.ENTITIES if msg.entities.size() > 0 else 0)
            msg.unread = True
            
            msg.out = ps.get('out', False)
            if msg.out:
                msg.flags |= MsgFlags.OUT
                p_me = TLRPC.TL_peerUser()
                p_me.user_id = int(UserConfig.getInstance(acc).getClientUserId())
                msg.from_id = p_me
            else:
                msg.from_id = ps.get('from_id', p)
                
            sender_flags = ps.get('sender_flags', {})
            if sender_flags and msg.from_id:
                uid = getattr(msg.from_id, 'user_id', None)
                if uid:
                    mc = MessagesController.getInstance(acc)
                    user = mc.getUser(jlong(uid))
                    if user:
                        user.verified = sender_flags.get('verified', user.verified)
                        user.premium = sender_flags.get('premium', user.premium)
                        user.scam = sender_flags.get('scam', False)
                        user.fake = sender_flags.get('fake', False)
                        if sender_flags.get('emoji_status_id'):
                            try:
                                es = TLRPC.TL_emojiStatus()
                                es.document_id = jlong(int(sender_flags['emoji_status_id']))
                                user.emoji_status = es
                            except: pass
                        mc.putUser(user, False)

                admin_title = sender_flags.get('admin_title')
                if admin_title:
                    _set_field(msg, 'post_author', admin_title)
                    msg.flags |= MsgFlags.POST_AUTHOR
                else:
                    _set_field(msg, 'post_author', "")
                    msg.flags &= ~MsgFlags.POST_AUTHOR

            admin_title = sender_flags.get('admin_title')
            if admin_title:
                _set_field(m.messageOwner, 'post_author', admin_title)
                m.messageOwner.flags |= MsgFlags.POST_AUTHOR
            else:
                _set_field(m.messageOwner, 'post_author', "")
                m.messageOwner.flags &= ~MsgFlags.POST_AUTHOR

            if ps.get('media'):
                msg.media = ps['media']
                msg.flags |= MsgFlags.MEDIA
                if ps.get('attach_path'):
                    msg.attachPath = ps['attach_path']
            else:
                msg.media = TLRPC.TL_messageMediaEmpty()
                
            if ps.get('views'):
                msg.views = ps['views']
                msg.flags |= MsgFlags.VIEWS
                
            custom_reply = ps.get('custom_reply')
            rep_obj = None
            if custom_reply:
                rep_tl = TLRPC.TL_message()
                rep_tl.message = custom_reply['text']
                rep_tl.id = 8888888
                rep_tl.date = int(time.time())
                p_rep = TLRPC.TL_peerUser()
                p_rep.user_id = 8888888
                rep_tl.from_id = p_rep
                fu = TLRPC.TL_user()
                fu.id = 8888888
                fu.first_name = custom_reply['name']
                MessagesController.getInstance(acc).putUser(fu, False)
                
                msg.flags |= MsgFlags.REPLY
                hdr = TLRPC.TL_messageReplyHeader()
                hdr.reply_to_msg_id = rep_tl.id
                msg.reply_to = hdr
                rep_obj = MessageObject(acc, rep_tl, False, False)
                
            via_bot_name = ps.get('via_bot_name', '')
            if via_bot_name:
                msg.flags |= MsgFlags.VIA_BOT_ID
                msg.via_bot_id = int(ps.get('via_bot_id', 123456))
                via_user = TLRPC.TL_user()
                via_user.id = int(ps.get('via_bot_id', 123456))
                via_user.username = via_bot_name.lstrip('@')
                via_user.first_name = via_bot_name.lstrip('@')
                via_user.bot = True
                MessagesController.getInstance(acc).putUser(via_user, False)
                
            apply_reactions_to_mo(msg, ps.get('reactions',[]))
            
            obj = MessageObject(acc, msg, False, True)
            if rep_obj:
                obj.replyMessageObject = rep_obj
            if ps.get('msg_type') is not None:
                obj.type = ps['msg_type']
                
            obj.resetLayout()
            obj.generateThumbs(False)
            obj.createMediaThumbs()
            
            lm = ArrayList(); lm.add(msg)
            lo = ArrayList(); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except Exception as e:
            logcat(f"Create msg error: {e}")

    def _apply_media_ui_internal(self, path, is_video, rebuild_cb):
        try:
            if not self.current_ps: return
            
            if is_video:
                doc = _prepare_document(path, "video/mp4")
                if doc:
                    _add_video_attributes(doc, path)
                    media = TLRPC.TL_messageMediaDocument()
                    media.document = doc
                    msg_type = 3
                else:
                    return
            else:
                photo = _generate_photo_sizes(path, False)
                if photo:
                    media = TLRPC.TL_messageMediaPhoto()
                    media.photo = photo
                    msg_type = 1
                else:
                    return
                    
            self.current_ps['media'] = media
            self.current_ps['msg_type'] = msg_type
            self.current_ps['attach_path'] = path
            if rebuild_cb: rebuild_cb()
            if self.current_sheet and not self.current_sheet.isShowing():
                self.current_sheet.show()
        except: logcat(traceback.format_exc())

    def _save_generated_msg(self, msg_id, peer_id):
        gen = self.get_setting('generated_msgs',[])
        if not isinstance(gen, list): gen =[]
        gen.append({'id': msg_id, 'peer': peer_id})
        self.set_setting('generated_msgs', gen)

    def _make_peer(self):
        if self.peer < 0:
            if self.peer <= -1000000000000:
                p = TLRPC.TL_peerChannel(); p.channel_id = int(abs(self.peer) - 1000000000000)
            else:
                p = TLRPC.TL_peerChat(); p.chat_id = int(abs(self.peer))
        else:
            p = TLRPC.TL_peerUser(); p.user_id = int(self.peer) if self.peer > 0 else int(0)
        return p

    def _get_catalog_gifts(self):
        acc = UserConfig.selectedAccount
        try:
            Ctrl = find_class("org.telegram.ui.Stars.StarsController")
            ctrl = Ctrl.getInstance(acc)
            ctrl.loadStarGifts()
            
            gifts =[]
            for f in ctrl.getClass().getDeclaredFields():
                try:
                    f.setAccessible(True)
                    val = f.get(ctrl)
                    if val is None: continue
                    
                    cls_name = str(val.getClass().getName()).lower()
                    if "arraylist" not in cls_name and "java.util.list" not in cls_name:
                        continue
                        
                    if val.size() > 0:
                        first = val.get(0)
                        if first is None: continue
                        
                        first_name = str(first.getClass().getName()).lower()
                        if "stargift" in first_name and "saved" not in first_name:
                            for i in range(val.size()):
                                g = val.get(i)
                                if g is None: continue
                                gname = str(g.getClass().getName()).lower()
                                if "unique" in gname or get_val(g, "upgrade_stars", 0):
                                    gifts.append(g)
                            return gifts
                except Exception:
                    pass
        except Exception as e:
            logcat(f"Error fetching catalog: {e}")
        return[]

    def _open_catalog_nft_sheet(self, activity, sheet):
        gifts = self._get_catalog_gifts()
        
        if not gifts:
            BulletinHelper.show_info("Загрузка каталога... Ждем ответа от Telegram.")
            def retry():
                retried_gifts = self._get_catalog_gifts()
                if retried_gifts:
                    self._show_catalog_dialog(activity, sheet, retried_gifts)
                else:
                    BulletinHelper.show_error("Каталог пуст. Попробуйте еще раз.")
            run_on_ui_thread(retry, 2000)
            return

        self._show_catalog_dialog(activity, sheet, gifts)

    def _show_catalog_dialog(self, activity, sheet, gifts):
        bs = BottomSheet(activity, True)
        
        scroll = ScrollView(activity)
        root = LinearLayout(activity)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(0, dp(16), 0, dp(16))
        scroll.addView(root)

        title = TextView(activity)
        title.setText("Выберите базу для NFT")
        try: title.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
        except: title.setTextColor(0xFFFFFFFF)
        title.setTextSize(1, 20.0)
        title.setTypeface(AndroidUtilities.bold())
        title.setPadding(dp(16), 0, dp(16), dp(16))
        root.addView(title, LayoutHelper.createLinear(-1, -2))

        items_per_page = 30
        current_page = [0]
        
        list_container = LinearLayout(activity)
        list_container.setOrientation(LinearLayout.VERTICAL)
        root.addView(list_container, LayoutHelper.createLinear(-1, -2))

        load_more_btn = TextView(activity)
        load_more_btn.setText("Показать еще")
        load_more_btn.setGravity(Gravity.CENTER)
        try: load_more_btn.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)))
        except: load_more_btn.setTextColor(0xFF3B82F6)
        load_more_btn.setTextSize(1, 15.0)
        load_more_btn.setTypeface(AndroidUtilities.bold())
        load_more_btn.setPadding(0, dp(16), 0, dp(16))
        load_more_btn.setBackground(self._get_ripple_drawable(0x00000000, 8))
        root.addView(load_more_btn, LayoutHelper.createLinear(-1, -2))

        def on_gift_click(gift_obj):
            bs.dismiss()
            self._fetch_gift_attributes(activity, sheet, gift_obj)

        def load_page():
            start_idx = current_page[0] * items_per_page
            end_idx = min(start_idx + items_per_page, len(gifts))
            
            for i in range(start_idx, end_idx):
                g = gifts[i]
                row = LinearLayout(activity)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(dp(16), dp(8), dp(16), dp(8))
                row.setBackground(self._get_ripple_drawable(0x00000000, 8))

                biv = find_class("org.telegram.ui.Components.BackupImageView")(activity)
                doc = get_val(g, "document") or get_val(g, "sticker")
                if doc:
                    ImageLocation = find_class("org.telegram.messenger.ImageLocation")
                    biv.setImage(ImageLocation.getForDocument(doc), "50_50", None, None, doc)
                row.addView(biv, LayoutHelper.createLinear(48, 48, 0, 0, 16, 0))

                text_layout = LinearLayout(activity)
                text_layout.setOrientation(LinearLayout.VERTICAL)

                tv_title = TextView(activity)
                tv_title.setText(get_val(g, "title", "NFT"))
                try: tv_title.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
                except: tv_title.setTextColor(0xFFFFFFFF)
                tv_title.setTextSize(1, 16.0)
                tv_title.setTypeface(AndroidUtilities.bold())
                text_layout.addView(tv_title, LayoutHelper.createLinear(-1, -2))

                tv_stars = TextView(activity)
                tv_stars.setText(f"⭐ {get_val(g, 'stars', 0)}")
                try: tv_stars.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextGray3)))
                except: tv_stars.setTextColor(0xFFAAAAAA)
                tv_stars.setTextSize(1, 13.0)
                text_layout.addView(tv_stars, LayoutHelper.createLinear(-1, -2))

                row.addView(text_layout, LayoutHelper.createLinear(-1, -2, 1.0))

                row.setOnClickListener(OnClickListener(lambda v, gift_obj=g: on_gift_click(gift_obj)))
                self._add_press_anim(row)
                
                list_container.addView(row, LayoutHelper.createLinear(-1, -2))
            
            current_page[0] += 1
            if current_page[0] * items_per_page >= len(gifts):
                load_more_btn.setVisibility(View.GONE)

        load_more_btn.setOnClickListener(OnClickListener(lambda v: load_page()))
        self._add_press_anim(load_more_btn)

        load_page()
        
        bs.setCustomView(scroll)
        bs.show()    

    @safe
    def _fetch_gift_attributes(self, activity, sheet, gift):
        try:
            acc = UserConfig.selectedAccount
            gift_id = get_val(gift, "id", 0)
            
            ReqClass = find_class("org.telegram.tgnet.tl.TL_stars$getStarGiftUpgradePreview")
            if not ReqClass:
                ReqClass = find_class("org.telegram.tgnet.tl.TL_stars$getStarGiftUpgradeAttributes")
            
            if not ReqClass:
                BulletinHelper.show_error("Класс атрибутов не найден, используем базовый NFT")
                self._show_nft_constructor(activity, sheet, gift, None)
                return

            req = ReqClass()
            _set_field(req, "gift_id", gift_id)
            
            BulletinHelper.show_info("Загрузка моделей и узоров...")

            def on_done(proxy, response, error):
                if error:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка сети: {error.text}"))
                    run_on_ui_thread(lambda: self._show_nft_constructor(activity, sheet, gift, None))
                    return
                run_on_ui_thread(lambda: self._show_nft_constructor(activity, sheet, gift, response))
                
            ConnectionsManager.getInstance(acc).sendRequest(req, ProxyF.create("org.telegram.tgnet.RequestDelegate", run=on_done))
        except Exception as e:
            logcat(f"Fetch attributes error: {e}\n{traceback.format_exc()}")
            run_on_ui_thread(lambda: self._show_nft_constructor(activity, sheet, gift, None))

    def _show_attr_selector(self, activity, parent_bs, title, items_list, state_key, tv_view, state):
        bs = BottomSheet(activity, True)
        scroll = ScrollView(activity)
        layout = LinearLayout(activity)
        layout.setOrientation(LinearLayout.VERTICAL)
        layout.setPadding(dp(16), dp(16), dp(16), dp(16))

        tv_title = TextView(activity)
        tv_title.setText(title)
        try: tv_title.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
        except: tv_title.setTextColor(0xFFFFFFFF)
        tv_title.setTextSize(1, 20.0)
        tv_title.setTypeface(AndroidUtilities.bold())
        layout.addView(tv_title, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 16))

        for idx, attr in enumerate(items_list):
            row = LinearLayout(activity)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(dp(8), dp(8), dp(8), dp(8))
            row.setBackground(self._get_ripple_drawable(0x00000000, 8))

            icon_view = FrameLayout(activity)
            doc = get_val(attr, "document") or get_val(attr, "sticker")
            if doc:
                biv = find_class("org.telegram.ui.Components.BackupImageView")(activity)
                ImageLocation = find_class("org.telegram.messenger.ImageLocation")
                biv.setImage(ImageLocation.getForDocument(doc), "50_50", None, None, doc)
                icon_view.addView(biv, LayoutHelper.createFrame(40, 40))
            else:
                cc = get_val(attr, "center_color")
                if cc is not None:
                    bg = GradientDrawable()
                    bg.setShape(GradientDrawable.OVAL)
                    bg.setColor(to_s32(int(cc) | 0xFF000000))
                    color_view = View(activity)
                    color_view.setBackground(bg)
                    icon_view.addView(color_view, LayoutHelper.createFrame(40, 40))

            row.addView(icon_view, LayoutHelper.createLinear(40, 40, 0, 0, 16, 0))

            tv_name = TextView(activity)
            tv_name.setText(get_val(attr, "name", f"Вариант {idx + 1}"))
            try: tv_name.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
            except: tv_name.setTextColor(0xFFFFFFFF)
            tv_name.setTextSize(1, 16.0)
            row.addView(tv_name, LayoutHelper.createLinear(-1, -2, 1.0))

            def make_click(i):
                def on_click(v):
                    state[state_key] = i
                    tv_view.setText(f"{title}: {get_val(items_list[i], 'name', f'Вариант {i + 1}')}")
                    bs.dismiss()
                return OnClickListener(on_click)

            row.setOnClickListener(make_click(idx))
            self._add_press_anim(row)
            layout.addView(row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))

        scroll.addView(layout)
        bs.setCustomView(scroll)
        bs.show()

    def _show_nft_constructor(self, activity, sheet, gift, attr_response):
        models, patterns, backdrops = [], [],[]
        
        if attr_response:
            attrs = get_val(attr_response, "sample_attributes")
            if not attrs:
                attrs = get_val(attr_response, "attributes")
            if not attrs:
                for f in attr_response.getClass().getFields():
                    try:
                        val = f.get(attr_response)
                        if val is not None and hasattr(val, 'getClass') and "ArrayList" in str(val.getClass().getName()):
                            attrs = val
                            break
                    except: pass
            if attrs:
                for i in range(attrs.size()):
                    a = attrs.get(i)
                    if a is None: continue
                    name = a.getClass().getName().lower()
                    if "model" in name: models.append(a)
                    elif "pattern" in name: patterns.append(a)
                    elif "backdrop" in name: backdrops.append(a)

        state = {"model": 0, "pattern": 0, "backdrop": 0}
        
        bs = BottomSheet(activity, True)
        scroll = ScrollView(activity)
        layout = LinearLayout(activity)
        layout.setOrientation(LinearLayout.VERTICAL)
        layout.setPadding(dp(16), dp(16), dp(16), dp(16))
        
        tv_title = TextView(activity)
        tv_title.setText("Конструктор NFT")
        try: tv_title.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
        except: tv_title.setTextColor(0xFFFFFFFF)
        tv_title.setTextSize(1, 20.0)
        tv_title.setTypeface(AndroidUtilities.bold())
        layout.addView(tv_title, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 16))
        
        def create_selector(title_text, items_list, state_key):
            if not items_list: return None
            
            btn = LinearLayout(activity)
            btn.setOrientation(LinearLayout.HORIZONTAL)
            btn.setGravity(Gravity.CENTER_VERTICAL)
            btn.setPadding(dp(12), dp(12), dp(12), dp(12))
            try: bg_color = Theme.getColor(Theme.key_windowBackgroundWhite)
            except: bg_color = 0xFF233041
            try: div_color = Theme.getColor(Theme.key_divider)
            except: div_color = 0x1AFFFFFF
            btn.setBackground(self._get_ripple_drawable(bg_color, 8, div_color, 1))
            
            tv = TextView(activity)
            first_name = get_val(items_list[0], "name", f"Вариант 1")
            tv.setText(f"{title_text}: {first_name}")
            try: tv.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)))
            except: tv.setTextColor(0xFF3B82F6)
            tv.setTextSize(1, 16.0)
            btn.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))
            
            chevron = ImageView(activity)
            chevron.setImageResource(get_icon_id("arrow_right", "msg_arrowright", "ic_chevron_right"))
            try: chevron.setColorFilter(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)))
            except: chevron.setColorFilter(_ji(0xFF3B82F6))
            btn.addView(chevron, LayoutHelper.createLinear(24, 24))
            
            def on_click(v):
                self._show_attr_selector(activity, bs, title_text, items_list, state_key, tv, state)
                
            btn.setOnClickListener(OnClickListener(on_click))
            self._add_press_anim(btn)
            return btn

        m_btn = create_selector("Модель", models, "model")
        p_btn = create_selector("Узор", patterns, "pattern")
        b_btn = create_selector("Фон", backdrops, "backdrop")
        
        if m_btn: layout.addView(m_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
        if p_btn: layout.addView(p_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
        if b_btn: layout.addView(b_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 16))
        
        ui_fields = {}
        def add_input(key, label, def_val, type_flag=1):
            tv = TextView(activity)
            tv.setText(label)
            try: tv.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)))
            except: tv.setTextColor(0xFF3B82F6)
            tv.setPadding(0, dp(8), 0, dp(4))
            layout.addView(tv)
            et = self._create_dialog_input(activity, "", str(def_val), type_flag)
            layout.addView(et, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
            ui_fields[key] = et

        base_title = get_val(gift, "title", "NFT")
        base_slug = get_val(gift, "slug", "nft")
        base_total = get_val(gift, "availability_total", 10000)

        add_input('title', 'Название:', base_title)
        add_input('slug', 'Slug (для ссылки):', base_slug)
        add_input('num', 'Номер NFT:', '1', InputType.TYPE_CLASS_NUMBER)
        add_input('limit', 'Всего выпущено (тираж):', str(base_total), InputType.TYPE_CLASS_NUMBER)
        
        cb_out = CheckBox(activity)
        cb_out.setText("Исходящее (Я отправил)")
        try: cb_out.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack)))
        except: cb_out.setTextColor(0xFFFFFFFF)
        layout.addView(cb_out, LayoutHelper.createLinear(-1, -2, 0, 8, 0, 16))
        
        create_btn = TextView(activity)
        create_btn.setText("Создать NFT")
        create_btn.setGravity(Gravity.CENTER)
        create_btn.setTextColor(_ji(0xFFFFFFFF))
        create_btn.setTextSize(1, 15.0)
        create_btn.setTypeface(AndroidUtilities.bold())
        try: btn_color = Theme.getColor(Theme.key_featuredStickers_addButton)
        except: btn_color = 0xFF3B82F6
        create_btn.setBackground(self._get_ripple_drawable(btn_color, 8))
        create_btn.setPadding(0, dp(14), 0, dp(14))
        
        def on_create(v):
            params = {k: v.getText().toString() for k, v in ui_fields.items()}
            params['is_out'] = cb_out.isChecked()
            
            selected_attrs = ArrayList()
            if models: selected_attrs.add(models[state["model"]])
            if patterns: selected_attrs.add(patterns[state["pattern"]])
            if backdrops: selected_attrs.add(backdrops[state["backdrop"]])
            
            self._execute_catalog_nft(gift, selected_attrs, params)
            bs.dismiss()
            if sheet: sheet.dismiss()
            BulletinHelper.show_success("NFT Подарок создан!")
            
        create_btn.setOnClickListener(OnClickListener(on_create))
        self._add_press_anim(create_btn)
        layout.addView(create_btn, LayoutHelper.createLinear(-1, -2))
        
        scroll.addView(layout)
        bs.setCustomView(scroll)
        bs.show()

    def _execute_catalog_nft(self, base_gift, selected_attrs, params):
        acc = UserConfig.selectedAccount
        try:
            ActionClass = find_class("org.telegram.tgnet.TLRPC$TL_messageActionStarGiftUnique")
            if not ActionClass:
                ActionClass = find_class("org.telegram.tgnet.TLRPC$TL_messageActionStarGift")
                
            GiftClass = find_class("org.telegram.tgnet.tl.TL_stars$TL_starGiftUnique")
            if not GiftClass:
                GiftClass = find_class("org.telegram.tgnet.tl.TL_stars$StarGift")

            action = ActionClass()
            gift = GiftClass()

            base_id = get_val(base_gift, "id", 0)
            num = int(params.get('num', '1'))
            limit = int(params.get('limit', '10000'))
            is_out = params.get('is_out', False)
            
            _set_field(gift, "id", random.randint(1000000, 9999999))
            _set_field(gift, "gift_id", base_id)
            _set_field(gift, "title", params.get('title', 'NFT'))
            
            slug_val = params.get('slug', 'nft')
            if not slug_val: slug_val = get_val(base_gift, "slug", "nft")
            _set_field(gift, "slug", slug_val)
            
            _set_field(gift, "num", num)
            _set_field(gift, "limited", True)
            _set_field(gift, "limited_count", limit)
            _set_field(gift, "availability_total", limit)
            
            _set_field(gift, "attributes", selected_attrs)
            try: gift.attributes = selected_attrs
            except: pass

            model_doc = None
            for i in range(selected_attrs.size()):
                attr = selected_attrs.get(i)
                if attr and "model" in attr.getClass().getName().lower():
                    model_doc = get_val(attr, "document")
                    if not model_doc: model_doc = get_val(attr, "sticker")
                    break

            if not model_doc:
                model_doc = get_val(base_gift, "document") or get_val(base_gift, "sticker")

            if model_doc:
                _set_field(gift, "document", model_doc)
                _set_field(gift, "sticker", model_doc)

            _set_field(action, "gift", gift)
            _set_field(action, "upgrade", False)
            _set_field(action, "saved", False)
            _set_field(action, "refunded", False)
            _set_field(action, "transferred", not is_out)

            p = self._make_peer()
            msg = TLRPC.TL_messageService()
            msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            
            msg.peer_id = p
            msg.dialog_id = int(self.peer)
            msg.date = int(time.time())
            msg.action = action
            msg.unread = True
            msg.flags = MsgFlags.FROM_ID
            msg.out = is_out
            
            if is_out:
                msg.flags |= MsgFlags.OUT
                p_me = TLRPC.TL_peerUser()
                p_me.user_id = int(UserConfig.getInstance(acc).getClientUserId())
                msg.from_id = p_me
            else:
                msg.from_id = p

            obj = MessageObject(acc, msg, False, True)
            lm = ArrayList(); lm.add(msg)
            lo = ArrayList(); lo.add(obj)
            
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)

            def trigger_fireworks():
                try:
                    LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
                    if LaunchActivity.instance and LaunchActivity.instance.getFireworksOverlay():
                        LaunchActivity.instance.getFireworksOverlay().start(True)
                except: pass
            
            run_on_ui_thread(trigger_fireworks, 500)

        except Exception as e:
            logcat(f"Catalog NFT Error: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error("Ошибка при генерации NFT")

    def _fake_gift_form(self, action_type, activity, sheet):
        layout = LinearLayout(activity); layout.setOrientation(1); layout.setPadding(dp(20), dp(10), dp(20), dp(10))
        ui_fields = {}
        def add_input(key, label, def_val, type_flag=1):
            tv = TextView(activity); tv.setText(label); tv.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText))); tv.setPadding(0, dp(12), 0, dp(4)); layout.addView(tv)
            et = self._create_dialog_input(activity, "", str(def_val), type_flag)
            layout.addView(et, LayoutHelper.createLinear(-1, -2)); ui_fields[key] = et
        if action_type == GiftType.PAYMENT: add_input('pay_amount', 'Сумма (например 10.50):', '50.00', InputType.TYPE_CLASS_NUMBER | InputType.TYPE_NUMBER_FLAG_DECIMAL)
        elif action_type == GiftType.PREMIUM: add_input('months', 'Срок (1/3/6/12 мес):', '3', InputType.TYPE_CLASS_NUMBER)
        elif action_type == GiftType.STARS: add_input('stars', 'Кол-во звезд:', '500', InputType.TYPE_CLASS_NUMBER)
        cb_out = CheckBox(activity); cb_out.setText("Исходящее (Я отправил)"); cb_out.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack))); layout.addView(cb_out)
        builder = AlertDialogBuilder(activity); builder.set_title("Настройка (Генерация в чат)"); builder.set_view(layout)
        def on_ok(d, w):
            params = {k: v.getText().toString() for k, v in ui_fields.items()}
            params['is_out'] = cb_out.isChecked()
            self._execute_fake_gift(action_type, params); d.dismiss()
            sheet.dismiss()
            BulletinHelper.show_success("Сгенерировано в чат!")
        builder.set_positive_button("Выполнить", on_ok); builder.show()

    def _execute_fake_gift(self, action_type, params):
        acc = UserConfig.selectedAccount
        try:
            curr_code = "USD"
            if action_type == GiftType.PAYMENT:
                a = TLRPC.TL_messageActionPaymentSent(); a.currency = curr_code; a.total_amount = int(float(params.get('pay_amount', '10.00')) * 100); a.flags = 0
            elif action_type == GiftType.PREMIUM:
                a = TLRPC.TL_messageActionGiftPremium(); months = int(params.get('months', '3')); a.months = months; a.currency = curr_code
                a.amount = int(GiftConfig.PREMIUM_PRICES_USD.get(months, 14.99) * 100); a.flags = 0
            elif action_type == GiftType.STARS:
                a = TLRPC.TL_messageActionGiftStars(); stars = int(params.get('stars', '500')); a.stars = int(stars); a.currency = curr_code
                price = float(Decimal(str(stars)) * Decimal(str(GiftConfig.STAR_PRICE_USD)))
                a.amount = int((price if price <= 100 else int(price)) * 100); a.flags = 0
            p = self._make_peer()
            msg = TLRPC.TL_messageService(); msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            msg.peer_id = p; msg.dialog_id = int(self.peer); msg.date = int(time.time()); msg.action = a; msg.unread = True
            msg.flags = MsgFlags.FROM_ID; msg.from_id = p; msg.out = params.get('is_out', False)
            if msg.out: msg.flags |= MsgFlags.OUT; p_me = TLRPC.TL_peerUser(); p_me.user_id = int(UserConfig.getInstance(acc).getClientUserId()); msg.from_id = p_me
            obj = MessageObject(acc, msg, False, True); lm = ArrayList(); lm.add(msg); lo = ArrayList(); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except: logcat(traceback.format_exc())

    def _fake_vote_form(self, activity, sheet):
        layout = LinearLayout(activity); layout.setOrientation(1); layout.setPadding(dp(20), dp(10), dp(20), dp(10))
        tv_q = TextView(activity); tv_q.setText("Вопрос:"); tv_q.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText))); tv_q.setPadding(0, 0, 0, dp(4)); layout.addView(tv_q)
        et_q = self._create_dialog_input(activity, "Текст вопроса"); layout.addView(et_q, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 12))
        tv_opts = TextView(activity); tv_opts.setText("Варианты (каждый с новой строки, % через |):"); tv_opts.setTextColor(_ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText))); tv_opts.setPadding(0, 0, 0, dp(4)); layout.addView(tv_opts)
        et_opts = self._create_dialog_input(activity, "Да|60\nНет|40", "", 131073); et_opts.setMinLines(3); layout.addView(et_opts, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
        cb_out = CheckBox(activity); cb_out.setText("Исходящее"); cb_out.setTextColor(_ji(Theme.getColor(Theme.key_dialogTextBlack))); layout.addView(cb_out)
        builder = AlertDialogBuilder(activity); builder.set_title("Fake Vote"); builder.set_view(layout)
        def on_ok(d, w):
            question = et_q.getText().toString().strip()
            opts_raw = et_opts.getText().toString().strip().split('\n')
            self._execute_fake_vote(question, opts_raw, cb_out.isChecked())
            d.dismiss(); sheet.dismiss(); BulletinHelper.show_success("Опрос создан!")
        builder.set_positive_button("Создать", on_ok); builder.set_negative_button("Отмена", lambda d, w: d.dismiss()); builder.show()

    def _execute_fake_vote(self, question, opts_raw, is_out):
        acc = UserConfig.selectedAccount
        try:
            p = self._make_peer()
            media = TLRPC.TL_messageMediaPoll()
            poll = TLRPC.TL_poll()
            poll.id = int(time.time() * 1000)
            poll.question = TLRPC.TL_textWithEntities() if hasattr(TLRPC, 'TL_textWithEntities') else type('T', (), {'text': question, 'entities': ArrayList()})()
            try: poll.question.text = question
            except: poll.question = question
            poll.answers = ArrayList()
            results = TLRPC.TL_pollResults()
            results.results = ArrayList()
            results.flags = 3
            total = 0
            parsed =[]
            for opt in opts_raw:
                if '|' in opt:
                    txt, pct = opt.rsplit('|', 1)
                    try: pct = int(pct.strip())
                    except: pct = 0
                else:
                    txt = opt; pct = 0
                parsed.append((txt.strip(), pct))
                total += pct
            for i, (txt, pct) in enumerate(parsed):
                ans = TLRPC.TL_pollAnswer()
                ans.text = TLRPC.TL_textWithEntities() if hasattr(TLRPC, 'TL_textWithEntities') else type('T', (), {'text': txt, 'entities': ArrayList()})()
                try: ans.text.text = txt
                except: ans.text = txt
                ans.option = bytes([i])
                poll.answers.add(ans)
                ar = TLRPC.TL_pollAnswerVoters()
                ar.option = bytes([i])
                ar.voters = pct
                ar.flags = 0
                results.results.add(ar)
            results.total_voters = total
            media.poll = poll
            media.results = results
            msg = TLRPC.TL_message(); msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            msg.peer_id = p; msg.dialog_id = int(self.peer); msg.date = int(time.time()); msg.media = media
            msg.flags = MsgFlags.FROM_ID | MsgFlags.MEDIA; msg.from_id = p; msg.out = is_out; msg.unread = True
            if is_out: msg.flags |= MsgFlags.OUT; p_me = TLRPC.TL_peerUser(); p_me.user_id = int(UserConfig.getInstance(acc).getClientUserId()); msg.from_id = p_me
            obj = MessageObject(acc, msg, False, True); lm = ArrayList(); lm.add(msg); lo = ArrayList(); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except: logcat(traceback.format_exc())

    def _fake_call_form(self, activity, sheet):
        layout = LinearLayout(activity); layout.setOrientation(1); layout.setPadding(dp(20), dp(10), dp(20), dp(10))
