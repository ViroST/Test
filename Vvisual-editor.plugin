    def _execute_fake_call(self, duration, is_out, is_missed):
        acc = UserConfig.selectedAccount
        try:
            p = self._make_peer()
            a = TLRPC.TL_messageActionPhoneCall()
            a.duration = duration
            a.flags = 0
            if is_missed:
                reason = TLRPC.TL_phoneCallDiscardReasonMissed()
                a.reason = reason
                a.flags |= 4
            msg = TLRPC.TL_messageService(); msg.id = UserConfig.getInstance(acc).getNewMessageId()
            self._save_generated_msg(msg.id, self.peer)
            msg.peer_id = p; msg.dialog_id = int(self.peer); msg.date = int(time.time()); msg.action = a
            msg.flags = MsgFlags.FROM_ID; msg.from_id = p; msg.out = is_out; msg.unread = True
            if is_out: msg.flags |= MsgFlags.OUT; p_me = TLRPC.TL_peerUser(); p_me.user_id = int(UserConfig.getInstance(acc).getClientUserId()); msg.from_id = p_me
            obj = MessageObject(acc, msg, False, True); lm = ArrayList(); lm.add(msg); lo = ArrayList(); lo.add(obj)
            try: MessagesStorage.getInstance(acc).putMessages(lm, True, True, False, 0, 0, 0)
            except: pass
            MessagesController.getInstance(acc).updateInterfaceWithMessages(int(self.peer), lo, 0)
        except: logcat(traceback.format_exc())

