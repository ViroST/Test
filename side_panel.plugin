    def _limit_dialogs_top_scroll(self, fragment):
        # Top scroll lock moved to dialogs_search_compact.plugin.
        return
    def _get_compact_top_scroll(self, fragment):
        try:
            if fragment is None:
                return -float(AndroidUtilities.dp(48.0))
            # Force compact "scrolled" position of folders panel.
            desired_abs = float(AndroidUtilities.dp(48.0))
            try:
                max_without_search = None
                for mn in ("getMaxScrollYOffsetWithoutSearch", "getMaxScrollYOffset"):
                    try:
                        m = fragment.getClass().getDeclaredMethod(mn)
                        m.setAccessible(True)
                        v = m.invoke(fragment)
                        if v is None:
                            continue
                        fv = abs(float(v))
                        if fv > 1.0:
                            max_without_search = fv
                            break
                    except Exception:
                        continue
                if max_without_search is not None and max_without_search > 1.0:
                    desired_abs = min(desired_abs, float(max_without_search))
            except Exception:
                pass
            if desired_abs < float(AndroidUtilities.dp(24.0)):
                desired_abs = float(AndroidUtilities.dp(24.0))
            return -float(desired_abs)
        except Exception:
            return -float(AndroidUtilities.dp(48.0))

    def _log_tabs_geometry(self, fragment, tabs, target_y, source):
        try:
            if fragment is None or tabs is None:
                return
            key = self._obj_key(fragment)
            try:
                tabs_y = float(tabs.getY() or 0.0) + float(tabs.getTranslationY() or 0.0)
            except Exception:
                tabs_y = 0.0
            try:
                tabs_h = int(tabs.getHeight() or 0)
            except Exception:
                tabs_h = -1
            try:
                tabs_v = int(tabs.getVisibility() or 0)
            except Exception:
                tabs_v = -1
            tkey = f"tabs_geom_{key}"
            prev = self._search_ui_state.get(tkey)
            cur = (round(tabs_y, 1), int(tabs_h), int(tabs_v), round(float(target_y), 1), int(self._obj_key(tabs)))
            if prev != cur:
                self._search_ui_state[tkey] = cur
                self._dbg(
                    f"tabs-geom [{source}]: id={cur[4]} y={tabs_y:.1f} h={tabs_h} v={tabs_v} target={float(target_y):.1f}"
                )
        except Exception:
            pass

    def _log_scroll_and_panel_state(self, fragment, tabs_view, search_active, source):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            scroll_v = self._get_field_value(fragment, "scrollYOffset")
            tabs_off = self._get_field_value(fragment, "tabsYOffset")
            try:
                sv = float(scroll_v) if scroll_v is not None else 0.0
            except Exception:
                sv = 0.0
            try:
                to = float(tabs_off) if tabs_off is not None else 0.0
            except Exception:
                to = 0.0
            panel_state = "unknown"
            tabs_y = 0.0
            locked_top = self._get_compact_top_scroll(fragment)
            if tabs_view is not None:
                try:
                    tabs_y = float(tabs_view.getY() or 0.0) + float(tabs_view.getTranslationY() or 0.0)
                except Exception:
                    tabs_y = 0.0
                compact_y = float(AndroidUtilities.dp(2.0))
                panel_state = "top" if tabs_y < compact_y else "compact"
            list_pad_top = -1
            long_v = -1
            long_h = -1
            st_v = -1
            st_h = -1
            tp_v = -1
            tp_h = -1
            try:
                lv = self._get_dialogs_list_view(fragment)
                if lv is not None:
                    list_pad_top = int(lv.getPaddingTop() or 0)
            except Exception:
                list_pad_top = -1
            try:
                long_search = self._get_field_value(fragment, "fragmentSearchField")
                if long_search is not None:
                    long_v = int(long_search.getVisibility() or 0)
                    long_h = int(long_search.getHeight() or 0)
            except Exception:
                pass
            try:
                search_tabs = self._get_field_value(fragment, "searchTabsAndFiltersLayout")
                if search_tabs is not None:
                    st_v = int(search_tabs.getVisibility() or 0)
                    st_h = int(search_tabs.getHeight() or 0)
            except Exception:
                pass
            try:
                top_panel = self._get_field_value(fragment, "topPanelLayout")
                if top_panel is not None:
                    tp_v = int(top_panel.getVisibility() or 0)
                    tp_h = int(top_panel.getHeight() or 0)
            except Exception:
                pass
            state = self._scroll_debug.get(key)
            if state is None:
                self._scroll_debug[key] = {
                    "scroll": sv,
                    "tabs_off": to,
                    "panel": panel_state,
                    "tabs_y": tabs_y,
                    "search": bool(search_active),
                    "pad_top": list_pad_top,
                    "lv": long_v,
                    "lh": long_h,
                    "svv": st_v,
                    "svh": st_h,
                    "tpv": tp_v,
                    "tph": tp_h,
                    "ts": int(time.time() * 1000),
                }
                self._dbg(
                    f"scroll/panel init [{source}]: search={bool(search_active)} scroll={sv:.1f} lock={locked_top:.1f} tabsOff={to:.1f} panel={panel_state} tabsY={tabs_y:.1f} padTop={list_pad_top} long(v={long_v},h={long_h}) st(v={st_v},h={st_h}) tp(v={tp_v},h={tp_h})"
                )
                return
            changed = (
                abs(float(state.get("scroll", 0.0)) - sv) > 10.0
                or abs(float(state.get("tabs_off", 0.0)) - to) > 2.0
                or str(state.get("panel", "")) != str(panel_state)
                or bool(state.get("search", False)) != bool(search_active)
                or int(state.get("pad_top", -1)) != int(list_pad_top)
                or int(state.get("lv", -1)) != int(long_v)
                or int(state.get("lh", -1)) != int(long_h)
                or int(state.get("svv", -1)) != int(st_v)
                or int(state.get("svh", -1)) != int(st_h)
                or int(state.get("tpv", -1)) != int(tp_v)
                or int(state.get("tph", -1)) != int(tp_h)
            )
            now_ms = int(time.time() * 1000)
            if changed and (now_ms - int(state.get("ts", 0) or 0) >= 120):
                self._scroll_debug[key] = {
                    "scroll": sv,
                    "tabs_off": to,
                    "panel": panel_state,
                    "tabs_y": tabs_y,
                    "search": bool(search_active),
                    "pad_top": list_pad_top,
                    "lv": long_v,
                    "lh": long_h,
                    "svv": st_v,
                    "svh": st_h,
                    "tpv": tp_v,
                    "tph": tp_h,
                    "ts": now_ms,
                }
                self._dbg(
                    f"scroll/panel [{source}]: search={bool(search_active)} scroll={sv:.1f} lock={locked_top:.1f} tabsOff={to:.1f} panel={panel_state} tabsY={tabs_y:.1f} padTop={list_pad_top} long(v={long_v},h={long_h}) st(v={st_v},h={st_h}) tp(v={tp_v},h={tp_h})"
                )
        except Exception:
            pass

    def _get_dialogs_list_view(self, fragment):
        try:
            if fragment is None:
                return None
            key = self._obj_key(fragment)
            cache_key = f"dialogs_list_field_{key}"
            cached = self._search_ui_state.get(cache_key, None)
            if cached:
                v = self._get_field_value(fragment, str(cached))
                if v is not None and hasattr(v, "setPadding"):
                    return v
            for name in ("listView", "dialogsListView", "recyclerListView", "dialogsList", "messagesListView"):
                v = self._get_field_value(fragment, name)
                if v is not None and hasattr(v, "setPadding"):
                    self._search_ui_state[cache_key] = name
                    return v
            cls = fragment.getClass()
            while cls is not None:
                try:
                    fields = cls.getDeclaredFields()
                except Exception:
                    fields = []
                for f in fields:
                    try:
                        nm = str(f.getName() or "")
                    except Exception:
                        nm = ""
                    if "list" not in nm.lower():
                        continue
                    try:
                        f.setAccessible(True)
                        vv = f.get(fragment)
                    except Exception:
                        vv = None
                    if vv is not None and hasattr(vv, "setPadding"):
                        self._search_ui_state[cache_key] = nm
                        self._dbg(f"dialogs list view detected: field={nm} class={str(vv.getClass().getName() or '')}")
                        return vv
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return None
        except Exception:
            return None

    def _restore_dialogs_list_spacing(self, fragment):
        # Dialog list spacing restore moved to dialogs_search_compact.plugin.
        return
    def _clamp_dialogs_offsets(self, fragment):
        # Dialog offsets clamp moved to dialogs_search_compact.plugin.
        return
    def _invoke_set_scroll_y(self, fragment, value):
        try:
            methods = fragment.getClass().getDeclaredMethods()
            for m in methods:
                if str(m.getName() or "") != "setScrollY":
                    continue
                params = m.getParameterTypes()
                if len(params) != 1:
                    continue
                type_name = str(params[0].getName() or "")
                if type_name not in ("float", "java.lang.Float"):
                    continue
                try:
                    m.setAccessible(True)
                    m.invoke(fragment, float(value))
                    return True
                except Exception:
                    continue
            self._set_field_value(fragment, "scrollYOffset", float(value))
            return True
        except Exception:
            return False

    def _build_profile_header(self, item_opts):
        try:
            fragment = get_private_field(item_opts, "fragment")
            if fragment is None:
                return None
            context = fragment.getContext()
            if context is None:
                return None

            account = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            user = None
            try:
                user = UserConfig.getInstance(account).getCurrentUser()
            except Exception:
                user = None

            root = FrameLayout(context)
            root.setTag(HEADER_TAG)

            bg = BackupImageView(context)
            try:
                avatar_bg = AvatarDrawable()
                if user is not None:
                    avatar_bg.setInfo(user)
                bg.setForUserOrChat(user, avatar_bg)
            except Exception:
                pass
            root.addView(bg, LayoutHelper.createFrame(-1, -1.0))

            overlay = View(context)
            try:
                dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                dark = False
            if dark:
                overlay.setBackgroundColor(Color.argb(166, 0, 0, 0))
            else:
                overlay.setBackgroundColor(Color.argb(104, 255, 255, 255))
            root.addView(overlay, LayoutHelper.createFrame(-1, -1.0))

            profile_click = OnClickListener(lambda _v: self._open_my_profile(fragment))

            avatar = BackupImageView(context)
            avatar.setRoundRadius(AndroidUtilities.dp(30.0))
            try:
                avatar_fg = AvatarDrawable()
                if user is not None:
                    avatar_fg.setInfo(user)
                avatar.setForUserOrChat(user, avatar_fg)
            except Exception:
                pass
            avatar.setOnClickListener(profile_click)
            root.addView(avatar, LayoutHelper.createFrame(66, 66.0, Gravity.LEFT | Gravity.TOP, 18.0, 20.0, 0.0, 0.0))

            text_block = LinearLayout(context)
            text_block.setOrientation(LinearLayout.VERTICAL)
            root.addView(
                text_block,
                LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.TOP, 18.0, 90.0, 74.0, 0.0),
            )

            name = TextView(context)
            name.setSingleLine(True)
            name.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
            try:
                name.setTextColor(int(Color.WHITE if dark else Color.BLACK))
            except Exception:
                name.setTextColor(Color.WHITE)
            name.setTextSize(18.0)
            try:
                display_name = UserObject.getUserName(user) if user is not None else "Telegram"
            except Exception:
                display_name = "Telegram"
            name.setText(display_name)
            name.setOnClickListener(profile_click)
            text_block.addView(name, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

            username = TextView(context)
            username.setSingleLine(True)
            username.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
            username.setTextSize(14.5)
            try:
                if dark:
                    username.setTextColor(Color.argb(236, 218, 224, 231))
                else:
                    username.setTextColor(Color.argb(238, 24, 24, 24))
            except Exception:
                username.setTextColor(Color.argb(236, 218, 224, 231))
            uname = ""
            try:
                raw_uname = str(getattr(user, "username", "") or "")
                if raw_uname:
                    uname = "@" + raw_uname
            except Exception:
                uname = ""
            if not uname:
                try:
                    uname = "id" + str(getattr(user, "id", "") or "")
                except Exception:
                    uname = "id"
            username.setText(uname)
            username.setOnClickListener(profile_click)
            text_block.addView(username, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

            arrow_touch = FrameLayout(context)
            arrow_touch.setTag(ACCOUNTS_ARROW_TAG)
            arrow_touch.setOnClickListener(OnClickListener(lambda _v, io=item_opts: self._toggle_accounts_panel(io)))
            try:
                arrow_touch.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1))
            except Exception:
                pass
            root.addView(
                arrow_touch,
                LayoutHelper.createFrame(58, 58.0, Gravity.RIGHT | Gravity.TOP, 0.0, 84.0, 8.0, 0.0),
            )

            arrow = ImageView(context)
            try:
                arrow.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_expand", 0))
            except Exception:
                try:
                    arrow.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_arrowright", 0))
                except Exception:
                    pass
            try:
                arrow.setColorFilter(int(Color.WHITE if dark else Color.BLACK))
            except Exception:
                arrow.setColorFilter(Color.argb(236, 218, 224, 231))
            try:
                arrow.setClickable(False)
                arrow.setEnabled(False)
            except Exception:
                pass
            arrow_touch.addView(arrow, LayoutHelper.createFrame(20, 20.0, Gravity.CENTER))

            return root
        except Exception as e:
            self._dbg(f"build profile header error: {e}")
            return None

    def _open_profile_menu(self, fragment, anchor_view):
        try:
            opts = ItemOptions.makeOptions(fragment, anchor_view, True)
            opts.setSwipebackGravity(False, False)
            opts.setMinWidth(240)
            profile_icon = getattr(jclass("org.telegram.messenger.R").drawable, "msg_openprofile", 0)
            if profile_icon == 0:
                profile_icon = getattr(jclass("org.telegram.messenger.R").drawable, "msg_contact_add", 0)
            open_profile_cb = self._make_runnable(lambda: self._open_my_profile(fragment))
            switch_cb = self._make_runnable(lambda: self._open_accounts_popup(fragment, anchor_view))
            if open_profile_cb is not None:
                opts.add(profile_icon, "Open profile", open_profile_cb)
            if switch_cb is not None:
                opts.add(getattr(jclass("org.telegram.messenger.R").drawable, "msg_arrowright", 0), "Switch account", switch_cb)
            opts.show()
            self._dbg("profile menu shown")
        except Exception:
            self._open_my_profile(fragment)

    def _make_runnable(self, fn):
        try:
            Runnable = jclass("java.lang.Runnable")
            Proxy = dynamic_proxy(Runnable)
            plugin_ref = self

            class _Run(Proxy):
                def run(self):
                    try:
                        fn()
                    except Exception as e:
                        plugin_ref._dbg(f"runnable error: {e}")

            return _Run()
        except Exception as e:
            self._dbg(f"make runnable error: {e}")
            return None

    def _open_my_profile(self, fragment):
        try:
            was_drawer = self._dismiss_active_drawer(fragment)
            account = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            user = None
            try:
                user = UserConfig.getInstance(account).getCurrentUser()
            except Exception:
                user = None
            user_id = int(getattr(user, "id", 0) or 0)
            if user_id == 0:
                return

            ProfileActivity = find_class("org.telegram.ui.ProfileActivity")
            if ProfileActivity is not None:
                try:
                    target = ProfileActivity.of(user_id)
                except Exception:
                    Bundle = find_class("android.os.Bundle")
                    if Bundle is not None:
                        b = Bundle()
                        b.putLong("user_id", int(user_id))
                        target = ProfileActivity(b)
                    else:
                        target = None
                if target is not None:
                    if was_drawer:
                        run_on_ui_thread(lambda: fragment.presentFragment(target), 120)
                    else:
                        fragment.presentFragment(target)
                    self._dbg("opened own profile")
        except Exception as e:
            self._dbg(f"open my profile error: {e}")

    def _open_accounts_popup(self, fragment, anchor_view):
        try:
            opts = ItemOptions.makeOptions(fragment, anchor_view, True)
            opts.setSwipebackGravity(False, False)
            opts.setMinWidth(260)

            selected = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            max_accounts = int(getattr(UserConfig, "MAX_ACCOUNT_COUNT", 16) or 16)
            added = 0
            for i in range(max_accounts):
                try:
                    cfg = UserConfig.getInstance(i)
                    if cfg is None or not cfg.isClientActivated():
                        continue
                    cb = self._make_switch_account_callback(fragment, i)
                    if cb is not None:
                        opts.addAccount(i, i == selected, cb)
                    added += 1
                except Exception:
                    pass

            if added > 0:
                try:
                    opts.addGap()
                except Exception:
                    pass

            add_cb = self._make_runnable(lambda: self._open_add_account(fragment))
            if add_cb is not None:
                opts.add(getattr(jclass("org.telegram.messenger.R").drawable, "msg_add", 0), "Add account", add_cb)
            opts.show()
            self._dbg("accounts popup shown")
        except Exception as e:
            self._dbg(f"accounts popup error: {e}")

    def _ensure_accounts_panel(self, item_opts, layout, fragment):
        try:
            if layout is None or fragment is None:
                return
            key = self._obj_key(fragment)
            linear = None
            try:
                linear = get_private_field(layout, "linearLayout")
            except Exception:
                linear = None
            if linear is None:
                linear = layout
            if linear is None or not hasattr(linear, "addView"):
                return

            panel = self._accounts_panel.get(key)
            if panel is not None:
                try:
                    p_parent = panel.getParent()
                    if p_parent is None:
                        panel = None
                    elif p_parent != linear:
                        if hasattr(p_parent, "removeView"):
                            p_parent.removeView(panel)
                        linear.addView(panel, 1, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
                        self._dbg("accounts panel reattached")
                except Exception:
                    panel = None
            if panel is None:
                panel = self._find_tagged_child(linear, ACCOUNTS_TAG)
            if panel is None:
                context = fragment.getContext()
                if context is None:
                    return
                panel = LinearLayout(context)
                panel.setTag(ACCOUNTS_TAG)
                panel.setOrientation(LinearLayout.VERTICAL)
                panel.setVisibility(View.GONE)
                panel.setAlpha(0.0)
                try:
                    panel.setBackgroundColor(int(Theme.getColor(Theme.key_windowBackgroundWhite)))
                except Exception:
                    pass
                linear.addView(panel, 1, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
                self._dbg("accounts panel created")
            else:
                self._dbg("accounts panel reused")
            self._accounts_panel[key] = panel
            if key not in self._accounts_open:
                self._accounts_open[key] = False

            arrow_touch = self._find_tagged_child(layout, ACCOUNTS_ARROW_TAG)
            if arrow_touch is not None:
                self._accounts_arrow[key] = arrow_touch

            self._fill_accounts_panel(fragment, panel)
            self._apply_accounts_panel_state(fragment, False)
        except Exception as e:
            self._dbg(f"ensure accounts panel error: {e}")

    def _fill_accounts_panel(self, fragment, panel):
        try:
            if panel is None:
                return
            context = fragment.getContext()
            if context is None:
                return
            key = self._obj_key(fragment)
            sig = self._get_accounts_signature(fragment)
            try:
                if sig is not None and self._accounts_signature.get(key) == sig and int(panel.getChildCount() or 0) > 0:
                    return
            except Exception:
                pass
            panel.removeAllViews()
            selected = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            max_accounts = int(getattr(UserConfig, "MAX_ACCOUNT_COUNT", 16) or 16)
            divider_color = int(Theme.getColor(Theme.key_divider))
            text_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            icon_color = int(Theme.getColor(Theme.key_chats_menuItemIcon))

            top_divider = View(context)
            top_divider.setBackgroundColor(divider_color)
            panel.addView(top_divider, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 1))

            for i in range(max_accounts):
                try:
                    cfg = UserConfig.getInstance(i)
                    if cfg is None or not cfg.isClientActivated():
                        continue
                    user = cfg.getCurrentUser()
                    if user is None:
                        continue

                    row = FrameLayout(context)
                    row.setBackground(Theme.getSelectorDrawable(True))

                    avatar = BackupImageView(context)
                    avatar.setRoundRadius(AndroidUtilities.dp(18.0))
                    try:
                        ad = AvatarDrawable()
                        ad.setInfo(user)
                        avatar.setForUserOrChat(user, ad)
                    except Exception:
                        pass
                    row.addView(avatar, LayoutHelper.createFrame(36, 36.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 12.0, 0.0, 0.0, 0.0))

                    name = TextView(context)
                    name.setSingleLine(True)
                    name.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                    name.setTextSize(16.0)
                    name.setTextColor(text_color)
                    try:
                        name.setText(UserObject.getUserName(user))
                    except Exception:
                        name.setText("Account")
                    row.addView(name, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 60.0, 0.0, 16.0, 0.0))

                    if i == selected:
                        check = ImageView(context)
                        try:
                            check.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_check", 0))
                            check.setColorFilter(icon_color)
                        except Exception:
                            pass
                        row.addView(check, LayoutHelper.createFrame(18, 18.0, Gravity.RIGHT | Gravity.CENTER_VERTICAL, 0.0, 0.0, 16.0, 0.0))

                    row.setOnClickListener(OnClickListener(lambda _v, aid=i: self._switch_account(fragment, aid)))
                    panel.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(52.0))))
                except Exception:
                    pass

            divider = View(context)
            divider.setBackgroundColor(divider_color)
            panel.addView(divider, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 1))

            add_row = FrameLayout(context)
            add_row.setBackground(Theme.getSelectorDrawable(True))
            add_icon = ImageView(context)
            try:
                add_icon.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_add", 0))
                add_icon.setColorFilter(icon_color)
            except Exception:
                pass
            add_row.addView(add_icon, LayoutHelper.createFrame(24, 24.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 18.0, 0.0, 0.0, 0.0))
            add_txt = TextView(context)
            add_txt.setText("Add account")
            add_txt.setTextSize(16.0)
            add_txt.setTextColor(text_color)
            add_row.addView(add_txt, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 60.0, 0.0, 16.0, 0.0))
            add_row.setOnClickListener(OnClickListener(lambda _v: self._open_add_account(fragment)))
            panel.addView(add_row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(52.0))))
            if sig is not None:
                self._accounts_signature[key] = sig
        except Exception as e:
            self._dbg(f"fill accounts panel error: {e}")

    def _get_accounts_signature(self, fragment):
        try:
            selected = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            max_accounts = int(getattr(UserConfig, "MAX_ACCOUNT_COUNT", 16) or 16)
            parts = [str(selected)]
            for i in range(max_accounts):
                try:
                    cfg = UserConfig.getInstance(i)
                    if cfg is None or not cfg.isClientActivated():
                        continue
                    user = cfg.getCurrentUser()
                    uid = int(getattr(user, "id", 0) or 0) if user is not None else 0
                    uname = ""
                    try:
                        uname = str(getattr(user, "username", "") or "")
                    except Exception:
                        uname = ""
                    parts.append(f"{i}:{uid}:{uname}")
                except Exception:
                    continue
            return "|".join(parts)
        except Exception:
            return None

    def _apply_accounts_panel_state(self, fragment, animated):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            panel = self._accounts_panel.get(key)
            if panel is None:
                return
            is_open = bool(self._accounts_open.get(key, False))
            arrow_touch = self._accounts_arrow.get(key)
            if arrow_touch is not None:
                try:
                    arrow_touch.animate().rotation(180.0 if is_open else 0.0).setDuration(180).start()
                except Exception:
                    pass

            if is_open:
                try:
                    panel.setVisibility(View.VISIBLE)
                    if animated:
                        panel.setAlpha(0.0)
                        panel.setTranslationY(-float(AndroidUtilities.dp(10.0)))
                        panel.animate().alpha(1.0).translationY(0.0).setDuration(200).start()
                    else:
                        panel.setAlpha(1.0)
                        panel.setTranslationY(0.0)
                except Exception:
                    pass
            else:
                try:
                    panel.animate().cancel()
                except Exception:
                    pass
                try:
                    if animated:
                        panel.setAlpha(0.0)
                        panel.setTranslationY(-float(AndroidUtilities.dp(10.0)))
                        panel.setVisibility(View.GONE)
                    else:
                        panel.setAlpha(0.0)
                        panel.setTranslationY(-float(AndroidUtilities.dp(10.0)))
                        panel.setVisibility(View.GONE)
                except Exception:
                    pass
        except Exception as e:
            self._dbg(f"apply accounts panel state error: {e}")

    def _toggle_accounts_panel(self, item_opts):
        try:
            fragment = get_private_field(item_opts, "fragment")
            if fragment is None:
                return
            key = self._obj_key(fragment)
            now_ms = int(time.time() * 1000)
            last_ms = int(self._accounts_last_toggle.get(key, 0) or 0)
            if now_ms - last_ms < 220:
                self._dbg(f"accounts panel toggle skipped: debounce key={key} dt={now_ms - last_ms}")
                return
            self._accounts_last_toggle[key] = now_ms
            panel = self._accounts_panel.get(key)
            if panel is None:
                try:
                    layout = item_opts.getLayout()
                except Exception:
                    layout = None
                self._ensure_accounts_panel(item_opts, layout, fragment)
                panel = self._accounts_panel.get(key)
            if panel is None:
                self._dbg("accounts panel toggle skipped: panel not ready")
                return
            self._fill_accounts_panel(fragment, panel)
            self._accounts_open[key] = not bool(self._accounts_open.get(key, False))
            self._dbg(f"accounts panel toggle request: key={key} open={self._accounts_open[key]}")
            self._apply_accounts_panel_state(fragment, True)
            try:
                if bool(self._accounts_open.get(key, False)):
                    panel.setVisibility(View.VISIBLE)
                    panel.setAlpha(1.0)
                    panel.setTranslationY(0.0)
                else:
                    panel.setAlpha(0.0)
                    panel.setTranslationY(-float(AndroidUtilities.dp(10.0)))
                    panel.setVisibility(View.GONE)
            except Exception:
                pass
            self._dbg(f"accounts panel toggled: {self._accounts_open.get(key)}")
        except Exception as e:
            self._dbg(f"toggle accounts panel error: {e}")

    def _open_plugins_activity(self, fragment):
        try:
            if fragment is None:
                return False

            # 1) Primary path in ETG sources: presentFragment(new PluginsActivity()).
            try:
                PluginsActivity = find_class("com.exteragram.messenger.plugins.ui.PluginsActivity")
            except Exception:
                PluginsActivity = None
            if PluginsActivity is not None:
                target = None
                try:
                    target = PluginsActivity()
                except Exception:
                    target = None
                if target is not None:
                    was_drawer = self._dismiss_active_drawer(fragment)
                    try:
                        if self._is_custom_drawer_enabled():
                            self._animate_custom_drawer(fragment, 0.0, 140)
                    except Exception:
                        pass
                    if was_drawer or bool(self._is_custom_drawer_enabled()):
                        run_on_ui_thread(lambda tg=target: fragment.presentFragment(tg), 145)
                    else:
                        fragment.presentFragment(target)
                    self._dbg("opened plugins activity direct")
                    return True

            # 2) Fallback: use PluginsController callback for "Plugins" item.
            try:
                cb = self._get_plugins_menu_callback()
            except Exception:
                cb = None
            if cb is not None:
                try:
                    self._dismiss_active_drawer(fragment)
                except Exception:
                    pass
                try:
                    if self._is_custom_drawer_enabled():
                        self._animate_custom_drawer(fragment, 0.0, 140)
                except Exception:
                    pass

                def _invoke_plugins_cb(callback_obj=cb):
                    try:
                        if hasattr(callback_obj, "invoke"):
                            callback_obj.invoke()
                        elif callable(callback_obj):
                            callback_obj()
                    except Exception as cb_err:
                        self._dbg(f"plugins callback invoke error: {cb_err}")

                run_on_ui_thread(_invoke_plugins_cb, 145)
                self._dbg("opened plugins via PluginsController callback")
                return True

            # 3) Last fallback: open other known plugin screens directly.
            target = None
            cls_names = (
                "com.exteragram.messenger.plugins.ui.PluginsFragment",
                "org.telegram.ui.PluginsActivity",
                "org.telegram.ui.PluginsFragment",
            )
            PluginsActivity = None
            for cls_name in cls_names:
                try:
                    PluginsActivity = find_class(cls_name)
                except Exception:
                    PluginsActivity = None
                if PluginsActivity is None:
                    continue
                target = None
                try:
                    target = PluginsActivity.newInstance()
                except Exception:
                    target = None
                if target is None:
                    try:
                        target = PluginsActivity.getInstance()
                    except Exception:
                        target = None
                if target is None:
                    try:
                        target = PluginsActivity()
                    except Exception:
                        target = None
                if target is not None:
                    break
            if target is None:
                return False

            was_drawer = self._dismiss_active_drawer(fragment)
            try:
                if self._is_custom_drawer_enabled():
                    self._animate_custom_drawer(fragment, 0.0, 140)
            except Exception:
                pass
            if was_drawer or bool(self._is_custom_drawer_enabled()):
                run_on_ui_thread(lambda tg=target: fragment.presentFragment(tg), 145)
            else:
                fragment.presentFragment(target)
            self._dbg("opened plugins activity from drawer")
            return True
        except Exception as e:
            self._dbg(f"open plugins activity error: {e}")
            return False

    def _get_plugins_menu_callback(self, menu_items=None):
        try:
            if menu_items is None:
                menu_items = self._get_plugins_menu_items_cached()
            if menu_items is None:
                return None
            size = int(menu_items.size() or 0)
            for i in range(size):
                try:
                    item = menu_items.get(i)
                except Exception:
                    item = None
                if item is None:
                    continue
                try:
                    txt = str(getattr(item, "text", "") or "").strip().lower()
                except Exception:
                    txt = ""
                if txt not in ("plugins", "плагины"):
                    continue
                try:
                    cb = getattr(item, "onClickCallback", None)
                except Exception:
                    cb = None
                if cb is None:
                    for attr in ("callback", "clickCallback", "onClick", "action"):
                        try:
                            cb = getattr(item, attr, None)
                        except Exception:
                            cb = None
                        if cb is not None:
                            break
                if cb is not None:
                    return cb
            return None
        except Exception:
            return None

    def _get_plugins_menu_icon(self, menu_items=None):
        try:
            if menu_items is None:
                menu_items = self._get_plugins_menu_items_cached()
            if menu_items is None:
                return None
            size = int(menu_items.size() or 0)
            for i in range(size):
                try:
                    item = menu_items.get(i)
                except Exception:
                    item = None
                if item is None:
                    continue
                try:
                    txt = str(getattr(item, "text", "") or "").strip().lower()
                except Exception:
                    txt = ""
                if txt not in ("plugins", "плагины"):
                    continue
                for attr in ("iconResId", "icon", "iconRes"):
                    try:
                        value = int(getattr(item, attr, 0) or 0)
                    except Exception:
                        value = 0
                    if value != 0:
                        return value
            try:
                fallback = int(getattr(jclass("org.telegram.messenger.R").drawable, "msg_plugins", 0) or 0)
            except Exception:
                fallback = 0
            return fallback if fallback != 0 else None
        except Exception:
            return None

    def _collect_plugins_menu_labels(self, menu_items=None):
        labels = set(["plugins", "плагины"])
        try:
            if menu_items is None:
                menu_items = self._get_plugins_menu_items_cached()
            if menu_items is None:
                return labels
            size = int(menu_items.size() or 0)
            for i in range(size):
                try:
                    item = menu_items.get(i)
                except Exception:
                    item = None
                if item is None:
                    continue
                try:
                    txt = str(getattr(item, "text", "") or "").strip().lower()
                except Exception:
                    txt = ""
                if txt:
                    labels.add(txt)
        except Exception as e:
            self._dbg(f"collect plugin labels error: {e}")
        return labels

    def _collect_plugins_menu_entries(self, menu_items=None):
        entries = []
        try:
            if menu_items is None:
                menu_items = self._get_plugins_menu_items_cached()
            if menu_items is None:
                return entries
            size = int(menu_items.size() or 0)
            for i in range(size):
                try:
                    item = menu_items.get(i)
                except Exception:
                    item = None
                if item is None:
                    continue
                try:
                    txt = str(getattr(item, "text", "") or "").strip()
                except Exception:
                    txt = ""
                if not txt or txt.lower() in ("plugins", "плагины"):
                    continue
                low = txt.lower()
                if self._is_theme_menu_item(low):
                    continue
                try:
                    icon_res = int(getattr(item, "iconResId", 0) or 0)
                except Exception:
                    icon_res = 0
                cb = getattr(item, "onClickCallback", None)
                if cb is None:
                    for attr in ("callback", "clickCallback", "onClick", "action"):
                        try:
                            cb = getattr(item, attr, None)
                        except Exception:
                            cb = None
                        if cb is not None:
                            break
                entries.append({"text": txt, "icon": icon_res, "callback": cb})
        except Exception as e:
            self._dbg(f"collect plugins entries error: {e}")
        return entries

    def _get_plugins_menu_items_cached(self):
        try:
            now_ms = int(time.time() * 1000)
            cache = self._plugins_menu_cache.get("main_menu")
            if cache is not None:
                ts = int(cache.get("ts", 0) or 0)
                items = cache.get("items", None)
                if items is not None and (now_ms - ts) < 30000:
                    return items
            items = self._get_plugins_menu_items()
            self._plugins_menu_cache["main_menu"] = {"ts": now_ms, "items": items}
            return items
        except Exception:
            return self._get_plugins_menu_items()

    def _get_plugins_menu_items(self):
        try:
            ctrl_cls = find_class("com.exteragram.messenger.plugins.PluginsController")
            if ctrl_cls is None:
                return None
            # First attempt: exact call style used in known working plugins.
            try:
                m_get = ctrl_cls.getMethod("getInstance")
                controller = m_get.invoke(None)
                if controller is not None:
                    StringCls = jclass("java.lang.String")
                    ObjectCls = jclass("java.lang.Object")
                    m_menu = ctrl_cls.getDeclaredMethod("getMenuItemsForLocation", StringCls, ObjectCls)
                    m_menu.setAccessible(True)
                    res = m_menu.invoke(controller, "main_menu", None)
                    if res is not None:
                        try:
                            self._dbg(f"plugins menu items fetched (fast path): {int(res.size() or 0)}")
                        except Exception:
                            self._dbg("plugins menu items fetched (fast path)")
                        return res
            except Exception:
                pass

            controller = None
            try:
                methods = ctrl_cls.getDeclaredMethods()
                for m in methods:
                    if str(m.getName() or "") == "getInstance" and len(m.getParameterTypes()) == 0:
                        m.setAccessible(True)
                        controller = m.invoke(None)
                        break
            except Exception:
                controller = None
            if controller is None:
                try:
                    controller = ctrl_cls.getInstance()
                except Exception:
                    controller = None
            if controller is None:
                return None

            methods = controller.getClass().getDeclaredMethods()
            for m in methods:
                if str(m.getName() or "") != "getMenuItemsForLocation":
                    continue
                if len(m.getParameterTypes()) != 2:
                    continue
                try:
                    m.setAccessible(True)
                    res = m.invoke(controller, "main_menu", None)
                    if res is not None:
                        try:
                            self._dbg(f"plugins menu items fetched (reflect): {int(res.size() or 0)}")
                        except Exception:
                            self._dbg("plugins menu items fetched (reflect)")
                    return res
                except Exception:
                    continue
            try:
                res = controller.getMenuItemsForLocation("main_menu", None)
                if res is not None:
                    try:
                        self._dbg(f"plugins menu items fetched (direct): {int(res.size() or 0)}")
                    except Exception:
                        self._dbg("plugins menu items fetched (direct)")
                return res
            except Exception:
                return None
        except Exception as e:
            self._dbg(f"get plugins menu items error: {e}")
            return None

    def _extract_text_from_view(self, view):
        try:
            if view is None:
                return ""
            if hasattr(view, "getText"):
                try:
                    t = str(view.getText() or "").strip()
                    if t:
                        return t
                except Exception:
                    pass
            if hasattr(view, "getChildCount"):
                count = int(view.getChildCount() or 0)
                for i in range(count):
                    t = self._extract_text_from_view(view.getChildAt(i))
                    if t:
                        return t
        except Exception:
            pass
        return ""

    def _reorder_plugins_menu_items(self, item_opts, layout):
        try:
            if layout is None:
                return
            fragment = None
            try:
                fragment = get_private_field(item_opts, "fragment")
            except Exception:
                fragment = None
            linear = None
            try:
                linear = get_private_field(layout, "linearLayout")
            except Exception:
                linear = None
            if linear is None:
                linear = layout
            if linear is None or not hasattr(linear, "getChildCount"):
                return

            menu_items = self._get_plugins_menu_items_cached()
            labels = self._collect_plugins_menu_labels(menu_items)
            child_count = int(linear.getChildCount() or 0)
            plugins_idx = -1
            plugins_row = None
            theme_row = None
            proxy_row = None
            plugin_views = []
            for i in range(child_count):
                child = linear.getChildAt(i)
                if child is None:
                    continue
                try:
                    if child.getTag() == HEADER_TAG:
                        continue
                except Exception:
                    pass
                txt = self._extract_text_from_view(child).strip().lower()
                if not txt:
                    continue
                if txt in ("plugins", "плагины"):
                    plugins_idx = i
                    plugins_row = child
                    continue
                if self._is_theme_menu_item(txt):
                    theme_row = child
                    continue
                if self._is_proxy_row_view(fragment, child, txt):
                    proxy_row = child
                    continue
                if txt in labels:
                    plugin_views.append(child)
            f_key = self._obj_key(fragment) if fragment is not None else 0
            if fragment is not None and f_key != 0:
                if theme_row is not None:
                    self._theme_row[f_key] = theme_row
                    try:
                        ic = self._extract_first_icon_drawable(theme_row)
                        if ic is not None:
                            self._theme_icon[f_key] = ic
                    except Exception:
                        pass
                    self._collapse_menu_row(theme_row)
                if proxy_row is not None:
                    self._proxy_row[f_key] = proxy_row
                    try:
                        ic = self._extract_first_icon_drawable(proxy_row)
                        if ic is not None:
                            self._proxy_icon[f_key] = ic
                    except Exception:
                        pass
                    self._collapse_menu_row(proxy_row)
            if plugins_row is not None and fragment is not None:
                try:
                    click = OnClickListener(lambda _v, fr=fragment: self._open_plugins_activity(fr))
                    plugins_row.setOnClickListener(click)
                    self._edge_listeners[f"plugins_row_click_{self._obj_key(plugins_row)}"] = click
                    self._hide_plugins_row_arrow(plugins_row)
                    self._dbg("plugins row hooked: click+arrow")
                except Exception as click_err:
                    self._dbg(f"plugins row click bind error: {click_err}")
            moved = 0
            if plugin_views:
                for view in plugin_views:
                    try:
                        linear.removeView(view)
                    except Exception:
                        pass
                insert_at = int(linear.getChildCount() or 0)
                for view in plugin_views:
                    try:
                        linear.addView(view, insert_at)
                        insert_at += 1
                        moved += 1
                    except Exception:
                        pass
            entries = self._collect_plugins_menu_entries(menu_items)
            self._append_plugin_extra_rows(linear, fragment, entries)
            self._apply_menu_row_style(linear)
            if fragment is not None:
                header = self._find_tagged_child(layout, HEADER_TAG)
                if header is not None:
                    self._ensure_theme_header_button(header, fragment)
                self._ensure_proxy_top_button(fragment)
            self._dbg(f"plugins reorder done: labels={len(labels)} moved={moved}")
            if plugins_row is not None:
                try:
                    ptxt = self._extract_text_from_view(plugins_row)
                except Exception:
                    ptxt = ""
                self._dbg(f"plugins row visible text='{ptxt}'")
            if moved > 0:
                self._dbg(f"plugin items moved below Plugins: {moved}")
        except Exception as e:
            self._dbg(f"reorder plugin items error: {e}")

    def _hide_plugins_row_arrow(self, row):
        try:
            if row is None:
                return
            # Do not mutate unknown internals anymore: this was hiding plugin icon on some builds.
            # Arrow hiding is handled by a lightweight right-edge overlay line to keep icon/text safe.
            self._ensure_plugins_row_right_bar(row)
        except Exception as e:
            self._dbg(f"hide plugins row arrow error: {e}")

    def _ensure_plugins_row_right_bar(self, row):
        try:
            if row is None:
                return
            marker_tag = "legacy_side_drawer_plugins_right_bar"
            if self._find_tagged_child(row, marker_tag) is not None:
                return
            context = row.getContext()
            if context is None:
                return
            bar = View(context)
            bar.setTag(marker_tag)
            try:
                bar.setBackgroundColor(int(Theme.getColor(Theme.key_windowBackgroundWhite)))
            except Exception:
                try:
                    bar.setBackgroundColor(int(Theme.getColor(Theme.key_dialogBackground)))
                except Exception:
                    pass
            row.addView(bar, LayoutHelper.createFrame(22, 50.0, Gravity.RIGHT | Gravity.CENTER_VERTICAL, 0.0, 0.0, 0.0, 0.0))
        except Exception as e:
            self._dbg(f"ensure plugins row right bar error: {e}")

    def _apply_menu_row_style(self, linear):
        try:
            if linear is None or not hasattr(linear, "getChildCount"):
                return
            count = int(linear.getChildCount() or 0)
            for i in range(count):
                child = linear.getChildAt(i)
                if child is None:
                    continue
                tag = None
                try:
                    tag = child.getTag()
                except Exception:
                    tag = None
                if tag in (HEADER_TAG, ACCOUNTS_TAG, PLUGIN_EXTRA_ROW_TAG):
                    continue
                self._style_divider_if_needed(child)
                try:
                    if hasattr(child, "isClickable") and child.isClickable():
                        child.setBackground(Theme.getSelectorDrawable(True))
                except Exception:
                    pass
                self._tint_texts_recursive(child)
                self._tint_icons_recursive(child)
        except Exception as e:
            self._dbg(f"apply menu row style error: {e}")

    def _style_divider_if_needed(self, child):
        try:
            if child is None:
                return
            lp = None
            try:
                lp = child.getLayoutParams()
            except Exception:
                lp = None
            h = int(getattr(lp, "height", 0) or 0) if lp is not None else 0
            cls = ""
            try:
                cls = str(child.getClass().getName() or "")
            except Exception:
                cls = ""
            is_native_divider_cls = (
                ("Divider" in cls)
                or ("ShadowSectionCell" in cls)
                or ("GraySectionCell" in cls)
                or ("GreySectionCell" in cls)
            )
            has_children = False
            try:
                has_children = hasattr(child, "getChildCount") and int(child.getChildCount() or 0) > 0
            except Exception:
                has_children = False
            if not is_native_divider_cls:
                txt = ""
                try:
                    txt = self._extract_text_from_view(child).strip()
                except Exception:
                    txt = ""
                clickable = False
                try:
                    clickable = bool(child.isClickable())
                except Exception:
                    clickable = False
                if txt or clickable:
                    return
            if has_children and (not is_native_divider_cls):
                return
            if h <= 0:
                if not is_native_divider_cls:
                    return
            elif h > int(AndroidUtilities.dp(22.0)):
                return
            bar_color = int(Theme.getColor(Theme.key_divider))
            try:
                bg_color = int(Theme.getColor(Theme.key_windowBackgroundWhite))
            except Exception:
                bg_color = bar_color
            if bar_color == bg_color:
                try:
                    icon_color = int(Theme.getColor(Theme.key_chats_menuItemIcon))
                    bar_color = Color.argb(170, Color.red(icon_color), Color.green(icon_color), Color.blue(icon_color))
                except Exception:
                    pass
            child.setBackgroundColor(bar_color)
            if lp is not None:
                if hasattr(lp, "height"):
                    lp.height = max(1, int(AndroidUtilities.dp(1.0)))
                if hasattr(lp, "leftMargin"):
                    lp.leftMargin = int(AndroidUtilities.dp(16.0))
                if hasattr(lp, "rightMargin"):
                    lp.rightMargin = int(AndroidUtilities.dp(16.0))
                child.setLayoutParams(lp)
        except Exception:
            pass

    def _tint_texts_recursive(self, node):
        try:
            if node is None:
                return
            if isinstance(node, TextView):
                try:
                    node.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
                except Exception:
                    pass
            if hasattr(node, "getChildCount"):
                count = int(node.getChildCount() or 0)
                for i in range(count):
                    self._tint_texts_recursive(node.getChildAt(i))
        except Exception:
            pass

    def _tint_icons_recursive(self, node):
        try:
            if node is None:
                return
            if isinstance(node, ImageView):
                try:
                    node.setColorFilter(int(Theme.getColor(Theme.key_chats_menuItemIcon)))
                except Exception:
                    pass
            if hasattr(node, "getChildCount"):
                count = int(node.getChildCount() or 0)
                for i in range(count):
                    self._tint_icons_recursive(node.getChildAt(i))
        except Exception:
            pass

    def _append_plugin_extra_rows(self, linear, fragment, entries=None):
        try:
            if linear is None or fragment is None:
                return
            context = fragment.getContext()
            if context is None:
                return

            # Remove previously injected rows.
            idx = int(linear.getChildCount() or 0) - 1
            while idx >= 0:
                child = linear.getChildAt(idx)
                if child is not None:
                    try:
                        if child.getTag() == PLUGIN_EXTRA_ROW_TAG:
                            linear.removeViewAt(idx)
                    except Exception:
                        pass
                idx -= 1

            if entries is None:
                entries = self._collect_plugins_menu_entries()
            if not entries:
                self._dbg("plugin entries injection skipped: no entries from PluginsController")
                return

            icon_color = int(Theme.getColor(Theme.key_chats_menuItemIcon))
            text_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            divider_color = int(Theme.getColor(Theme.key_divider))

            divider = View(context)
            divider.setTag(PLUGIN_EXTRA_ROW_TAG)
            divider.setBackgroundColor(divider_color)
            linear.addView(divider, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 1))

            for ent in entries:
                row = FrameLayout(context)
                row.setTag(PLUGIN_EXTRA_ROW_TAG)
                row.setBackground(Theme.getSelectorDrawable(True))

                icon = ImageView(context)
                try:
                    if int(ent["icon"] or 0) != 0:
                        icon.setImageResource(int(ent["icon"]))
                        icon.setColorFilter(icon_color)
                except Exception:
                    pass
                row.addView(icon, LayoutHelper.createFrame(24, 24.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 18.0, 0.0, 0.0, 0.0))

                tv = TextView(context)
                tv.setSingleLine(True)
                tv.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                tv.setTextSize(16.0)
                tv.setTextColor(text_color)
                tv.setText(str(ent["text"]))
                row.addView(tv, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 60.0, 0.0, 16.0, 0.0))

                cb = ent.get("callback", None)

                def _invoke_callback(callback_obj=cb, fr=fragment):
                    try:
                        self._dismiss_active_drawer(fr)
                    except Exception:
                        pass
                    if callback_obj is None:
                        return
                    try:
                        if hasattr(callback_obj, "invoke"):
                            callback_obj.invoke()
                        elif callable(callback_obj):
                            callback_obj()
                    except Exception as call_err:
                        self._dbg(f"plugin callback invoke error: {call_err}")

                row.setOnClickListener(OnClickListener(lambda _v, fn=_invoke_callback: fn()))
                linear.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(50.0))))

            self._dbg(f"plugin entries injected at bottom: {len(entries)}")
        except Exception as e:
            self._dbg(f"append plugin extra rows error: {e}")

    def _make_switch_account_callback(self, fragment, account_id):
        return self._make_runnable(lambda: self._switch_account(fragment, account_id))

    def _switch_account(self, fragment, account_id):
        try:
            try:
                if self._is_custom_drawer_enabled():
                    self._animate_custom_drawer(fragment, 0.0, 140)
            except Exception:
                pass
            activity = fragment.getParentActivity()
            if activity is None:
                return
            activity.switchToAccount(int(account_id), True)
            self._dbg(f"switched account -> {account_id}")
        except Exception as e:
            self._dbg(f"switch account error: {e}")

    def _open_add_account(self, fragment):
        try:
            was_drawer = self._dismiss_active_drawer(fragment)
            activity = fragment.getParentActivity()
            if activity is None:
                return
            LoginActivity = find_class("org.telegram.ui.LoginActivity")
            if LoginActivity is not None:
                if was_drawer:
                    run_on_ui_thread(lambda: activity.presentFragment(LoginActivity()), 120)
                else:
                    activity.presentFragment(LoginActivity())
                self._dbg("presented LoginActivity")
        except Exception as e:
            self._dbg(f"open add account error: {e}")

    def _get_field_value(self, obj, field_name):
        try:
            if obj is None:
                return None
            cls = obj.getClass()
            while cls is not None:
                try:
                    f = cls.getDeclaredField(field_name)
                    f.setAccessible(True)
                    return f.get(obj)
                except Exception:
                    cls = cls.getSuperclass()
            return None
        except Exception:
            return None

    def _set_field_value(self, obj, field_name, value):
        try:
            if obj is None:
                return False
            cls = obj.getClass()
            while cls is not None:
                try:
                    f = cls.getDeclaredField(field_name)
                    f.setAccessible(True)
                    type_name = str(f.getType().getName() or "")
                    if type_name == "int":
                        f.setInt(obj, int(value))
                    elif type_name == "long":
                        f.setLong(obj, int(value))
                    elif type_name == "float":
                        f.setFloat(obj, float(value))
                    elif type_name == "double":
                        f.setDouble(obj, float(value))
                    elif type_name == "boolean":
                        f.setBoolean(obj, bool(value))
                    else:
                        f.set(obj, value)
                    return True
                except Exception:
                    cls = cls.getSuperclass()
            return False
        except Exception:
            return False

    def _find_tagged_child(self, parent, tag):
        try:
            if parent is None or not hasattr(parent, "getChildCount"):
                return None
            stack = [parent]
            while stack:
                node = stack.pop()
                try:
                    if node is not None and hasattr(node, "getTag") and node.getTag() == tag:
                        return node
                except Exception:
                    pass
                try:
                    if node is not None and hasattr(node, "getChildCount"):
                        child_count = int(node.getChildCount() or 0)
                        for i in range(child_count - 1, -1, -1):
                            child = node.getChildAt(i)
                            if child is not None:
                                stack.append(child)
                except Exception:
                    pass
            return None
        except Exception:
            return None
