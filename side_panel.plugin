    def _apply_compact_context_lock(self, fragment, source=""):
        # Search/header compact lock moved to dialogs_search_compact.plugin.
        return
    def _pin_filter_tabs_compact(self, fragment):
        try:
            if fragment is None:
                return
            # Disabled: direct Y pinning causes misplacement on some builds.
            return
            tabs = None
            try:
                tabs = self._get_field_value(fragment, "filterTabsView")
            except Exception:
                tabs = None
            if tabs is None:
                return
            desired_y = float(AndroidUtilities.dp(3.0))
            try:
                cur_y = float(tabs.getY() or 0.0) + float(tabs.getTranslationY() or 0.0)
            except Exception:
                cur_y = desired_y
            if abs(cur_y - desired_y) <= 0.5:
                return
            try:
                tabs.setTranslationY(0.0)
            except Exception:
                pass
            try:
                tabs.setY(desired_y)
            except Exception:
                pass
            try:
                key = self._obj_key(fragment)
                now_ms = int(time.time() * 1000)
                ts_key = f"tabs_pin_log_{key}"
                last = int(self._search_ui_state.get(ts_key, 0) or 0)
                if now_ms - last >= 800:
                    self._search_ui_state[ts_key] = now_ms
                    self._dbg(f"tabs pin: {cur_y:.1f} -> {desired_y:.1f}")
            except Exception:
                pass
        except Exception as e:
            self._dbg(f"pin tabs compact error: {e}")

