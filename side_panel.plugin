    def _dbg(self, text):
        if self.get_setting("debug_logs", False):
            log(f"[SidePanel] {text}")

    def _dbg_proxy(self, fragment, tag, text, min_ms=0, state=None):
        try:
            if not self.get_setting("debug_logs", False):
                return
            f_key = self._obj_key(fragment) if fragment is not None else 0
            cache_key = f"proxy_{f_key}_{str(tag or '')}"
            now_ms = int(time.time() * 1000)
            prev = self._proxy_log_state.get(cache_key)
            if prev is not None:
                try:
                    prev_ts = int(prev.get("ts", 0) or 0)
                except Exception:
                    prev_ts = 0
                if state is not None:
                    if prev.get("state") == state and (now_ms - prev_ts) < int(max(0, min_ms)):
                        return
                elif (now_ms - prev_ts) < int(max(0, min_ms)):
                    return
            self._proxy_log_state[cache_key] = {"ts": now_ms, "state": state}
            self._dbg(text)
        except Exception:
            pass

    def _obj_key(self, obj):
        try:
            if obj is None:
                return 0
            try:
                return int(obj.hashCode())
            except Exception:
                return int(hash(obj))
        except Exception:
            return 0

    def on_plugin_load(self):
        if self.get_setting("enabled") is None:
            self.set_setting("enabled", True)
        if self.get_setting("edge_swipe") is None:
            self.set_setting("edge_swipe", True)
        if self.get_setting("custom_drawer_mode") is None:
            self.set_setting("custom_drawer_mode", True)
        if self.get_setting("debug_logs") is None:
            self.set_setting("debug_logs", True)
        self._install_hooks()

    def on_plugin_unload(self):
        for h in list(self._hooks):
            try:
                self.unhook_method(h)
            except Exception:
                pass
        try:
            for k, v in list(self._custom_drawer_root.items()):
                try:
                    p = v.getParent()
                    if p is not None and hasattr(p, "removeView"):
                        p.removeView(v)
                except Exception:
                    pass
        except Exception:
            pass
        try:
            for k, v in list(self._edge_views.items()):
                try:
                    p = v.getParent()
                    if p is not None and hasattr(p, "removeView"):
                        p.removeView(v)
                except Exception:
                    pass
        except Exception:
            pass
        self._hooks = []
        self._edge_views = {}
        self._edge_listeners = {}
        self._itemoptions_marker = {}
        self._swipe_track = {}
        self._active_drawer = {}
        self._accounts_panel = {}
        self._accounts_open = {}
        self._accounts_arrow = {}
        self._search_ui_state = {}
        self._last_scroll_fix = {}
        self._accounts_last_toggle = {}
        self._menu_patch_done = {}
        self._scroll_debug = {}
        self._top_lock_state = {}
        self._ctx_lock_state = {}
        self._set_scroll_guard = {}
        self._reset_scroll_state = {}
        self._open_origin = {}
        self._header_cache = {}
        self._plugins_menu_cache = {}
        self._accounts_signature = {}
        self._theme_row = {}
        self._proxy_row = {}
        self._theme_icon = {}
        self._proxy_icon = {}
        self._proxy_btn_sig = {}
        self._proxy_btn_x = {}
        self._proxy_anim_state = {}
        self._proxy_recover_ts = {}
        self._proxy_ui_state = {}
        self._proxy_settle_token = {}
        self._proxy_log_state = {}
        self._menu_icon_compact_off = {}
        self._menu_pair_off = {}
        self._menu_pair_icon_off = {}
        self._recycler_cancel_guard = {}
        self._anim_defer_pending = {}
        self._open_anim_pending = {}
