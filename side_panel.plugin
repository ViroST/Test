        ]

    def _install_hooks(self):
        if not self.get_setting("enabled", True):
            self._dbg("plugin disabled; hooks skipped")
            return
        self._dialogs_dispatch_hooked = False

        try:
            DialogsActivity = find_class("org.telegram.ui.DialogsActivity")
            ContextClass = find_class("android.content.Context")
            if DialogsActivity and ContextClass:
                create_view = DialogsActivity.getClass().getDeclaredMethod("createView", ContextClass)
                create_view.setAccessible(True)
                self._hooks.append(self.hook_method(create_view, self._DialogsCreateViewHook(self)))
                self._dbg("hooked DialogsActivity.createView")
                try:
                    on_resume = DialogsActivity.getClass().getDeclaredMethod("onResume")
                    on_resume.setAccessible(True)
                    self._hooks.append(self.hook_method(on_resume, self._DialogsOnResumeHook(self)))
                    self._dbg("hooked DialogsActivity.onResume")
                except Exception as resume_err:
                    self._dbg(f"hook DialogsActivity.onResume failed: {resume_err}")
                try:
                    check_ui = DialogsActivity.getClass().getDeclaredMethod("checkUi_menuItems")
                    check_ui.setAccessible(True)
                    self._hooks.append(self.hook_method(check_ui, self._DialogsCheckUiHook(self)))
                    self._dbg("hooked DialogsActivity.checkUi_menuItems")
                except Exception as check_err:
                    self._dbg(f"hook DialogsActivity.checkUi_menuItems failed: {check_err}")
                for ui_name in ("checkUi_itemSearchVisibility", "checkUi_searchFieldVisibility"):
                    try:
                        ui_method = DialogsActivity.getClass().getDeclaredMethod(ui_name)
                        ui_method.setAccessible(True)
                        self._hooks.append(self.hook_method(ui_method, self._DialogsSearchUiHook(self)))
                        self._dbg(f"hooked DialogsActivity.{ui_name}")
                    except Exception as ui_err:
                        self._dbg(f"hook DialogsActivity.{ui_name} failed: {ui_err}")
                try:
                    MotionEventClsMain = find_class("android.view.MotionEvent")
                    dispatch_touch = None
                    try:
                        dispatch_touch = DialogsActivity.getClass().getDeclaredMethod("dispatchTouchEvent", MotionEventClsMain)
                    except Exception:
                        dispatch_touch = None
                    if dispatch_touch is None:
                        try:
                            dispatch_touch = DialogsActivity.getClass().getMethod("dispatchTouchEvent", MotionEventClsMain)
                        except Exception:
                            dispatch_touch = None
                    if dispatch_touch is not None:
                        dispatch_touch.setAccessible(True)
                        self._hooks.append(self.hook_method(dispatch_touch, self._DialogsDispatchTouchHook(self)))
                        self._dialogs_dispatch_hooked = True
                        self._dbg("hooked DialogsActivity.dispatchTouchEvent")
                    else:
                        self._dbg("DialogsActivity.dispatchTouchEvent not found")
                except Exception as dt_err:
                    self._dbg(f"hook DialogsActivity.dispatchTouchEvent failed: {dt_err}")
                # Search panel locking/fixes were moved to dialogs_search_compact plugin.
            else:
                self._dbg("DialogsActivity or Context class not found")
        except Exception as e:
            self._dbg(f"hook DialogsActivity.createView failed: {e}")

        try:
            RecyclerCls = find_class("org.telegram.ui.DialogsActivity$DialogsRecyclerView")
            MotionEventCls = find_class("android.view.MotionEvent")
            if RecyclerCls and MotionEventCls:
                for method_name in ("onInterceptTouchEvent", "onTouchEvent"):
                    target = None
                    for m in RecyclerCls.getClass().getDeclaredMethods():
                        if str(m.getName() or "") != method_name:
                            continue
                        params = m.getParameterTypes()
                        if len(params) != 1:
                            continue
                        try:
                            if "android.view.MotionEvent" not in str(params[0].getName() or ""):
                                continue
                        except Exception:
                            continue
                        target = m
                        break
                    if target is not None:
                        target.setAccessible(True)
                        self._hooks.append(self.hook_method(target, self._RecyclerSwipeHook(self, method_name)))
                        self._dbg(f"hooked DialogsRecyclerView.{method_name}")
                    else:
                        self._dbg(f"DialogsRecyclerView.{method_name} not found")
        except Exception as e:
            self._dbg(f"hook DialogsRecyclerView swipe failed: {e}")

        try:
            ItemOptionsClass = find_class("org.telegram.ui.Components.ItemOptions")
            if ItemOptionsClass:
                show_method = ItemOptionsClass.getClass().getDeclaredMethod("show")
                show_method.setAccessible(True)
                self._hooks.append(self.hook_method(show_method, self._ItemOptionsShowHook(self)))
                self._dbg("hooked ItemOptions.show")
                try:
                    dismiss_method = ItemOptionsClass.getClass().getDeclaredMethod("dismiss")
                    dismiss_method.setAccessible(True)
                    self._hooks.append(self.hook_method(dismiss_method, self._ItemOptionsDismissHook(self)))
                    self._dbg("hooked ItemOptions.dismiss")
                except Exception as dismiss_err:
                    self._dbg(f"hook ItemOptions.dismiss failed: {dismiss_err}")
            else:
                self._dbg("ItemOptions class not found")
        except Exception as e:
            self._dbg(f"hook ItemOptions.show failed: {e}")

    class _DialogsCreateViewHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True):
                    return
                fragment = param.thisObject
                root = param.getResult()
                self.plugin._ensure_fragment_ui(fragment, root)
            except Exception as e:
                self.plugin._dbg(f"createView hook error: {e}")

    class _DialogsOnResumeHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True):
                    return
                fragment = param.thisObject
                self.plugin._ensure_fragment_ui(fragment, None)
            except Exception as e:
                self.plugin._dbg(f"onResume hook error: {e}")

    class _DialogsCheckUiHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True):
                    return
                fragment = param.thisObject
                self.plugin._update_dialogs_controls(fragment, False)
            except Exception as e:
                self.plugin._dbg(f"checkUi_menuItems hook error: {e}")

    class _DialogsSearchUiHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                fragment = param.thisObject
                if fragment is None:
                    return
                self.plugin._update_dialogs_controls(fragment, False)
            except Exception as e:
                self.plugin._dbg(f"search-ui hook error: {e}")

    # Search/header fixation hooks were moved to dialogs_search_compact.plugin.

    class _DialogsDispatchTouchHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True) or not self.plugin.get_setting("edge_swipe", True):
                    return
                fragment = param.thisObject
                if fragment is None:
                    return
                args = getattr(param, "args", []) or []
                if not args:
                    return
                ev = args[0]
                if ev is None:
                    return
                f_key = self.plugin._obj_key(fragment)
                track_key = f"dlg_touch_{f_key}"
                st = self.plugin._swipe_track.get(track_key) or {"active": False, "opened": False, "x": 0.0, "y": 0.0}
                action = int(ev.getActionMasked())

                if self.plugin._is_custom_drawer_enabled():
                    self.plugin._handle_custom_swipe_touch(fragment, ev, track_key, "dispatchTouchEvent", param, None)
                    return

                if action == MotionEvent.ACTION_DOWN:
                    st["active"] = True
                    st["opened"] = False
                    st["x"] = float(ev.getRawX())
                    st["y"] = float(ev.getRawY())
                    self.plugin._swipe_track[track_key] = st
                    return

                if action == MotionEvent.ACTION_MOVE and st.get("active"):
                    dx = float(ev.getRawX()) - float(st.get("x", 0.0))
                    dy = abs(float(ev.getRawY()) - float(st.get("y", 0.0)))
                    if (not st.get("opened")) and dx > float(AndroidUtilities.dp(54.0)) and dy < float(AndroidUtilities.dp(126.0)) and dx > (dy * 0.85):
                        st["opened"] = True
                        st["active"] = False
                        self.plugin._swipe_track[track_key] = st
                        self.plugin._request_swipe_open(fragment, float(ev.getRawY()), "dispatchTouchEvent")
                        return
                    drawer = self.plugin._active_drawer.get(f_key)
                    if drawer is not None and dx < -float(AndroidUtilities.dp(34.0)) and abs(dx) > (dy * 0.65):
                        st["active"] = False
                        st["opened"] = False
                        self.plugin._swipe_track[track_key] = st
                        self.plugin._dismiss_active_drawer(fragment)
                        param.setResult(True)
                    return

                if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                    if track_key in self.plugin._swipe_track:
                        del self.plugin._swipe_track[track_key]
            except Exception as e:
                self.plugin._dbg(f"Dialogs dispatch touch hook error: {e}")

    class _RecyclerSwipeHook(MethodHook):
        def __init__(self, plugin, source_name):
            self.plugin = plugin
            self.source_name = source_name

        def before_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True) or not self.plugin.get_setting("edge_swipe", True):
                    return
                args = getattr(param, "args", []) or []
                if not args:
                    return
                ev = args[0]
                if ev is None:
                    return
                view = param.thisObject
                fragment = self.plugin._resolve_dialogs_fragment(view)
                if fragment is None:
                    fragment = get_last_fragment()
                if self.plugin._is_custom_drawer_enabled():
                    # Primary path is DialogsActivity.dispatchTouchEvent.
                    # Fallback to recycler hooks only when dispatch hook is unavailable.
                    if self.plugin._dialogs_dispatch_hooked:
                        return
                    rv_track_key = f"rv_custom_{self.plugin._obj_key(view)}"
                    src_name = str(self.source_name or "")
                    action = int(ev.getActionMasked())
                    try:
                        v_key = self.plugin._obj_key(view)
                    except Exception:
                        v_key = 0
                    try:
                        guard_ts = int(self.plugin._recycler_cancel_guard.get(v_key, 0) or 0)
                    except Exception:
                        guard_ts = 0
                    if guard_ts > 0:
                        now_ms = int(time.time() * 1000)
                        if now_ms - guard_ts > 450:
                            try:
                                del self.plugin._recycler_cancel_guard[v_key]
                            except Exception:
                                pass
                        elif action == MotionEvent.ACTION_CANCEL:
                            try:
                                del self.plugin._recycler_cancel_guard[v_key]
                            except Exception:
                                pass
                            return
                    # Fallback mode: intercept seeds DOWN, touch handles full gesture.
                    if src_name == "onInterceptTouchEvent":
                        if action != MotionEvent.ACTION_DOWN:
                            return
                    elif src_name == "onTouchEvent":
                        if action == MotionEvent.ACTION_DOWN and rv_track_key in self.plugin._swipe_track:
                            return
                        if action != MotionEvent.ACTION_DOWN and rv_track_key not in self.plugin._swipe_track:
                            return
                    else:
                        return
                    if action == MotionEvent.ACTION_DOWN and src_name == "onInterceptTouchEvent":
                        try:
                            self.plugin._dbg("custom swipe fallback path: recycler")
                        except Exception:
                            pass
                    self.plugin._handle_custom_swipe_touch(
                        fragment,
                        ev,
                        rv_track_key,
                        f"recycler_{src_name}",
                        param,
                        view,
                    )
                    return

                key = self.plugin._obj_key(view)
                action = int(ev.getActionMasked())
                st = self.plugin._swipe_track.get(key) or {"active": False, "opened": False, "x": 0.0, "y": 0.0}

                if action == MotionEvent.ACTION_DOWN:
                    st["active"] = True
                    st["opened"] = False
                    st["x"] = float(ev.getRawX())
                    st["y"] = float(ev.getRawY())
                    self.plugin._swipe_track[key] = st
                    return

                if action == MotionEvent.ACTION_MOVE and st.get("active"):
                    dx = float(ev.getRawX()) - float(st.get("x", 0.0))
                    dy = abs(float(ev.getRawY()) - float(st.get("y", 0.0)))
                    if (not st.get("opened")) and dx > float(AndroidUtilities.dp(54.0)) and dy < float(AndroidUtilities.dp(126.0)) and dx > (dy * 0.85):
                        if fragment is not None:
                            try:
                                if str(fragment.getClass().getName() or "") == "org.telegram.ui.DialogsActivity":
                                    st["opened"] = True
                                    st["active"] = False
                                    self.plugin._swipe_track[key] = st
                                    self.plugin._request_swipe_open(fragment, float(ev.getRawY()), self.source_name)
                            except Exception:
                                pass
                    return

                if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                    if key in self.plugin._swipe_track:
                        del self.plugin._swipe_track[key]
            except Exception as e:
                self.plugin._dbg(f"Recycler swipe hook error: {e}")

    class _ItemOptionsDismissHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            try:
                item_opts = param.thisObject
                if not self.plugin._is_dialogs_activity_item_options(item_opts):
                    return
                fragment = None
                try:
                    fragment = get_private_field(item_opts, "fragment")
                except Exception:
                    fragment = None
                if fragment is not None:
                    key = self.plugin._obj_key(fragment)
                    if key in self.plugin._active_drawer:
                        del self.plugin._active_drawer[key]
                    self.plugin._accounts_open[key] = False
                    if key in self.plugin._open_origin:
                        del self.plugin._open_origin[key]
                    if key in self.plugin._theme_row:
                        del self.plugin._theme_row[key]
                    if key in self.plugin._proxy_row:
                        del self.plugin._proxy_row[key]
                    if key in self.plugin._title_margin_cache:
                        del self.plugin._title_margin_cache[key]
                    try:
                        ik = self.plugin._obj_key(item_opts)
                        if ik in self.plugin._anim_defer_pending:
                            del self.plugin._anim_defer_pending[ik]
                        if ik in self.plugin._open_anim_pending:
                            del self.plugin._open_anim_pending[ik]
                        if ik in self.plugin._menu_patch_done:
                            del self.plugin._menu_patch_done[ik]
                        if ik in self.plugin._itemoptions_marker:
                            del self.plugin._itemoptions_marker[ik]
                        lk = f"item_close_swipe_{ik}"
                        if lk in self.plugin._edge_listeners:
                            del self.plugin._edge_listeners[lk]
                    except Exception:
                        pass
                    self.plugin._dbg(f"drawer dismissed: key={key}")
                    self.plugin._update_dialogs_controls(fragment, True)
            except Exception as e:
                self.plugin._dbg(f"ItemOptions.dismiss hook error: {e}")

    class _ItemOptionsShowHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True):
                    return
                item_opts = param.thisObject
                if self.plugin._extracting_menu:
                    try:
                        self.plugin._parse_item_options_for_custom_menu(item_opts)
                        param.setResult(item_opts)
                        self.plugin._dbg("custom menu extraction: intercepted ItemOptions.show")
                        return
                    except Exception as ex:
                        self.plugin._dbg(f"custom menu extraction hook error: {ex}")
                if self.plugin._is_dialogs_activity_item_options(item_opts):
                    try:
                        item_opts.setSwipebackGravity(False, False)
                    except Exception:
                        pass
                if not self.plugin._is_dialogs_main_menu(item_opts):
                    return
                self.plugin._prepare_as_drawer(item_opts)
            except Exception as e:
                self.plugin._dbg(f"ItemOptions.show before error: {e}")

        def after_hooked_method(self, param):
            try:
                if not self.plugin.get_setting("enabled", True):
                    return
                if self.plugin._extracting_menu:
                    return
                item_opts = param.thisObject
                if not self.plugin._is_dialogs_main_menu(item_opts):
                    if self.plugin._is_dialogs_activity_item_options(item_opts):
                        try:
                            fragment = get_private_field(item_opts, "fragment")
                        except Exception:
                            fragment = None
                        if fragment is not None:
                            key = self.plugin._obj_key(fragment)
                            main_menu = self.plugin._active_drawer.get(key)
                            if main_menu is not None:
                                run_on_ui_thread(lambda io=main_menu: self.plugin._restyle_opened_drawer(io, False), 72)
                    return
                try:
                    fragment = get_private_field(item_opts, "fragment")
                except Exception:
                    fragment = None
                key = self.plugin._obj_key(fragment) if fragment is not None else self.plugin._obj_key(item_opts)
                self.plugin._active_drawer[key] = item_opts
                self.plugin._restyle_opened_drawer(item_opts, True)
                run_on_ui_thread(lambda io=item_opts: self.plugin._restyle_opened_drawer(io, True), 28)
                self.plugin._dbg("drawer heavy restyle started")
            except Exception as e:
                self.plugin._dbg(f"ItemOptions.show after error: {e}")

    def _is_dialogs_main_menu(self, item_opts):
        try:
            fragment = get_private_field(item_opts, "fragment")
            if fragment is None:
                return False
            cls_name = str(fragment.getClass().getName() or "")
            if cls_name != "org.telegram.ui.DialogsActivity":
                return False
            scrim = get_private_field(item_opts, "scrimView")
            options_item = get_private_field(fragment, "optionsItem")
            if options_item is None:
                return False
            return scrim == options_item
        except Exception:
            return False

    def _is_dialogs_activity_item_options(self, item_opts):
        try:
            fragment = get_private_field(item_opts, "fragment")
            if fragment is None:
                return False
            return str(fragment.getClass().getName() or "") == "org.telegram.ui.DialogsActivity"
        except Exception:
            return False

    def _resolve_dialogs_fragment(self, source_view):
        try:
            if source_view is None:
                return None
            for fld in ("this$0", "parentFragment", "fragment"):
                try:
                    owner = get_private_field(source_view, fld)
                except Exception:
                    owner = None
                if owner is None:
                    continue
                try:
                    if str(owner.getClass().getName() or "") == "org.telegram.ui.DialogsActivity":
                        return owner
                except Exception:
                    pass
            return None
        except Exception:
            return None

    def _prepare_as_drawer(self, item_opts):
        fragment = None
        try:
            fragment = get_private_field(item_opts, "fragment")
        except Exception:
            fragment = None

        try:
            item_opts.setGravity(Gravity.LEFT)
        except Exception:
            try:
                item_opts.setGravity(3)
            except Exception:
                pass

        try:
            item_opts.setDismissOnMoveOutside(False)
        except Exception:
            pass
        try:
            item_opts.forceTop(True)
        except Exception:
            pass
        try:
            item_opts.allowCenter(False)
        except Exception:
            pass
        try:
            item_opts.forceBottom(False)
        except Exception:
            pass
        try:
            item_opts.setSwipebackGravity(True, False)
        except Exception:
            pass
        try:
            item_opts.ignoreX()
        except Exception:
            pass
        try:
            item_opts.setDrawScrim(True)
        except Exception:
            pass
        try:
            item_opts.setDimAlpha(120)
        except Exception:
            pass

        try:
            item_opts.setTranslationY(0.0)
        except Exception:
            pass

        try:
            max_h = int(getattr(AndroidUtilities.displaySize, "y", 0) or 0)
            if max_h > 0:
                item_opts.setMaxHeight(max_h)
        except Exception:
            pass
        try:
            item_opts.setFixedWidth(int(DRAWER_MAX_WIDTH_DP))
        except Exception:
            pass

        # Heavy UI injection is deferred to _restyle_opened_drawer for faster showItemOptions start.
        return

    def _restyle_opened_drawer(self, item_opts, allow_heavy=True):
        popup = None
        layout = None
        container = None
        try:
            popup = getattr(item_opts, "actionBarPopupWindow", None)
        except Exception:
            popup = None

        try:
            layout = item_opts.getLayout()
        except Exception:
            layout = None

        try:
            container = get_private_field(item_opts, "pointContainer")
        except Exception:
            container = None

        if popup is None or layout is None or container is None:
            return

        try:
            if not self._is_custom_drawer_enabled():
                self._install_itemoptions_close_swipe(item_opts, layout)
            try:
                popup.setAnimationStyle(0)
            except Exception:
                pass
            try:
                popup.setScaleOut(False)
            except Exception:
                pass

            container_h = int(container.getHeight() or 0)
            container_w = int(container.getWidth() or 0)
            if container_h <= 0:
                container_h = int(getattr(AndroidUtilities.displaySize, "y", 0) or 0)
            if container_w <= 0:
                container_w = int(getattr(AndroidUtilities.displaySize, "x", 0) or 0)
            status_h = int(getattr(AndroidUtilities, "statusBarHeight", 0) or 0)
            full_h = int(getattr(AndroidUtilities.displaySize, "y", 0) or 0) + status_h
            if full_h > container_h:
                container_h = full_h

            max_w = int(AndroidUtilities.dp(float(DRAWER_MAX_WIDTH_DP)))
            panel_w = int(min(max_w, max(AndroidUtilities.dp(280.0), container_w * 0.78)))

            try:
                lp = layout.getLayoutParams()
                if lp is not None:
                    lp.width = panel_w
                    lp.height = container_h
                    layout.setLayoutParams(lp)
            except Exception:
                pass

            try:
                layout.setMinimumHeight(container_h)
            except Exception:
                pass
            try:
                clp = container.getLayoutParams()
                if clp is not None:
                    if hasattr(clp, "height"):
                        clp.height = container_h
                    container.setLayoutParams(clp)
            except Exception:
                pass

            try:
                top_pad = 0
                layout.setPadding(layout.getPaddingLeft(), top_pad, layout.getPaddingRight(), layout.getPaddingBottom())
            except Exception:
                pass

            try:
                popup.update(0, 0, panel_w, container_h)
            except Exception:
                pass
            key = self._obj_key(item_opts)
            anim_pending = bool(self._open_anim_pending.get(key, False))
            if not anim_pending:
                try:
                    container.setTranslationY(0.0)
                    container.setY(0.0)
                except Exception:
                    pass
                try:
                    item_opts.setTranslationY(0.0)
                except Exception:
                    pass
                try:
                    layout.setTranslationY(0.0)
                    layout.setY(0.0)
                except Exception:
                    pass
            first_pass = not bool(self._menu_patch_done.get(key, False))
            if allow_heavy and first_pass:
                try:
                    fr = self._get_field_value(item_opts, "fragment")
                except Exception:
                    fr = None
                self._ensure_profile_header(item_opts, layout, fr)
                self._reorder_plugins_menu_items(item_opts, layout)
                self._ensure_accounts_panel(item_opts, layout, fr)
                self._trim_header_gap(layout)
                self._menu_patch_done[key] = True

            if not self._itemoptions_marker.get(key):
                open_y = self._take_open_origin_y(item_opts, container_h)
                measured_ok = False
                try:
                    measured_ok = int(layout.getWidth() or 0) > 1 and int(container.getWidth() or 0) > 1
                except Exception:
                    measured_ok = False
                if not measured_ok:
                    if not bool(self._anim_defer_pending.get(key, False)):
                        self._anim_defer_pending[key] = True
                        self._dbg("drawer animation deferred: layout not measured yet")
                        run_on_ui_thread(lambda io=item_opts, ah=allow_heavy: self._restyle_opened_drawer(io, ah), 22)
                else:
                    if key in self._anim_defer_pending:
                        del self._anim_defer_pending[key]
                    self._itemoptions_marker[key] = True
                    try:
                        try:
                            layout.animate().cancel()
                        except Exception:
                            pass
                        layout.setPivotX(0.0)
                        pivot_y = float(container_h) * 0.5
                        if open_y is not None:
                            try:
                                oy = float(open_y)
                                if oy < 0.0:
                                    oy = 0.0
                                if oy > float(container_h):
                                    oy = float(container_h)
                                pivot_y = oy
                            except Exception:
                                pivot_y = float(container_h) * 0.5
                        layout.setPivotY(float(pivot_y))
                        layout.setScaleX(1.0)
                        layout.setScaleY(1.0)
                        layout.setAlpha(1.0)
                        layout.setTranslationY(0.0)
                    except Exception:
                        pass
                    if open_y is not None:
                        try:
                            self._dbg(
                                f"drawer animate horizontal from y={float(open_y):.1f} "
                                f"pivotY={float(layout.getPivotY() or 0.0):.1f}"
                            )
                        except Exception:
                            pass
                    layout.setTranslationX(float(-panel_w))
                    self._open_anim_pending[key] = True
                    try:
                        layout.animate().cancel()
                    except Exception:
                        pass
                    try:
                        layout.animate().translationX(0.0).setDuration(250).start()
                    except Exception:
                        pass
                    run_on_ui_thread(lambda k=key: self._open_anim_pending.pop(k, None), 320)
                    self._dbg("drawer animation started (horizontal only)")

            if allow_heavy and first_pass:
                self._dbg(f"drawer restyled: w={panel_w} h={container_h}")
        except Exception as e:
            self._dbg(f"restyle error: {e}")

    def _install_itemoptions_close_swipe(self, item_opts, touch_target):
        try:
            if item_opts is None or touch_target is None:
                return
            i_key = self._obj_key(item_opts)
            l_key = f"item_close_swipe_{i_key}"
            listener = self._edge_listeners.get(l_key)
            if listener is not None:
                try:
                    touch_target.setOnTouchListener(listener)
                except Exception:
                    pass
                return
            iface = find_class("android.view.View$OnTouchListener")
            if iface is None:
                return
            Proxy = dynamic_proxy(iface)
            plugin_ref = self
            state = {"active": False, "drag": False, "x0": 0.0, "y0": 0.0}

            class _DrawerCloseTouch(Proxy):
                def onTouch(self, v, e):
                    try:
                        action = int(e.getActionMasked())
                        if action == MotionEvent.ACTION_DOWN:
                            state["active"] = True
                            state["drag"] = False
                            state["x0"] = float(e.getRawX())
                            state["y0"] = float(e.getRawY())
                            return False
                        if action == MotionEvent.ACTION_MOVE and state.get("active"):
                            dx = float(e.getRawX()) - float(state.get("x0", 0.0))
                            dy = abs(float(e.getRawY()) - float(state.get("y0", 0.0)))
                            if (not state.get("drag")) and dx < -float(AndroidUtilities.dp(10.0)) and abs(dx) > (dy * 0.62):
                                state["drag"] = True
                            if state.get("drag"):
                                try:
                                    v.setTranslationX(max(float(-AndroidUtilities.dp(36.0)), float(dx * 0.33)))
                                except Exception:
                                    pass
                                return True
                            return False
                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            if state.get("drag"):
                                dx = float(e.getRawX()) - float(state.get("x0", 0.0))
                                try:
                                    v.animate().translationX(0.0).setDuration(120).start()
                                except Exception:
                                    try:
                                        v.setTranslationX(0.0)
                                    except Exception:
                                        pass
                                if dx < -float(AndroidUtilities.dp(34.0)):
                                    try:
                                        item_opts.dismiss()
                                    except Exception:
                                        pass
                                    state["active"] = False
                                    state["drag"] = False
                                    return True
                            state["active"] = False
                            state["drag"] = False
                            return False
                    except Exception:
                        return False
                    return False

            listener = _DrawerCloseTouch()
            try:
                touch_target.setOnTouchListener(listener)
                self._edge_listeners[l_key] = listener
                self._dbg("legacy drawer close-swipe listener installed")
            except Exception:
                pass
        except Exception as e:
            self._dbg(f"install itemoptions close swipe error: {e}")

    def _ensure_profile_header(self, item_opts, layout, fragment):
        try:
            if layout is None or fragment is None:
                return
            existing = self._find_tagged_child(layout, HEADER_TAG)
            if existing is not None:
                self._ensure_theme_header_button(existing, fragment)
                return
            key = self._obj_key(fragment)
            linear = None
            try:
                linear = get_private_field(layout, "linearLayout")
            except Exception:
                linear = None
            if linear is None:
                linear = layout
            if linear is None or not hasattr(linear, "addView"):
                return

            header = self._header_cache.get(key)
            if header is not None:
                try:
                    p = header.getParent()
                    if p is not None and p != linear and hasattr(p, "removeView"):
                        p.removeView(header)
                except Exception:
                    header = None
            if header is None:
                header = self._build_profile_header(item_opts)
                if header is None:
                    return
                self._header_cache[key] = header

            try:
                header_h = int(AndroidUtilities.dp(140.0))
                linear.addView(
                    header,
                    0,
                    LinearLayout.LayoutParams(
                        ViewGroup.LayoutParams.MATCH_PARENT,
                        header_h,
                    ),
                )
                self._dbg("profile header injected")
            except Exception:
                pass
            self._ensure_theme_header_button(header, fragment)
        except Exception as e:
            self._dbg(f"ensure profile header error: {e}")

    def _ensure_theme_header_button(self, header, fragment):
        try:
            if header is None or fragment is None:
                return
            btn = self._find_tagged_child(header, THEME_HEADER_BTN_TAG)
            if btn is None:
                context = fragment.getContext()
                if context is None:
                    return
                btn = ImageView(context)
                btn.setTag(THEME_HEADER_BTN_TAG)
                btn.setScaleType(ImageView.ScaleType.CENTER)
                try:
                    btn.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1))
                except Exception:
                    pass
                pad = int(AndroidUtilities.dp(11.0))
                btn.setPadding(pad, pad, pad, pad)
                header.addView(
                    btn,
                    LayoutHelper.createFrame(44, 44.0, Gravity.RIGHT | Gravity.TOP, 0.0, 10.0, 10.0, 0.0),
                )
            try:
                lp = btn.getLayoutParams()
                if lp is not None and hasattr(lp, "gravity"):
                    lp.gravity = int(Gravity.RIGHT | Gravity.TOP)
                    if hasattr(lp, "topMargin"):
                        lp.topMargin = int(AndroidUtilities.dp(11.0))
                    if hasattr(lp, "rightMargin"):
                        lp.rightMargin = int(AndroidUtilities.dp(14.0))
                    btn.setLayoutParams(lp)
            except Exception:
                pass
            key = self._obj_key(fragment)
            icon = self._theme_icon.get(key)
            if icon is not None:
                try:
                    if not self._set_image_with_anim(btn, icon, True):
                        btn.setImageDrawable(icon)
                except Exception:
                    pass
                try:
                    dr = btn.getDrawable()
                    if dr is not None and hasattr(dr, "start"):
                        dr.start()
                except Exception:
                    pass
            else:
                try:
                    dark = False
                    try:
                        dark = bool(Theme.isCurrentThemeDark())
                    except Exception:
                        dark = False
                    res = "menu_day_mode_24" if dark else "menu_night_mode_24"
                    btn.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, res, 0))
                except Exception:
                    pass
            try:
                dark_tint = False
                try:
                    dark_tint = bool(Theme.isCurrentThemeDark())
                except Exception:
                    dark_tint = False
                btn.setColorFilter(int(Color.WHITE if dark_tint else Color.BLACK))
            except Exception:
                pass
            btn.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._trigger_theme_toggle(fr, _v)))
            self._dbg("theme header button aligned to top-right corner")
        except Exception as e:
            self._dbg(f"ensure theme header button error: {e}")

    def _extract_first_icon_drawable(self, node):
        try:
            if node is None:
                return None
            if isinstance(node, ImageView):
                try:
                    dr = node.getDrawable()
                except Exception:
                    dr = None
                if dr is not None:
                    try:
                        cs = dr.getConstantState()
                        if cs is not None:
                            nd = cs.newDrawable()
                            try:
                                nd = nd.mutate()
                            except Exception:
                                pass
                            return nd
                    except Exception:
                        return dr
                    return dr
            if hasattr(node, "getChildCount"):
                cnt = int(node.getChildCount() or 0)
                for i in range(cnt):
                    got = self._extract_first_icon_drawable(node.getChildAt(i))
                    if got is not None:
                        return got
        except Exception:
            pass
        return None

    def _is_theme_menu_item(self, txt):
        try:
            s = str(txt or "").strip().lower()
            if not s:
                return False
            return (
                ("ночн" in s and "режим" in s)
                or ("днев" in s and "режим" in s)
                or ("switchtheme" in s)
                or ("night mode" in s)
                or ("day mode" in s)
            )
        except Exception:
            return False

    def _is_proxy_menu_item(self, txt):
        try:
            s = str(txt or "").strip().lower()
            if not s:
                return False
            return ("прокси" in s) or ("proxy" in s)
        except Exception:
            return False

    def _is_proxy_related_item(self, txt):
        try:
            s = str(txt or "").strip().lower()
            if not s:
                return False
            if self._is_proxy_menu_item(s):
                return True
            if s in ("подключено", "connected", "proxy connected"):
                return True
            if ("подключ" in s) or ("connect" in s):
                return True
            if ("socks" in s) and (("proxy" in s) or ("прокси" in s) or ("подключ" in s)):
                return True
            return False
        except Exception:
            return False

    def _same_drawable_constant_state(self, d1, d2):
        try:
            if d1 is None or d2 is None:
                return False
            try:
                c1 = d1.getConstantState()
            except Exception:
                c1 = None
            try:
                c2 = d2.getConstantState()
            except Exception:
                c2 = None
            if c1 is None or c2 is None:
                return False
            return str(c1) == str(c2)
        except Exception:
            return False

    def _is_proxy_entry(self, fragment, ent):
        try:
            txt = str(ent.get("text", "") or "").strip()
            if self._is_proxy_related_item(txt):
                return True
            if fragment is None:
                return False
            key = self._obj_key(fragment)
            picon = self._proxy_icon.get(key, None)
            if picon is None:
                return False
            icon = ent.get("icon", None)
            if icon is None:
                return False
            return self._same_drawable_constant_state(icon, picon)
        except Exception:
            return False

    def _is_proxy_row_view(self, fragment, row, txt=""):
        try:
            if self._is_proxy_related_item(txt):
                return True
            if fragment is None or row is None:
                return False
            key = self._obj_key(fragment)
            picon = self._proxy_icon.get(key, None)
            if picon is None:
                return False
            icon = self._extract_first_icon_drawable(row)
            if icon is None:
                return False
            return self._same_drawable_constant_state(icon, picon)
        except Exception:
            return False

    def _collapse_menu_row(self, row):
        try:
            if row is None:
                return
            try:
                row.setVisibility(View.GONE)
            except Exception:
                pass
            try:
                lp = row.getLayoutParams()
                if lp is not None and hasattr(lp, "height"):
                    lp.height = 0
                    if hasattr(lp, "topMargin"):
                        lp.topMargin = 0
                    if hasattr(lp, "bottomMargin"):
                        lp.bottomMargin = 0
                    row.setLayoutParams(lp)
            except Exception:
                pass
        except Exception:
            pass

    def _take_open_origin_y(self, item_opts, container_h):
        try:
            if item_opts is None:
                return None
            try:
                fragment = get_private_field(item_opts, "fragment")
            except Exception:
                fragment = None
            if fragment is None:
                return None
            key = self._obj_key(fragment)
            data = self._open_origin.get(key)
            if not data:
                return None
            # Use once per open cycle.
            try:
                del self._open_origin[key]
            except Exception:
                pass
            try:
                y = float(data.get("y", 0.0))
            except Exception:
                y = 0.0
            raw_y = float(y)
            h = float(container_h) if container_h is not None else 0.0
            if h <= 0.0:
                h = float(getattr(AndroidUtilities.displaySize, "y", 0) or 0)

            # Convert raw screen Y to drawer-container local Y so pivot really matches swipe point.
            try:
                c = None
                try:
                    c = get_private_field(item_opts, "pointContainer")
                except Exception:
                    c = None
                if c is None:
                    try:
                        c = item_opts.getLayout()
                    except Exception:
                        c = None
                if c is not None and hasattr(c, "getLocationOnScreen"):
                    pos = [0, 0]
                    c.getLocationOnScreen(pos)
                    y = y - float(pos[1] or 0)
            except Exception:
                pass

            if y < 0.0:
                y = 0.0
            if h > 0.0 and y > h:
                y = h
            try:
                self._dbg(f"open-origin map: rawY={raw_y:.1f} localY={y:.1f} h={h:.1f}")
            except Exception:
                pass
            return y
        except Exception:
            return None

    def _trim_header_gap(self, layout):
        try:
            if layout is None:
                return
            linear = None
            try:
                linear = self._get_field_value(layout, "linearLayout")
            except Exception:
                linear = None
            if linear is None:
                linear = layout
            if linear is None or (not hasattr(linear, "getChildCount")):
                return
            count = int(linear.getChildCount() or 0)
            if count <= 1:
                return
            header_idx = -1
            for i in range(count):
                c = linear.getChildAt(i)
                if c is None:
                    continue
                try:
                    if c.getTag() == HEADER_TAG:
                        header_idx = i
                        break
                except Exception:
                    pass
            if header_idx < 0:
                return
            # Collapse only first non-clickable spacer after header/accounts block.
            for j in range(header_idx + 1, count):
                c = linear.getChildAt(j)
                if c is None:
                    continue
                tg = None
                try:
                    tg = c.getTag()
                except Exception:
                    tg = None
                if tg == ACCOUNTS_TAG:
                    continue
                txt = self._extract_text_from_view(c).strip()
                clickable = False
                try:
                    clickable = bool(c.isClickable())
                except Exception:
                    clickable = False
                if txt or clickable:
                    break
                lp = None
                try:
                    lp = c.getLayoutParams()
                except Exception:
                    lp = None
                h = int(getattr(lp, "height", 0) or 0) if lp is not None else 0
                if h <= 0:
                    break
                if h >= int(AndroidUtilities.dp(10.0)):
                    if lp is not None and hasattr(lp, "height"):
                        lp.height = 1
                        if hasattr(lp, "leftMargin"):
                            lp.leftMargin = int(AndroidUtilities.dp(16.0))
                        if hasattr(lp, "rightMargin"):
                            lp.rightMargin = int(AndroidUtilities.dp(16.0))
                        c.setLayoutParams(lp)
                    try:
                        c.setBackgroundColor(int(Theme.getColor(Theme.key_divider)))
                    except Exception:
                        pass
                break
        except Exception as e:
            self._dbg(f"trim header gap error: {e}")

    def _ensure_fragment_ui(self, fragment, root):
        try:
            if fragment is None:
                return
            actual_root = root
            if actual_root is None:
                try:
                    actual_root = get_private_field(fragment, "fragmentView")
                except Exception:
                    actual_root = None
            if actual_root is None:
                try:
                    actual_root = fragment.getFragmentView()
                except Exception:
                    actual_root = None

            if actual_root is not None:
                self._dbg(f"ensure ui: root={actual_root.getClass().getName()}")
                if self.get_setting("custom_drawer_mode", True):
                    self._ensure_custom_drawer(fragment, actual_root)
                if self.get_setting("edge_swipe", True):
                    self._install_edge_swipe(fragment, actual_root)
            self._update_dialogs_controls(fragment, True)
            run_on_ui_thread(lambda fr=fragment: self._update_dialogs_controls(fr, True), 96)
            run_on_ui_thread(lambda fr=fragment: self._update_dialogs_controls(fr, True), 220)
        except Exception as e:
            self._dbg(f"ensure fragment ui error: {e}")

    def _dismiss_active_drawer(self, fragment):
        try:
            if fragment is None:
                return False
            key = self._obj_key(fragment)
            dismissed = False
            if self._is_custom_drawer_enabled():
                try:
                    if bool(self._custom_drawer_open.get(key, False)) or float(self._custom_drawer_progress.get(key, 0.0) or 0.0) > 0.0:
                        self._animate_custom_drawer(fragment, 0.0, 150)
                        dismissed = True
                except Exception:
                    pass
            item_opts = self._active_drawer.get(key)
            if item_opts is not None:
                try:
                    item_opts.dismiss()
                    self._dbg("active drawer dismissed")
                    dismissed = True
                except Exception:
                    pass
                try:
                    ik = self._obj_key(item_opts)
                    if ik in self._anim_defer_pending:
                        del self._anim_defer_pending[ik]
                    if ik in self._open_anim_pending:
                        del self._open_anim_pending[ik]
                    if ik in self._menu_patch_done:
                        del self._menu_patch_done[ik]
                    if ik in self._itemoptions_marker:
                        del self._itemoptions_marker[ik]
                except Exception:
                    pass
                if key in self._active_drawer:
                    del self._active_drawer[key]
            if key in self._accounts_panel:
                del self._accounts_panel[key]
            if key in self._accounts_open:
                del self._accounts_open[key]
            if key in self._accounts_arrow:
                del self._accounts_arrow[key]
            if key in self._accounts_last_toggle:
                del self._accounts_last_toggle[key]
            if key in self._open_origin:
                del self._open_origin[key]
            if key in self._theme_row:
                del self._theme_row[key]
            if key in self._proxy_row:
                del self._proxy_row[key]
            if key in self._title_margin_cache:
                del self._title_margin_cache[key]
            if key in self._custom_ui_built_at:
                del self._custom_ui_built_at[key]
            if key in self._custom_drawer_open:
                del self._custom_drawer_open[key]
            if key in self._custom_drawer_progress:
                del self._custom_drawer_progress[key]
            if key in self._custom_drawer_anim:
                del self._custom_drawer_anim[key]
            self._update_dialogs_controls(fragment, True)
            return dismissed
        except Exception as e:
            self._dbg(f"dismiss active drawer error: {e}")
            return False

    def _install_edge_swipe(self, fragment, root):
        try:
            if root is None or not hasattr(root, "setOnTouchListener"):
                return

            key = self._obj_key(fragment)
            exist_listener = self._edge_listeners.get(f"swipe_{key}")
            if exist_listener is not None:
                try:
                    root.setOnTouchListener(exist_listener)
                except Exception:
                    pass
                self._ensure_edge_swipe_area(fragment, root, exist_listener)
                return

            iface = find_class("android.view.View$OnTouchListener")
            if not iface:
                return
            Proxy = dynamic_proxy(iface)

            state = {
                "active": False,
                "dragging": False,
                "mode": "",
                "x0": 0.0,
                "y0": 0.0,
                "p0": 0.0,
            }
            trigger_dx = float(AndroidUtilities.dp(54.0))
            max_dy = float(AndroidUtilities.dp(200.0))

            class _EdgeTouch(Proxy):
                def onTouch(self, v, e):
                    try:
                        action = int(e.getActionMasked())
                        if action == MotionEvent.ACTION_DOWN:
                            state["active"] = True
                            state["dragging"] = False
                            state["mode"] = ""
                            state["x0"] = float(e.getRawX())
                            state["y0"] = float(e.getRawY())
                            state["p0"] = float(plugin_ref._get_custom_drawer_progress(fragment))
                            try:
                                now_ms = int(time.time() * 1000)
                                dbg_key = f"root_down_{key}"
                                last_ms = int(plugin_ref._set_scroll_guard.get(dbg_key, 0) or 0)
                                if now_ms - last_ms > 1200:
                                    plugin_ref._set_scroll_guard[dbg_key] = now_ms
                                    plugin_ref._dbg(f"root custom down: y={float(e.getRawY()):.1f}")
                            except Exception:
                                pass
                            return False

                        if action == MotionEvent.ACTION_MOVE and state["active"]:
                            dx = float(e.getRawX()) - state["x0"]
                            dy = abs(float(e.getRawY()) - state["y0"])
                            if plugin_ref._is_custom_drawer_enabled():
                                return bool(plugin_ref._handle_custom_swipe_touch(fragment, e, f"root_touch_{key}", "root_touch", None, v))

                            if dx > trigger_dx and dy < max_dy and dx > (dy * 0.85):
                                state["active"] = False
                                plugin_ref._request_swipe_open(fragment, float(e.getRawY()), "root_touch")
                            return False

                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            if plugin_ref._is_custom_drawer_enabled():
                                return bool(plugin_ref._handle_custom_swipe_touch(fragment, e, f"root_touch_{key}", "root_touch", None, v))
                            state["active"] = False
                            state["dragging"] = False
                            state["mode"] = ""
                            return False
                    except Exception:
                        return False
                    return False

            plugin_ref = self
            listener = _EdgeTouch()
            root.setOnTouchListener(listener)
            self._edge_listeners[f"swipe_{key}"] = listener
            self._ensure_edge_swipe_area(fragment, root, listener)
            self._dbg("chat swipe detector installed (full-screen)")
        except Exception as e:
            self._dbg(f"edge swipe install error: {e}")

    def _ensure_edge_swipe_area(self, fragment, root, listener):
        try:
            if fragment is None or root is None or listener is None:
                return
            if not hasattr(root, "addView"):
                return
            key = self._obj_key(fragment)
            edge_key = f"swipe_{key}"
            edge = self._edge_views.get(edge_key)
            context = None
            try:
                context = root.getContext()
            except Exception:
                context = None
            if context is None:
                try:
                    context = fragment.getContext()
                except Exception:
                    context = None
            if edge is None:
                if context is None:
                    return
                edge = View(context)
                edge.setTag(EDGE_TAG)
                try:
                    edge.setBackgroundColor(Color.TRANSPARENT)
                except Exception:
                    pass
                try:
                    edge.setClickable(True)
                except Exception:
                    pass
            try:
                edge.setOnTouchListener(listener)
            except Exception:
                pass
            try:
                parent = edge.getParent()
            except Exception:
                parent = None
            if parent is not None and parent != root and hasattr(parent, "removeView"):
                try:
                    parent.removeView(edge)
                except Exception:
                    pass
                parent = None
            edge_w = int(AndroidUtilities.dp(24.0))
            if parent is None:
                try:
                    lp = FrameLayout.LayoutParams(edge_w, ViewGroup.LayoutParams.MATCH_PARENT)
                    lp.gravity = int(Gravity.LEFT | Gravity.TOP)
                    if hasattr(lp, "topMargin"):
                        lp.topMargin = int(AndroidUtilities.dp(56.0))
                    root.addView(edge, lp)
                except Exception:
                    try:
                        root.addView(edge, ViewGroup.LayoutParams(edge_w, ViewGroup.LayoutParams.MATCH_PARENT))
                    except Exception:
                        return
            else:
                try:
                    lp = edge.getLayoutParams()
                    if lp is not None:
                        if hasattr(lp, "width"):
                            lp.width = edge_w
                        if hasattr(lp, "height"):
                            lp.height = ViewGroup.LayoutParams.MATCH_PARENT
                        if hasattr(lp, "gravity"):
                            lp.gravity = int(Gravity.LEFT | Gravity.TOP)
                        if hasattr(lp, "topMargin"):
                            lp.topMargin = int(AndroidUtilities.dp(56.0))
                        edge.setLayoutParams(lp)
                except Exception:
                    pass
            try:
                edge.bringToFront()
            except Exception:
                pass
            self._edge_views[edge_key] = edge
        except Exception as e:
            self._dbg(f"ensure edge swipe area error: {e}")

    def _handle_custom_swipe_touch(self, fragment, ev, track_key, source="", hook_param=None, touch_view=None):
        try:
            if fragment is None or ev is None:
                return False
            if not track_key:
                return False
            f_key = self._obj_key(fragment)
            action = int(ev.getActionMasked())
            st = self._swipe_track.get(track_key) or {
                "active": False,
                "drag": False,
                "mode": "",
                "x": 0.0,
                "y": 0.0,
                "p0": 0.0,
            }
            src = str(source or "custom")

            if action == MotionEvent.ACTION_DOWN:
                st["active"] = True
                st["drag"] = False
                st["mode"] = ""
                st["x"] = float(ev.getRawX())
                st["y"] = float(ev.getRawY())
                st["p0"] = float(self._get_custom_drawer_progress(fragment))
                self._swipe_track[track_key] = st
                try:
                    now_ms = int(time.time() * 1000)
                    dbg_key = f"custom_down_{f_key}_{src}"
                    last_ms = int(self._set_scroll_guard.get(dbg_key, 0) or 0)
                    if now_ms - last_ms > 1200:
                        self._set_scroll_guard[dbg_key] = now_ms
                        self._dbg(f"{src} custom down: y={float(ev.getRawY()):.1f}")
                except Exception:
                    pass
                return False

            if action == MotionEvent.ACTION_MOVE and st.get("active"):
                dx = float(ev.getRawX()) - float(st.get("x", 0.0))
                dy = abs(float(ev.getRawY()) - float(st.get("y", 0.0)))
                p_now = float(self._get_custom_drawer_progress(fragment))
                is_open = bool(self._custom_drawer_open.get(f_key, False)) or p_now > 0.01
                if (not st.get("drag")) and abs(dx) > float(AndroidUtilities.dp(8.0)) and abs(dx) > (dy * 0.62):
                    if dx > 0.0 and (not is_open):
                        st["drag"] = True
                        st["mode"] = "open"
                        st["p0"] = p_now
                        try:
                            existing_od = self._custom_open_y.get(f_key)
                        except Exception:
                            existing_od = None
                        if existing_od is None or (not bool(existing_od.get("pending", False))):
                            try:
                                self._custom_open_y[f_key] = {"swipe": True, "y": float(ev.getRawY()), "pending": True}
                            except Exception:
                                pass
                        self._ensure_custom_drawer(fragment, None)
                        self._cancel_dialogs_list_touch(fragment, ev, touch_view)
                        self._dbg(f"{src} custom drag start: mode=open y={float(ev.getRawY()):.1f}")
                    elif dx < 0.0 and is_open:
                        st["drag"] = True
                        st["mode"] = "close"
                        st["p0"] = p_now
                        self._cancel_dialogs_list_touch(fragment, ev, touch_view)
                        self._dbg(f"{src} custom drag start: mode=close y={float(ev.getRawY()):.1f}")
                if st.get("drag"):
                    w = float(self._get_custom_drawer_width(fragment))
                    p = float(st.get("p0", 0.0)) + (dx / max(1.0, w))
                    if p < 0.0:
                        p = 0.0
                    elif p > 1.0:
                        p = 1.0
                    self._set_custom_drawer_progress(fragment, p, force_visible=True)
                    self._swipe_track[track_key] = st
                    try:
                        if hook_param is not None:
                            hook_param.setResult(True)
                    except Exception:
                        pass
                    return True
                return False

            if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                handled = False
                if st.get("drag"):
                    p = float(self._get_custom_drawer_progress(fragment))
                    if p >= 0.38:
                        self._animate_custom_drawer(fragment, 1.0, 160)
                    else:
                        self._animate_custom_drawer(fragment, 0.0, 160)
                    self._dbg(f"{src} custom drag finish: mode={st.get('mode')} p={p:.2f}")
                    handled = True
                elif st.get("active"):
                    dx = float(ev.getRawX()) - float(st.get("x", 0.0))
                    dy = abs(float(ev.getRawY()) - float(st.get("y", 0.0)))
                    is_open = bool(self._custom_drawer_open.get(f_key, False)) or float(self._get_custom_drawer_progress(fragment)) > 0.01
                    if dy < float(AndroidUtilities.dp(240.0)) and abs(dx) > float(AndroidUtilities.dp(24.0)) and abs(dx) > (dy * 0.45):
                        if (not is_open) and dx > 0.0:
                            try:
                                existing_od = self._custom_open_y.get(f_key)
                            except Exception:
                                existing_od = None
                            if existing_od is None or (not bool(existing_od.get("pending", False))):
                                try:
                                    self._custom_open_y[f_key] = {"swipe": True, "y": float(ev.getRawY()), "pending": True}
                                except Exception:
                                    pass
                            self._ensure_custom_drawer(fragment, None)
                            self._cancel_dialogs_list_touch(fragment, ev, touch_view)
                            self._animate_custom_drawer(fragment, 1.0, 160)
                            self._dbg(f"{src} custom quick open: y={float(ev.getRawY()):.1f}")
                            handled = True
                        elif is_open and dx < 0.0:
                            self._cancel_dialogs_list_touch(fragment, ev, touch_view)
                            self._animate_custom_drawer(fragment, 0.0, 160)
                            self._dbg(f"{src} custom quick close: y={float(ev.getRawY()):.1f}")
                            handled = True
                if track_key in self._swipe_track:
                    del self._swipe_track[track_key]
                if handled:
                    try:
                        if hook_param is not None:
                            hook_param.setResult(True)
                    except Exception:
                        pass
                return handled
            return False
        except Exception as e:
            self._dbg(f"custom swipe handler error [{source}]: {e}")
            return False

    def _request_swipe_open(self, fragment, swipe_y, source):
        try:
            if fragment is None:
                return False
            f_key = self._obj_key(fragment)
            if self._is_custom_drawer_enabled():
                try:
                    p = float(self._get_custom_drawer_progress(fragment))
                    if p > 0.98:
                        self._dbg(f"swipe-open skipped: custom drawer already open key={f_key} src={source}")
                        return False
                except Exception:
                    pass
            else:
                active = self._active_drawer.get(f_key)
                if active is not None:
                    try:
                        is_shown = False
                        try:
                            l = active.getLayout()
                            if l is not None:
                                has_parent = l.getParent() is not None
                                shown_flag = False
                                try:
                                    shown_flag = bool(l.isShown())
                                except Exception:
                                    shown_flag = False
                                vis_flag = True
                                try:
                                    vis_flag = int(l.getVisibility() or 0) == View.VISIBLE
                                except Exception:
                                    vis_flag = True
                                alpha_ok = True
                                try:
                                    alpha_ok = float(l.getAlpha() or 1.0) > 0.04
                                except Exception:
                                    alpha_ok = True
                                is_shown = has_parent and shown_flag and vis_flag and alpha_ok
                        except Exception:
                            is_shown = False
                        if is_shown:
                            self._dbg(f"swipe-open skipped: active drawer visible key={f_key} src={source}")
                            return False
                    except Exception:
                        pass
                    try:
                        del self._active_drawer[f_key]
                        self._dbg(f"swipe-open stale drawer cleared key={f_key} src={source}")
                    except Exception:
                        pass
            now_ms = int(time.time() * 1000)
            gate_key = f"swipe_open_{f_key}"
            last_ms = int(self._set_scroll_guard.get(gate_key, 0) or 0)
            gate_ms = 140 if self._is_custom_drawer_enabled() else 360
            if now_ms - last_ms < gate_ms:
                self._dbg(f"swipe-open throttled: dt={now_ms - last_ms}ms src={source}")
                return False
            self._set_scroll_guard[gate_key] = now_ms
            y = float(swipe_y)
            self._dbg(f"swipe-open accepted: src={source} y={y:.1f}")
            run_on_ui_thread(lambda fr=fragment, yy=y: self._open_main_menu(fr, yy))
            return True
        except Exception as e:
            self._dbg(f"request swipe open error: {e}")
            return False

    def _open_main_menu(self, fragment, swipe_y=None):
        if self._is_custom_drawer_enabled():
            try:
                key = self._obj_key(fragment)
                if swipe_y is not None:
                    self._custom_open_y[key] = {"swipe": True, "y": float(swipe_y), "pending": True}
                else:
                    self._custom_open_y[key] = {"swipe": False, "y": 0.0, "pending": True}
                self._ensure_custom_drawer(fragment, None)
                panel = self._custom_drawer_panel.get(key)
                if panel is not None:
                    need_rebuild = True
                    now_ms = int(time.time() * 1000)
                    try:
                        last_built = int(self._custom_ui_built_at.get(key, 0) or 0)
                    except Exception:
                        last_built = 0
                    try:
                        if hasattr(panel, "getChildCount") and int(panel.getChildCount() or 0) > 0 and (now_ms - last_built) < 2500:
                            need_rebuild = False
                    except Exception:
                        need_rebuild = True
                    if need_rebuild:
                        self._build_custom_drawer_ui(fragment, panel)
                        self._custom_ui_built_at[key] = now_ms
                self._layout_custom_drawer(fragment)
                self._animate_custom_drawer(fragment, 1.0, 190)
                if swipe_y is not None:
                    self._dbg(f"custom drawer open by swipe: y={float(swipe_y):.1f}")
                else:
                    self._dbg("custom drawer open by button")
                return
            except Exception as e:
                self._dbg(f"custom drawer open failed, fallback to ItemOptions: {e}")

        if fragment is not None:
            try:
                f_key = self._obj_key(fragment)
                if swipe_y is None:
                    if f_key in self._open_origin:
                        del self._open_origin[f_key]
                else:
                    self._open_origin[f_key] = {
                        "y": float(swipe_y),
                        "ts": int(time.time() * 1000),
                    }
                    self._dbg(f"drawer open origin y saved: {float(swipe_y):.1f}")
            except Exception:
                pass
        try:
            options_item = get_private_field(fragment, "optionsItem")
        except Exception:
            options_item = None
        if options_item is not None:
            self._hide_right_options_button(options_item)
        try:
            methods = fragment.getClass().getDeclaredMethods()
            target = None
            for m in methods:
                if str(m.getName() or "") == "showItemOptions" and len(m.getParameterTypes()) == 0:
                    target = m
                    break
            if target is not None:
                target.setAccessible(True)
                target.invoke(fragment)
                self._dbg("showItemOptions invoked by edge swipe")
                return
        except Exception as e:
            self._dbg(f"showItemOptions invoke failed: {e}")
            self._set_left_button_visible(fragment, True)

    def _shift_options_anchor_to_y(self, anchor_view, swipe_y):
        try:
            if anchor_view is None:
                return None
            try:
                base_ty = float(anchor_view.getTranslationY() or 0.0)
            except Exception:
                base_ty = 0.0
            pos = [0, 0]
            try:
                anchor_view.getLocationOnScreen(pos)
            except Exception:
                return None
            h = 0.0
            try:
                h = float(anchor_view.getHeight() or 0)
            except Exception:
                h = 0.0
            if h <= 1.0:
                h = float(AndroidUtilities.dp(48.0))
            center_y = float(pos[1]) + (h * 0.5)
            dy = float(swipe_y) - center_y
            try:
                screen_h = float(getattr(AndroidUtilities.displaySize, "y", 0) or 0)
            except Exception:
                screen_h = 0.0
            if screen_h > 0.0:
                target_center = center_y + dy
                min_c = h * 0.5
                max_c = max(min_c, screen_h - (h * 0.5))
                if target_center < min_c:
                    dy += (min_c - target_center)
                elif target_center > max_c:
                    dy -= (target_center - max_c)
            try:
                anchor_view.setTranslationY(base_ty + dy)
                self._dbg(f"anchor shifted for swipe: dy={dy:.1f}")
            except Exception:
                return None
            return (lambda v=anchor_view, ty=base_ty: self._restore_anchor_translation(v, ty))
        except Exception:
            return None

    def _restore_anchor_translation(self, view, base_ty):
        try:
            if view is None:
                return
            view.setTranslationY(float(base_ty))
        except Exception:
            pass

    def _is_custom_drawer_enabled(self):
        try:
            return bool(self.get_setting("custom_drawer_mode", True))
        except Exception:
            return True

    def _capture_original_menu_entries(self, fragment, force=False):
        try:
            if fragment is None:
                return []
            key = self._obj_key(fragment)
            now_ms = int(time.time() * 1000)
            if (not force):
                last = int(self._orig_menu_cache_ts.get(key, 0) or 0)
                if now_ms - last < 1500:
                    cached = self._orig_menu_cache.get(key) or []
                    if cached:
                        return cached

            self._extracting_menu = True
            self._extract_menu_target_key = key
            self._orig_menu_cache[key] = []
            try:
                methods = fragment.getClass().getDeclaredMethods()
                target = None
                for m in methods:
                    if str(m.getName() or "") == "showItemOptions" and len(m.getParameterTypes()) == 0:
                        target = m
                        break
                if target is not None:
                    target.setAccessible(True)
                    target.invoke(fragment)
            except Exception as e:
                self._dbg(f"capture original menu invoke error: {e}")
            finally:
                self._extracting_menu = False
                self._extract_menu_target_key = 0
            entries = self._orig_menu_cache.get(key) or []
            try:
                for ent in entries:
                    if str(ent.get("type", "row") or "row") != "row":
                        continue
                    txt = str(ent.get("text", "") or "").strip().lower()
                    ic = ent.get("icon", None)
                    if ic is None:
                        continue
                    if self._is_theme_menu_item(txt):
                        self._theme_icon[key] = ic
                    elif self._is_proxy_related_item(txt):
                        self._proxy_icon[key] = ic
            except Exception:
                pass
            self._orig_menu_cache_ts[key] = now_ms
            self._dbg(f"captured original menu entries: {len(entries)}")
            return entries
        except Exception as e:
            self._dbg(f"capture original menu error: {e}")
            return []

    def _parse_item_options_for_custom_menu(self, item_opts):
        try:
            if item_opts is None:
                return
            key = int(self._extract_menu_target_key or 0)
            if key == 0:
                return
            layout = None
            try:
                layout = item_opts.getLayout()
            except Exception:
                layout = None
            if layout is None:
                layout = self._get_field_value(item_opts, "layout")
            if layout is None:
                return
            entries = []
            linear = None
            try:
                linear = self._get_field_value(layout, "linearLayout")
            except Exception:
                linear = None
            if linear is None:
                linear = layout
            if linear is not None and hasattr(linear, "getChildCount"):
                cnt = int(linear.getChildCount() or 0)
                for i in range(cnt):
                    child = linear.getChildAt(i)
                    if child is None:
                        continue
                    if self._is_original_menu_divider(child):
                        entries.append({"type": "divider"})
                        continue
                    chunk = []
                    self._collect_clickable_menu_entries(child, chunk)
                    for e in chunk:
                        e["type"] = "row"
                        entries.append(e)
            else:
                self._collect_clickable_menu_entries(layout, entries)
            self._orig_menu_cache[key] = entries
        except Exception as e:
            self._dbg(f"parse item options for custom menu error: {e}")

    def _collect_clickable_menu_entries(self, view, out):
        try:
            if view is None:
                return
            clickable = False
            try:
                clickable = bool(view.isClickable())
            except Exception:
                clickable = False
            if clickable:
                txt = self._extract_text_from_view(view).strip()
                if txt:
                    low = txt.lower()
                    blocked = (
                        "назад" in low
                        or low == "back"
                        or "archive settings" in low
                        or "настройки архива" in low
                        or "how does it work" in low
                        or "как это работает" in low
                    )
                    if not blocked:
                        icon = self._extract_first_icon_drawable(view)
                        out.append({
                            "type": "row",
                            "text": txt,
                            "icon": icon,
                            "view": view,
                        })
                    return
                # Some builds wrap actionable rows into clickable containers without text.
                # Keep walking children to avoid losing plugin rows.
            if hasattr(view, "getChildCount"):
                cnt = int(view.getChildCount() or 0)
                for i in range(cnt):
                    self._collect_clickable_menu_entries(view.getChildAt(i), out)
        except Exception:
            pass

    def _is_original_menu_divider(self, view):
        try:
            if view is None:
                return False
            try:
                if bool(view.isClickable()):
                    return False
            except Exception:
                pass
            txt = ""
            try:
                txt = self._extract_text_from_view(view).strip()
            except Exception:
                txt = ""
            if txt:
                return False
            cls = ""
            try:
                cls = str(view.getClass().getName() or "")
            except Exception:
                cls = ""
            if ("Divider" in cls) or ("ShadowSectionCell" in cls) or ("GraySectionCell" in cls) or ("GreySectionCell" in cls):
                return True
            lp = None
            try:
                lp = view.getLayoutParams()
            except Exception:
                lp = None
            h = int(getattr(lp, "height", 0) or 0) if lp is not None else 0
            if 0 < h <= int(AndroidUtilities.dp(22.0)):
                has_children = False
                try:
                    has_children = hasattr(view, "getChildCount") and int(view.getChildCount() or 0) > 0
                except Exception:
                    has_children = False
                return (not has_children)
            return False
        except Exception:
            return False

    def _cancel_touch_feedback(self, view, src_event=None):
        try:
            if view is None:
                return
            try:
                if hasattr(view, "setPressed"):
                    view.setPressed(False)
            except Exception:
                pass
            try:
                if hasattr(view, "cancelLongPress"):
                    view.cancelLongPress()
            except Exception:
                pass
            try:
                cls_name = str(view.getClass().getName() or "")
            except Exception:
                cls_name = ""
            is_recycler = ("DialogsRecyclerView" in cls_name) or ("RecyclerView" in cls_name)
            if is_recycler:
                ev = None
                try:
                    if src_event is not None:
                        ev = MotionEvent.obtain(src_event)
                except Exception:
                    ev = None
                if ev is None:
                    try:
                        ev = MotionEvent.obtain(0, 0, MotionEvent.ACTION_CANCEL, 0.0, 0.0, 0)
                    except Exception:
                        ev = None
                if ev is None:
                    return
                try:
                    ev.setAction(MotionEvent.ACTION_CANCEL)
                except Exception:
                    pass
                try:
                    v_key = self._obj_key(view)
                    self._recycler_cancel_guard[v_key] = int(time.time() * 1000)
                except Exception:
                    pass
                try:
                    view.onTouchEvent(ev)
                except Exception:
                    pass
                try:
                    ev.recycle()
                except Exception:
                    pass
                return
            try:
                ev = None
                if src_event is not None:
                    try:
                        ev = MotionEvent.obtain(src_event)
                    except Exception:
                        ev = None
                if ev is None:
                    try:
                        ev = MotionEvent.obtain(0, 0, MotionEvent.ACTION_CANCEL, 0.0, 0.0, 0)
                    except Exception:
                        ev = None
                if ev is not None:
                    try:
                        ev.setAction(MotionEvent.ACTION_CANCEL)
                    except Exception:
                        pass
                    try:
                        view.onTouchEvent(ev)
                    except Exception:
                        pass
                    try:
                        if hasattr(view, "onInterceptTouchEvent"):
                            view.onInterceptTouchEvent(ev)
                    except Exception:
                        pass
                    try:
                        ev.recycle()
                    except Exception:
                        pass
            except Exception:
                pass
        except Exception:
            pass

    def _cancel_dialogs_list_touch(self, fragment, src_event=None, touch_view=None):
        try:
            if touch_view is not None:
                try:
                    self._cancel_touch_feedback(touch_view, src_event)
                except Exception:
                    pass
            if fragment is None:
                return
            list_view = None
            try:
                list_view = self._get_dialogs_list_view(fragment)
            except Exception:
                list_view = None
            if list_view is None:
                try:
                    list_view = self._get_field_value(fragment, "listView")
                except Exception:
                    list_view = None
            if list_view is None:
                return
            self._cancel_touch_feedback(list_view, src_event)
        except Exception:
            pass

    def _get_custom_drawer_progress(self, fragment):
        try:
            if fragment is None:
                return 0.0
            key = self._obj_key(fragment)
            return float(self._custom_drawer_progress.get(key, 0.0) or 0.0)
        except Exception:
            return 0.0

    def _get_custom_drawer_width(self, fragment):
        try:
            if fragment is None:
                return float(AndroidUtilities.dp(float(DRAWER_MAX_WIDTH_DP)))
            key = self._obj_key(fragment)
            w = float(self._custom_drawer_width.get(key, 0.0) or 0.0)
            if w > 1.0:
                return w
            root = self._custom_drawer_root.get(key)
            root_w = 0.0
            try:
                if root is not None:
                    root_w = float(root.getWidth() or 0)
            except Exception:
                root_w = 0.0
            if root_w <= 1.0:
                root_w = float(getattr(AndroidUtilities.displaySize, "x", 0) or 0)
            max_w = float(AndroidUtilities.dp(float(DRAWER_MAX_WIDTH_DP)))
            if root_w <= 1.0:
                return max_w
            w = min(max_w, max(float(AndroidUtilities.dp(276.0)), root_w * 0.78))
            self._custom_drawer_width[key] = w
            return w
        except Exception:
            return float(AndroidUtilities.dp(float(DRAWER_MAX_WIDTH_DP)))

    def _ensure_custom_drawer(self, fragment, root):
        try:
            if fragment is None or (not self._is_custom_drawer_enabled()):
                return
            key = self._obj_key(fragment)
            holder = self._custom_drawer_root.get(key)

            actual_root = root
            if actual_root is None:
                try:
                    actual_root = get_private_field(fragment, "fragmentView")
                except Exception:
                    actual_root = None
            if actual_root is None:
                try:
                    actual_root = fragment.getFragmentView()
                except Exception:
                    actual_root = None
            if actual_root is None or (not hasattr(actual_root, "addView")):
                return

            if holder is not None:
                try:
                    parent = holder.getParent()
                except Exception:
                    parent = None
                if parent is not None and parent != actual_root:
                    try:
                        if hasattr(parent, "removeView"):
                            parent.removeView(holder)
                    except Exception:
                        pass
                    holder = None
                elif parent is not None:
                    self._layout_custom_drawer(fragment)
                    return
            context = fragment.getContext()
            if context is None:
                return

            holder = FrameLayout(context)
            holder.setTag(CUSTOM_DRAWER_ROOT_TAG)
            holder.setVisibility(View.GONE)
            holder.setClickable(True)
            try:
                holder.setFocusable(True)
            except Exception:
                pass
            try:
                holder.setOnClickListener(OnClickListener(lambda _v: None))
            except Exception:
                pass
            try:
                holder.setElevation(float(AndroidUtilities.dp(24.0)))
            except Exception:
                pass
            try:
                holder.setTranslationZ(float(AndroidUtilities.dp(24.0)))
            except Exception:
                pass

            scrim = View(context)
            scrim.setTag(CUSTOM_DRAWER_SCRIM_TAG)
            scrim.setBackgroundColor(Color.argb(175, 0, 0, 0))
            scrim.setAlpha(0.0)
            scrim.setVisibility(View.VISIBLE)
            scrim.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._animate_custom_drawer(fr, 0.0, 150)))
            holder.addView(scrim, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))

            panel = FrameLayout(context)
            panel.setTag(CUSTOM_DRAWER_PANEL_TAG)
            try:
                panel.setElevation(float(AndroidUtilities.dp(26.0)))
            except Exception:
                pass
            try:
                panel.setTranslationZ(float(AndroidUtilities.dp(26.0)))
            except Exception:
                pass
            try:
                GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
                bg = GradientDrawable()
                try:
                    bg.setColor(int(Theme.getColor(Theme.key_windowBackgroundWhite)))
                except Exception:
                    bg.setColor(Color.WHITE)
                bg.setCornerRadius(float(AndroidUtilities.dp(18.0)))
                panel.setBackground(bg)
                try:
                    panel.setClipToOutline(True)
                except Exception:
                    pass
            except Exception:
                try:
                    panel.setBackgroundColor(int(Theme.getColor(Theme.key_windowBackgroundWhite)))
                except Exception:
                    panel.setBackgroundColor(Color.WHITE)
            panel_w = int(self._get_custom_drawer_width(fragment))
            plp = FrameLayout.LayoutParams(panel_w, ViewGroup.LayoutParams.WRAP_CONTENT)
            plp.gravity = int(Gravity.LEFT | Gravity.TOP)
            holder.addView(panel, plp)

            self._build_custom_drawer_ui(fragment, panel)

            # Close by horizontal swipe on scrim.
            iface = find_class("android.view.View$OnTouchListener")
            if iface is not None:
                Proxy = dynamic_proxy(iface)
                touch_state = {"active": False, "drag": False, "x0": 0.0, "y0": 0.0, "p0": 1.0}
                plugin_ref = self

                class _ScrimTouch(Proxy):
                    def onTouch(self, v, e):
                        try:
                            action = int(e.getActionMasked())
                            if action == MotionEvent.ACTION_DOWN:
                                touch_state["active"] = True
                                touch_state["drag"] = False
                                touch_state["x0"] = float(e.getRawX())
                                touch_state["y0"] = float(e.getRawY())
                                touch_state["p0"] = float(plugin_ref._get_custom_drawer_progress(fragment))
                                return True
                            if action == MotionEvent.ACTION_MOVE and touch_state["active"]:
                                dx = float(e.getRawX()) - float(touch_state["x0"])
                                dy = abs(float(e.getRawY()) - float(touch_state["y0"]))
                                if (not touch_state["drag"]) and dx < -float(AndroidUtilities.dp(10.0)) and abs(dx) > (dy * 0.75):
                                    touch_state["drag"] = True
                                if touch_state["drag"]:
                                    w = float(plugin_ref._get_custom_drawer_width(fragment))
                                    p = float(touch_state["p0"]) + (dx / max(1.0, w))
                                    if p < 0.0:
                                        p = 0.0
                                    elif p > 1.0:
                                        p = 1.0
                                    plugin_ref._set_custom_drawer_progress(fragment, p, force_visible=True)
                                    return True
                                return True
                            if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                                if touch_state.get("drag"):
                                    p = float(plugin_ref._get_custom_drawer_progress(fragment))
                                    if p >= 0.5:
                                        plugin_ref._animate_custom_drawer(fragment, 1.0, 150)
                                    else:
                                        plugin_ref._animate_custom_drawer(fragment, 0.0, 150)
                                else:
                                    plugin_ref._animate_custom_drawer(fragment, 0.0, 150)
                                touch_state["active"] = False
                                touch_state["drag"] = False
                                return True
                        except Exception:
                            return False
                        return False

                scrim.setOnTouchListener(_ScrimTouch())

            actual_root.addView(holder, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))
            try:
                holder.bringToFront()
            except Exception:
                pass

            self._custom_drawer_root[key] = holder
            self._custom_drawer_scrim[key] = scrim
            self._custom_drawer_panel[key] = panel
            self._custom_drawer_open[key] = False
            self._custom_drawer_progress[key] = 0.0
            self._custom_panel_h[key] = 0
            self._layout_custom_drawer(fragment)
            self._set_custom_drawer_progress(fragment, 0.0, force_visible=False)
            self._dbg("custom drawer attached")
        except Exception as e:
            self._dbg(f"ensure custom drawer error: {e}")

    def _layout_custom_drawer(self, fragment):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            holder = self._custom_drawer_root.get(key)
            panel = self._custom_drawer_panel.get(key)
            if holder is None or panel is None:
                return
            od = self._custom_open_y.get(key)
            pending_open = bool(od is not None and bool(od.get("pending", False)))
            animating = bool(self._custom_drawer_anim.get(key, False))
            p_now = float(self._custom_drawer_progress.get(key, 0.0) or 0.0)
            open_now = bool(self._custom_drawer_open.get(key, False)) or p_now > 0.001
            if (not pending_open) and (not animating) and (not open_now):
                return
            try:
                holder.bringToFront()
            except Exception:
                pass
            root_w = 0
            root_h = 0
            try:
                root_w = int(holder.getWidth() or 0)
                root_h = int(holder.getHeight() or 0)
            except Exception:
                root_w = 0
                root_h = 0
            if root_w <= 1:
                root_w = int(getattr(AndroidUtilities.displaySize, "x", 0) or 0)
            if root_h <= 1:
                root_h = int(getattr(AndroidUtilities.displaySize, "y", 0) or 0)
            panel_w = int(min(float(AndroidUtilities.dp(float(DRAWER_MAX_WIDTH_DP))), max(float(AndroidUtilities.dp(276.0)), float(root_w) * 0.78)))
            self._custom_drawer_width[key] = float(panel_w)
            margin_top_min = int(AndroidUtilities.dp(64.0))
            margin_top_button = int(AndroidUtilities.dp(64.0))
            margin_bottom = int(AndroidUtilities.dp(112.0))
            try:
                sb = int(getattr(AndroidUtilities, "statusBarHeight", 0) or 0)
                if sb > 0:
                    margin_top_min = max(margin_top_min, sb + int(AndroidUtilities.dp(16.0)))
            except Exception:
                pass
            try:
                nb = int(getattr(AndroidUtilities, "navigationBarHeight", 0) or 0)
                if nb > 0:
                    margin_bottom = max(margin_bottom, nb + int(AndroidUtilities.dp(10.0)))
            except Exception:
                pass
            # Dynamic bottom inset for 12.4.1+ bottom menu bar (if present).
            # If the bar is absent, fallback remains minimal.
            try:
                list_view = None
                try:
                    list_view = self._get_dialogs_list_view(fragment)
                except Exception:
                    list_view = None
                if list_view is None:
                    try:
                        list_view = self._get_field_value(fragment, "listView")
                    except Exception:
                        list_view = None
                if list_view is not None:
                    hp = [0, 0]
                    lp = [0, 0]
                    holder.getLocationOnScreen(hp)
                    list_view.getLocationOnScreen(lp)
                    list_bottom_local = int((lp[1] or 0) - (hp[1] or 0) + int(list_view.getHeight() or 0))
                    if list_bottom_local > 0:
                        extra_bottom = int(root_h - list_bottom_local + int(AndroidUtilities.dp(8.0)))
                        if extra_bottom > 0:
                            margin_bottom = max(margin_bottom, extra_bottom)
            except Exception:
                pass
            max_panel_h = max(1, int(root_h - margin_top_min - margin_bottom))
            panel_h = int(self._custom_panel_h.get(key, 0) or 0)
            if panel_h <= 1:
                panel_h = int(self._measure_custom_panel_content_height(panel, panel_w, max_panel_h))
            if panel_h <= 1:
                panel_h = max_panel_h
            if panel_h > max_panel_h:
                panel_h = max_panel_h
            self._custom_panel_h[key] = int(panel_h)

            top_margin = int(self._custom_drawer_top.get(key, margin_top_button) or margin_top_button)
            try:
                od = self._custom_open_y.get(key)
                if od is not None and bool(od.get("pending", False)):
                    if bool(od.get("swipe", False)):
                        raw_y = float(od.get("y", 0.0) or 0.0)
                        local_y = raw_y
                        try:
                            pos = [0, 0]
                            holder.getLocationOnScreen(pos)
                            local_y = raw_y - float(pos[1] or 0.0)
                        except Exception:
                            pass
                        top_margin = int(local_y - float(AndroidUtilities.dp(178.0)))
                        self._dbg(f"custom drawer top from swipe: rawY={raw_y:.1f} localY={local_y:.1f} top={top_margin}")
                    else:
                        top_margin = margin_top_button
                    od["pending"] = False
                    self._custom_open_y[key] = od
            except Exception:
                pass
            max_top = int(root_h - margin_bottom - panel_h)
            if top_margin < margin_top_min:
                top_margin = margin_top_min
            if max_top >= margin_top_min and top_margin > max_top:
                top_margin = max_top
            self._custom_drawer_top[key] = int(top_margin)
            try:
                lp = panel.getLayoutParams()
                if lp is not None:
                    lp.width = int(panel_w)
                    lp.height = int(panel_h)
                    if hasattr(lp, "gravity"):
                        lp.gravity = int(Gravity.LEFT | Gravity.TOP)
                    if hasattr(lp, "topMargin"):
                        lp.topMargin = int(top_margin)
                    if hasattr(lp, "bottomMargin"):
                        lp.bottomMargin = int(margin_bottom)
                    panel.setLayoutParams(lp)
            except Exception:
                pass
            if not bool(self._custom_drawer_anim.get(key, False)):
                self._set_custom_drawer_progress(fragment, self._get_custom_drawer_progress(fragment), force_visible=bool(self._custom_drawer_open.get(key, False)))
        except Exception as e:
            self._dbg(f"layout custom drawer error: {e}")

    def _measure_custom_panel_content_height(self, panel, panel_w, max_h):
        try:
            if panel is None:
                return max_h
            scroll = None
            try:
                if hasattr(panel, "getChildCount") and int(panel.getChildCount() or 0) > 0:
                    scroll = panel.getChildAt(0)
            except Exception:
                scroll = None
            if scroll is None:
                return max_h
            child = scroll
            try:
                if hasattr(scroll, "getChildCount") and int(scroll.getChildCount() or 0) > 0:
                    child = scroll.getChildAt(0)
            except Exception:
                child = scroll
            try:
                MeasureSpec = jclass("android.view.View$MeasureSpec")
                w_spec = MeasureSpec.makeMeasureSpec(int(max(1, panel_w)), MeasureSpec.EXACTLY)
                h_spec = MeasureSpec.makeMeasureSpec(0, MeasureSpec.UNSPECIFIED)
                child.measure(w_spec, h_spec)
                content_h = int(child.getMeasuredHeight() or 0)
            except Exception:
                content_h = 0
            if content_h <= 0:
                return max_h
            desired = int(content_h)
            min_h = int(AndroidUtilities.dp(200.0))
            if desired < min_h:
                desired = min_h
            if desired > int(max_h):
                desired = int(max_h)
            return desired
        except Exception as e:
            self._dbg(f"measure custom panel height error: {e}")
            return max_h

    def _set_custom_drawer_progress(self, fragment, progress, force_visible=False):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            holder = self._custom_drawer_root.get(key)
            panel = self._custom_drawer_panel.get(key)
            scrim = self._custom_drawer_scrim.get(key)
            if holder is None or panel is None or scrim is None:
                return
            p = float(progress)
            if p < 0.0:
                p = 0.0
            elif p > 1.0:
                p = 1.0
            w = float(self._get_custom_drawer_width(fragment))
            if force_visible or p > 0.001:
                holder.setVisibility(View.VISIBLE)
            panel.setTranslationX(float(-w * (1.0 - p)))
            panel.setTranslationY(0.0)
            scrim.setAlpha(float(0.58 * p))
            try:
                holder.setClickable(p > 0.02)
                scrim.setClickable(p > 0.02)
            except Exception:
                pass
            if (p <= 0.001) and (not force_visible):
                holder.setVisibility(View.GONE)
            self._custom_drawer_progress[key] = p
            self._custom_drawer_open[key] = bool(p >= 0.999)
        except Exception as e:
            self._dbg(f"set custom drawer progress error: {e}")

    def _animate_custom_drawer(self, fragment, target, duration_ms):
        try:
            if fragment is None:
                return
            self._ensure_custom_drawer(fragment, None)
            key = self._obj_key(fragment)
            holder = self._custom_drawer_root.get(key)
            panel = self._custom_drawer_panel.get(key)
            scrim = self._custom_drawer_scrim.get(key)
            if holder is None or panel is None or scrim is None:
                return
            try:
                holder.animate().cancel()
            except Exception:
                pass
            try:
                holder.setTranslationY(0.0)
                holder.setAlpha(1.0)
            except Exception:
                pass
            try:
                panel.animate().cancel()
            except Exception:
                pass
            try:
                scrim.animate().cancel()
            except Exception:
                pass
            t = float(target)
            if t < 0.0:
                t = 0.0
            elif t > 1.0:
                t = 1.0
            holder.setVisibility(View.VISIBLE)
            w = float(self._get_custom_drawer_width(fragment))
            end_x = float(-w * (1.0 - t))
            end_alpha = float(0.58 * t)
            self._custom_drawer_anim[key] = True
            panel.animate().translationX(end_x).setDuration(int(duration_ms)).start()
            scrim.animate().alpha(end_alpha).setDuration(int(duration_ms)).start()

            def _finish(fr=fragment, tgt=t):
                try:
                    k = self._obj_key(fr)
                    self._custom_drawer_anim[k] = False
                    self._set_custom_drawer_progress(fr, float(tgt), force_visible=bool(tgt > 0.001))
                    if float(tgt) <= 0.001 and k in self._custom_open_y:
                        del self._custom_open_y[k]
                    if float(tgt) <= 0.001 and k in self._custom_drawer_top:
                        del self._custom_drawer_top[k]
                except Exception:
                    pass

            run_on_ui_thread(_finish, int(duration_ms) + 24)
        except Exception as e:
            self._dbg(f"animate custom drawer error: {e}")

    def _install_custom_panel_drag(self, fragment, touch_view):
        try:
            if fragment is None or touch_view is None:
                return
            if not self._is_custom_drawer_enabled():
                return
            iface = find_class("android.view.View$OnTouchListener")
            if iface is None:
                return
            Proxy = dynamic_proxy(iface)
            plugin_ref = self
            state = {"active": False, "drag": False, "x0": 0.0, "y0": 0.0, "p0": 1.0}

            class _PanelTouch(Proxy):
                def onTouch(self, v, e):
                    try:
                        action = int(e.getActionMasked())
                        if action == MotionEvent.ACTION_DOWN:
                            state["active"] = True
                            state["drag"] = False
                            state["x0"] = float(e.getRawX())
                            state["y0"] = float(e.getRawY())
                            state["p0"] = float(plugin_ref._get_custom_drawer_progress(fragment))
                            return False
                        if action == MotionEvent.ACTION_MOVE and state.get("active"):
                            dx = float(e.getRawX()) - float(state.get("x0", 0.0))
                            dy = abs(float(e.getRawY()) - float(state.get("y0", 0.0)))
                            if (not state.get("drag")) and abs(dx) > float(AndroidUtilities.dp(7.0)) and abs(dx) > (dy * 0.55):
                                state["drag"] = True
                                try:
                                    if hasattr(v, "requestDisallowInterceptTouchEvent"):
                                        v.requestDisallowInterceptTouchEvent(True)
                                except Exception:
                                    pass
                                plugin_ref._dbg(f"custom panel drag start: dx={dx:.1f} dy={dy:.1f}")
                            if state.get("drag"):
                                w = float(plugin_ref._get_custom_drawer_width(fragment))
                                p = float(state.get("p0", 1.0)) + (dx / max(1.0, w))
                                if p < 0.0:
                                    p = 0.0
                                elif p > 1.0:
                                    p = 1.0
                                plugin_ref._set_custom_drawer_progress(fragment, p, force_visible=True)
                                return True
                            return False
                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            if state.get("drag"):
                                p = float(plugin_ref._get_custom_drawer_progress(fragment))
                                if p >= 0.5:
                                    plugin_ref._animate_custom_drawer(fragment, 1.0, 150)
                                else:
                                    plugin_ref._animate_custom_drawer(fragment, 0.0, 150)
                                plugin_ref._dbg(f"custom panel drag finish: p={p:.2f}")
                                state["active"] = False
                                state["drag"] = False
                                return True
                            if state.get("active"):
                                dx = float(e.getRawX()) - float(state.get("x0", 0.0))
                                dy = abs(float(e.getRawY()) - float(state.get("y0", 0.0)))
                                if dx < -float(AndroidUtilities.dp(26.0)) and abs(dx) > (dy * 0.45):
                                    plugin_ref._animate_custom_drawer(fragment, 0.0, 150)
                                    plugin_ref._dbg(f"custom panel quick close: dx={dx:.1f} dy={dy:.1f}")
                                    state["active"] = False
                                    state["drag"] = False
                                    return True
                            state["active"] = False
                            state["drag"] = False
                            return False
                    except Exception:
                        return False
                    return False

            listener = _PanelTouch()
            touch_view.setOnTouchListener(listener)
        except Exception as e:
            self._dbg(f"install custom panel drag error: {e}")

    def _build_custom_drawer_ui(self, fragment, panel):
        try:
            context = fragment.getContext()
            if context is None:
                return
            try:
                self._custom_panel_h[self._obj_key(fragment)] = 0
            except Exception:
                pass
            panel.removeAllViews()
            try:
                self._custom_ui_built_at[self._obj_key(fragment)] = int(time.time() * 1000)
            except Exception:
                pass

            scroll = ScrollView(context)
            scroll.setTag(CUSTOM_DRAWER_SCROLL_TAG)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            try:
                scroll.setBackgroundColor(Color.TRANSPARENT)
            except Exception:
                pass
            panel.addView(scroll, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))
            self._install_custom_panel_drag(fragment, panel)

            linear = LinearLayout(context)
            linear.setOrientation(LinearLayout.VERTICAL)
            try:
                linear.setBackgroundColor(int(Theme.getColor(Theme.key_windowBackgroundWhite)))
            except Exception:
                pass
            scroll.addView(linear, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

            header = self._build_custom_header(fragment)
            if header is not None:
                linear.addView(header, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(176.0))))

            accounts = LinearLayout(context)
            accounts.setTag(CUSTOM_DRAWER_ACCOUNTS_TAG)
            accounts.setOrientation(LinearLayout.VERTICAL)
            accounts.setVisibility(View.GONE)
            accounts.setAlpha(0.0)
            accounts.setTranslationY(-float(AndroidUtilities.dp(10.0)))
            linear.addView(accounts, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
            self._custom_drawer_accounts[self._obj_key(fragment)] = accounts
            self._fill_custom_accounts(fragment, accounts)

            self._add_custom_divider(linear)

            entries = self._capture_original_menu_entries(fragment, force=False)
            used = set()
            had_rows = False
            prev_divider = True
            plugins_icon_spec = self._get_plugins_menu_icon()
            if entries:
                for ent in entries:
                    et = str(ent.get("type", "row") or "row")
                    if et == "divider":
                        # ETG can emit visual separators for almost every row.
                        # We use our own section separators to avoid "divider after each item".
                        continue
                    txt = str(ent.get("text", "") or "").strip()
                    if not txt:
                        continue
                    low = txt.lower()
                    if low in ("plugins", "плагины"):
                        # Always use dedicated plugins opener, original callback is flaky on some builds.
                        if plugins_icon_spec is None:
                            try:
                                plugins_icon_spec = ent.get("icon")
                            except Exception:
                                plugins_icon_spec = None
                        continue
                    if self._is_theme_menu_item(low):
                        continue
                    if low in used:
                        continue
                    used.add(low)
                    icon = ent.get("icon")
                    self._add_custom_row(fragment, linear, txt, icon, lambda e=ent: self._run_original_menu_entry(fragment, e))
                    had_rows = True
                    prev_divider = False

                if ("plugins" not in used) and ("плагины" not in used):
                    if had_rows and (not prev_divider):
                        self._add_custom_divider(linear)
                    self._add_custom_row(
                        fragment,
                        linear,
                        "Плагины",
                        plugins_icon_spec if plugins_icon_spec is not None else "msg_plugins",
                        lambda fr=fragment: self._open_plugins_activity(fr),
                    )
                    used.add("plugins")
                    used.add("плагины")
                    had_rows = True
                    prev_divider = False

                plugin_extra = self._collect_plugins_menu_entries()
                extra_count = 0
                if plugin_extra:
                    if had_rows and (not prev_divider):
                        self._add_custom_divider(linear)
                    for ent in plugin_extra:
                        txt = str(ent.get("text", "") or "").strip()
                        if not txt:
                            continue
                        low = txt.lower()
                        if low in used:
                            continue
                        used.add(low)
                        icon = ent.get("icon")
                        cb = ent.get("callback", None)
                        self._add_custom_row(fragment, linear, txt, icon, lambda callback_obj=cb, fr=fragment: self._run_plugin_extra_callback(fr, callback_obj))
                        extra_count += 1
                    if extra_count > 0:
                        self._dbg(f"custom plugin extra rows: {extra_count}")
            else:
                self._add_custom_row(fragment, linear, "Профиль", "msg_openprofile", lambda: self._open_my_profile(fragment))
                self._add_custom_row(
                    fragment,
                    linear,
                    "Плагины",
                    plugins_icon_spec if plugins_icon_spec is not None else "msg_plugins",
                    lambda: self._open_plugins_activity(fragment),
                )
                self._add_custom_row(fragment, linear, "Настройки", "msg_settings", lambda: self._open_settings(fragment))
                self._add_custom_row(fragment, linear, "Сменить аккаунт", "msg_add", lambda: self._toggle_custom_accounts(fragment))
            self._dbg(f"custom drawer menu rows: {len(entries) if entries else 0}")
        except Exception as e:
            self._dbg(f"build custom drawer ui error: {e}")

    def _build_custom_header(self, fragment):
        try:
            context = fragment.getContext()
            if context is None:
                return None
            account = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            user = None
            try:
                user = UserConfig.getInstance(account).getCurrentUser()
            except Exception:
                user = None

            root = FrameLayout(context)
            try:
                root.setBackgroundColor(int(Theme.getColor(Theme.key_chats_menuTopBackground)))
            except Exception:
                root.setBackgroundColor(int(Color.argb(255, 37, 43, 52)))

            bg_img = BackupImageView(context)
            try:
                try:
                    bg_img.getImageReceiver().setCurrentAccount(account)
                except Exception:
                    pass
                av_bg = AvatarDrawable()
                if user is not None:
                    av_bg.setInfo(user)
                img_bg = getattr(user, "photo", None)
                small_bg = getattr(img_bg, "photo_small", None) if img_bg is not None else None
                if user is not None and hasattr(bg_img, "setForUserOrChat"):
                    bg_img.setForUserOrChat(user, av_bg)
                else:
                    bg_img.setImage(small_bg, "320_320", av_bg)
                bg_img.setAlpha(0.28)
                try:
                    uid = int(getattr(user, "id", 0) or 0) if user is not None else 0
                    self._dbg(f"header bg avatar load: uid={uid} has_small={bool(small_bg is not None)}")
                except Exception:
                    pass
                root.addView(bg_img, LayoutHelper.createFrame(-1, -1.0, Gravity.LEFT | Gravity.TOP, 0.0, 0.0, 0.0, 0.0))
            except Exception:
                self._dbg("header bg avatar load failed; fallback background only")
                pass
            overlay = View(context)
            try:
                dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                dark = False
            if dark:
                overlay.setBackgroundColor(Color.argb(122, 0, 0, 0))
            else:
                overlay.setBackgroundColor(Color.argb(88, 255, 255, 255))
            root.addView(overlay, LayoutHelper.createFrame(-1, -1.0, Gravity.LEFT | Gravity.TOP, 0.0, 0.0, 0.0, 0.0))

            avatar = BackupImageView(context)
            try:
                avatar.setRoundRadius(int(AndroidUtilities.dp(32.0)))
            except Exception:
                pass
            av = AvatarDrawable()
            if user is not None:
                try:
                    av.setInfo(user)
                except Exception:
                    pass
            try:
                try:
                    avatar.getImageReceiver().setCurrentAccount(account)
                except Exception:
                    pass
                img = getattr(user, "photo", None)
                small = getattr(img, "photo_small", None) if img is not None else None
                if user is not None and hasattr(avatar, "setForUserOrChat"):
                    avatar.setForUserOrChat(user, av)
                else:
                    avatar.setImage(small, "50_50", av)
                try:
                    uid = int(getattr(user, "id", 0) or 0) if user is not None else 0
                    self._dbg(f"header avatar load: uid={uid} has_small={bool(small is not None)}")
                except Exception:
                    pass
            except Exception:
                avatar.setImageDrawable(av)
                self._dbg("header avatar load failed; avatar drawable fallback")
            root.addView(avatar, LayoutHelper.createFrame(64, 64.0, Gravity.LEFT | Gravity.TOP, 18.0, 50.0, 0.0, 0.0))

            name = TextView(context)
            name.setSingleLine(True)
            name.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
            name.setTextSize(17.0)
            try:
                name.setTextColor(int(Theme.getColor(Theme.key_chats_menuName)))
            except Exception:
                name.setTextColor(Color.WHITE)
            try:
                name.setText(str(UserObject.getUserName(user) or ""))
            except Exception:
                name.setText("")
            root.addView(name, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.TOP, 18.0, 124.0, 76.0, 0.0))

            uname = TextView(context)
            uname.setSingleLine(True)
            uname.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
            uname.setTextSize(13.0)
            try:
                if dark:
                    uname.setTextColor(Color.argb(224, 218, 224, 232))
                else:
                    uname.setTextColor(Color.argb(232, 24, 24, 24))
            except Exception:
                uname.setTextColor(Color.argb(224, 218, 224, 232))
            u = ""
            try:
                un = str(getattr(user, "username", "") or "").strip()
                u = ("@" + un) if un else ""
            except Exception:
                u = ""
            if not u:
                try:
                    u = "id" + str(getattr(user, "id", "") or "")
                except Exception:
                    u = "id"
            uname.setText(u)
            root.addView(uname, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.TOP, 18.0, 147.0, 76.0, 0.0))

            profile_click = OnClickListener(lambda _v, fr=fragment: self._open_my_profile(fr))
            root.setOnClickListener(profile_click)
            avatar.setOnClickListener(profile_click)
            name.setOnClickListener(profile_click)
            uname.setOnClickListener(profile_click)

            acc_toggle = FrameLayout(context)
            try:
                acc_toggle.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1))
            except Exception:
                pass
            acc_toggle.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._toggle_custom_accounts(fr)))
            root.addView(acc_toggle, LayoutHelper.createFrame(50, 58.0, Gravity.RIGHT | Gravity.BOTTOM, 0.0, 0.0, 0.0, 6.0))
            acc_arrow = ImageView(context)
            try:
                acc_arrow.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "arrow_more", 0))
            except Exception:
                try:
                    acc_arrow.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_expand", 0))
                except Exception:
                    pass
            try:
                acc_arrow.setColorFilter(int(Color.WHITE if dark else Color.BLACK))
            except Exception:
                pass
            acc_toggle.addView(acc_arrow, LayoutHelper.createFrame(20, 20.0, Gravity.CENTER))

            theme_btn = ImageView(context)
            theme_btn.setScaleType(ImageView.ScaleType.CENTER)
            try:
                theme_btn.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1))
            except Exception:
                pass
            try:
                key = self._obj_key(fragment)
                ic = self._theme_icon.get(key, None)
                if ic is not None:
                    self._set_image_with_anim(theme_btn, ic, True)
                else:
                    dark = False
                    try:
                        dark = bool(Theme.isCurrentThemeDark())
                    except Exception:
                        dark = False
                    theme_btn.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "menu_day_mode_24" if dark else "menu_night_mode_24", 0))
                theme_btn.setColorFilter(int(Color.WHITE if dark else Color.BLACK))
                try:
                    dr = theme_btn.getDrawable()
                    if dr is not None and hasattr(dr, "start"):
                        dr.start()
                except Exception:
                    pass
            except Exception:
                pass
            theme_btn.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._trigger_theme_toggle(fr, _v)))
            root.addView(theme_btn, LayoutHelper.createFrame(44, 44.0, Gravity.RIGHT | Gravity.TOP, 0.0, 14.0, 3.0, 0.0))
            self._dbg("custom header built")
            return root
        except Exception as e:
            self._dbg(f"build custom header error: {e}")
            return None

    def _add_custom_divider(self, linear):
        try:
            if linear is None:
                return
            d = View(linear.getContext())
            try:
                d.setBackgroundColor(int(Theme.getColor(Theme.key_divider)))
            except Exception:
                d.setBackgroundColor(Color.argb(48, 255, 255, 255))
            lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 1)
            lp.leftMargin = int(AndroidUtilities.dp(16.0))
            lp.rightMargin = int(AndroidUtilities.dp(16.0))
            linear.addView(d, lp)
        except Exception:
            pass

    def _add_custom_row(self, fragment, linear, text, icon_spec, action):
        try:
            if linear is None:
                return
            context = linear.getContext()
            row = FrameLayout(context)
            try:
                row.setClickable(True)
                row.setLongClickable(False)
            except Exception:
                pass
            try:
                row.setBackground(Theme.getSelectorDrawable(True))
            except Exception:
                pass
            icon = ImageView(context)
            icon.setScaleType(ImageView.ScaleType.CENTER)
            self._apply_custom_row_icon(icon, icon_spec, str(text or ""))
            try:
                icon.setColorFilter(int(Theme.getColor(Theme.key_chats_menuItemIcon)))
            except Exception:
                pass
            row.addView(icon, LayoutHelper.createFrame(24, 24.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 18.0, 0.0, 0.0, 0.0))

            tv = TextView(context)
            tv.setText(str(text))
            tv.setSingleLine(True)
            tv.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
            tv.setTextSize(16.0)
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                tv.setTextColor(Color.WHITE)
            row.addView(tv, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 60.0, 0.0, 16.0, 0.0))

            def _run(fr_action=action, fr=fragment):
                try:
                    self._dbg(f"custom row click: {str(text or '')}")
                except Exception:
                    pass
                try:
                    self._animate_custom_drawer(fr, 0.0, 140)
                except Exception:
                    pass
                try:
                    fr_action()
                except Exception as e:
                    self._dbg(f"custom row action error: {e}")

            row.setOnClickListener(OnClickListener(lambda _v: _run()))
            linear.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(50.0))))
        except Exception as e:
            self._dbg(f"add custom row error: {e}")

    def _apply_custom_row_icon(self, icon, icon_spec, text):
        try:
            if icon is None:
                return
            if icon_spec is not None:
                try:
                    if hasattr(icon_spec, "getConstantState"):
                        cs = icon_spec.getConstantState()
                        if cs is not None:
                            icon.setImageDrawable(cs.newDrawable())
                            return
                        icon.setImageDrawable(icon_spec)
                        return
                except Exception:
                    pass
                try:
                    if isinstance(icon_spec, str):
                        res = int(getattr(jclass("org.telegram.messenger.R").drawable, icon_spec, 0) or 0)
                        if res != 0:
                            icon.setImageResource(res)
                            return
                except Exception:
                    pass
                try:
                    res = int(icon_spec or 0)
                    if res != 0:
                        icon.setImageResource(res)
                        return
                except Exception:
                    pass

            low = str(text or "").lower()
            fallback = "msg_settings"
            if ("плагин" in low) or ("plugin" in low):
                fallback = "msg_plugins"
            elif ("профил" in low) or ("profile" in low):
                fallback = "msg_openprofile"
            elif ("тема" in low) or ("theme" in low):
                fallback = "menu_night_mode_24"
            elif ("прокси" in low) or ("proxy" in low):
                fallback = "msg_proxy"
            elif ("аккаунт" in low) or ("account" in low):
                fallback = "msg_add"
            res = int(getattr(jclass("org.telegram.messenger.R").drawable, fallback, 0) or 0)
            if res != 0:
                icon.setImageResource(res)
        except Exception:
            pass

    def _set_image_with_anim(self, image_view, drawable_obj, mutate_copy=False):
        try:
            if image_view is None or drawable_obj is None:
                return False
            dr = drawable_obj
            if mutate_copy:
                try:
                    cs = drawable_obj.getConstantState()
                    if cs is not None:
                        dr = cs.newDrawable()
                except Exception:
                    dr = drawable_obj
            try:
                image_view.setImageDrawable(dr)
            except Exception:
                return False
            started = False
            try:
                if hasattr(dr, "setAutoRepeat"):
                    dr.setAutoRepeat(1)
            except Exception:
                pass
            try:
                if hasattr(dr, "start"):
                    dr.start()
                    started = True
            except Exception:
                pass
            if started:
                self._dbg("animated drawable started")
            return True
        except Exception:
            return False

    def _run_original_menu_entry(self, fragment, entry, close_drawer=True):
        if close_drawer:
            try:
                self._animate_custom_drawer(fragment, 0.0, 140)
            except Exception:
                pass
        try:
            view = entry.get("view")
            if view is not None:
                try:
                    if hasattr(view, "callOnClick"):
                        view.callOnClick()
                    else:
                        view.performClick()
                    return
                except Exception:
                    pass
            cb = entry.get("callback")
            if cb is not None:
                if hasattr(cb, "invoke"):
                    cb.invoke()
                elif callable(cb):
                    cb()
        except Exception as e:
            self._dbg(f"run original menu entry error: {e}")

    def _refresh_custom_drawer_theme(self, fragment):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            p = float(self._get_custom_drawer_progress(fragment))
            is_open = bool(self._custom_drawer_open.get(key, False)) or p > 0.01
            self._capture_original_menu_entries(fragment, force=True)
            panel = self._custom_drawer_panel.get(key)
            if panel is not None:
                self._build_custom_drawer_ui(fragment, panel)
                self._layout_custom_drawer(fragment)
                if is_open:
                    self._set_custom_drawer_progress(fragment, max(0.08, p), force_visible=True)
            self._ensure_left_menu_button(fragment)
            self._set_left_button_visible(fragment, True)
            self._dbg("custom drawer theme refreshed")
        except Exception as e:
            self._dbg(f"refresh custom drawer theme error: {e}")

    def _run_special_from_original_menu(self, fragment, kind):
        try:
            entries = self._capture_original_menu_entries(fragment, force=True)
            if not entries:
                return
            for ent in entries:
                txt = str(ent.get("text", "") or "").strip().lower()
                if not txt:
                    continue
                if kind == "theme":
                    if ("ночн" in txt and "режим" in txt) or ("днев" in txt and "режим" in txt) or ("night mode" in txt) or ("day mode" in txt) or ("switchtheme" in txt):
                        self._run_original_menu_entry(fragment, ent, close_drawer=False)
                        run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 40)
                        run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 180)
                        run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 420)
                        self._dbg("custom special action: theme")
                        return
                elif kind == "proxy":
                    if self._is_proxy_related_item(txt):
                        self._run_original_menu_entry(fragment, ent)
                        self._dbg("custom special action: proxy")
                        return
        except Exception as e:
            self._dbg(f"run special from original menu error: {e}")

    def _run_plugin_extra_callback(self, fragment, callback_obj):
        try:
            self._animate_custom_drawer(fragment, 0.0, 140)
        except Exception:
            pass
        def _invoke(cb=callback_obj):
            try:
                if cb is None:
                    return
                if hasattr(cb, "invoke"):
                    try:
                        cb.invoke()
                    except Exception:
                        cb.invoke(None)
                elif callable(cb):
                    try:
                        cb()
                    except Exception:
                        cb(None)
            except Exception as e:
                self._dbg(f"plugin extra callback invoke error: {e}")
        run_on_ui_thread(_invoke, 145)

    def _toggle_custom_accounts(self, fragment):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            holder = self._custom_drawer_accounts.get(key)
            if holder is None:
                return
            opening = int(holder.getVisibility() or 0) != View.VISIBLE
            if opening:
                self._fill_custom_accounts(fragment, holder)
                self._custom_panel_h[key] = 0
                holder.setVisibility(View.VISIBLE)
                holder.setAlpha(0.0)
                holder.setTranslationY(-float(AndroidUtilities.dp(10.0)))
                holder.animate().alpha(1.0).translationY(0.0).setDuration(180).start()
                run_on_ui_thread(lambda fr=fragment: self._layout_custom_drawer(fr), 16)
            else:
                self._custom_panel_h[key] = 0
                holder.animate().alpha(0.0).translationY(-float(AndroidUtilities.dp(10.0))).setDuration(160).start()
                run_on_ui_thread(lambda h=holder: h.setVisibility(View.GONE), 170)
                run_on_ui_thread(lambda fr=fragment: self._layout_custom_drawer(fr), 180)
            self._dbg(f"custom accounts toggled: {opening}")
        except Exception as e:
            self._dbg(f"toggle custom accounts error: {e}")

    def _fill_custom_accounts(self, fragment, holder):
        try:
            if fragment is None or holder is None:
                return
            context = holder.getContext()
            holder.removeAllViews()
            selected = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            max_accounts = int(getattr(UserConfig, "MAX_ACCOUNT_COUNT", 16) or 16)
            for i in range(max_accounts):
                try:
                    cfg = UserConfig.getInstance(i)
                except Exception:
                    cfg = None
                if cfg is None:
                    continue
                try:
                    if not cfg.isClientActivated():
                        continue
                except Exception:
                    continue

                user = None
                try:
                    user = cfg.getCurrentUser()
                except Exception:
                    user = None
                row = FrameLayout(context)
                try:
                    row.setBackground(Theme.getSelectorDrawable(True))
                except Exception:
                    pass
                av = BackupImageView(context)
                av.setRoundRadius(int(AndroidUtilities.dp(12.0)))
                avd = AvatarDrawable()
                if user is not None:
                    try:
                        avd.setInfo(user)
                    except Exception:
                        pass
                try:
                    try:
                        av.getImageReceiver().setCurrentAccount(i)
                    except Exception:
                        pass
                    img = getattr(user, "photo", None)
                    small = getattr(img, "photo_small", None) if img is not None else None
                    if user is not None and hasattr(av, "setForUserOrChat"):
                        av.setForUserOrChat(user, avd)
                    else:
                        av.setImage(small, "50_50", avd)
                    self._dbg(f"accounts avatar load: acc={i} has_small={bool(small is not None)}")
                except Exception:
                    av.setImageDrawable(avd)
                    self._dbg(f"accounts avatar load failed: acc={i}")
                row.addView(av, LayoutHelper.createFrame(24, 24.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 18.0, 0.0, 0.0, 0.0))

                tv = TextView(context)
                tv.setSingleLine(True)
                tv.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                tv.setTextSize(15.0)
                try:
                    tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
                except Exception:
                    tv.setTextColor(Color.WHITE)
                try:
                    nm = str(UserObject.getUserName(user) or "")
                except Exception:
                    nm = ""
                if i == selected:
                    nm = "• " + nm
                tv.setText(nm)
                row.addView(tv, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 56.0, 0.0, 16.0, 0.0))
                row.setOnClickListener(OnClickListener(lambda _v, fr=fragment, aid=i: self._switch_account(fr, aid)))
                holder.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(46.0))))

            add_row = FrameLayout(context)
            try:
                add_row.setBackground(Theme.getSelectorDrawable(True))
            except Exception:
                pass
            iv = ImageView(context)
            try:
                iv.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "msg_add", 0))
                iv.setColorFilter(int(Theme.getColor(Theme.key_chats_menuItemIcon)))
            except Exception:
                pass
            add_row.addView(iv, LayoutHelper.createFrame(24, 24.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 18.0, 0.0, 0.0, 0.0))
            t = TextView(context)
            t.setText("Добавить аккаунт")
            t.setSingleLine(True)
            t.setTextSize(15.0)
            try:
                t.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                t.setTextColor(Color.WHITE)
            add_row.addView(t, LayoutHelper.createFrame(-1, -2.0, Gravity.LEFT | Gravity.CENTER_VERTICAL, 56.0, 0.0, 16.0, 0.0))
            add_row.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._open_add_account(fr)))
            holder.addView(add_row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, int(AndroidUtilities.dp(46.0))))

            self._add_custom_divider(holder)
            self._dbg("accounts list rendered in custom drawer")
        except Exception as e:
            self._dbg(f"fill custom accounts error: {e}")

    def _open_settings(self, fragment):
        try:
            if fragment is None:
                return
            SettingsActivity = find_class("org.telegram.ui.SettingsActivity")
            if SettingsActivity is None:
                return
            target = None
            try:
                target = SettingsActivity()
            except Exception:
                target = None
            if target is not None:
                fragment.presentFragment(target)
        except Exception as e:
            self._dbg(f"open settings error: {e}")

    def _update_dialogs_controls(self, fragment, force):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            now_ms = int(time.time() * 1000)
            ts_key = f"ui_tick_light_{key}"
            last = int(self._search_ui_state.get(ts_key, 0) or 0)
            if (not force) and (now_ms - last < 120):
                return
            self._search_ui_state[ts_key] = now_ms
            self._ensure_left_menu_button(fragment)
            self._set_left_button_visible(fragment, True)
            if self._is_custom_drawer_enabled():
                p = float(self._custom_drawer_progress.get(key, 0.0) or 0.0)
                if bool(self._custom_drawer_open.get(key, False)) or p > 0.001 or bool(self._custom_drawer_anim.get(key, False)):
                    self._layout_custom_drawer(fragment)
        except Exception as e:
            self._dbg(f"update dialogs controls error: {e}")

    def _move_options_button_left(self, fragment):
        # Disabled: old approach creates duplicate visual ghost on some builds.
        return

    def _ensure_left_menu_button(self, fragment):
        try:
            if fragment is None:
                return
            options_item = None
            try:
                options_item = self._get_field_value(fragment, "optionsItem")
            except Exception:
                options_item = None
            if options_item is not None:
                self._hide_right_options_button(options_item)

            action_bar = None
            try:
                action_bar = self._get_field_value(fragment, "actionBar")
            except Exception:
                action_bar = None
            if action_bar is None or not hasattr(action_bar, "addView"):
                return

            left_btn = self._find_tagged_child(action_bar, LEFT_DOTS_TAG)
            if left_btn is None:
                context = fragment.getContext()
                if context is None:
                    return
                left_btn = ImageView(context)
                left_btn.setTag(LEFT_DOTS_TAG)
                left_btn.setScaleType(ImageView.ScaleType.CENTER)
                try:
                    left_btn.setImageResource(getattr(jclass("org.telegram.messenger.R").drawable, "ic_ab_other", 0))
                except Exception:
                    pass
                try:
                    icon_color = int(Theme.getColor(Theme.key_actionBarDefaultIcon))
                    left_btn.setColorFilter(icon_color)
                except Exception:
                    pass
                try:
                    sel = Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1)
                    left_btn.setBackground(sel)
                except Exception:
                    pass
                pad = int(AndroidUtilities.dp(12.0))
                left_btn.setPadding(pad, pad, pad, pad)
                size = int(AndroidUtilities.dp(48.0))
                lp = FrameLayout.LayoutParams(size, size)
                lp.gravity = int(Gravity.LEFT | Gravity.CENTER_VERTICAL)
                lp.leftMargin = int(AndroidUtilities.dp(4.0))
                action_bar.addView(left_btn, lp)
                self._dbg("left three-dots button created")
            try:
                icon_color = int(Theme.getColor(Theme.key_actionBarDefaultIcon))
                left_btn.setColorFilter(icon_color)
            except Exception:
                pass
            try:
                left_btn.setTranslationY(float(AndroidUtilities.dp(12.0)))
            except Exception:
                pass
            try:
                lp = left_btn.getLayoutParams()
                if lp is not None and hasattr(lp, "gravity"):
                    lp.gravity = int(Gravity.LEFT | Gravity.CENTER_VERTICAL)
                    if hasattr(lp, "leftMargin"):
                        lp.leftMargin = int(AndroidUtilities.dp(4.0))
                    if hasattr(lp, "topMargin"):
                        lp.topMargin = int(AndroidUtilities.dp(8.0))
                    left_btn.setLayoutParams(lp)
            except Exception:
                pass
            left_btn.setOnClickListener(OnClickListener(lambda _v: self._open_main_menu(fragment)))
            self._set_left_button_visible(fragment, True)
        except Exception as e:
            self._dbg(f"ensure left button error: {e}")

    def _set_left_button_visible(self, fragment, visible):
        try:
            action_bar = None
            try:
                action_bar = self._get_field_value(fragment, "actionBar")
            except Exception:
                action_bar = None
            if action_bar is None:
                return
            left_btn = self._find_tagged_child(action_bar, LEFT_DOTS_TAG)
            if left_btn is None:
                return
            is_search = self._is_search_overlay_visible(fragment)
            show = bool(visible) and (not is_search)
            left_btn.setVisibility(View.VISIBLE if show else View.GONE)
            left_btn.setEnabled(show)
            left_btn.setClickable(show)
        except Exception as e:
            self._dbg(f"set left button visible error: {e}")

    def _is_search_overlay_visible(self, fragment):
        try:
            # Consider search active only in real search state.
            searching = False
            try:
                searching = bool(self._get_field_value(fragment, "searching"))
            except Exception:
                searching = False
            if searching:
                return True

            long_search = None
            try:
                long_search = self._get_field_value(fragment, "fragmentSearchField")
            except Exception:
                long_search = None
            if long_search is not None:
                try:
                    if bool(long_search.hasFocus()):
                        return True
                except Exception:
                    pass

            return False
        except Exception:
            return False

    def _is_view_visible(self, view):
        try:
            if view is None:
                return False
            try:
                if int(view.getVisibility() or 0) != View.VISIBLE:
                    return False
            except Exception:
                return False
            try:
                if float(view.getAlpha() or 0.0) <= 0.03:
                    return False
            except Exception:
                pass
            try:
                if float(view.getScaleX() or 1.0) <= 0.22:
                    return False
                if float(view.getScaleY() or 1.0) <= 0.22:
                    return False
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _is_menu_button_present(self, view):
        try:
            if view is None:
                return False
            try:
                if int(view.getVisibility() or 0) != View.VISIBLE:
                    return False
            except Exception:
                return False
            try:
                if float(view.getAlpha() or 0.0) <= 0.55:
                    return False
            except Exception:
                pass
            try:
                if float(view.getScaleX() or 1.0) <= 0.5:
                    return False
                if float(view.getScaleY() or 1.0) <= 0.5:
                    return False
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _should_apply_search_ui(self, fragment):
        try:
            if fragment is None:
                return False
            key = self._obj_key(fragment)
            active = self._is_search_overlay_visible(fragment)
            st = self._search_ui_state.get(key)
            if st is None:
                self._search_ui_state[key] = {"active": active}
                self._dbg(f"search ui state init: key={key} active={active}")
                return True
            if bool(st.get("active")) != bool(active):
                self._search_ui_state[key] = {"active": active}
                self._dbg(f"search ui state changed: key={key} active={active}")
                return True
            return False
        except Exception:
            return True

    def _hide_right_options_button(self, options_item):
        try:
            options_item.setClickable(False)
        except Exception:
            pass
        try:
            options_item.setEnabled(False)
        except Exception:
            pass
        try:
            options_item.setAlpha(0.0)
        except Exception:
            pass
        try:
            options_item.setVisibility(View.GONE)
        except Exception:
            pass
        try:
            options_item.setOnClickListener(OnClickListener(lambda _v: None))
        except Exception:
            pass
        try:
            lp = options_item.getLayoutParams()
            if lp is not None:
                if hasattr(lp, "width"):
                    lp.width = 0
                if hasattr(lp, "height"):
                    lp.height = int(AndroidUtilities.dp(48.0))
                if hasattr(lp, "leftMargin"):
                    lp.leftMargin = 0
                if hasattr(lp, "rightMargin"):
                    lp.rightMargin = 0
                options_item.setLayoutParams(lp)
        except Exception:
            pass
        try:
            icon = options_item.getIconView()
            if icon is not None:
                icon.setAlpha(0.0)
                icon.setVisibility(View.GONE)
                icon.setClickable(False)
                try:
                    icon.setOnClickListener(OnClickListener(lambda _v: None))
                except Exception:
                    pass
        except Exception:
            pass

    def _ensure_search_button_right(self, fragment):
        try:
            if fragment is None:
                return
            search_active = self._is_search_overlay_visible(fragment)
            action_bar = None
            try:
                action_bar = self._get_field_value(fragment, "actionBar")
            except Exception:
                action_bar = None
            search_item = None
            try:
                search_item = self._get_field_value(fragment, "searchItem")
            except Exception:
                search_item = None
            if action_bar is None or search_item is None:
                return
            try:
                options_item = self._get_field_value(fragment, "optionsItem")
            except Exception:
                options_item = None
            if options_item is not None:
                self._hide_right_options_button(options_item)

            # Move search item to the end of ActionBarMenu so it stays at far right.
            try:
                menu = self._get_field_value(action_bar, "menu")
            except Exception:
                menu = None
            try:
                if menu is not None and search_item.getParent() == menu:
                    menu.removeView(search_item)
                    menu.addView(search_item)
            except Exception:
                pass

            try:
                anim_btn = self._get_field_value(fragment, "animatorSearchButtonVisible")
                if anim_btn is not None and hasattr(anim_btn, "setValue"):
                    try:
                        anim_btn.setValue((not search_active), False)
                    except Exception:
                        anim_btn.setValue((not search_active))
            except Exception:
                pass

            try:
                search_item.setVisibility(View.GONE if search_active else View.VISIBLE)
            except Exception:
                pass
            if not search_active:
                try:
                    search_item.setAlpha(1.0)
                except Exception:
                    pass
                try:
                    search_item.setScaleX(1.0)
                    search_item.setScaleY(1.0)
                except Exception:
                    pass
            try:
                search_item.setEnabled(not search_active)
            except Exception:
                pass
            try:
                search_item.setClickable(not search_active)
            except Exception:
                pass
            try:
                extra_shift = 0.0
                try:
                    downloads_item = self._get_field_value(fragment, "downloadsItem")
                except Exception:
                    downloads_item = None
                try:
                    if downloads_item is not None and self._is_view_visible(downloads_item):
                        extra_shift = float(AndroidUtilities.dp(4.0))
                except Exception:
                    extra_shift = 0.0
                search_item.setTranslationX(float(extra_shift))
            except Exception:
                pass
            try:
                lp = search_item.getLayoutParams()
                if lp is not None and hasattr(lp, "width"):
                    if int(getattr(lp, "width", 0) or 0) <= 0:
                        lp.width = int(AndroidUtilities.dp(48.0))
                    search_item.setLayoutParams(lp)
            except Exception:
                pass
        except Exception as e:
            self._dbg(f"ensure search right error: {e}")

    def _ensure_proxy_top_button(self, fragment):
        # Top proxy/search/download alignment logic is intentionally disabled.
        # Proxy action must stay in side menu only.
        return
        try:
            if fragment is None:
                return
            action_bar = None
            try:
                action_bar = self._get_field_value(fragment, "actionBar")
            except Exception:
                action_bar = None
            if action_bar is None or (not hasattr(action_bar, "addView")):
                return
            menu = None
            try:
                menu = self._get_field_value(action_bar, "menu")
            except Exception:
                menu = None
            search_item = None
            try:
                search_item = self._get_field_value(fragment, "searchItem")
            except Exception:
                search_item = None
            container = action_bar

            btn = self._find_tagged_child(action_bar, PROXY_TOP_BTN_TAG)
            if btn is None:
                context = fragment.getContext()
                if context is None:
                    return
                btn = ImageView(context)
                btn.setTag(PROXY_TOP_BTN_TAG)
                btn.setScaleType(ImageView.ScaleType.CENTER)
                try:
                    btn.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1))
                except Exception:
                    pass
                pad = int(AndroidUtilities.dp(12.0))
                btn.setPadding(pad, pad, pad, pad)
                size = int(AndroidUtilities.dp(48.0))
                lp = FrameLayout.LayoutParams(size, size)
                container.addView(btn, lp)
            else:
                try:
                    p = btn.getParent()
                except Exception:
                    p = None
                try:
                    if p is not None and p != container and hasattr(p, "removeView"):
                        p.removeView(btn)
                        size = int(AndroidUtilities.dp(48.0))
                        lp = FrameLayout.LayoutParams(size, size)
                        container.addView(btn, lp)
                except Exception:
                    pass

            key = self._obj_key(fragment)
            try:
                dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                dark = False
            proxy_tint = int(Color.WHITE if dark else Color.BLACK)
            try:
                btn.setColorFilter(proxy_tint)
            except Exception:
                pass
            try:
                btn_key = self._obj_key(btn)
                ic = self._proxy_icon.get(key)
                if ic is not None:
                    sig = self._obj_key(ic)
                    if int(self._proxy_btn_sig.get(btn_key, 0) or 0) != int(sig):
                        applied = False
                        try:
                            cs = ic.getConstantState()
                        except Exception:
                            cs = None
                        if cs is not None:
                            try:
                                dr = cs.newDrawable()
                                try:
                                    dr = dr.mutate()
                                except Exception:
                                    pass
                                btn.setImageDrawable(dr)
                                applied = True
                            except Exception:
                                applied = False
                        if not applied:
                            try:
                                btn.setImageDrawable(ic)
                            except Exception:
                                pass
                        self._proxy_btn_sig[btn_key] = int(sig)
                else:
                    dr_cls = getattr(jclass("org.telegram.messenger.R"), "drawable")
                    proxy_res = 0
                    for nm in (
                        "menu_proxy_24",
                        "menu_proxy",
                        "msg_proxy",
                        "outline_proxy_24",
                        "filled_proxy_24",
                        "outline_header_lock_24",
                    ):
                        try:
                            proxy_res = int(getattr(dr_cls, nm, 0) or 0)
                        except Exception:
                            proxy_res = 0
                        if proxy_res != 0:
                            break
                    if proxy_res != 0:
                        sig = -int(proxy_res)
                        if int(self._proxy_btn_sig.get(btn_key, 0) or 0) != sig:
                            btn.setImageResource(proxy_res)
                            self._proxy_btn_sig[btn_key] = sig
            except Exception:
                pass
            try:
                btn.setColorFilter(proxy_tint)
            except Exception:
                pass
            btn.setOnClickListener(OnClickListener(lambda _v, fr=fragment: self._trigger_special_action(fr, "proxy")))

            try:
                if hasattr(btn, "bringToFront"):
                    btn.bringToFront()
            except Exception:
                pass

            try:
                if search_item is not None:
                    s_ty = float(search_item.getTranslationY() or 0.0)
                else:
                    s_ty = float(AndroidUtilities.dp(3.0))
            except Exception:
                s_ty = 0.0
            try:
                btn.setTranslationY(float(s_ty) + float(AndroidUtilities.dp(12.0)))
            except Exception:
                pass
            search_visible = False
            downloads_visible = False
            passcode_visible = False
            d_item = None
            p_item = None
            s_shift = 0.0
            d_shift = 0.0
            p_shift = 0.0
            s_alpha = 0.0
            d_alpha = 0.0
            p_alpha = 0.0
            try:
                search_visible = self._is_menu_button_present(search_item)
            except Exception:
                search_visible = False
            try:
                d_item = self._get_field_value(fragment, "downloadsItem")
                downloads_visible = self._is_menu_button_present(d_item)
            except Exception:
                downloads_visible = False
            try:
                p_item = self._get_field_value(fragment, "passcodeItem")
                passcode_visible = self._is_menu_button_present(p_item)
            except Exception:
                passcode_visible = False
            search_in_menu = False
            try:
                if search_item is not None and menu is not None and hasattr(search_item, "getParent"):
                    search_in_menu = bool(search_item.getParent() == menu)
            except Exception:
                search_in_menu = False
            try:
                menu_icons = int(self._count_visible_menu_icons(menu))
            except Exception:
                menu_icons = 0
            # Fallback for builds where downloads/passcode fields are renamed or not exposed.
            if menu_icons > 0:
                known = 1 if search_in_menu else 0
                extras = int(menu_icons - known)
                if extras >= 1 and (not downloads_visible):
                    downloads_visible = True
                if extras >= 2 and (not passcode_visible):
                    passcode_visible = True
            prev_sig_hint = self._proxy_ui_state.get(key, None)
            search_sticky = False
            try:
                if search_item is not None:
                    s_alpha = float(search_item.getAlpha() or 0.0)
            except Exception:
                s_alpha = 0.0
            search_loose = False
            try:
                if search_item is not None and int(search_item.getVisibility() or 0) == View.VISIBLE:
                    sx = float(search_item.getScaleX() or 1.0)
                    sy = float(search_item.getScaleY() or 1.0)
                    if s_alpha > 0.02 and sx > 0.22 and sy > 0.22:
                        search_loose = True
            except Exception:
                search_loose = False
            if (not search_visible) and search_loose:
                if menu_icons >= 2:
                    search_visible = True
                    search_sticky = True
                else:
                    try:
                        if prev_sig_hint is not None and int(prev_sig_hint[0]) == 1 and menu_icons >= 1:
                            search_visible = True
                            search_sticky = True
                    except Exception:
                        pass
            bool_buttons_count = (
                (1 if search_visible else 0)
                + (1 if downloads_visible else 0)
                + (1 if passcode_visible else 0)
            )
            right_buttons_count = int(menu_icons)
            if search_visible and (not search_in_menu):
                right_buttons_count += 1
            if bool_buttons_count > right_buttons_count:
                right_buttons_count = int(bool_buttons_count)
            proxy_expected = 1
            try:
                if bool(self._is_search_overlay_visible(fragment)):
                    proxy_expected = 0
            except Exception:
                pass
            try:
                if bool(self._custom_drawer_open.get(key, False)) or float(self._custom_drawer_progress.get(key, 0.0) or 0.0) > 0.02:
                    proxy_expected = 0
            except Exception:
                pass
            effective_buttons = int(right_buttons_count + (1 if proxy_expected else 0))
            has_three_plus = bool(effective_buttons >= 3)
            passcode_layout = bool(passcode_visible)
            try:
                if search_item is not None:
                    s_alpha = float(search_item.getAlpha() or 0.0)
            except Exception:
                s_alpha = 0.0
            try:
                if d_item is not None:
                    d_alpha = float(d_item.getAlpha() or 0.0)
            except Exception:
                d_alpha = 0.0
            try:
                if p_item is not None:
                    p_alpha = float(p_item.getAlpha() or 0.0)
            except Exception:
                p_alpha = 0.0
            try:
                if search_item is not None:
                    # Search inside actionBar.menu is compacted via _apply_menu_icons_compaction.
                    # Keep field-level shift only for builds where search is outside the menu container.
                    if search_visible and (not search_in_menu):
                        if downloads_visible and passcode_layout:
                            s_shift = float(AndroidUtilities.dp(6.0))
                        elif downloads_visible:
                            s_shift = float(AndroidUtilities.dp(4.0))
                        elif passcode_layout:
                            s_shift = float(AndroidUtilities.dp(3.0))
                        else:
                            s_shift = 0.0
                    else:
                        s_shift = 0.0
                    search_item.setTranslationX(float(s_shift))
            except Exception:
                pass
            try:
                if d_item is not None:
                    # Avoid conflicting with menu child compaction.
                    d_shift = 0.0
                    d_item.setTranslationX(float(d_shift))
            except Exception:
                pass
            try:
                if p_item is not None:
                    p_shift = 0.0
                    p_item.setTranslationX(float(p_shift))
            except Exception:
                pass
            compacted_icons = int(self._apply_menu_icons_compaction(menu, has_three_plus))
            pair_fix = self._apply_menu_right_pair_gap_fix(menu, search_item, d_item, has_three_plus)
            try:
                pair_n = int(pair_fix.get("n", 0) or 0)
                pair_gap = float(pair_fix.get("gap", -1.0) or -1.0)
                pair_sec_tx = float(pair_fix.get("second_tx", 0.0) or 0.0)
                pair_right_tx = float(pair_fix.get("right_tx", 0.0) or 0.0)
                pair_mode = str(pair_fix.get("mode", "") or "")
                pair_sid = int(pair_fix.get("sid", 0) or 0)
                pair_did = int(pair_fix.get("did", 0) or 0)
                pair_scls = str(pair_fix.get("scls", "") or "")
                pair_dcls = str(pair_fix.get("dcls", "") or "")
                pair_sx = float(pair_fix.get("sx", 0.0) or 0.0)
                pair_dx = float(pair_fix.get("dx", 0.0) or 0.0)
                pair_sw = int(pair_fix.get("sw", 0) or 0)
                pair_dw = int(pair_fix.get("dw", 0) or 0)
                pair_delta = float(pair_fix.get("delta", -1.0) or -1.0)
                pair_base_delta = float(pair_fix.get("base_delta", -1.0) or -1.0)
                pair_target_delta = float(pair_fix.get("target_delta", -1.0) or -1.0)
                pair_move = float(pair_fix.get("move", 0.0) or 0.0)
                pair_ord = str(pair_fix.get("ord", "") or "")
                pair_icon_gap = float(pair_fix.get("icon_gap", -1.0) or -1.0)
                pair_icon_delta = float(pair_fix.get("icon_delta", -1.0) or -1.0)
                pair_icon_move = float(pair_fix.get("icon_move", 0.0) or 0.0)
                pair_icon_left_tx = float(pair_fix.get("icon_left_tx", 0.0) or 0.0)
                pair_icon_right_tx = float(pair_fix.get("icon_right_tx", 0.0) or 0.0)
                pair_icon_mode = str(pair_fix.get("icon_mode", "") or "")
                pair_icon_lw = int(pair_fix.get("icon_lw", 0) or 0)
                pair_icon_rw = int(pair_fix.get("icon_rw", 0) or 0)
                pair_icon_lew = int(pair_fix.get("icon_lew", 0) or 0)
                pair_icon_rew = int(pair_fix.get("icon_rew", 0) or 0)
            except Exception:
                pair_n = 0
                pair_gap = -1.0
                pair_sec_tx = 0.0
                pair_right_tx = 0.0
                pair_mode = ""
                pair_sid = 0
                pair_did = 0
                pair_scls = ""
                pair_dcls = ""
                pair_sx = 0.0
                pair_dx = 0.0
                pair_sw = 0
                pair_dw = 0
                pair_delta = -1.0
                pair_base_delta = -1.0
                pair_target_delta = -1.0
                pair_move = 0.0
                pair_ord = ""
                pair_icon_gap = -1.0
                pair_icon_delta = -1.0
                pair_icon_move = 0.0
                pair_icon_left_tx = 0.0
                pair_icon_right_tx = 0.0
                pair_icon_mode = ""
                pair_icon_lw = 0
                pair_icon_rw = 0
                pair_icon_lew = 0
                pair_icon_rew = 0
            ui_sig = (
                1 if search_visible else 0,
                1 if downloads_visible else 0,
                1 if passcode_layout else 0,
                int(right_buttons_count),
            )
            prev_sig = self._proxy_ui_state.get(key, None)
            state_changed = bool(prev_sig != ui_sig)
            if state_changed:
                self._proxy_ui_state[key] = ui_sig
                self._dbg_proxy(
                    fragment,
                    "state",
                    "proxy state changed: "
                    f"v={__version__} "
                    f"s={ui_sig[0]} d={ui_sig[1]} p={ui_sig[2]} "
                    f"icons={int(menu_icons)} total={int(right_buttons_count)} eff={int(effective_buttons)} compact={int(compacted_icons)} "
                    f"inMenu={1 if search_in_menu else 0} sticky={1 if search_sticky else 0} "
                    f"pair(n={pair_n},mode={pair_mode},ord={pair_ord},sid={pair_sid},did={pair_did},gap={pair_gap:.1f},delta={pair_delta:.1f},base={pair_base_delta:.1f},target={pair_target_delta:.1f},move={pair_move:.1f},sx={pair_sx:.1f},dx={pair_dx:.1f},sw={pair_sw},dw={pair_dw},tx2={pair_sec_tx:.1f},tx1={pair_right_tx:.1f},icon(mode={pair_icon_mode},gap={pair_icon_gap:.1f},delta={pair_icon_delta:.1f},move={pair_icon_move:.1f},ltx={pair_icon_left_tx:.1f},rtx={pair_icon_right_tx:.1f},lw={pair_icon_lw},rw={pair_icon_rw},lew={pair_icon_lew},rew={pair_icon_rew}),scls={pair_scls},dcls={pair_dcls}) "
                    f"alpha=({s_alpha:.2f},{d_alpha:.2f},{p_alpha:.2f}) "
                    f"shift=({s_shift:.1f},{d_shift:.1f},{p_shift:.1f})",
                    0,
                    ui_sig,
                )
                self._schedule_proxy_settle(fragment, "state")
            target_tx = float(self._compute_proxy_target_tx_state(search_visible, downloads_visible, passcode_layout))
            try:
                btn_key = self._obj_key(btn)
                prev_target = float(self._proxy_btn_x.get(btn_key, 9999.0) or 9999.0)
            except Exception:
                btn_key = 0
                prev_target = 9999.0
            try:
                cur_tx = float(btn.getTranslationX() or 0.0)
            except Exception:
                cur_tx = 0.0
            diff = float(target_tx - cur_tx)
            target_changed = bool(prev_target == 9999.0 or abs(prev_target - target_tx) > 0.35)
            apply_mode = "hold"
            try:
                if abs(diff) > 0.30:
                    if prev_target == 9999.0:
                        btn.setTranslationX(float(target_tx))
                        apply_mode = "init"
                    else:
                        now_ms = int(time.time() * 1000)
                        need_retarget = bool(state_changed or target_changed)
                        anim_inflight = False
                        try:
                            ast = self._proxy_anim_state.get(btn_key)
                            if ast is not None:
                                a_until = int(ast.get("until", 0) or 0)
                                a_target = float(ast.get("target", 9999.0) or 9999.0)
                                if now_ms < a_until and abs(a_target - target_tx) <= 0.35:
                                    anim_inflight = True
                        except Exception:
                            anim_inflight = False
                        if need_retarget:
                            dur = 90 if abs(diff) <= float(AndroidUtilities.dp(10.0)) else 130
                            if abs(diff) > float(AndroidUtilities.dp(22.0)):
                                dur = 155
                            try:
                                btn.animate().cancel()
                            except Exception:
                                pass
                            try:
                                btn.animate().translationX(float(target_tx)).setDuration(int(dur)).start()
                                if btn_key != 0:
                                    self._proxy_anim_state[btn_key] = {
                                        "target": float(target_tx),
                                        "until": int(now_ms + int(dur) + 42),
                                    }
                                apply_mode = f"anim{int(dur)}"
                            except Exception:
                                btn.setTranslationX(float(target_tx))
                                if btn_key != 0 and btn_key in self._proxy_anim_state:
                                    del self._proxy_anim_state[btn_key]
                                apply_mode = "anim_fallback"
                        elif anim_inflight:
                            apply_mode = "inflight"
                        else:
                            do_recover = False
                            try:
                                last_recover = int(self._proxy_recover_ts.get(btn_key, 0) or 0)
                            except Exception:
                                last_recover = 0
                            if abs(diff) > float(AndroidUtilities.dp(14.0)) and (now_ms - last_recover) >= 280:
                                do_recover = True
                            if do_recover:
                                dur = 110 if abs(diff) <= float(AndroidUtilities.dp(20.0)) else 145
                                try:
                                    btn.animate().cancel()
                                except Exception:
                                    pass
                                try:
                                    btn.animate().translationX(float(target_tx)).setDuration(int(dur)).start()
                                    if btn_key != 0:
                                        self._proxy_anim_state[btn_key] = {
                                            "target": float(target_tx),
                                            "until": int(now_ms + int(dur) + 42),
                                        }
                                        self._proxy_recover_ts[btn_key] = int(now_ms)
                                    apply_mode = f"recover{int(dur)}"
                                except Exception:
                                    btn.setTranslationX(float(target_tx))
                                    apply_mode = "recover_fallback"
                            else:
                                apply_mode = "follow"
                    if btn_key != 0:
                        self._proxy_btn_x[btn_key] = float(target_tx)
                elif prev_target == 9999.0:
                    btn.setTranslationX(float(target_tx))
                    if btn_key != 0:
                        self._proxy_btn_x[btn_key] = float(target_tx)
                    apply_mode = "init"
                else:
                    if btn_key != 0 and abs(diff) <= 0.75 and btn_key in self._proxy_anim_state:
                        del self._proxy_anim_state[btn_key]
                if target_changed and (not state_changed):
                    self._schedule_proxy_settle(fragment, "target")
            except Exception:
                pass
            if state_changed or target_changed or abs(diff) > 0.95:
                tx_state = (
                    int(ui_sig[0]),
                    int(ui_sig[1]),
                    int(ui_sig[2]),
                    int(ui_sig[3]),
                    int(round(cur_tx)),
                    int(round(target_tx)),
                    str(apply_mode),
                )
                self._dbg_proxy(
                    fragment,
                    "tx",
                    "proxy tx: "
                    f"v={__version__} "
                    f"cur={cur_tx:.1f} target={target_tx:.1f} diff={diff:.1f} mode={apply_mode} "
                    f"s={ui_sig[0]} d={ui_sig[1]} p={ui_sig[2]} "
                    f"icons={int(menu_icons)} total={int(right_buttons_count)} eff={int(effective_buttons)} compact={int(compacted_icons)} "
                    f"sticky={1 if search_sticky else 0} "
                    f"pair(mode={pair_mode},ord={pair_ord},sid={pair_sid},did={pair_did},gap={pair_gap:.1f},delta={pair_delta:.1f},base={pair_base_delta:.1f},target={pair_target_delta:.1f},move={pair_move:.1f},sx={pair_sx:.1f},dx={pair_dx:.1f},sw={pair_sw},dw={pair_dw},tx2={pair_sec_tx:.1f},tx1={pair_right_tx:.1f},icon(mode={pair_icon_mode},gap={pair_icon_gap:.1f},delta={pair_icon_delta:.1f},move={pair_icon_move:.1f},ltx={pair_icon_left_tx:.1f},rtx={pair_icon_right_tx:.1f},lw={pair_icon_lw},rw={pair_icon_rw},lew={pair_icon_lew},rew={pair_icon_rew})) "
                    f"shift=({s_shift:.1f},{d_shift:.1f},{p_shift:.1f})",
                    140,
                    tx_state,
                )
            try:
                blp = btn.getLayoutParams()
                if blp is not None:
                    slp = None
                    try:
                        if search_item is not None:
                            slp = search_item.getLayoutParams()
                    except Exception:
                        slp = None
                    if slp is not None and hasattr(slp, "topMargin") and hasattr(blp, "topMargin"):
                        blp.topMargin = int(getattr(slp, "topMargin", 0) or 0) + int(AndroidUtilities.dp(7.0))
                    elif hasattr(blp, "topMargin"):
                        blp.topMargin = int(AndroidUtilities.dp(14.0))
                    if slp is not None and hasattr(slp, "bottomMargin") and hasattr(blp, "bottomMargin"):
                        blp.bottomMargin = int(getattr(slp, "bottomMargin", 0) or 0)
                    elif hasattr(blp, "bottomMargin"):
                        blp.bottomMargin = 0
                    if hasattr(blp, "rightMargin"):
                        blp.rightMargin = int(AndroidUtilities.dp(5.0))
                    if hasattr(blp, "gravity"):
                        blp.gravity = int(Gravity.RIGHT | Gravity.CENTER_VERTICAL)
                    btn.setLayoutParams(blp)
            except Exception:
                pass

            visible = False
            drawer_hides_proxy = False
            drawer_progress = 0.0
            try:
                drawer_progress = float(self._custom_drawer_progress.get(key, 0.0) or 0.0)
            except Exception:
                drawer_progress = 0.0
            try:
                holder = self._custom_drawer_root.get(key)
            except Exception:
                holder = None
            try:
                holder_visible = bool(
                    holder is not None
                    and holder.getParent() is not None
                    and int(holder.getVisibility() or 0) == View.VISIBLE
                )
            except Exception:
                holder_visible = False
            try:
                drawer_hides_proxy = bool(holder_visible and (bool(self._custom_drawer_open.get(key, False)) or drawer_progress > 0.88))
            except Exception:
                drawer_hides_proxy = False
            search_active = False
            try:
                search_active = bool(self._is_search_overlay_visible(fragment))
            except Exception:
                search_active = False
            try:
                visible = (not drawer_hides_proxy) and (not search_active)
                btn.setVisibility(View.VISIBLE if visible else View.GONE)
                btn.setEnabled(visible)
                btn.setClickable(visible)
                if visible:
                    try:
                        if hasattr(btn, "bringToFront"):
                            btn.bringToFront()
                    except Exception:
                        pass
            except Exception:
                pass
            self._apply_proxy_title_right_margin(fragment, bool(visible), btn, action_bar, menu)
        except Exception as e:
            self._dbg(f"ensure proxy top button error: {e}")

    def _apply_proxy_title_right_margin(self, fragment, proxy_visible, proxy_btn=None, action_bar=None, menu=None):
        # Disabled together with top proxy button logic.
        return
        try:
            if fragment is None:
                return
            if action_bar is None:
                try:
                    action_bar = self._get_field_value(fragment, "actionBar")
                except Exception:
                    action_bar = None
            if action_bar is None:
                return
            key = self._obj_key(fragment)
            # Stable margin: lets TG apply native ellipsize without breaking ActionBar layout.
            target = 0
            if bool(proxy_visible):
                target = int(AndroidUtilities.dp(58.0))
            prev = int(self._title_margin_cache.get(key, -1) or -1)
            if prev == target:
                return
            try:
                action_bar.setTitleRightMargin(int(target))
                self._title_margin_cache[key] = int(target)
                self._dbg(f"actionbar title right margin -> {target}")
            except Exception:
                pass
        except Exception as e:
            self._dbg(f"apply proxy title margin error: {e}")

    def _find_leftmost_visible_menu_x(self, action_bar, menu):
        try:
            if action_bar is None or menu is None or (not hasattr(menu, "getChildCount")):
                return None
            try:
                mx = float(menu.getX() or 0.0)
            except Exception:
                mx = 0.0
            min_x = None
            cnt = int(menu.getChildCount() or 0)
            for i in range(cnt):
                c = menu.getChildAt(i)
                if c is None:
                    continue
                if not self._is_view_visible(c):
                    continue
                try:
                    cw = int(c.getWidth() or 0)
                except Exception:
                    cw = 0
                if cw > int(AndroidUtilities.dp(76.0)):
                    continue
                try:
                    cx = mx + float(c.getX() or 0.0) + float(c.getTranslationX() or 0.0)
                except Exception:
                    continue
                if min_x is None or cx < min_x:
                    min_x = cx
            return min_x
        except Exception:
            return None

    def _get_view_left_in_actionbar(self, action_bar, view):
        try:
            if action_bar is None or view is None:
                return None
            if not self._is_view_visible(view):
                return None
            a_pos = [0, 0]
            v_pos = [0, 0]
            try:
                action_bar.getLocationOnScreen(a_pos)
                view.getLocationOnScreen(v_pos)
                return float(v_pos[0] - a_pos[0])
            except Exception:
                pass
            try:
                return float(view.getX() or 0.0) + float(view.getTranslationX() or 0.0)
            except Exception:
                return None
        except Exception:
            return None

    def _count_visible_menu_icons(self, menu):
        try:
            if menu is None or (not hasattr(menu, "getChildCount")):
                return 0
            cnt = int(menu.getChildCount() or 0)
            icons = 0
            for i in range(cnt):
                c = menu.getChildAt(i)
                if c is None or (not self._is_view_visible(c)):
                    continue
                try:
                    cw = int(c.getWidth() or 0)
                except Exception:
                    cw = 0
                if cw <= int(AndroidUtilities.dp(76.0)):
                    icons += 1
            return int(icons)
        except Exception:
            return 0

    def _apply_menu_icons_compaction(self, menu, compact):
        try:
            if menu is None or (not hasattr(menu, "getChildCount")):
                return 0
            cnt = int(menu.getChildCount() or 0)
            icons = []
            for i in range(cnt):
                c = menu.getChildAt(i)
                if c is None or (not self._is_view_visible(c)):
                    continue
                try:
                    cw = int(c.getWidth() or 0)
                except Exception:
                    cw = 0
                if cw > int(AndroidUtilities.dp(76.0)):
                    continue
                try:
                    x = float(c.getX() or 0.0) + float(c.getTranslationX() or 0.0)
                except Exception:
                    x = float(i)
                icons.append((float(x), c))
            if not icons:
                return 0
            icons.sort(key=lambda t: t[0])
            n = int(len(icons))
            # Keep generic compaction only for 3+ native icons.
            # For 2 native icons (downloads+search) use targeted pair fix below.
            use_compact = bool(compact) and n >= 3
            if use_compact:
                step_dp = 10.0
                step = float(AndroidUtilities.dp(step_dp))
            else:
                step = 0.0
            center = float(n - 1) * 0.5
            for idx, (_x, v) in enumerate(icons):
                key = self._obj_key(v)
                target = (center - float(idx)) * step
                try:
                    cur = float(v.getTranslationX() or 0.0)
                except Exception:
                    cur = 0.0
                new_tx = float(target)
                if abs(new_tx - cur) > 0.2:
                    try:
                        v.setTranslationX(float(new_tx))
                    except Exception:
                        pass
                self._menu_icon_compact_off[key] = float(target)
            return n
        except Exception:
            return 0

    def _find_actionbar_menu_icon_view(self, menu_item):
        try:
            if menu_item is None:
                return None
            max_side = int(AndroidUtilities.dp(56.0))
            min_side = int(AndroidUtilities.dp(8.0))
            best = None
            best_area = 0
            fallback = None

            def _consider(v):
                nonlocal best
                nonlocal best_area
                nonlocal fallback
                if v is None:
                    return
                if fallback is None:
                    fallback = v
                try:
                    vv = int(v.getVisibility() or 0)
                    if vv != View.VISIBLE:
                        return
                except Exception:
                    pass
                try:
                    vw = int(v.getWidth() or 0)
                except Exception:
                    vw = 0
                try:
                    vh = int(v.getHeight() or 0)
                except Exception:
                    vh = 0
                if vw <= 0 or vh <= 0:
                    return
                if vw < min_side or vh < min_side:
                    return
                if vw > max_side or vh > max_side:
                    return
                area = int(vw * vh)
                if best is None or area < best_area:
                    best = v
                    best_area = area

            def _scan(node, depth):
                if node is None or depth < 0:
                    return
                if isinstance(node, ImageView):
                    _consider(node)
                if depth == 0:
                    return
                try:
                    if hasattr(node, "getChildCount"):
                        cnt = int(node.getChildCount() or 0)
                        for i in range(cnt):
                            c = node.getChildAt(i)
                            if c is None:
                                continue
                            _scan(c, depth - 1)
                except Exception:
                    pass

            try:
                if hasattr(menu_item, "getIconView"):
                    icon = menu_item.getIconView()
                    _consider(icon)
            except Exception:
                pass
            for field_name in ("iconView", "imageView", "icon"):
                try:
                    icon = self._get_field_value(menu_item, field_name)
                except Exception:
                    icon = None
                _consider(icon)
                _scan(icon, 2)
            _scan(menu_item, 3)
            if best is not None:
                return best
            return fallback
        except Exception:
            return None

    def _apply_menu_right_pair_gap_fix(self, menu, search_item=None, downloads_item=None, enabled=False):
        try:
            if menu is None or (not hasattr(menu, "getChildCount")):
                return {
                    "n": 0,
                    "gap": -1.0,
                    "delta": -1.0,
                    "base_delta": -1.0,
                    "target_delta": -1.0,
                    "move": 0.0,
                    "second_tx": 0.0,
                    "right_tx": 0.0,
                    "mode": "none",
                    "ord": "",
                    "sid": 0,
                    "did": 0,
                    "scls": "",
                    "dcls": "",
                    "sx": 0.0,
                    "dx": 0.0,
                    "sw": 0,
                    "dw": 0,
                    "icon_gap": -1.0,
                    "icon_delta": -1.0,
                    "icon_move": 0.0,
                    "icon_left_tx": 0.0,
                    "icon_right_tx": 0.0,
                    "icon_mode": "none",
                    "icon_lw": 0,
                    "icon_rw": 0,
                    "icon_lew": 0,
                    "icon_rew": 0,
                }
            cnt = int(menu.getChildCount() or 0)
            icons = []
            for i in range(cnt):
                c = menu.getChildAt(i)
                if c is None or (not self._is_view_visible(c)):
                    continue
                try:
                    cw = int(c.getWidth() or 0)
                except Exception:
                    cw = 0
                if cw > int(AndroidUtilities.dp(76.0)):
                    continue
                try:
                    cx = float(c.getX() or 0.0) + float(c.getTranslationX() or 0.0)
                except Exception:
                    cx = float(i)
                icons.append((float(cx), c))
            if not icons:
                return {
                    "n": 0,
                    "gap": -1.0,
                    "delta": -1.0,
                    "base_delta": -1.0,
                    "target_delta": -1.0,
                    "move": 0.0,
                    "second_tx": 0.0,
                    "right_tx": 0.0,
                    "mode": "none",
                    "ord": "",
                    "sid": 0,
                    "did": 0,
                    "scls": "",
                    "dcls": "",
                    "sx": 0.0,
                    "dx": 0.0,
                    "sw": 0,
                    "dw": 0,
                    "icon_gap": -1.0,
                    "icon_delta": -1.0,
                    "icon_move": 0.0,
                    "icon_left_tx": 0.0,
                    "icon_right_tx": 0.0,
                    "icon_mode": "none",
                    "icon_lw": 0,
                    "icon_rw": 0,
                    "icon_lew": 0,
                    "icon_rew": 0,
                }
            icons.sort(key=lambda t: t[0])
            n = int(len(icons))
            # Helper: remove previously applied pair offset while preserving any external TG shift.
            def _strip_prev(v):
                k = int(self._obj_key(v) or 0)
                prev = float(self._menu_pair_off.get(k, 0.0) or 0.0)
                try:
                    cur_tx = float(v.getTranslationX() or 0.0)
                except Exception:
                    cur_tx = 0.0
                if abs(prev) > 0.2:
                    try:
                        v.setTranslationX(float(cur_tx - prev))
                    except Exception:
                        pass
                self._menu_pair_off[k] = 0.0
                return k

            if n < 2:
                only = icons[-1][1]
                _strip_prev(only)
                return {
                    "n": n,
                    "gap": -1.0,
                    "delta": -1.0,
                    "base_delta": -1.0,
                    "target_delta": -1.0,
                    "move": 0.0,
                    "second_tx": 0.0,
                    "right_tx": 0.0,
                    "mode": "single",
                    "ord": "",
                    "sid": 0,
                    "did": 0,
                    "scls": "",
                    "dcls": "",
                    "sx": 0.0,
                    "dx": 0.0,
                    "sw": 0,
                    "dw": 0,
                    "icon_gap": -1.0,
                    "icon_delta": -1.0,
                    "icon_move": 0.0,
                    "icon_left_tx": 0.0,
                    "icon_right_tx": 0.0,
                    "icon_mode": "single",
                    "icon_lw": 0,
                    "icon_rw": 0,
                    "icon_lew": 0,
                    "icon_rew": 0,
                }

            # Select pair: prefer explicit fields, fallback to two rightmost menu icons.
            mode = "menu"
            left = icons[-2][1]
            right = icons[-1][1]
            ord_hint = "menu"
            try:
                if self._is_view_visible(search_item) and self._is_view_visible(downloads_item):
                    p1 = None
                    p2 = None
                    try:
                        p1 = search_item.getParent()
                    except Exception:
                        p1 = None
                    try:
                        p2 = downloads_item.getParent()
                    except Exception:
                        p2 = None
                    if p1 is not None and p1 == p2:
                        mode = "fields"
                        try:
                            sx0 = float(search_item.getX() or 0.0)
                        except Exception:
                            sx0 = 0.0
                        try:
                            dx0 = float(downloads_item.getX() or 0.0)
                        except Exception:
                            dx0 = 0.0
                        if sx0 <= dx0:
                            left = search_item
                            right = downloads_item
                            ord_hint = "search-left"
                        else:
                            left = downloads_item
                            right = search_item
                            ord_hint = "search-right"
            except Exception:
                mode = "menu"

            icon_gap = -1.0
            icon_delta = -1.0
            icon_move = 0.0
            icon_left_tx = 0.0
            icon_right_tx = 0.0
            icon_mode = "none"
            icon_lw = 0
            icon_rw = 0
            icon_lew = 0
            icon_rew = 0

            # Clear old offsets from non-pair icons.
            pair_ids = set([int(self._obj_key(left) or 0), int(self._obj_key(right) or 0)])
            for _x, v in icons:
                vid = int(self._obj_key(v) or 0)
                if vid in pair_ids:
                    continue
                prev = float(self._menu_pair_off.get(vid, 0.0) or 0.0)
                if abs(prev) > 0.2:
                    try:
                        cur_tx = float(v.getTranslationX() or 0.0)
                        v.setTranslationX(float(cur_tx - prev))
                    except Exception:
                        pass
                self._menu_pair_off[vid] = 0.0
                try:
                    icon_v = self._find_actionbar_menu_icon_view(v)
                except Exception:
                    icon_v = None
                if icon_v is not None:
                    ik = int(self._obj_key(icon_v) or 0)
                    i_prev = float(self._menu_pair_icon_off.get(ik, 0.0) or 0.0)
                    if abs(i_prev) > 0.2:
                        try:
                            i_cur = float(icon_v.getTranslationX() or 0.0)
                            icon_v.setTranslationX(float(i_cur - i_prev))
                        except Exception:
                            pass
                    self._menu_pair_icon_off[ik] = 0.0

            l_key = int(self._obj_key(left) or 0)
            r_key = int(self._obj_key(right) or 0)
            l_prev = float(self._menu_pair_off.get(l_key, 0.0) or 0.0)
            r_prev = float(self._menu_pair_off.get(r_key, 0.0) or 0.0)
            try:
                l_icon = self._find_actionbar_menu_icon_view(left)
            except Exception:
                l_icon = None
            try:
                r_icon = self._find_actionbar_menu_icon_view(right)
            except Exception:
                r_icon = None
            l_icon_id = int(self._obj_key(l_icon) or 0) if l_icon is not None else 0
            r_icon_id = int(self._obj_key(r_icon) or 0) if r_icon is not None else 0
            l_icon_prev = float(self._menu_pair_icon_off.get(l_icon_id, 0.0) or 0.0) if l_icon_id != 0 else 0.0
            r_icon_prev = float(self._menu_pair_icon_off.get(r_icon_id, 0.0) or 0.0) if r_icon_id != 0 else 0.0
            l_icon_base_tx = 0.0
            r_icon_base_tx = 0.0
            if l_icon is not None:
                try:
                    l_icon_cur_tx = float(l_icon.getTranslationX() or 0.0)
                except Exception:
                    l_icon_cur_tx = 0.0
                l_icon_base_tx = float(l_icon_cur_tx - l_icon_prev)
                if abs(l_icon_prev) > 0.2:
                    try:
                        l_icon.setTranslationX(float(l_icon_base_tx))
                    except Exception:
                        pass
                self._menu_pair_icon_off[l_icon_id] = 0.0
            if r_icon is not None:
                try:
                    r_icon_cur_tx = float(r_icon.getTranslationX() or 0.0)
                except Exception:
                    r_icon_cur_tx = 0.0
                r_icon_base_tx = float(r_icon_cur_tx - r_icon_prev)
                if abs(r_icon_prev) > 0.2:
                    try:
                        r_icon.setTranslationX(float(r_icon_base_tx))
                    except Exception:
                        pass
                self._menu_pair_icon_off[r_icon_id] = 0.0
            try:
                l_x_cur = float(left.getX() or 0.0)
            except Exception:
                l_x_cur = 0.0
            try:
                r_x_cur = float(right.getX() or 0.0)
            except Exception:
                r_x_cur = 0.0
            # Baseline positions after removing our previous pair offsets.
            l_base_x = float(l_x_cur - l_prev)
            r_base_x = float(r_x_cur - r_prev)
            base_delta = float(r_base_x - l_base_x)
            if base_delta < 0.0:
                # Safety: keep left<right ordering.
                tmp = left
                left = right
                right = tmp
                tmp_key = l_key
                l_key = r_key
                r_key = tmp_key
                tmp_prev = l_prev
                l_prev = r_prev
                r_prev = tmp_prev
                tmp_icon = l_icon
                l_icon = r_icon
                r_icon = tmp_icon
                tmp_icon_id = l_icon_id
                l_icon_id = r_icon_id
                r_icon_id = tmp_icon_id
                tmp_icon_base_tx = l_icon_base_tx
                l_icon_base_tx = r_icon_base_tx
                r_icon_base_tx = tmp_icon_base_tx
                l_base_x, r_base_x = r_base_x, l_base_x
                base_delta = float(r_base_x - l_base_x)
                if mode == "fields":
                    ord_hint = "search-right" if ord_hint == "search-left" else "search-left"

            if base_delta <= 0.0:
                base_delta = 1.0
            half_sum = 0.0
            try:
                half_sum = float(int(left.getWidth() or 0) + int(right.getWidth() or 0)) * 0.5
            except Exception:
                half_sum = 0.0
            base_gap = float(base_delta - half_sum)
            if bool(enabled):
                # Keep a positive, small edge gap between search/downloads; never overlap.
                target_gap = float(AndroidUtilities.dp(4.0))
                if target_gap < 0.0:
                    target_gap = 0.0
                if base_gap < target_gap:
                    target_gap = max(0.0, base_gap)
                target_delta = float(half_sum + target_gap)
                if target_delta > base_delta:
                    target_delta = float(base_delta)
                move = float(max(0.0, (base_delta - target_delta) * 0.5))
            else:
                target_delta = float(base_delta)
                move = 0.0

            l_target_off = float(move)
            r_target_off = -float(move)
            if bool(enabled) and str(mode) == "fields" and move < float(AndroidUtilities.dp(0.15)):
                # Fallback squeeze: some builds keep fixed 83dp slots and ignore pair delta math.
                # Apply a small deterministic convergence so downloads/search visually get closer.
                hard_squeeze = float(AndroidUtilities.dp(3.0))
                l_target_off += hard_squeeze
                r_target_off -= hard_squeeze
                move = float(move + hard_squeeze)
                target_delta = float(max(1.0, base_delta - (hard_squeeze * 2.0)))
            try:
                l_tx_cur = float(left.getTranslationX() or 0.0)
            except Exception:
                l_tx_cur = 0.0
            try:
                r_tx_cur = float(right.getTranslationX() or 0.0)
            except Exception:
                r_tx_cur = 0.0
            l_new_tx = float(l_tx_cur - l_prev + l_target_off)
            r_new_tx = float(r_tx_cur - r_prev + r_target_off)
            try:
                left.setTranslationX(float(l_new_tx))
            except Exception:
                pass
            try:
                right.setTranslationX(float(r_new_tx))
            except Exception:
                pass
            self._menu_pair_off[l_key] = float(l_target_off)
            self._menu_pair_off[r_key] = float(r_target_off)

            # On some builds search/downloads containers are already tightly packed.
            # Reduce visual gap by shifting inner icon views toward each other.
            if l_icon is not None and r_icon is not None:
                try:
                    l_ix = float(l_icon.getX() or 0.0)
                except Exception:
                    l_ix = 0.0
                try:
                    r_ix = float(r_icon.getX() or 0.0)
                except Exception:
                    r_ix = 0.0
                try:
                    l_iw_raw = int(l_icon.getWidth() or 0)
                except Exception:
                    l_iw_raw = 0
                try:
                    r_iw_raw = int(r_icon.getWidth() or 0)
                except Exception:
                    r_iw_raw = 0
                l_iw = int(l_iw_raw)
                r_iw = int(r_iw_raw)
                max_icon_side = int(AndroidUtilities.dp(56.0))
                min_icon_side = int(AndroidUtilities.dp(8.0))
                if l_iw < min_icon_side or l_iw > max_icon_side:
                    l_iw = int(AndroidUtilities.dp(24.0))
                if r_iw < min_icon_side or r_iw > max_icon_side:
                    r_iw = int(AndroidUtilities.dp(24.0))
                icon_lw = int(l_iw_raw)
                icon_rw = int(r_iw_raw)
                icon_lew = int(l_iw)
                icon_rew = int(r_iw)
                try:
                    l_item_x = float(left.getX() or 0.0)
                except Exception:
                    l_item_x = float(l_base_x)
                try:
                    r_item_x = float(right.getX() or 0.0)
                except Exception:
                    r_item_x = float(r_base_x)
                l_center = float(
                    l_item_x + l_target_off + l_ix + l_icon_base_tx + (float(l_iw) * 0.5)
                )
                r_center = float(
                    r_item_x + r_target_off + r_ix + r_icon_base_tx + (float(r_iw) * 0.5)
                )
                icon_delta = float(r_center - l_center)
                if icon_delta < 0.0:
                    icon_delta = float(-icon_delta)
                icon_half_sum = float(l_iw + r_iw) * 0.5
                icon_gap = float(icon_delta - icon_half_sum)
                if bool(enabled) and str(mode) == "fields":
                    icon_mode = "fields"
                    target_icon_gap = float(AndroidUtilities.dp(8.0))
                    if target_icon_gap < 0.0:
                        target_icon_gap = 0.0
                    if icon_gap > target_icon_gap:
                        icon_move = float((icon_gap - target_icon_gap) * 0.5)
                        max_icon_move = float(AndroidUtilities.dp(24.0))
                        if icon_move > max_icon_move:
                            icon_move = max_icon_move
                    else:
                        icon_move = 0.0
                else:
                    icon_mode = "off"
                    icon_move = 0.0
                icon_left_tx = float(icon_move)
                icon_right_tx = -float(icon_move)
                l_icon_new_tx = float(l_icon_base_tx + icon_left_tx)
                r_icon_new_tx = float(r_icon_base_tx + icon_right_tx)
                try:
                    l_icon.setTranslationX(float(l_icon_new_tx))
                except Exception:
                    pass
                try:
                    r_icon.setTranslationX(float(r_icon_new_tx))
                except Exception:
                    pass
                if l_icon_id != 0:
                    self._menu_pair_icon_off[l_icon_id] = float(icon_left_tx)
                if r_icon_id != 0:
                    self._menu_pair_icon_off[r_icon_id] = float(icon_right_tx)
                if icon_move <= 0.0:
                    icon_left_tx = 0.0
                    icon_right_tx = 0.0
            else:
                if l_icon_id != 0:
                    self._menu_pair_icon_off[l_icon_id] = 0.0
                if r_icon_id != 0:
                    self._menu_pair_icon_off[r_icon_id] = 0.0

            try:
                sx = float(left.getX() or 0.0)
            except Exception:
                sx = float(l_base_x + l_target_off)
            try:
                dx = float(right.getX() or 0.0)
            except Exception:
                dx = float(r_base_x + r_target_off)
            try:
                sw = int(left.getWidth() or 0)
            except Exception:
                sw = 0
            try:
                dw = int(right.getWidth() or 0)
            except Exception:
                dw = 0
            try:
                gap = float(dx - (sx + float(sw)))
            except Exception:
                gap = -1.0
            try:
                center_delta = float((dx + (float(dw) * 0.5)) - (sx + (float(sw) * 0.5)))
            except Exception:
                center_delta = float(dx - sx)
            try:
                scls = str(left.getClass().getName() or "")
            except Exception:
                scls = ""
            try:
                dcls = str(right.getClass().getName() or "")
            except Exception:
                dcls = ""
            return {
                "n": n,
                "gap": float(gap),
                "delta": float(center_delta),
                "base_delta": float(base_delta),
                "target_delta": float(target_delta),
                "move": float(move),
                "second_tx": float(l_target_off),
                "right_tx": float(r_target_off),
                "mode": str(mode),
                "ord": str(ord_hint),
                "sid": int(l_key),
                "did": int(r_key),
                "scls": str(scls),
                "dcls": str(dcls),
                "sx": float(sx),
                "dx": float(dx),
                "sw": int(sw),
                "dw": int(dw),
                "icon_gap": float(icon_gap),
                "icon_delta": float(icon_delta),
                "icon_move": float(icon_move),
                "icon_left_tx": float(icon_left_tx),
                "icon_right_tx": float(icon_right_tx),
                "icon_mode": str(icon_mode),
                "icon_lw": int(icon_lw),
                "icon_rw": int(icon_rw),
                "icon_lew": int(icon_lew),
                "icon_rew": int(icon_rew),
            }
        except Exception:
            return {
                "n": 0,
                "gap": -1.0,
                "delta": -1.0,
                "base_delta": -1.0,
                "target_delta": -1.0,
                "move": 0.0,
                "second_tx": 0.0,
                "right_tx": 0.0,
                "mode": "err",
                "ord": "",
                "sid": 0,
                "did": 0,
                "scls": "",
                "dcls": "",
                "sx": 0.0,
                "dx": 0.0,
                "sw": 0,
                "dw": 0,
                "icon_gap": -1.0,
                "icon_delta": -1.0,
                "icon_move": 0.0,
                "icon_left_tx": 0.0,
                "icon_right_tx": 0.0,
                "icon_mode": "err",
                "icon_lw": 0,
                "icon_rw": 0,
                "icon_lew": 0,
                "icon_rew": 0,
            }

    def _compute_proxy_target_tx_state(self, search_visible, downloads_visible, passcode_visible):
        try:
            # Base from v1.1.7: stable right (-2) and left-of-search (-38),
            # extended for 2/3 right buttons to avoid overlaps.
            if bool(search_visible):
                if bool(downloads_visible) and bool(passcode_visible):
                    return -float(AndroidUtilities.dp(72.0))
                if bool(downloads_visible) or bool(passcode_visible):
                    return -float(AndroidUtilities.dp(54.0))
                return -float(AndroidUtilities.dp(36.0))
            if bool(downloads_visible) and bool(passcode_visible):
                return -float(AndroidUtilities.dp(50.0))
            if bool(downloads_visible) or bool(passcode_visible):
                return -float(AndroidUtilities.dp(32.0))
            return -float(AndroidUtilities.dp(2.0))
        except Exception:
            return -float(AndroidUtilities.dp(2.0))

    def _compute_proxy_target_tx(self, action_bar, btn, menu, search_item, downloads_item=None, passcode_item=None):
        try:
            if action_bar is None or btn is None:
                return 0.0
            lp = None
            try:
                lp = btn.getLayoutParams()
            except Exception:
                lp = None
            right_margin = float(getattr(lp, "rightMargin", int(AndroidUtilities.dp(5.0))) or int(AndroidUtilities.dp(5.0)))
            try:
                aw = float(action_bar.getWidth() or 0.0)
            except Exception:
                aw = 0.0
            try:
                bw = float(btn.getWidth() or 0.0)
            except Exception:
                bw = 0.0
            if bw <= 1.0:
                bw = float(AndroidUtilities.dp(48.0))
            cand_icons = 0
            for candidate in (search_item, downloads_item, passcode_item):
                try:
                    if self._is_view_visible(candidate):
                        cand_icons += 1
                except Exception:
                    pass
            menu_icons = int(self._count_visible_menu_icons(menu))
            right_icons = int(max(cand_icons, menu_icons))
            if right_icons <= 0:
                return 0.0
            base_left = None
            try:
                base_left = float(btn.getX() or 0.0) - float(btn.getTranslationX() or 0.0)
            except Exception:
                base_left = None
            if base_left is None or base_left <= 1.0:
                base_left = aw - right_margin - bw
            anchor_left = None
            for candidate in (search_item, downloads_item, passcode_item):
                left = self._get_view_left_in_actionbar(action_bar, candidate)
                if left is None:
                    continue
                if anchor_left is None or float(left) < float(anchor_left):
                    anchor_left = float(left)
            menu_left = self._find_leftmost_visible_menu_x(action_bar, menu)
            if menu_left is not None and (anchor_left is None or float(menu_left) < float(anchor_left)):
                anchor_left = float(menu_left)
            if anchor_left is None:
                try:
                    if search_item is not None and self._is_view_visible(search_item):
                        anchor_left = self._get_view_left_in_actionbar(action_bar, search_item)
                except Exception:
                    anchor_left = None
            if anchor_left is None:
                return 0.0
            if right_icons >= 3:
                gap_dp = 8.0
                max_shift = float(AndroidUtilities.dp(72.0))
            elif right_icons == 2:
                gap_dp = 9.0
                max_shift = float(AndroidUtilities.dp(46.0))
            else:
                gap_dp = 11.0
                max_shift = float(AndroidUtilities.dp(28.0))
            desired_left = float(anchor_left) - bw - float(AndroidUtilities.dp(gap_dp))
            min_left = float(AndroidUtilities.dp(56.0))
            if desired_left < min_left:
                desired_left = min_left
            tx = desired_left - base_left
            if tx > 0.0:
                tx = 0.0
            if tx < -max_shift:
                tx = -max_shift
            return float(tx)
        except Exception:
            return 0.0

    def _schedule_proxy_settle(self, fragment, reason=""):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            token = int(time.time() * 1000)
            self._proxy_settle_token[key] = token
            delays = (28, 110, 240, 430)
            self._dbg_proxy(
                fragment,
                "settle_sched",
                f"proxy settle schedule: token={token} reason={str(reason or '-')}"
                f" delays={','.join([str(int(d)) for d in delays])}",
                40,
                (int(token), str(reason or "")),
            )
            total = len(delays)
            for idx, delay in enumerate(delays):
                run_on_ui_thread(
                    lambda fr=fragment, k=key, t=token, st=(idx + 1), tt=total, rs=str(reason or ""): self._proxy_settle_tick(fr, k, t, st, tt, rs),
                    int(delay),
                )
        except Exception:
            pass

    def _proxy_settle_tick(self, fragment, key, token, stage=0, total=0, reason=""):
        try:
            if fragment is None:
                return
            cur = int(self._proxy_settle_token.get(key, 0) or 0)
            if cur != int(token):
                return
            if int(stage) == 1 or int(stage) == int(total):
                self._dbg_proxy(
                    fragment,
                    "settle_tick",
                    f"proxy settle tick: {int(stage)}/{int(total)} token={int(token)} reason={str(reason or '-')}",
                    40,
                    (int(token), int(stage), int(total), str(reason or "")),
                )
            self._ensure_proxy_top_button(fragment)
        except Exception:
            pass

    def _trigger_theme_toggle(self, fragment, anchor_view=None):
        try:
            if fragment is None:
                return
            try:
                cls = fragment.getClass()
                fld = cls.getDeclaredField("switchingTheme")
                fld.setAccessible(True)
                is_switching = False
                try:
                    is_switching = bool(fld.getBoolean(None))
                except Exception:
                    try:
                        is_switching = bool(fld.getBoolean(fragment))
                    except Exception:
                        is_switching = False
                if is_switching:
                    return
            except Exception:
                pass

            sp = None
            try:
                sp = ApplicationLoader.applicationContext.getSharedPreferences("themeconfig", 0)
            except Exception:
                sp = None
            day_key = "Blue"
            dark_key = "Dark Blue"
            if sp is not None:
                try:
                    day_key = str(sp.getString("lastDayTheme", "Blue") or "Blue")
                except Exception:
                    day_key = "Blue"
                try:
                    dark_key = str(sp.getString("lastDarkTheme", "Dark Blue") or "Dark Blue")
                except Exception:
                    dark_key = "Dark Blue"
            day_theme = None
            dark_theme = None
            try:
                day_theme = Theme.getTheme(day_key)
            except Exception:
                day_theme = None
            try:
                if day_theme is None or bool(day_theme.isDark()):
                    day_theme = Theme.getTheme("Blue")
            except Exception:
                pass
            try:
                dark_theme = Theme.getTheme(dark_key)
            except Exception:
                dark_theme = None
            try:
                if dark_theme is None or (not bool(dark_theme.isDark())):
                    dark_theme = Theme.getTheme("Dark Blue")
            except Exception:
                pass

            is_dark = False
            try:
                is_dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark = False
            go_dark = (not is_dark)
            target_theme = dark_theme if go_dark else day_theme
            if target_theme is None:
                self._run_special_from_original_menu(fragment, "theme")
                return

            anchor = anchor_view
            if anchor is None:
                try:
                    options_item = self._get_field_value(fragment, "optionsItem")
                except Exception:
                    options_item = None
                try:
                    if options_item is not None and hasattr(options_item, "getIconView"):
                        anchor = options_item.getIconView()
                    else:
                        anchor = options_item
                except Exception:
                    anchor = options_item
            center = None
            try:
                if anchor is not None:
                    center = [0, 0]
                    anchor.getLocationInWindow(center)
                    center[0] = int(center[0]) + int((int(anchor.getMeasuredWidth() or 0)) / 2)
                    center[1] = int(center[1]) + int((int(anchor.getMeasuredHeight() or 0)) / 2)
            except Exception:
                center = None

            try:
                post_theme = getattr(NotificationCenter.getGlobalInstance(), "lambda$postNotificationNameOnUIThread$1", None)
                if post_theme is None:
                    raise RuntimeError("needSetDayNightTheme notifier not found")
                post_theme(
                    NotificationCenter.needSetDayNightTheme,
                    target_theme,
                    False,
                    center,
                    -1,
                    bool(go_dark),
                    anchor,
                )
                self._dbg(f"theme toggle from custom anchor: dark={go_dark} anchor={bool(anchor is not None)}")
            except Exception as e:
                self._dbg(f"theme toggle notify failed: {e}")
                self._run_special_from_original_menu(fragment, "theme")
                return

            try:
                Theme.turnOffAutoNight(fragment)
            except Exception:
                pass
            run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 40)
            run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 180)
            run_on_ui_thread(lambda fr=fragment: self._refresh_custom_drawer_theme(fr), 420)
            run_on_ui_thread(lambda fr=fragment: self._update_dialogs_controls(fr, True), 120)
            run_on_ui_thread(lambda fr=fragment: self._update_dialogs_controls(fr, True), 280)
        except Exception as e:
            self._dbg(f"trigger theme toggle error: {e}")

    def _trigger_special_action(self, fragment, kind, attempt=0):
        try:
            if fragment is None:
                return
            key = self._obj_key(fragment)
            row = None
            if kind == "theme":
                row = self._theme_row.get(key)
            elif kind == "proxy":
                row = self._proxy_row.get(key)

            if row is not None:
                try:
                    if self._invoke_row_click(row):
                        return
                except Exception:
                    pass

            if self._is_custom_drawer_enabled():
                self._run_special_from_original_menu(fragment, kind)
                return

            drawer = self._active_drawer.get(key)
            if drawer is None and attempt == 0:
                self._open_main_menu(fragment)

            if attempt < 4:
                run_on_ui_thread(
                    lambda fr=fragment, kd=kind, a=attempt + 1: self._trigger_special_action(fr, kd, a),
                    120 + (attempt * 80),
                )
        except Exception as e:
            self._dbg(f"trigger special action error: {e}")

    def _invoke_row_click(self, row):
        try:
            if row is None:
                return False
            try:
                if hasattr(row, "callOnClick") and bool(row.callOnClick()):
                    return True
            except Exception:
                pass
            try:
                row.performClick()
                return True
            except Exception:
                return False
        except Exception:
            return False

    def _restyle_dialogs_search_ui(self, fragment):
        try:
            if fragment is None:
                return
            # Search UI handling was moved to separate plugin.
            self._set_left_button_visible(fragment, True)
        except Exception as e:
            self._dbg(f"restyle search ui error: {e}")

