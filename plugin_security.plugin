    def __init__(self):
        self.language = Locale.getDefault().getLanguage()
        self.language = self.language if self.language in self.strings else "en"

    def get(self, key: str) -> str:
        return self.strings[self.language].get(key, self.strings["en"].get(key, key))

texts = TextCatalog()

class GeminiClient:
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            "Content-Type": "application/json",
            "User-Agent": f"exteraPlugin/{__id__}/{__version__}"
        })

    def analyze(self, api_key: str, model_name: str, prompt: str, temperature: float, max_tokens: int) -> Dict[str, Any]:
        payload = {
            "contents": [{"parts": [{"text": prompt}]}],
            "generationConfig": {
                "temperature": temperature,
                "maxOutputTokens": max_tokens,
            }
        }
        
        actual_url = f"{GEMINI_BASE_URL}{model_name}:generateContent?key={api_key}"
        
        try:
            response = self.session.post(actual_url, json=payload, timeout=90)
            response.raise_for_status()
            data = response.json()

            if "candidates" in data:
                if data["candidates"] and data["candidates"][0].get("content", {}).get("parts", [{}])[0].get("text"):
                    text = data["candidates"][0]["content"]["parts"][0]["text"]
                    return {"success": True, "text": text}
                else:
                    log(f"[Gemini] Error: No text in candidates")
                    error_details = "No text in API response candidates"
                    return {"success": False, "error": error_details}
            else:
                error_details = data.get("error", {}).get("message", "Invalid API response format.")
                log(f"[Gemini] Error: No candidates in response. Error: {error_details}")
                return {"success": False, "error": error_details}
                
        except requests.exceptions.HTTPError as e:
            error_text = f"HTTP {e.response.status_code}"
            try:
                error_json = e.response.json()
                error_detail = error_json.get('error', {}).get('message', e.response.text)
                error_text += f": {error_detail}"
            except:
                error_text += f": {e.response.text}"
            log(f"[Gemini] HTTP error: {error_text}")
            return {"success": False, "error": error_text}
        except requests.exceptions.Timeout as e:
            log(f"[Gemini] Timeout error: {str(e)}")
            return {"success": False, "error": f"Request timeout: {str(e)}"}
        except requests.exceptions.ConnectionError as e:
            log(f"[Gemini] Connection error: {str(e)}")
            return {"success": False, "error": f"Connection error: {str(e)}"}
        except requests.exceptions.RequestException as e:
            log(f"[Gemini] Request exception: {str(e)}")
            return {"success": False, "error": f"Network error: {str(e)}"}
        except json.JSONDecodeError as e:
            log(f"[Gemini] JSON decode error: {str(e)}")
            return {"success": False, "error": f"Invalid JSON response: {str(e)}"}
        except Exception as e:
            log(f"[Gemini] Unexpected error: {str(e)}")
            log(f"[Gemini] Traceback: {traceback.format_exc()}")
            return {"success": False, "error": f"Unexpected error: {str(e)}"}


class OpenAIClient:
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            "Content-Type": "application/json",
            "User-Agent": f"exteraPlugin/{__id__}/{__version__}"
        })

    def analyze(self, base_url: str, api_key: str, model_name: str, prompt: str,
                           temperature: float, max_tokens: int,
                           api_key_header: str = "Authorization", api_key_prefix: str = "Bearer") -> Dict[str, Any]:
        try:
            bu = (base_url or "https://api.openai.com").rstrip('/')
            
            if "/chat/completions" in bu:
                url = bu
            elif bu.endswith("/v1"):
                url = bu + "/chat/completions"
            elif "/v1/" in bu:
                url = bu.rstrip('/') + "/chat/completions" if not bu.endswith('/') else bu + "chat/completions"
            else:
                url = bu + "/v1/chat/completions"

            headers = {}
            if api_key_header:
                if api_key_prefix:
                    headers[api_key_header] = f"{api_key_prefix} {api_key}"
                else:
                    headers[api_key_header] = api_key

            payload = {
                "model": model_name,
                "messages": [
                    {"role": "user", "content": prompt}
                ],
                "temperature": float(temperature),
                "max_tokens": int(max_tokens),
                "stream": False
            }

            response = self.session.post(url, json=payload, headers=headers, timeout=90)

            response.raise_for_status()
            data = response.json()

            if "choices" not in data or not data["choices"]:
                err = data.get("error", {}).get("message", "No choices in API response")
                log(f"[Gemini/OpenAI] Error: No choices in response")
                return {"success": False, "error": err}
            
            first_choice = data["choices"][0]
            finish_reason = first_choice.get("finish_reason") or first_choice.get("finishReason", "")
            
            if finish_reason and finish_reason not in ["stop", ""]:
                if finish_reason == "length":
                    log(f"[Gemini/OpenAI] Error: Response truncated due to token limit")
                    return {"success": False, "error": "Response truncated due to token limit"}
                if finish_reason == "content_filter":
                    log(f"[Gemini/OpenAI] Error: Blocked by content filter")
                    return {"success": False, "error": "Blocked by content filter"}

            message = first_choice.get("message") or {}
            text = (message.get("content") if isinstance(message, dict) else None) or first_choice.get("text", "")

            if not text or not str(text).strip():
                log(f"[Gemini/OpenAI] Error: Empty content in API response")
                return {"success": False, "error": "Empty content in API response"}
            return {"success": True, "text": text}

        except requests.exceptions.HTTPError as e:
            error_text = f"HTTP {e.response.status_code}"
            try:
                error_json = e.response.json()
                error_detail = error_json.get('error', {}).get('message', e.response.text)
                error_text += f": {error_detail}"
            except Exception:
                error_text += f": {e.response.text}"
            log(f"[Gemini/OpenAI] HTTP error: {error_text}")
            return {"success": False, "error": error_text}
        except requests.exceptions.Timeout as e:
            log(f"[Gemini/OpenAI] Timeout error: {str(e)}")
            return {"success": False, "error": f"Request timeout: {str(e)}"}
        except requests.exceptions.ConnectionError as e:
            log(f"[Gemini/OpenAI] Connection error: {str(e)}")
            return {"success": False, "error": f"Connection error: {str(e)}"}
        except requests.exceptions.RequestException as e:
            log(f"[Gemini/OpenAI] Request exception: {str(e)}")
            return {"success": False, "error": f"Network error: {str(e)}"}
        except json.JSONDecodeError as e:
            log(f"[Gemini/OpenAI] JSON decode error: {str(e)}")
            return {"success": False, "error": f"Invalid JSON response: {str(e)}"}
        except Exception as e:
            log(f"[Gemini/OpenAI] Unexpected error: {str(e)}")
            log(f"[Gemini/OpenAI] Traceback: {traceback.format_exc()}")
            return {"success": False, "error": f"Unexpected error: {str(e)}"}

class PluginSecurityPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.gemini_client = GeminiClient()
        self.openai_client = OpenAIClient()
        self.alerts = AlertHelper()
        self.menu_item_id = None
        self._sheet_hook_ref = None
        self._current_local_scan_sheet = None
        self._current_report_sheet = None
        self._current_analyze_btn = None
        self._current_sheet = None
        self._last_analysis_response = None
        self._analyze_animation = None
        self._dots_animation_running = False
        self._dots_count = 0
        self._is_analyzing = False

    def on_plugin_load(self):
        self.add_on_send_message_hook()
        self.menu_item_id = self._add_menu()
        self._hook_install_ui()

    def on_plugin_unload(self):
        self._reset_ai_state()
        self._dismiss_local_sheet()
        self._dismiss_report_sheet()
        self.alerts.dismiss_dialog()
        self._unhook_safe(self._sheet_hook_ref)
        self._sheet_hook_ref = None
        self._remove_menu_safe(self.menu_item_id)
        self.menu_item_id = None
        self._current_sheet = None

    def _ensure_enabled(self) -> bool:
        if self.get_setting("enabled", True):
            return True
        self._show_error("PLUGIN_DISABLED")
        return False

    def _fmt_text(self, key: str, **kwargs) -> str:
        template = texts.get(key)
        if not kwargs:
            return template
        try:
            return template.format(**kwargs)
        except Exception as e:
            log(f"[Gemini] Ошибка форматирования строки {key}: {e}")
            return template

    def _show_scan_started(self):
        BulletinHelper.show_info(texts.get("LOCAL_ANALYZING_MESSAGE"))

    def _build_ai_loading_text(self, parent_view: Any, label: str):
        ellipsis = "\u2026"
        clean_label = (label or "").rstrip(f".{ellipsis} ").strip()
        if not clean_label or not parent_view:
            return None

        try:
            SpannableStringBuilder = jclass("android.text.SpannableStringBuilder")
            UploadingDotsSpannable = jclass("org.telegram.ui.Stories.UploadingDotsSpannable")

            loading_text = SpannableStringBuilder.valueOf(f"{clean_label}{ellipsis}")
            dots_span = UploadingDotsSpannable()
            dots_span.setParent(parent_view, True)
            loading_text.setSpan(
                dots_span,
                loading_text.length() - 1,
                loading_text.length(),
                0,
            )
            return loading_text
        except Exception as e:
            log(f"[Gemini] Не удалось включить Telegram-анимацию для AI-кнопки: {e}")
            return None

    def _unhook_safe(self, hook_ref):
        if not hook_ref:
            return
        try:
            self.unhook_method(hook_ref)
        except Exception:
            pass

    def _remove_menu_safe(self, item_id):
        if not item_id:
            return
        try:
            self.remove_menu_item(item_id)
        except Exception:
            pass

    def _reset_ai_state(self):
        if self._analyze_animation:
            try:
                self._analyze_animation.cancel()
            except Exception:
                pass
            self._analyze_animation = None
        self._stop_dots()
        self._is_analyzing = False

    def _get_field_deep(self, target: Any, field_name: str) -> Any:
        if not target:
            return None
        current_class = target.getClass()
        while current_class is not None:
            try:
                field = current_class.getDeclaredField(field_name)
                field.setAccessible(True)
                return field.get(target)
            except Exception:
                current_class = current_class.getSuperclass()
        return None

    def _call_zero_arg_deep(self, target: Any, method_name: str) -> Any:
        if not target:
            return None
        current_class = target.getClass()
        while current_class is not None:
            try:
                method = current_class.getDeclaredMethod(method_name)
                method.setAccessible(True)
                return method.invoke(target)
            except Exception:
                current_class = current_class.getSuperclass()
        return None

    def _find_view_pair(self, root_view: Any, view_class: Any) -> Tuple[Any, Any]:
        if not root_view or not view_class:
            return None, None
        if isinstance(root_view, view_class):
            return root_view, root_view.getParent()
        if not hasattr(root_view, "getChildCount") or not hasattr(root_view, "getChildAt"):
            return None, None
        for index in range(root_view.getChildCount()):
            child = root_view.getChildAt(index)
            found_view, parent = self._find_view_pair(child, view_class)
            if found_view:
                return found_view, parent
        return None, None

    def _make_button_bg(
        self,
        theme_class: Any,
        android_utilities_class: Any,
        fallback_color: int,
        fallback_pressed: int,
    ):
        try:
            button_color = theme_class.getColor(theme_class.key_featuredStickers_addButton)
            try:
                button_pressed = theme_class.getColor(theme_class.key_featuredStickers_addButtonPressed)
            except Exception:
                button_pressed = theme_class.getColor(theme_class.key_listSelector)
        except Exception:
            button_color = as_java_color(fallback_color)
            button_pressed = as_java_color(fallback_pressed)
        return theme_class.createSimpleSelectorRoundRectDrawable(
            android_utilities_class.dp(8),
            button_color,
            button_pressed,
        )

    def _get_primary_button_text_color(self, theme_class: Any, fallback_color: int = 0xFFFFFFFF):
        try:
            return theme_class.getColor(theme_class.key_featuredStickers_buttonText)
        except Exception:
            return as_java_color(fallback_color)

    def _get_install_sheet_class(self):
        try:
            java_class = find_class("java.lang.Class")
            if java_class:
                try:
                    return java_class.forName("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
                except Exception:
                    pass
            sheet_class = find_class("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
            if sheet_class:
                return getattr(sheet_class, "class_", sheet_class)
        except Exception:
            pass
        return None

    def _get_install_sheet_ctor(self):
        sheet_class = self._get_install_sheet_class()
        if not sheet_class:
            log("[Gemini] InstallPluginBottomSheet не найден")
            return None
        for ctor in sheet_class.getDeclaredConstructors():
            try:
                params = ctor.getParameterTypes()
                if len(params) != 3:
                    continue
                if "BaseFragment" not in params[0].getName():
                    continue
                if "PluginInstallParams" not in params[2].getName():
                    continue
                return ctor
            except Exception:
                continue
        return None

    def _log_context_keys(self, context):
        return

    def _get_message_from_context(self, context):
        for key in ["message", "messageObject", "selectedMessage", "currentMessage"]:
            try:
                if context.containsKey(key):
                    return context.get(key)
            except Exception:
                continue
        return None

    def _get_document_from_msg(self, message):
        try:
            if hasattr(message, "messageOwner"):
                document = MessageObject.getDocument(message.messageOwner)
            elif hasattr(message, "messageText"):
                document = MessageObject.getDocument(message)
            else:
                document = MessageObject.getDocument(message)
            return document
        except Exception as e:
            log(f"[Gemini] Error getting document: {e}")
            return None

    def _get_verdict_style(self, verdict_type: str, text: Optional[str] = None) -> Dict[str, Any]:
        style = dict(VERDICT_STYLES.get(verdict_type, VERDICT_STYLES["unknown"]))
        lang = "ru" if texts.language == "ru" else "en"
        default_text = VERDICT_TEXTS.get(style["type"], VERDICT_TEXTS["unknown"]).get(lang, VERDICT_TEXTS["unknown"]["en"])
        style["text"] = text or default_text
        return style

    def _collect_evidence(self, code_lines: List[str], patterns: List[Any], limit: int = 3) -> List[str]:
        evidence = []
        seen = set()
        for line_no, line in enumerate(code_lines, start=1):
            stripped = line.strip()
            if not stripped:
                continue

            lowered = stripped.lower()
            matched = False
            for pattern in patterns:
                if hasattr(pattern, "search"):
                    try:
                        if pattern.search(stripped):
                            matched = True
                            break
                    except Exception:
                        continue
                elif str(pattern).lower() in lowered:
                    matched = True
                    break

            if not matched:
                continue

            sanitized = mask_sensitive_text(stripped)
            if len(sanitized) > 110:
                sanitized = sanitized[:107] + "..."

            entry = f"L{line_no}: {sanitized}"
            if entry in seen:
                continue

            evidence.append(entry)
            seen.add(entry)
            if len(evidence) >= limit:
                break

        return evidence

    def _get_func_block(self, code: str, function_name: str) -> str:
        try:
            tree = ast.parse(code)
            code_lines = code.splitlines()
            for node in ast.walk(tree):
                if isinstance(node, ast.FunctionDef) and node.name == function_name:
                    start = max(node.lineno - 1, 0)
                    end = getattr(node, "end_lineno", node.lineno)
                    return "\n".join(code_lines[start:end])
        except Exception:
            pass
        return ""

    def _find_recursive_defs(self, code: str) -> List[str]:
        recursive_functions = []
        try:
            tree = ast.parse(code)
            for node in ast.walk(tree):
                if not isinstance(node, ast.FunctionDef):
                    continue
                for child in ast.walk(node):
                    if not isinstance(child, ast.Call):
                        continue
                    func = child.func
                    if isinstance(func, ast.Name) and func.id == node.name:
                        recursive_functions.append(node.name)
                        break
                    if isinstance(func, ast.Attribute) and func.attr == node.name:
                        recursive_functions.append(node.name)
                        break
        except Exception:
            pass
        return recursive_functions

    def _parse_ast_tree(self, code: str) -> Optional[Any]:
        try:
            return ast.parse(code)
        except Exception:
            return None

    def _is_true_literal(self, node: Any) -> bool:
        if isinstance(node, ast.Constant):
            return node.value is True
        return isinstance(node, ast.NameConstant) and node.value is True

    def _is_large_int_literal(self, node: Any) -> bool:
        if isinstance(node, ast.Constant) and isinstance(node.value, int) and not isinstance(node.value, bool):
            return abs(node.value) >= 10000
        if isinstance(node, ast.UnaryOp) and isinstance(node.op, ast.USub):
            operand = node.operand
            if isinstance(operand, ast.Constant) and isinstance(operand.value, int) and not isinstance(operand.value, bool):
                return abs(operand.value) >= 10000
        return False

    def _is_thread_constructor_call(self, node: Any) -> bool:
        if not isinstance(node, ast.Call):
            return False
        func = node.func
        if isinstance(func, ast.Name):
            return func.id == "Thread"
        if isinstance(func, ast.Attribute):
            return (
                func.attr == "Thread"
                and isinstance(func.value, ast.Name)
                and func.value.id == "threading"
            )
        return False

    def _is_thread_start_call(self, node: Any) -> bool:
        return (
            isinstance(node, ast.Call)
            and isinstance(node.func, ast.Attribute)
            and node.func.attr == "start"
            and self._is_thread_constructor_call(node.func.value)
        )

    def _collect_hardcoded_id_names(self, tree: Optional[Any]) -> set:
        hardcoded_names = set()
        if tree is None:
            return hardcoded_names

        def remember_targets(targets: List[Any], value: Any):
            if not self._is_large_int_literal(value):
                return
            for target in targets:
                if isinstance(target, ast.Name):
                    hardcoded_names.add(target.id)

        for node in ast.walk(tree):
            if isinstance(node, ast.Assign):
                remember_targets(node.targets, node.value)
            elif isinstance(node, ast.AnnAssign) and node.value is not None:
                remember_targets([node.target], node.value)

        return hardcoded_names

    def _expr_contains_hardcoded_target(self, expr: Any, hardcoded_names: set) -> bool:
        if expr is None:
            return False
        if self._is_large_int_literal(expr):
            return True
        if isinstance(expr, ast.Name) and expr.id in hardcoded_names:
            return True
        if isinstance(expr, ast.Dict):
            for key, value in zip(expr.keys, expr.values):
                key_name = None
                if isinstance(key, ast.Constant) and isinstance(key.value, str):
                    key_name = key.value
                elif isinstance(key, ast.Str):
                    key_name = key.s
                if key_name in ("peer", "peer_id", "dialog_id", "chat_id", "user_id", "id"):
                    if self._expr_contains_hardcoded_target(value, hardcoded_names):
                        return True
            return False
        for child in ast.iter_child_nodes(expr):
            if self._expr_contains_hardcoded_target(child, hardcoded_names):
                return True
        return False

    def _is_send_params_builder_call(self, node: Any) -> bool:
        if not isinstance(node, ast.Call) or not isinstance(node.func, ast.Attribute):
            return False
        if node.func.attr != "of":
            return False
        base = node.func.value
        return (
            isinstance(base, ast.Name) and base.id == "SendMessageParams"
        ) or (
            isinstance(base, ast.Attribute) and base.attr == "SendMessageParams"
        )

    def _is_send_message_call(self, node: Any) -> bool:
        if not isinstance(node, ast.Call):
            return False
        func = node.func
        if isinstance(func, ast.Name):
            return func.id == "send_message"
        return isinstance(func, ast.Attribute) and func.attr == "sendMessage"

    def _has_hardcoded_peer_target(self, code: str) -> bool:
        tree = self._parse_ast_tree(code)
        if tree is None:
            return False

        hardcoded_names = self._collect_hardcoded_id_names(tree)
        if not hardcoded_names and not HARD_CODED_ID_REGEX.search(code):
            return False

        for node in ast.walk(tree):
            if not isinstance(node, ast.Call):
                continue

            candidates = []
            if self._is_send_params_builder_call(node):
                candidates.extend(node.args)
                candidates.extend(keyword.value for keyword in node.keywords)
            elif self._is_send_message_call(node):
                candidates.extend(node.args)
                candidates.extend(
                    keyword.value
                    for keyword in node.keywords
                    if keyword.arg in ("peer", "peer_id", "dialog_id", "chat_id", "user_id", "id")
                )
            else:
                continue

            if any(self._expr_contains_hardcoded_target(expr, hardcoded_names) for expr in candidates):
                return True

        return False

    def _has_startup_thread_bomb(self, code: str) -> bool:
        tree = self._parse_ast_tree(code)
        if tree is None:
            return False

        top_level_thread_starts = 0
        has_top_level_infinite_loop = False

        for node in getattr(tree, "body", []):
            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):
                continue
            if isinstance(node, ast.While) and self._is_true_literal(node.test):
                has_top_level_infinite_loop = True
            for child in ast.walk(node):
                if self._is_thread_start_call(child):
                    top_level_thread_starts += 1

        return (has_top_level_infinite_loop and top_level_thread_starts >= 2) or top_level_thread_starts >= 4

    def _has_mass_dialog_deletion(self, code: str) -> bool:
        lower_code = code.lower()
        if "alldialogs" not in lower_code:
            return False

        tree = self._parse_ast_tree(code)
        if tree is None:
            return "deletedialog(" in lower_code

        for node in ast.walk(tree):
            if not isinstance(node, (ast.For, ast.While)):
                continue
            for child in ast.walk(node):
                if (
                    isinstance(child, ast.Call)
                    and isinstance(child.func, ast.Attribute)
                    and child.func.attr == "deleteDialog"
                ):
                    return True

        return "deletedialog(" in lower_code

    def _scan_local(self, plugin_code: str) -> Dict[str, Any]:
        plugin_name, plugin_version = self._parse_plugin_meta(plugin_code)
        code_lines = plugin_code.splitlines()
        lower_code = plugin_code.lower()
        unload_block = self._get_func_block(plugin_code, "on_plugin_unload").lower()
        issues = []
        seen_issue_ids = set()
        is_ru = texts.language == "ru"

        def add_issue(issue_id: str, severity: str, title: str, description: str, patterns: List[Any]):
            if issue_id in seen_issue_ids:
                return
            issues.append({
                "id": issue_id,
                "severity": severity,
                "title": title,
                "description": description,
                "evidence": self._collect_evidence(code_lines, patterns),
            })
            seen_issue_ids.add(issue_id)

        has_plugin_infection = (
            "# doxgram_injected_start" in lower_code
            or "_inject_snippet_into_file" in lower_code
            or (
                "loadpluginfromfile" in lower_code
                and (
                    "_infect_other_plugins" in lower_code
                    or ("pluginscontroller" in lower_code and "os.walk" in lower_code and ".plugin" in lower_code)
                )
            )
        )
        has_external_app_paths = bool(DATA_PATH_REGEX.search(plugin_code)) and any(
            package_name in lower_code
            for package_name in [
                "com.exteragram.messenger",
                "com.radolyn.ayugram",
            ]
        )
        has_external_file_ops = any(
            marker in lower_code
            for marker in [
                "os.remove(",
                "os.rename(",
                "os.makedirs(",
                "with open(file_path, \"w\"",
                "with open(file_path, 'w'",
                "with open(path, \"a\"",
                "with open(path, 'a'",
                "with open(path, \"w\"",
                "with open(path, 'w'",
            ]
        )

        has_bot_token = bool(BOT_TOKEN_REGEX.search(plugin_code))
        has_discord_webhook = bool(DISCORD_WEBHOOK_REGEX.search(plugin_code))
        has_telegram_bot_api = "https://api.telegram.org/bot" in lower_code
        has_exfil_channel = has_bot_token or has_discord_webhook or has_telegram_bot_api

        has_profile_dump = any(
            marker in lower_code
            for marker in [
                "access_hash",
                "currentuser.phone",
                "currentuser.username",
                "currentuser.first_name",
                "currentuser.last_name",
                "get_private_field(user_config, \"currentuser\")",
                "get_private_field(user_config, 'currentuser')",
                "getclientphone(",
            ]
        )
        has_chat_harvest = any(
            marker in lower_code
            for marker in [
                "dialogs_dict",
                ".valueat(",
                "api.ipify.org",
                "build.model",
                "build.version.release",
                "getcurrentuser()",
            ]
        )
        has_hardcoded_peer_target = self._has_hardcoded_peer_target(plugin_code)
        has_fixed_target = bool(FIXED_ID_ASSIGNMENT_REGEX.search(plugin_code)) or has_hardcoded_peer_target or any(
            marker in lower_code
            for marker in [
                "target_user_id",
                "your_chat_id",
                "bot1_token",
                "bot2_token",
                "discord_webhook",
            ]
        )
        has_send_helper = "send_messages_helper" in lower_code or "sendmessage(send_params)" in lower_code
        has_startup_thread_bomb = self._has_startup_thread_bomb(plugin_code)
        has_session_sabotage = any(
            marker in lower_code
            for marker in [
                "tl_account_resetauthorization",
                "tl_auth_logout",
                ".clearconfig(",
                "launchactivity.instance.reboot(",
                "launchactivity.instance.reboot()",
                "setpluginenabled(self.id, false",
                "setpluginenabled(self.id,false",
            ]
        ) or (".clearconfig(" in lower_code and ".saveconfig(true" in lower_code)
        has_mass_dialog_deletion = self._has_mass_dialog_deletion(plugin_code)
        has_device_coercion_overlay = (
            any(marker in lower_code for marker in ["type_application_overlay", "type_phone"])
            and any(marker in lower_code for marker in ["flag_fullscreen", "flag_layout_in_screen"])
            and "addview(" in lower_code
            and any(marker in lower_code for marker in ["windowmanager", "layoutparams"])
        )
        has_camera_or_wallpaper_abuse = (
            ("action_image_capture" in lower_code and "startactivity(" in lower_code)
            or ("wallpapermanager" in lower_code and "setbitmap(" in lower_code)
        )
        recursive_functions = self._find_recursive_defs(plugin_code)
        recursive_function_markers = [name for name in recursive_functions[:2]]
        has_crash_command = any(
            marker in lower_code
            for marker in [
                '".crash"',
                "'.crash'",
                "force_crash",
                "crash telegram",
                "crash app",
            ]
        )
        has_crash_primitives = any(
            marker in lower_code
            for marker in [
                "ctypes.string_at(0)",
                "os._exit(",
                "os.abort(",
                "process.killprocess(",
                "system.exit(",
                "signal.sigsegv",
                "signal.sigabrt",
                "runtime.getruntime().halt(",
            ]
        )
        has_recursive_crash = any(
            marker in name.lower()
            for name in recursive_functions
            for marker in ["crash", "recurse", "overflow", "boom"]
        )
        has_unload_thread_spawn = bool(re.search(r"(^|[^a-z_])thread\s*\(", unload_block))
        has_unload_sabotage = bool(unload_block) and (
            has_unload_thread_spawn
            or any(
                marker in unload_block
                for marker in [
                    "hydra(",
                    "requests.",
                    "send_request(",
                    "send_message(",
                    "_infect_other_plugins",
                    "loadpluginfromfile",
                    "tl_account_resetauthorization",
                    "tl_auth_logout",
                    "clearconfig(",
                    "setpluginenabled(",
                    "launchactivity.instance.reboot(",
                    "eval(",
                    "exec(",
                    "os.system(",
                    "subprocess.",
                    "runtime.getruntime().exec",
                    "ctypes.string_at(0)",
                    "os._exit(",
                    "os.abort(",
                    "process.killprocess(",
                    "system.exit(",
                    "1/0",
                ]
            )
        )

        if has_plugin_infection:
            add_issue(
                "plugin_infection",
                "danger",
                "Самораспространение и заражение других плагинов" if is_ru else "Self-replication and plugin infection",
                (
                    "Код перехватывает загрузку плагинов и внедряет изменения в чужие `.plugin` файлы."
                    if is_ru else
                    "The code hooks plugin loading and injects changes into other `.plugin` files."
                ),
                [
                    "# DOXGRAM_INJECTED_START",
                    "_inject_snippet_into_file",
                    "_infect_other_plugins",
                    "loadPluginFromFile",
                    "PluginsController.getInstance().loadPluginFromFile",
                ],
            )

        if has_startup_thread_bomb:
            add_issue(
                "startup_thread_bomb",
                "danger",
                "Запуск бесконечного потокового флуда" if is_ru else "Startup thread bomb",
                (
                    "В модуле найден верхнеуровневый `while True` и многократный запуск `Thread.start()`, что может моментально повесить или уронить клиент."
                    if is_ru else
                    "A top-level `while True` with repeated `Thread.start()` calls was found, which can quickly hang or crash the client."
                ),
                [
                    "while True:",
                    "threading.Thread(",
                    "Thread(",
                ],
            )

        if has_external_app_paths and has_external_file_ops:
            add_issue(
                "external_app_paths",
                "high_risk",
                "Запись в системные директории приложения" if is_ru else "Writes into app system directories",
                (
                    "Плагин пишет или удаляет файлы за пределами собственной области хранения."
                    if is_ru else
                    "The plugin writes or deletes files outside its own storage scope."
                ),
                [
                    DATA_PATH_REGEX,
                    "os.remove(",
                    "os.rename(",
                    "os.makedirs(",
                    "with open(file_path, \"w\"",
                    "with open(path, \"a\"",
                    "with open(path, \"w\"",
                ],
            )

        if has_session_sabotage:
            add_issue(
                "session_sabotage",
                "danger",
                "Сброс сессии и принудительное отключение" if is_ru else "Session sabotage and forced logout",
                (
                    "Плагин вызывает сброс авторизации, трогает `UserConfig`, перезапускает клиент или принудительно отключает себя после вредных действий."
                    if is_ru else
                    "The plugin resets authorization, mutates `UserConfig`, reboots the client or forcibly disables itself after harmful actions."
                ),
                [
                    "TL_account_resetAuthorization",
                    "TL_auth_logOut",
                    ".clearConfig(",
                    ".saveConfig(True",
                    "LaunchActivity.instance.reboot(",
                    "setPluginEnabled(self.id, False",
                ],
            )

        if has_mass_dialog_deletion:
            add_issue(
                "mass_dialog_deletion",
                "danger",
                "Массовое удаление диалогов" if is_ru else "Mass dialog deletion",
                (
                    "Код перебирает `allDialogs` и вызывает `deleteDialog(...)` в цикле, что может массово тереть историю и чаты."
                    if is_ru else
                    "The code iterates over `allDialogs` and calls `deleteDialog(...)` in a loop, which can mass-delete chats and history."
                ),
                [
                    "allDialogs",
                    "ArrayList(controller.allDialogs)",
                    "deleteDialog(",
                ],
            )

        if has_profile_dump and has_send_helper and has_fixed_target:
            add_issue(
                "fake_nft_profile_theft",
                "danger",
                "Кража профиля пользователя и access_hash" if is_ru else "User profile and access_hash theft",
                (
                    "Из кода читаются поля `currentUser`, телефон или `access_hash`, после чего они отправляются на фиксированный ID."
                    if is_ru else
                    "The code reads `currentUser`, phone or `access_hash` fields and sends them to a hardcoded peer or ID."
                ),
                [
                    HARD_CODED_ID_REGEX,
                    "access_hash",
                    "get_private_field",
                    "send_messages_helper",
                    "SendMessageParams.of",
                ],
            )

        if has_chat_harvest and has_exfil_channel:
            add_issue(
                "snosogram_data_exfiltration",
                "danger",
                "Скрытый сбор телефона, чатов или IP" if is_ru else "Hidden harvesting of phone, chats or IP",
                (
                    "Плагин собирает телефон, список чатов, IP или данные устройства и готовит их к отправке наружу."
                    if is_ru else
                    "The plugin collects phone, chat list, IP or device data and prepares it for exfiltration."
                ),
                [
                    "getClientPhone(",
                    "dialogs_dict",
                    "api.ipify.org",
                    "Build.MODEL",
                    "Build.VERSION.RELEASE",
                    BOT_TOKEN_REGEX,
                    DISCORD_WEBHOOK_REGEX,
                ],
            )

        if has_device_coercion_overlay:
            add_issue(
                "device_coercion_overlay",
                "high_risk",
                "Принудительный fullscreen-overlay" if is_ru else "Coercive fullscreen overlay",
                (
                    "Плагин собирает system overlay через `WindowManager` с fullscreen-флагами, что может блокировать интерфейс и давить на пользователя."
                    if is_ru else
                    "The plugin mounts a fullscreen system overlay via `WindowManager`, which can block the UI and coerce the user."
                ),
                [
                    "WindowManager",
                    "TYPE_APPLICATION_OVERLAY",
                    "TYPE_PHONE",
                    "FLAG_FULLSCREEN",
                    "FLAG_LAYOUT_IN_SCREEN",
                    "addView(",
                ],
            )

        if has_camera_or_wallpaper_abuse:
            add_issue(
                "camera_or_wallpaper_abuse",
                "high_risk",
                "Злоупотребление камерой или сменой обоев" if is_ru else "Camera or wallpaper abuse",
                (
                    "Код запускает камеру и/или меняет обои устройства автоматически, что относится к чувствительным действиям на устройстве."
                    if is_ru else
                    "The code launches the camera and/or changes the device wallpaper automatically, which is a sensitive device-side action."
                ),
                [
                    "ACTION_IMAGE_CAPTURE",
                    "WallpaperManager",
                    "setBitmap(",
                    "startActivity(",
                ],
            )

        if has_exfil_channel:
            add_issue(
                "hardcoded_exfiltration_channels",
                "high_risk",
                "Жестко прошитые каналы внешней отправки" if is_ru else "Hardcoded exfiltration channels",
                (
                    "Найдены bot-token, Telegram Bot API или Discord webhook. Это частый индикатор скрытой отправки данных."
                    if is_ru else
                    "Bot tokens, Telegram Bot API or a Discord webhook were found. This is a common indicator of stealthy data exfiltration."
                ),
                [
                    BOT_TOKEN_REGEX,
                    DISCORD_WEBHOOK_REGEX,
                    "https://api.telegram.org/bot",
                ],
            )

        if has_crash_primitives or (has_crash_command and (has_recursive_crash or recursive_functions)):
            add_issue(
                "forced_app_crash",
                "danger",
                "Принудительный краш приложения" if is_ru else "Forced application crash",
                (
                    "Код содержит примитивы, которые могут намеренно уронить приложение: опасную рекурсию, прямой доступ к памяти через ctypes или жёсткое завершение процесса."
                    if is_ru else
                    "The code contains primitives that can intentionally crash the app: dangerous recursion, direct memory access via ctypes or hard process termination."
                ),
                [
                    ".crash",
                    "force_crash",
                    "ctypes.string_at(0)",
                    "os._exit(",
                    "os.abort(",
                    "Process.killProcess(",
                    "System.exit(",
                ] + recursive_function_markers,
            )

        if has_unload_sabotage:
            add_issue(
                "unload_sabotage",
                "high_risk",
                "Подозрительные действия при выгрузке" if is_ru else "Suspicious unload behavior",
                (
                    "В `on_plugin_unload` запускаются побочные действия вместо безопасной очистки: поток, самовосстановление, сетевой вызов или намеренный сбой."
                    if is_ru else
                    "The `on_plugin_unload` handler performs real side effects instead of safe cleanup: network activity, session sabotage, self-restoration, thread spawning or command execution."
                ),
                [
                    "def on_plugin_unload",
                    "Thread(",
                    "hydra(",
                    "requests.",
                    "send_request(",
                    "TL_auth_logOut",
                    "os.system(",
                ],
            )

        if any(marker in lower_code for marker in ["eval(", "exec(", "os.system(", "subprocess.", "runtime.getruntime().exec"]):
            add_issue(
                "arbitrary_code_execution",
                "danger",
                "Выполнение произвольного кода или команд" if is_ru else "Arbitrary code or command execution",
                (
                    "Обнаружены конструкции `eval/exec/os.system/subprocess`, которые дают плагину возможность выполнять непроверенный код."
                    if is_ru else
                    "Constructs like `eval/exec/os.system/subprocess` were found, giving the plugin the ability to execute untrusted code."
                ),
                [
                    "eval(",
                    "exec(",
                    "os.system(",
                    "subprocess.",
                    "Runtime.getRuntime().exec",
                ],
            )

        if "http://" in lower_code:
            add_issue(
                "plain_http",
                "caution",
                "Незащищенные HTTP-запросы" if is_ru else "Plain HTTP requests",
                (
                    "Код использует HTTP без шифрования, что повышает риск подмены или утечки данных."
                    if is_ru else
                    "The code uses unencrypted HTTP, increasing the risk of tampering or data leaks."
                ),
                ["http://"],
            )

        issues.sort(key=lambda item: (-LOCAL_SEVERITY_WEIGHT.get(item["severity"], 0), item["title"]))
        issue_ids = {item["id"] for item in issues}
        total_score = sum(LOCAL_SEVERITY_WEIGHT.get(item["severity"], 0) for item in issues)
        has_danger = any(item["severity"] == "danger" for item in issues)
        has_high = any(item["severity"] == "high_risk" for item in issues)
        has_caution = any(item["severity"] == "caution" for item in issues)

        if has_danger or ("plugin_infection" in issue_ids and ("fake_nft_profile_theft" in issue_ids or "snosogram_data_exfiltration" in issue_ids)):
            verdict_type = "danger"
        elif has_high or total_score >= 4:
            verdict_type = "high_risk"
        elif has_caution or total_score >= 2:
            verdict_type = "caution"
        elif issues:
            verdict_type = "low_risk"
        else:
            verdict_type = "safe"

        if not issues:
            summary = (
                "Подозрительных действий по коду не найдено."
                if is_ru else
                "No suspicious actions were found in the code."
            )
        else:
            if verdict_type == "danger":
                summary = (
                    "Найдены критические вредоносные действия."
                    if is_ru else
                    "Critical malicious actions were found."
                )
            elif verdict_type == "high_risk":
                summary = (
                    "Найдены действия с высоким риском для приватности или безопасности."
                    if is_ru else
                    "High-risk privacy or security actions were found."
                )
            elif verdict_type == "caution":
                summary = (
                    "Найдены подозрительные конструкции, требующие дополнительной проверки."
                    if is_ru else
                    "Suspicious constructs were found and need extra review."
                )
            else:
                summary = (
                    "Есть спорные места, но критичных действий не найдено."
                    if is_ru else
                    "There are questionable areas, but no critical actions were found."
                )

        return {
            "plugin_name": plugin_name,
            "plugin_version": plugin_version,
            "issues": issues,
            "summary": summary,
            "verdict": self._get_verdict_style(verdict_type),
        }

    def _dismiss_local_sheet(self):
        try:
            if self._current_local_scan_sheet:
                self._current_local_scan_sheet.dismiss()
        except Exception:
            pass
        self._current_local_scan_sheet = None
        self._current_analyze_btn = None
        self._current_sheet = None

    def _dismiss_report_sheet(self):
        try:
            if self._current_report_sheet:
                self._current_report_sheet.dismiss()
        except Exception:
            pass
        self._current_report_sheet = None

    def _show_full_report_alert(self):
        try:
            if hasattr(self, "_last_analysis_response") and self._last_analysis_response:
                title = "🛡️ Полный отчет анализа"
                close_button = texts.get("ALERT_CLOSE_BUTTON")
                copy_button = texts.get("COPY_BUTTON")
                self.alerts.show_info_alert(
                    title,
                    self._last_analysis_response,
                    close_button,
                    copy_button,
                    lambda: self._copy_text("REPORT_LABEL", self._last_analysis_response),
                )
        except Exception as e:
            log(f"[Gemini] Ошибка показа отчета: {e}")

    def _prepare_report_sheet_data(self) -> Optional[Dict[str, Any]]:
        if not self._last_analysis_response:
            return None

        is_ru = texts.language == "ru"
        raw_response = str(self._last_analysis_response or "")
        clean_response = strip_premium_emoji(raw_response).replace("\r\n", "\n").strip()
        try:
            parsed_report = parse_markdown(clean_response)
            report_text = str(parsed_report.text or "").strip()
        except Exception:
            report_text = clean_response

        report_lines = [line.strip() for line in report_text.splitlines() if line.strip()]
        verdict = self._parse_verdict(raw_response)
        preview_text = verdict["text"]
        for line in report_lines:
            normalized = str(line or "").strip().lower()
            if "назначение:" not in normalized and "purpose:" not in normalized:
                continue
            preview_text = line.split(":", 1)[1].strip() or verdict["text"]
            break

        provider_type = self._get_provider_type()
        if provider_type == API_PROVIDER_OPENAI_COMPATIBLE:
            provider_name = "OpenAI API"
            model_name = str(self.get_setting("openai_model", "gpt-5") or "gpt-5")
        else:
            provider_name = "Gemini"
            try:
                model_name = GEMINI_MODEL_DISPLAY_NAMES[self._validate_model_index(self.get_setting("model_selection", 1))]
            except Exception:
                model_name = GEMINI_MODEL_DISPLAY_NAMES[1]

        return {
            "is_ru": is_ru,
            "raw_response": raw_response,
            "report_text": report_text,
            "preview_text": preview_text,
            "verdict": verdict,
            "provider_name": provider_name,
            "model_name": model_name,
            "title_text": "AI-анализ безопасности" if is_ru else "AI Security Analysis",
            "preview_title": "Назначение" if is_ru else "Purpose",
        }

    def _open_full_report_from_preview(self, source_view=None):
        def show_fullscreen():
            self._show_full_report(source_view)

        if source_view is None:
            show_fullscreen()
            return

        try:
            from java.lang import Runnable as JRunnable

            class OpenFullReportRunnable(dynamic_proxy(JRunnable)):
                def run(self_inner):
                    show_fullscreen()

            source_view.animate().cancel()
            pressed = source_view.animate().alpha(0.96).scaleX(0.985).scaleY(0.985).setDuration(110)
            pressed.withEndAction(OpenFullReportRunnable()).start()
        except Exception:
            show_fullscreen()

    def _animate_full_report_entry(self, overlay_view, content_view, source_view=None):
        try:
            initial_shift = AndroidUtilities.dp(24)
            initial_scale = 0.982
            if source_view is not None:
                try:
                    source_height = int(source_view.getHeight() or 0)
                    if source_height > 0:
                        initial_shift = max(AndroidUtilities.dp(18), min(AndroidUtilities.dp(56), int(source_height * 0.18)))
                    initial_scale = 0.972
                except Exception:
                    pass

            overlay_view.setAlpha(0.0)
            content_view.setAlpha(0.0)
            content_view.setTranslationY(initial_shift)
            content_view.setScaleX(initial_scale)
            content_view.setScaleY(initial_scale)

            def start_animation():
                try:
                    overlay_view.animate().cancel()
                    content_view.animate().cancel()
                except Exception:
                    pass

                try:
                    overlay_view.animate().alpha(1.0).setDuration(180).start()
                except Exception:
                    try:
                        overlay_view.setAlpha(1.0)
                    except Exception:
                        pass

                try:
                    animator = content_view.animate().alpha(1.0).translationY(0).scaleX(1.0).scaleY(1.0).setDuration(260)
                    try:
                        animator.setInterpolator(AndroidUtilities.decelerateInterpolator)
                    except Exception:
                        pass
                    animator.start()
                except Exception:
                    try:
                        content_view.setAlpha(1.0)
                        content_view.setTranslationY(0)
                        content_view.setScaleX(1.0)
                        content_view.setScaleY(1.0)
                    except Exception:
                        pass

            run_on_ui_thread(start_animation, 16)
        except Exception:
            try:
                overlay_view.setAlpha(1.0)
                content_view.setAlpha(1.0)
                content_view.setTranslationY(0)
                content_view.setScaleX(1.0)
                content_view.setScaleY(1.0)
            except Exception:
                pass

    def _dismiss_report_sheet_with_animation(self, sheet, overlay_view=None, content_view=None):
        def finish():
            try:
                if sheet:
                    sheet.dismiss()
            except Exception:
                pass
            if self._current_report_sheet == sheet:
                self._current_report_sheet = None

        if not sheet:
            finish()
            return

        if overlay_view is None or content_view is None:
            finish()
            return

        try:
            try:
                overlay_view.animate().cancel()
                content_view.animate().cancel()
            except Exception:
                pass

            overlay_view.animate().alpha(0.0).setDuration(120).start()
            animator = content_view.animate().alpha(0.0).translationY(AndroidUtilities.dp(18)).scaleX(0.988).scaleY(0.988).setDuration(150)
            try:
                animator.setInterpolator(AndroidUtilities.decelerateInterpolator)
            except Exception:
                pass
            animator.start()
            run_on_ui_thread(finish, 165)
        except Exception:
            finish()

    def _restore_report_preview_state(self, source_view):
        if source_view is None:
            return
        try:
            source_view.animate().cancel()
            source_view.animate().alpha(1.0).scaleX(1.0).scaleY(1.0).setDuration(150).start()
        except Exception:
            try:
                source_view.setAlpha(1.0)
                source_view.setScaleX(1.0)
                source_view.setScaleY(1.0)
            except Exception:
                pass

    def _animate_press_then(self, view, action=None, scale_to: float = 0.965, alpha_to: float = 0.92):
        def run_action():
            try:
                if callable(action):
                    action()
            except Exception as e:
                log(f"[Gemini] Ошибка action после анимации: {e}")

        if view is None:
            run_action()
            return

        try:
            from java.lang import Runnable as JRunnable
            child_view = None
            try:
                if hasattr(view, "getChildCount") and view.getChildCount() > 0:
                    child_view = view.getChildAt(0)
            except Exception:
                child_view = None

            class FinishPressRunnable(dynamic_proxy(JRunnable)):
                def run(self_inner):
                    try:
                        bounce = view.animate().scaleX(1.035).scaleY(1.035).translationY(-AndroidUtilities.dp(1)).alpha(1.0).setDuration(155)
                        try:
                            bounce.setInterpolator(AndroidUtilities.decelerateInterpolator)
                        except Exception:
                            pass
                        bounce.start()
                    except Exception:
                        try:
                            view.setScaleX(1.0)
                            view.setScaleY(1.0)
                            view.setAlpha(1.0)
                            view.setTranslationY(0)
                        except Exception:
                            pass

                    if child_view is not None:
                        try:
                            child_view.animate().translationX(AndroidUtilities.dp(1)).setDuration(155).start()
                        except Exception:
                            try:
                                child_view.setTranslationX(0)
                            except Exception:
                                pass

                    def settle():
                        try:
                            settle_anim = view.animate().scaleX(1.0).scaleY(1.0).translationY(0).alpha(1.0).setDuration(135)
                            try:
                                settle_anim.setInterpolator(AndroidUtilities.decelerateInterpolator)
                            except Exception:
                                pass
                            settle_anim.start()
                        except Exception:
                            try:
                                view.setScaleX(1.0)
                                view.setScaleY(1.0)
                                view.setTranslationY(0)
                                view.setAlpha(1.0)
                            except Exception:
                                pass

                        if child_view is not None:
                            try:
                                child_view.animate().translationX(0).setDuration(120).start()
                            except Exception:
                                try:
                                    child_view.setTranslationX(0)
                                except Exception:
                                    pass

                    run_action()
                    run_on_ui_thread(settle, 120)

            view.animate().cancel()
            try:
                animator = view.animate().scaleX(scale_to).scaleY(scale_to).translationY(AndroidUtilities.dp(2)).alpha(alpha_to).setDuration(85)
            except Exception:
                animator = view.animate().scaleX(scale_to).scaleY(scale_to).alpha(alpha_to).setDuration(85)
            animator.withEndAction(FinishPressRunnable()).start()
            if child_view is not None:
                try:
                    child_view.animate().translationX(-AndroidUtilities.dp(2)).setDuration(85).start()
                except Exception:
                    try:
                        child_view.setTranslationX(0)
                    except Exception:
                        pass
        except Exception:
            try:
                view.setScaleX(1.0)
                view.setScaleY(1.0)
                view.setAlpha(1.0)
                view.setTranslationY(0)
            except Exception:
                pass
            run_action()

    def _show_local_sheet(self, file_path: str, local_result: Dict[str, Any]):
        try:
            fragment = get_last_fragment()
            if not fragment or not hasattr(fragment, "getParentActivity"):
                BulletinHelper.show_error(texts.get("FILE_READ_ERROR"))
                return

            context = fragment.getParentActivity()
            if not context:
                BulletinHelper.show_error(texts.get("FILE_READ_ERROR"))
                return

            self._dismiss_local_sheet()

            is_ru = texts.language == "ru"
            verdict = local_result["verdict"]
            audit_note_title = (
                "Важно: это локальный аудит"
                if is_ru else
                "Important: this is a local audit"
            )
            audit_note_text = (
                "Локальная проверка ищет сигнатуры и подозрительные конструкции, но не понимает весь контекст и может ошибаться. Перед установкой всё равно проверьте код сами и, если нужно, запустите AI-анализ кнопкой ниже."
                if is_ru else
                "The local scan looks for signatures and suspicious patterns, but it does not understand the full context and can be wrong. Before installing, still review the code yourself and, if needed, run the AI analysis with the button below."
            )
            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            ThemeClass = jclass("org.telegram.ui.ActionBar.Theme")
            AndroidUtilitiesClass = jclass("org.telegram.messenger.AndroidUtilities")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            RClass = jclass("org.telegram.messenger.R")
            LinearLayoutClass = jclass("android.widget.LinearLayout")
            ScrollView = jclass("android.widget.ScrollView")
            TextView = jclass("android.widget.TextView")
            ImageView = jclass("android.widget.ImageView")
            FrameLayout = jclass("android.widget.FrameLayout")
            TypedValue = jclass("android.util.TypedValue")
            Gravity = jclass("android.view.Gravity")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            ButtonWithCounterView = jclass("org.telegram.ui.Stories.recorder.ButtonWithCounterView")
            DecelerateInterpolator = find_class("android.view.animation.DecelerateInterpolator")
            AccelerateDecelerateInterpolator = find_class("android.view.animation.AccelerateDecelerateInterpolator")
            OvershootInterpolator = find_class("android.view.animation.OvershootInterpolator")
            AccelerateInterpolator = find_class("android.view.animation.AccelerateInterpolator")
            from android.os import Handler, Looper
            from java.lang import Runnable as JRunnable

            try:
                SpannableStringBuilder = jclass("android.text.SpannableStringBuilder")
            except Exception:
                SpannableStringBuilder = None
            try:
                ForegroundColorSpan = jclass("android.text.style.ForegroundColorSpan")
            except Exception:
                ForegroundColorSpan = None
            try:
                RelativeSizeSpan = jclass("android.text.style.RelativeSizeSpan")
            except Exception:
                RelativeSizeSpan = None
            try:
                ScaleStateListAnimator = jclass("org.telegram.ui.Components.ScaleStateListAnimator")
            except Exception:
                ScaleStateListAnimator = None

            main_handler = Handler(Looper.getMainLooper())

            def resolve_drawable(*names: str) -> int:
                drawable_class = None
                resources = None
                package_name = None
                try:
                    drawable_class = getattr(RClass, "drawable", None)
                except Exception:
                    drawable_class = None
                try:
                    resources = context.getResources()
                except Exception:
                    resources = None
                try:
                    package_name = context.getPackageName()
                except Exception:
                    package_name = None

                seen = set()
                for name in names:
                    candidate = str(name or "").strip()
                    if not candidate or candidate in seen:
                        continue
                    seen.add(candidate)

                    if drawable_class is not None:
                        try:
                            res_id = int(getattr(drawable_class, candidate, 0) or 0)
                            if res_id:
                                return res_id
                        except Exception:
                            pass

                    if resources is not None and package_name:
                        try:
                            res_id = int(resources.getIdentifier(candidate, "drawable", package_name) or 0)
                            if res_id:
                                return res_id
                        except Exception:
                            pass

                return 0

            def create_chip(text: str, text_color: int, bg_color: int, icon_res: int = 0):
                chip_frame = FrameLayout(context)
                chip_bg = GradientDrawable()
                chip_bg.setCornerRadius(AndroidUtilitiesClass.dp(14))
                chip_bg.setColor(as_java_color(bg_color))
                chip_frame.setBackground(chip_bg)

                chip_layout = LinearLayoutClass(context)
                chip_layout.setOrientation(LinearLayoutClass.HORIZONTAL)
                chip_layout.setGravity(Gravity.CENTER)
                chip_layout.setPadding(
                    AndroidUtilitiesClass.dp(10),
                    AndroidUtilitiesClass.dp(5),
                    AndroidUtilitiesClass.dp(10),
                    AndroidUtilitiesClass.dp(5),
                )

                if icon_res:
                    chip_icon = ImageView(context)
                    chip_icon.setImageResource(icon_res)
                    chip_icon.setColorFilter(as_java_color(text_color))
                    chip_layout.addView(
                        chip_icon,
                        LayoutHelper.createLinear(14, 14, Gravity.CENTER_VERTICAL, 0, 0, 6, 0),
                    )

                chip_text = TextView(context)
                chip_text.setText(text)
                chip_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                chip_text.setTypeface(AndroidUtilitiesClass.bold())
                chip_text.setTextColor(as_java_color(text_color))
                chip_layout.addView(chip_text, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL))
                chip_frame.addView(chip_layout, LayoutHelper.createFrame(-2, -2, Gravity.CENTER))
                return chip_frame

            def apply_chip_press_feedback(chip_view, accent_color: int, radius_dp: int = 14):
                if chip_view is None:
                    return

                try:
                    chip_view.setClickable(True)
                    chip_view.setFocusable(True)
                except Exception:
                    pass

                try:
                    chip_view.setForeground(
                        ThemeClass.createSimpleSelectorRoundRectDrawable(
                            AndroidUtilitiesClass.dp(radius_dp),
                            0,
                            as_java_color(with_alpha(accent_color, 0x16)),
                        )
                    )
                except Exception:
                    pass

                if ScaleStateListAnimator is not None:
                    try:
                        ScaleStateListAnimator.apply(chip_view, 0.04, 1.2)
                    except Exception:
                        pass

            def create_secondary_button(text: str, on_click):
                button_frame = FrameLayout(context)
                button_bg = GradientDrawable()
                button_bg.setCornerRadius(AndroidUtilitiesClass.dp(10))
                try:
                    button_bg.setColor(ThemeClass.getColor(ThemeClass.key_listSelector))
                except Exception:
                    button_bg.setColor(as_java_color(0xFFEDEDED))
                button_frame.setBackground(button_bg)

                label = TextView(context)
                label.setText(text)
                label.setGravity(Gravity.CENTER)
                label.setTypeface(AndroidUtilitiesClass.bold())
                label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                try:
                    label.setTextColor(ThemeClass.getColor(ThemeClass.key_windowBackgroundWhiteBlueText))
                except Exception:
                    label.setTextColor(as_java_color(0xFF3390EC))

                button_frame.addView(label, LayoutHelper.createFrame(-1, -1))
                button_frame.setOnClickListener(OnClickListener(on_click))
                return button_frame

            def clean_ui_text(text: str) -> str:
                return str(text).replace("`", "").replace("  ", " ").strip()

            def create_issue_card(title: str, description: str, color: int):
                card_frame = FrameLayout(context)
                card_bg = GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilitiesClass.dp(14))
                card_bg.setColor(as_java_color(with_alpha(color, 0x12)))
                card_frame.setBackground(card_bg)

                card_layout = LinearLayoutClass(context)
                card_layout.setOrientation(LinearLayoutClass.VERTICAL)
                card_layout.setPadding(
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                )

                title_view = TextView(context)
                title_view.setText(clean_ui_text(title))
                title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                title_view.setTypeface(AndroidUtilitiesClass.bold())
                title_view.setTextColor(as_java_color(color))
                try:
                    title_view.setLineSpacing(AndroidUtilitiesClass.dp(2), 1.05)
                except Exception:
                    pass
                card_layout.addView(title_view)

                desc_view = TextView(context)
                desc_view.setText(clean_ui_text(description))
                desc_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                try:
                    desc_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextGray2))
                except Exception:
                    desc_view.setTextColor(as_java_color(0xFF8F96A3))
                try:
                    desc_view.setLineSpacing(AndroidUtilitiesClass.dp(3), 1.1)
                except Exception:
                    pass
                card_layout.addView(desc_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 0))

                card_frame.addView(card_layout, LayoutHelper.createFrame(-1, -2))
                return card_frame

            def create_note_card(title: str, description: str, accent_color: int):
                card_frame = FrameLayout(context)
                card_bg = GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilitiesClass.dp(14))
                card_bg.setColor(as_java_color(with_alpha(accent_color, 0x10)))
                try:
                    card_bg.setStroke(
                        AndroidUtilitiesClass.dp(1),
                        as_java_color(with_alpha(accent_color, 0x1E)),
                    )
                except Exception:
                    pass
                card_frame.setBackground(card_bg)
                glow_view = None

                card_layout = LinearLayoutClass(context)
                card_layout.setOrientation(LinearLayoutClass.VERTICAL)
                card_layout.setPadding(
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                )

                accent_line = View(context)
                accent_bg = GradientDrawable()
                accent_bg.setCornerRadius(AndroidUtilitiesClass.dp(2))
                accent_bg.setColor(as_java_color(with_alpha(accent_color, 0xD0)))
                accent_line.setBackground(accent_bg)
                try:
                    accent_line.setAlpha(0.0)
                except Exception:
                    pass
                card_layout.addView(
                    accent_line,
                    LayoutHelper.createLinear(42, 3, 0, 0, 0, 0, 10),
                )

                title_view = TextView(context)
                title_view.setText("")
                title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                title_view.setTypeface(AndroidUtilitiesClass.bold())
                title_view.setTextColor(as_java_color(accent_color))
                try:
                    title_view.setLineSpacing(AndroidUtilitiesClass.dp(2), 1.05)
                except Exception:
                    pass
                card_layout.addView(title_view)

                desc_view = TextView(context)
                desc_view.setText("")
                desc_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                try:
                    desc_color = int(ThemeClass.getColor(ThemeClass.key_dialogTextGray2))
                except Exception:
                    desc_color = 0xFF8F96A3
                desc_view.setTextColor(as_java_color(desc_color))
                try:
                    desc_view.setLineSpacing(AndroidUtilitiesClass.dp(3), 1.1)
                except Exception:
                    pass
                card_layout.addView(desc_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 0))

                card_frame.addView(card_layout, LayoutHelper.createFrame(-1, -2))
                return {
                    "card": card_frame,
                    "content": card_layout,
                    "glow": glow_view,
                    "accent_line": accent_line,
                    "title_view": title_view,
                    "desc_view": desc_view,
                    "title_text": clean_ui_text(title),
                    "desc_text": clean_ui_text(description),
                    "title_color": int(accent_color),
                    "desc_color": int(desc_color),
                }

            def post_delayed(delay_ms: int, callback):
                class DelayedRunnable(dynamic_proxy(JRunnable)):
                    def run(self_inner):
                        try:
                            callback()
                        except Exception:
                            pass

                runnable = DelayedRunnable()
                try:
                    main_handler.postDelayed(runnable, int(delay_ms))
                except Exception:
                    run_on_ui_thread(callback)
                return runnable

            def cancel_view_anim(view):
                if view is None:
                    return
                try:
                    if hasattr(view, "animate"):
                        view.animate().cancel()
                except Exception:
                    pass

            def prepare_note_layers(note_info: Optional[Dict[str, Any]]):
                if not note_info:
                    return

                content = note_info.get("content")
                glow = note_info.get("glow")
                accent_line = note_info.get("accent_line")

                cancel_view_anim(content)
                cancel_view_anim(glow)
                cancel_view_anim(accent_line)

                try:
                    if content is not None:
                        content.setAlpha(0.0)
                        content.setTranslationY(AndroidUtilitiesClass.dp(10))
                except Exception:
                    pass

                try:
                    if glow is not None:
                        glow.setAlpha(0.0)
                        glow.setScaleX(0.92)
                        glow.setScaleY(0.9)
                except Exception:
                    pass

                try:
                    if accent_line is not None:
                        accent_line.setPivotX(0.0)
                        accent_line.setAlpha(0.0)
                        accent_line.setScaleX(0.58)
                        accent_line.setTranslationX(-AndroidUtilitiesClass.dp(8))
                except Exception:
                    pass

            def animate_note_layers_in(note_info: Optional[Dict[str, Any]], state: Optional[Dict[str, Any]], animation_id: int):
                if not note_info:
                    return

                content = note_info.get("content")
                glow = note_info.get("glow")
                accent_line = note_info.get("accent_line")

                def start_glow():
                    try:
                        if state is not None and (state.get("animation_id") != animation_id or not state.get("visible")):
                            return
                        if glow is None:
                            return
                        animator = glow.animate().alpha(0.72).scaleX(1.012).scaleY(1.008).setDuration(260)
                        if AccelerateDecelerateInterpolator:
                            try:
                                animator.setInterpolator(AccelerateDecelerateInterpolator())
                            except Exception:
                                pass
                        animator.start()

                        def settle_glow():
                            try:
                                if state is not None and (state.get("animation_id") != animation_id or not state.get("visible")):
                                    return
                                glow.animate().alpha(0.16).scaleX(1.0).scaleY(1.0).setDuration(280).start()
                            except Exception:
                                pass

                        post_delayed(200, settle_glow)
                    except Exception:
                        pass

                def start_content():
                    try:
                        if state is not None and (state.get("animation_id") != animation_id or not state.get("visible")):
                            return
                        if content is None:
                            return
                        animator = content.animate().alpha(1.0).translationY(0).setDuration(320)
                        if DecelerateInterpolator:
                            try:
                                animator.setInterpolator(DecelerateInterpolator())
                            except Exception:
                                pass
                        animator.start()
                    except Exception:
                        pass

                def start_accent():
                    try:
                        if state is not None and (state.get("animation_id") != animation_id or not state.get("visible")):
                            return
                        if accent_line is None:
                            return
                        animator = accent_line.animate().alpha(1.0).translationX(0).scaleX(1.08).setDuration(250)
                        if OvershootInterpolator:
                            try:
                                animator.setInterpolator(OvershootInterpolator(0.5))
                            except Exception:
                                pass
                        animator.start()

                        def settle_accent():
                            try:
                                if state is not None and (state.get("animation_id") != animation_id or not state.get("visible")):
                                    return
                                accent_line.animate().scaleX(1.0).setDuration(150).start()
                            except Exception:
                                pass

                        post_delayed(170, settle_accent)
                    except Exception:
                        pass

                post_delayed(45, start_glow)
                post_delayed(115, start_content)
                post_delayed(135, start_accent)

            def animate_note_layers_out(note_info: Optional[Dict[str, Any]], state: Optional[Dict[str, Any]], animation_id: int):
                if not note_info:
                    return

                content = note_info.get("content")
                glow = note_info.get("glow")
                accent_line = note_info.get("accent_line")

                try:
                    if state is not None and (state.get("animation_id") != animation_id or state.get("visible")):
                        return
                except Exception:
                    pass

                try:
                    if content is not None:
                        cancel_view_anim(content)
                        animator = content.animate().alpha(0.0).translationY(-AndroidUtilitiesClass.dp(5)).setDuration(120)
                        if AccelerateDecelerateInterpolator:
                            try:
                                animator.setInterpolator(AccelerateDecelerateInterpolator())
                            except Exception:
                                pass
                        animator.start()
                except Exception:
                    pass

                try:
                    if accent_line is not None:
                        cancel_view_anim(accent_line)
                        accent_line.animate().alpha(0.0).translationX(-AndroidUtilitiesClass.dp(6)).scaleX(0.68).setDuration(105).start()
                except Exception:
                    pass

                try:
                    if glow is not None:
                        cancel_view_anim(glow)
                        glow.animate().alpha(0.0).scaleX(0.94).scaleY(0.92).setDuration(130).start()
                except Exception:
                    pass

            def clamp01(value: float) -> float:
                return max(0.0, min(1.0, float(value)))

            def ease_out_cubic(value: float) -> float:
                t = clamp01(value)
                return 1.0 - math.pow(1.0 - t, 3.0)

            def blend_rgb(color_from: int, color_to: int, amount: float) -> int:
                t = clamp01(amount)
                start = int(color_from) & 0x00FFFFFF
                end = int(color_to) & 0x00FFFFFF
                from_r = (start >> 16) & 0xFF
                from_g = (start >> 8) & 0xFF
                from_b = start & 0xFF
                to_r = (end >> 16) & 0xFF
                to_g = (end >> 8) & 0xFF
                to_b = end & 0xFF
                out_r = int(round(from_r + ((to_r - from_r) * t)))
                out_g = int(round(from_g + ((to_g - from_g) * t)))
                out_b = int(round(from_b + ((to_b - from_b) * t)))
                return 0xFF000000 | (out_r << 16) | (out_g << 8) | out_b

            def build_text_reveal_map(text: str):
                positions: List[float] = []
                cursor = 0.0
                previous_was_space = True

                for char in text:
                    positions.append(cursor)
                    if char in "\r\n":
                        step = 0.18
                    elif char.isspace():
                        step = 0.30
                    elif char in ",.;:!?":
                        step = 0.72
                    elif char in ")]}\"'":
                        step = 0.62
                    elif char in "([{\"":
                        step = 0.55
                    else:
                        step = 1.0

                    if previous_was_space and not char.isspace():
                        step = max(0.78, step - 0.08)

                    cursor += step
                    previous_was_space = char.isspace()

                return positions, max(1.0, cursor)

            def set_text_reveal_progress(text_view, full_text: str, base_color: int, progress: float):
                text = str(full_text or "")
                total = len(text)
                if total <= 0:
                    try:
                        text_view.setText("")
                    except Exception:
                        pass
                    return

                clamped = max(0.0, min(float(total), float(progress)))
                if not SpannableStringBuilder or not ForegroundColorSpan:
                    visible_chars = int(round(clamped))
                    try:
                        text_view.setText(text[:max(0, min(total, visible_chars))])
                    except Exception:
                        pass
                    return

                try:
                    builder = SpannableStringBuilder(text)
                    positions, weighted_total = build_text_reveal_map(text)
                    weighted_progress = (clamped / float(total)) * weighted_total
                    fully_visible = 0

                    for index in range(total):
                        start_unit = positions[index]
                        next_unit = positions[index + 1] if index + 1 < total else weighted_total
                        reveal_window = max(0.58, (next_unit - start_unit) * 1.75)
                        phase = (weighted_progress - start_unit) / reveal_window
                        if phase >= 1.0:
                            fully_visible = index + 1
                            continue
                        break

                    if fully_visible > 0:
                        builder.setSpan(
                            ForegroundColorSpan(as_java_color(base_color)),
                            0,
                            min(fully_visible, total),
                            33,
                        )

                    hidden_start = total

                    for index in range(fully_visible, total):
                        start_unit = positions[index]
                        next_unit = positions[index + 1] if index + 1 < total else weighted_total
                        reveal_window = max(0.58, (next_unit - start_unit) * 1.75)
                        phase = (weighted_progress - start_unit) / reveal_window

                        if phase <= 0.0:
                            hidden_start = index
                            break

                        eased = ease_out_cubic(phase)
                        shimmer = math.sin(clamp01(phase) * math.pi)
                        alpha = int(max(0, min(255, round(255.0 * eased))))
                        highlight = 0.0 if text[index].isspace() else 0.16 * shimmer * (1.0 - (eased * 0.22))
                        char_color = blend_rgb(base_color, 0xFFFFFFFF, highlight)

                        builder.setSpan(
                            ForegroundColorSpan(as_java_color(with_alpha(char_color, alpha))),
                            index,
                            index + 1,
                            33,
                        )

                        if RelativeSizeSpan is not None and not text[index].isspace():
                            size = 0.985 + (0.015 * eased) + (0.035 * shimmer * (1.0 - (eased * 0.45)))
                            if abs(size - 1.0) >= 0.01:
                                builder.setSpan(
                                    RelativeSizeSpan(float(size)),
                                    index,
                                    index + 1,
                                    33,
                                )

                    if hidden_start < total:
                        builder.setSpan(
                            ForegroundColorSpan(as_java_color(with_alpha(base_color, 0))),
                            hidden_start,
                            total,
                            33,
                        )

                    if fully_visible == 0 and hidden_start == total and clamped <= 0.0:
                        builder.setSpan(
                            ForegroundColorSpan(as_java_color(with_alpha(base_color, 0))),
                            0,
                            total,
                            33,
                        )

                    text_view.setText(builder)
                except Exception:
                    try:
                        visible_chars = int(round(clamped))
                        text_view.setText(text[:max(0, min(total, visible_chars))])
                    except Exception:
                        pass

            def start_note_text_animation(note_info: Dict[str, Any], state: Dict[str, Any], animation_id: int):
                title_text = str(note_info.get("title_text") or "")
                desc_text = str(note_info.get("desc_text") or "")
                title_len = len(title_text)
                desc_len = len(desc_text)
                started_at = time.monotonic()
                title_duration_ms = max(500.0, min(860.0, float(title_len) * 22.0))
                desc_duration_ms = max(980.0, min(1900.0, float(desc_len) * 8.8))
                desc_delay_ms = min(320.0, title_duration_ms * 0.38)

                def compute_progress(total_chars: int, duration_ms: float, delay_ms: float = 0.0) -> float:
                    if total_chars <= 0:
                        return 0.0

                    elapsed_ms = max(0.0, (time.monotonic() - started_at) * 1000.0 - delay_ms)
                    if elapsed_ms <= 0.0:
                        return 0.0

                    normalized = clamp01(elapsed_ms / max(1.0, duration_ms))
                    eased = ease_out_cubic(normalized)
                    surge = math.sin(normalized * math.pi) * 0.035 * (1.0 - normalized)
                    return min(float(total_chars), float(total_chars) * min(1.0, eased + surge))

                def tick():
                    try:
                        if state.get("animation_id") != animation_id or not state.get("visible"):
                            return

                        title_progress = compute_progress(title_len, title_duration_ms, 0.0)
                        desc_progress = compute_progress(desc_len, desc_duration_ms, desc_delay_ms)

                        set_text_reveal_progress(note_info["title_view"], title_text, int(note_info["title_color"]), title_progress)
                        set_text_reveal_progress(note_info["desc_view"], desc_text, int(note_info["desc_color"]), desc_progress)

                        if title_progress < float(title_len) or desc_progress < float(desc_len):
                            post_delayed(16, tick)
                    except Exception:
                        try:
                            note_info["title_view"].setText(title_text)
                            note_info["desc_view"].setText(desc_text)
                        except Exception:
                            pass

                set_text_reveal_progress(note_info["title_view"], title_text, int(note_info["title_color"]), 0.0)
                set_text_reveal_progress(note_info["desc_view"], desc_text, int(note_info["desc_color"]), 0.0)
                post_delayed(96, tick)

            def _apply_card_motion_origin(view):
                if view is None:
                    return
                try:
                    width = float(view.getWidth() or 0.0)
                    if width > 0.0:
                        view.setPivotX(width / 2.0)
                except Exception:
                    pass
                try:
                    view.setPivotY(0.0)
                except Exception:
                    pass
                try:
                    metrics = context.getResources().getDisplayMetrics()
                    density = float(getattr(metrics, "density", 1.0) or 1.0)
                    view.setCameraDistance(max(1.0, density) * 2200.0)
                except Exception:
                    pass

            def animate_reveal(view, note_info: Optional[Dict[str, Any]] = None, state: Optional[Dict[str, Any]] = None, animation_id: int = 0):
                if view is None:
                    return
                cancel_view_anim(view)

                try:
                    _apply_card_motion_origin(view)
                    prepare_note_layers(note_info)
                    view.setAlpha(0.0)
                    view.setTranslationY(AndroidUtilitiesClass.dp(18))
                    view.setScaleX(0.958)
                    view.setScaleY(0.76)
                    try:
                        view.setRotationX(-10.0)
                    except Exception:
                        pass

                    class RevealSettleRunnable(dynamic_proxy(JRunnable)):
                        def run(self_inner):
                            try:
                                if state is not None:
                                    if state.get("animation_id") != animation_id or not state.get("visible"):
                                        return
                                settle = view.animate().translationY(0).scaleX(1.0).scaleY(1.0).rotationX(0.0).setDuration(190)
                                if DecelerateInterpolator:
                                    try:
                                        settle.setInterpolator(DecelerateInterpolator())
                                    except Exception:
                                        pass
                                elif AccelerateDecelerateInterpolator:
                                    try:
                                        settle.setInterpolator(AccelerateDecelerateInterpolator())
                                    except Exception:
                                        pass
                                settle.start()
                            except Exception:
                                pass

                    animator = view.animate().alpha(1.0).translationY(-AndroidUtilitiesClass.dp(1)).scaleX(1.0).scaleY(1.026).rotationX(1.2).setDuration(430)

                    if OvershootInterpolator:
                        try:
                            animator.setInterpolator(OvershootInterpolator(0.68))
                        except Exception:
                            try:
                                animator.setInterpolator(OvershootInterpolator())
                            except Exception:
                                pass
                    elif DecelerateInterpolator:
                        try:
                            animator.setInterpolator(DecelerateInterpolator())
                        except Exception:
                            pass
                    elif AccelerateDecelerateInterpolator:
                        try:
                            animator.setInterpolator(AccelerateDecelerateInterpolator())
                        except Exception:
                            pass
                    animator.withEndAction(RevealSettleRunnable()).start()
                    animate_note_layers_in(note_info, state, animation_id)
                except Exception:
                    try:
                        view.setAlpha(1.0)
                        view.setTranslationY(0)
                        view.setScaleX(1.0)
                        view.setScaleY(1.0)
                        try:
                            view.setRotationX(0.0)
                        except Exception:
                            pass
                    except Exception:
                        pass

            def animate_hide(view, note_info: Optional[Dict[str, Any]] = None, state: Optional[Dict[str, Any]] = None, animation_id: int = 0):
                if view is None:
                    return
                cancel_view_anim(view)

                try:
                    _apply_card_motion_origin(view)
                    animate_note_layers_out(note_info, state, animation_id)

                    class HideEndRunnable(dynamic_proxy(JRunnable)):
                        def run(self_inner):
                            try:
                                if state is not None:
                                    if state.get("animation_id") != animation_id or state.get("visible"):
                                        return
                                view.setVisibility(View.GONE)
                                view.setAlpha(1.0)
                                view.setTranslationY(0)
                                view.setScaleX(1.0)
                                view.setScaleY(1.0)
                                try:
                                    view.setRotationX(0.0)
                                except Exception:
                                    pass
                            except Exception:
                                pass

                    class HideFoldRunnable(dynamic_proxy(JRunnable)):
                        def run(self_inner):
                            try:
                                if state is not None:
                                    if state.get("animation_id") != animation_id or state.get("visible"):
                                        return
                                fold = view.animate().alpha(0.0).translationY(-AndroidUtilitiesClass.dp(3)).scaleX(0.986).scaleY(0.78).rotationX(9.5).setDuration(250)
                                if AccelerateInterpolator:
                                    try:
                                        fold.setInterpolator(AccelerateInterpolator(1.08))
                                    except Exception:
                                        try:
                                            fold.setInterpolator(AccelerateInterpolator())
                                        except Exception:
                                            pass
                                elif AccelerateDecelerateInterpolator:
                                    try:
                                        fold.setInterpolator(AccelerateDecelerateInterpolator())
                                    except Exception:
                                        pass
                                fold.withEndAction(HideEndRunnable()).start()
                            except Exception:
                                pass

                    animator = view.animate().translationY(AndroidUtilitiesClass.dp(2)).scaleX(1.004).scaleY(1.016).rotationX(-1.0).setDuration(95)
                    if AccelerateDecelerateInterpolator:
                        try:
                            animator.setInterpolator(AccelerateDecelerateInterpolator())
                        except Exception:
                            pass
                    elif DecelerateInterpolator:
                        try:
                            animator.setInterpolator(DecelerateInterpolator())
                        except Exception:
                            pass
                    animator.withEndAction(HideFoldRunnable()).start()
                except Exception:
                    try:
                        view.setVisibility(View.GONE)
                        view.setAlpha(1.0)
                        view.setTranslationY(0)
                        view.setScaleX(1.0)
                        view.setScaleY(1.0)
                        try:
                            view.setRotationX(0.0)
                        except Exception:
                            pass
                    except Exception:
                        pass

            sheet = BottomSheet(context, False)
            try:
                sheet.fixNavigationBar(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                pass

            root = LinearLayoutClass(context)
            root.setOrientation(LinearLayoutClass.VERTICAL)
            root.setPadding(
                AndroidUtilitiesClass.dp(18),
                AndroidUtilitiesClass.dp(20),
                AndroidUtilitiesClass.dp(18),
                AndroidUtilitiesClass.dp(16),
            )
            try:
                root.setBackgroundColor(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                pass

            top_icon_res = resolve_drawable(
                "menu_feature_reliable",
                "menu_privacy_policy",
            )
            verdict_icon_res = resolve_drawable(
                verdict.get("icon_name"),
                *(verdict.get("icon_fallbacks") or ()),
                "menu_privacy_policy",
            )

            icon_holder = FrameLayout(context)
            icon_bg = GradientDrawable()
            icon_bg.setShape(GradientDrawable.OVAL)
            icon_bg.setColor(as_java_color(with_alpha(verdict["color"], 0x18)))

            icon_view = ImageView(context)
            if top_icon_res:
                icon_view.setImageResource(top_icon_res)
            else:
                icon_view.setImageResource(RClass.drawable.menu_privacy_policy)
            icon_view.setColorFilter(as_java_color(verdict["color"]))
            icon_view.setBackground(icon_bg)
            icon_view.setPadding(
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
            )
            icon_holder.addView(icon_view, LayoutHelper.createFrame(64, 64, Gravity.CENTER))
            root.addView(icon_holder, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 10))

            title_view = TextView(context)
            title_view.setText(texts.get("LOCAL_SCAN_TITLE"))
            title_view.setGravity(Gravity.CENTER)
            title_view.setTypeface(AndroidUtilitiesClass.bold())
            title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(title_view, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 8))

            subtitle_view = TextView(context)
            subtitle_view.setText(
                f"{local_result['plugin_name']} v{local_result['plugin_version']}\n"
                + (
                    "Локальная проверка кода."
                    if is_ru else
                    "Local code scan."
                )
            )
            subtitle_view.setGravity(Gravity.CENTER)
            subtitle_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            try:
                subtitle_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextGray2))
            except Exception:
                pass
            root.addView(subtitle_view, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 12))

            verdict_chip = create_chip(
                verdict["text"],
                verdict["color"],
                with_alpha(verdict["color"], 0x18),
                verdict_icon_res,
            )
            apply_chip_press_feedback(verdict_chip, verdict["color"])
            root.addView(verdict_chip, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 8))

            audit_note = create_note_card(
                audit_note_title,
                audit_note_text,
                verdict["color"],
            )
            audit_note_card = audit_note["card"]
            try:
                audit_note_card.setVisibility(View.GONE)
                audit_note_card.setAlpha(0.0)
            except Exception:
                pass
            root.addView(audit_note_card, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 12))

            audit_note_state = {"visible": False, "animation_id": 0}

            def set_view_visible(target_view, visible: bool):
                if target_view is None:
                    return
                try:
                    target_view.setVisibility(View.VISIBLE if visible else View.GONE)
                except Exception:
                    pass
                try:
                    target_view.setAlpha(1.0 if visible else 0.0)
                except Exception:
                    pass

            def on_verdict_chip_click(_view=None):
                try:
                    if audit_note_state["visible"]:
                        return

                    for target_view in (
                        icon_holder,
                        title_view,
                        subtitle_view,
                        verdict_chip,
                        summary_view,
                        body_scroll,
                    ):
                        set_view_visible(target_view, False)

                    audit_note_state["animation_id"] += 1
                    audit_note_state["visible"] = True
                    set_view_visible(audit_note_card, True)
                    set_view_visible(ai_button, True)
                    animate_reveal(audit_note_card, audit_note, audit_note_state, int(audit_note_state["animation_id"]))
                    start_note_text_animation(audit_note, audit_note_state, int(audit_note_state["animation_id"]))
                    try:
                        root.requestLayout()
                    except Exception:
                        pass
                except Exception:
                    pass

            verdict_chip.setOnClickListener(OnClickListener(on_verdict_chip_click))

            ai_button = ButtonWithCounterView(context, True, None)
            ai_button.setText(texts.get("LOCAL_SCAN_AI_BUTTON"), False)
            ai_button.setBackground(
                self._make_button_bg(
                    ThemeClass,
                    AndroidUtilitiesClass,
                    0xFF3390EC,
                    0xFF2D7FCF,
                )
            )
            ai_button.setOnClickListener(
                OnClickListener(lambda _view=None: self._start_ai_analysis(file_path, ai_button))
            )
            set_view_visible(ai_button, False)
            root.addView(ai_button, LayoutHelper.createLinear(-1, 50, 0, 0, 0, 0, 12))

            summary_view = TextView(context)
            summary_view.setText(local_result["summary"])
            summary_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            summary_view.setGravity(Gravity.LEFT)
            try:
                summary_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
            except Exception:
                pass
            try:
                summary_view.setLineSpacing(AndroidUtilitiesClass.dp(4), 1.12)
            except Exception:
                pass
            root.addView(summary_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 12))

            body_scroll = ScrollView(context)
            body_scroll.setVerticalScrollBarEnabled(False)

            body_layout = LinearLayoutClass(context)
            body_layout.setOrientation(LinearLayoutClass.VERTICAL)

            issues = local_result["issues"][:3]
            if issues:
                for issue in issues:
                    issue_style = self._get_verdict_style(issue["severity"])
                    issue_card = create_issue_card(issue["title"], issue["description"], issue_style["color"])
                    body_layout.addView(issue_card, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 10))
            else:
                safe_text = (
                    "Явных признаков вредоносной логики не видно."
                    if is_ru else
                    "No obvious signs of malicious logic are visible."
                )
                safe_card = create_issue_card(
                    "Локальная проверка" if is_ru else "Local scan",
                    safe_text,
                    verdict["color"],
                )
                body_layout.addView(safe_card, LayoutHelper.createLinear(-1, -2))

            body_scroll.addView(body_layout)
            root.addView(body_scroll, LayoutHelper.createLinear(-1, 0, 1.0, 0, 0, 0, 14))

            close_button = create_secondary_button(
                texts.get("LOCAL_SCAN_CLOSE_BUTTON"),
                lambda _view=None: sheet.dismiss(),
            )
            root.addView(close_button, LayoutHelper.createLinear(-1, 50))

            self._current_local_scan_sheet = sheet
            self._current_analyze_btn = ai_button
            sheet.setCustomView(root)
            sheet.show()

        except Exception:
            log(f"[Gemini] Ошибка показа локальной проверки: {traceback.format_exc()}")
            BulletinHelper.show_error(texts.get("UNEXPECTED_ERROR").format(error="Local scan UI"))

    def _scan_local_file_task(self, file_path: str):
        try:
            plugin_code = self._read_file_text(file_path)
            local_result = self._scan_local(plugin_code)
            run_on_ui_thread(lambda: self._show_local_sheet(file_path, local_result))

        except Exception as e:
            log(f"[Gemini] Ошибка локальной проверки: {traceback.format_exc()}")
            self._show_error("FILE_READ_ERROR", error=str(e))

    def _scan_file(self, file_path: str):
        if not self._ensure_enabled():
            return
        if not file_path:
            self._show_error("FILE_READ_ERROR")
            return
        self._show_scan_started()
        run_on_queue(lambda: self._scan_local_file_task(file_path))

    def _scan_document(self, document: Any):
        if not self._ensure_enabled():
            return

        self._show_scan_started()

        def task():
            try:
                file_path_obj = get_file_loader().getPathToAttach(document, True)
                file_path = file_path_obj.getAbsolutePath()
                if not self._wait_file(file_path, document):
                    self._show_error("FILE_DOWNLOAD_ERROR")
                    return
                self._scan_local_file_task(file_path)
            except Exception as e:
                log(f"[Gemini] Ошибка подготовки локальной проверки: {traceback.format_exc()}")
                self._show_error("UNEXPECTED_ERROR", error=str(e))

        run_on_queue(task)

    def _start_ai_analysis(self, file_path: str, analyze_btn=None):
        if self._is_analyzing:
            return

        self._is_analyzing = True

        def start_ui():
            try:
                if analyze_btn:
                    loading_text = self._build_ai_loading_text(analyze_btn, texts.get("AI_ANALYZING_BUTTON"))
                    if loading_text is not None:
                        analyze_btn.setText(loading_text, True)
                    else:
                        analyze_btn.setText(texts.get("AI_ANALYZING_BUTTON"), True)
                        self._start_dots(analyze_btn)
                    analyze_btn.setClickable(False)
                    analyze_btn.setEnabled(True)
                    analyze_btn.setAlpha(1.0)

            except Exception as e:
                log(f"[Gemini] Ошибка запуска AI-анимации: {e}")

        run_on_ui_thread(start_ui)
        self._analyze_file_ai(file_path, analyze_btn)

    def _hook_install_ui(self):
        try:
            target_ctor = self._get_install_sheet_ctor()
            if not target_ctor:
                log("[Gemini] Конструктор InstallPluginBottomSheet не найден")
                return

            try:
                target_ctor.setAccessible(True)
            except Exception:
                pass
            self._sheet_hook_ref = self.hook_method(target_ctor, self._InstallSheetHook(self))

        except Exception as e:
            log(f"[Gemini] Ошибка хука InstallPluginBottomSheet: {traceback.format_exc()}")

    class _InstallSheetHook(MethodHook):
        def __init__(self, plugin_instance):
            self.plugin = plugin_instance

        def after_hooked_method(self, param):
            plugin = self.plugin

            def modify_ui():
                try:
                    sheet = param.thisObject
                    install_params = param.args[2] if len(param.args) > 2 else None

                    if not sheet or not install_params:
                        return

                    file_path = plugin._get_field_deep(install_params, "filePath")
                    if not file_path:
                        return
                    file_path = str(file_path)

                    custom_view = plugin._get_field_deep(sheet, "customView")
                    if not custom_view:
                        custom_view = plugin._get_field_deep(sheet, "containerView")

                    if not custom_view:
                        return

                    ButtonWithCounterView = find_class("org.telegram.ui.Stories.recorder.ButtonWithCounterView")
                    LinearLayoutClass = find_class("android.widget.LinearLayout")
                    ThemeClass = find_class("org.telegram.ui.ActionBar.Theme")
                    AndroidUtilitiesClass = find_class("org.telegram.messenger.AndroidUtilities")

                    install_btn, parent_layout = plugin._find_view_pair(custom_view, ButtonWithCounterView)
                    if not install_btn or not parent_layout:
                        return

                    context = sheet.getContext()
                    resources_provider = plugin._call_zero_arg_deep(sheet, "getResourceProvider")

                    analyze_btn = ButtonWithCounterView(context, True, resources_provider)
                    analyze_btn.setText(texts.get("LOCAL_SCAN_BUTTON"), False)
                    analyze_btn.setBackground(
                        plugin._make_button_bg(
                            ThemeClass,
                            AndroidUtilitiesClass,
                            0xFF63B4F4,
                            0xFF4A9FE0,
                        )
                    )

                    plugin._current_analyze_btn = analyze_btn
                    plugin._current_sheet = sheet

                    class AnalyzeClickListener(dynamic_proxy(View.OnClickListener)):
                        def onClick(self_inner, v):
                            if file_path:
                                plugin._scan_file(file_path)
                            else:
                                BulletinHelper.show_error("Путь к файлу не найден")

                    analyze_btn.setOnClickListener(AnalyzeClickListener())

                    idx = -1
                    for i in range(parent_layout.getChildCount()):
                        if parent_layout.getChildAt(i) == install_btn:
                            idx = i + 1
                            break
                    
                    if idx != -1 and idx <= parent_layout.getChildCount():
                        lp = LinearLayoutClass.LayoutParams(install_btn.getLayoutParams())
                        lp.topMargin = AndroidUtilitiesClass.dp(8)
                        lp.bottomMargin = 0
                        
                        try:
                            install_lp = install_btn.getLayoutParams()
                            if isinstance(install_lp, LinearLayoutClass.LayoutParams):
                                install_lp.bottomMargin = 0
                                install_btn.setLayoutParams(install_lp)
                        except:
                            pass
                        
                        parent_layout.addView(analyze_btn, idx, lp)

                except Exception as e:
                    log(f"[Gemini] Ошибка модификации UI: {traceback.format_exc()}")

            run_on_ui_thread(modify_ui)

    def _start_dots(self, analyze_btn):
        self._dots_animation_running = True
        self._dots_count = 0
        base_text = texts.get("AI_ANALYZING_BUTTON")
        
        def update_dots():
            if not self._dots_animation_running:
                return
            
            try:
                self._dots_count = (self._dots_count % 3) + 1
                dots = "." * self._dots_count
                
                def set_text():
                    if analyze_btn and self._dots_animation_running:
                        try:
                            analyze_btn.setText(f"{base_text}{dots}", True)
                        except Exception:
                            pass
                
                run_on_ui_thread(set_text)
                
                if self._dots_animation_running:
                    from android.os import Handler, Looper
                    handler = Handler(Looper.getMainLooper())
                    
                    from java import dynamic_proxy
                    from java.lang import Runnable as JRunnable
                    
                    class DotsRunnable(dynamic_proxy(JRunnable)):
                        def run(self_inner):
                            update_dots()
                    
                    handler.postDelayed(DotsRunnable(), 420)
                    
            except Exception as e:
                log(f"[Gemini] Ошибка анимации точек: {e}")
        
        update_dots()

    def _stop_dots(self):
        self._dots_animation_running = False

    def _analyze_file_ai(self, file_path: str, analyze_btn=None):
        error_text = "Ошибка" if texts.language == "ru" else "Error"
        try:
            missing_key_text = "API ключ не найден" if texts.language == "ru" else "API key missing"
            disabled_text = "Плагин отключен" if texts.language == "ru" else "Plugin disabled"
            analysis_error_text = "Ошибка анализа" if texts.language == "ru" else "Analysis error"

            provider_type = self._get_provider_type()
            api_key_error = "OPENAI_API_KEY_MISSING" if provider_type == API_PROVIDER_OPENAI_COMPATIBLE else "API_KEY_MISSING"
            api_key = self._get_api_key(provider_type)
            if not api_key:
                self._show_error(api_key_error)
                self._reset_ai_button(analyze_btn, missing_key_text)
                return

            if not self.get_setting("enabled", True):
                self._show_error("PLUGIN_DISABLED")
                self._reset_ai_button(analyze_btn, disabled_text)
                return

            def analyze_task():
                try:
                    plugin_code, plugin_name, plugin_version = self._load_plugin_source(file_path)
                    masked_code = self._mask_code(plugin_code)
                    use_blockquote = self.get_setting("use_blockquote", True)
                    temperature = self._get_float_setting("gemini_temperature", "0.2", 0.2)
                    max_tokens = self._get_int_setting("gemini_max_tokens", "200000", 200000)
                    full_prompt = self._build_prompt(masked_code, plugin_name, plugin_version, use_blockquote)
                    result = self._run_ai_request(
                        provider_type,
                        api_key,
                        full_prompt,
                        temperature,
                        max_tokens,
                        "gpt-5",
                    )

                    if result.get("success"):
                        response_text = result["text"]
                        verdict = self._parse_verdict(response_text)
                        self._set_ai_button_verdict(analyze_btn, verdict, response_text)
                    else:
                        error_msg = result.get("error", "Unknown")
                        self._show_error("API_ERROR", error=error_msg)
                        self._reset_ai_button(analyze_btn, error_text)

                except Exception as e:
                    log(f"[Gemini] Ошибка анализа из меню установки: {traceback.format_exc()}")
                    self._show_error("UNEXPECTED_ERROR", error=str(e))
                    self._reset_ai_button(analyze_btn, analysis_error_text)

            run_on_queue(analyze_task)

        except Exception as e:
            log(f"[Gemini] Ошибка _analyze_file_ai: {traceback.format_exc()}")
            self._show_error("UNEXPECTED_ERROR", error=str(e))
            self._reset_ai_button(analyze_btn, error_text)

    def _parse_verdict(self, response_text: str) -> dict:
        verdict_line = response_text.split('\n', 1)[0].strip()
        clean_verdict = verdict_line.replace("◈ Вердикт:", "").strip()
        
        if "✅" in verdict_line or "Безопасно" in verdict_line or "Safe" in verdict_line:
            return self._get_verdict_style("safe")
        elif "❌" in verdict_line or "Опасно" in verdict_line or "Danger" in verdict_line:
            return self._get_verdict_style("danger")
        elif "📛" in verdict_line or "Высокий риск" in verdict_line or "High risk" in verdict_line:
            return self._get_verdict_style("high_risk")
        elif "⚠️" in verdict_line or "Осторожно" in verdict_line or "Caution" in verdict_line:
            return self._get_verdict_style("caution")
        elif "❔" in verdict_line or "Низкий риск" in verdict_line or "Low risk" in verdict_line:
            return self._get_verdict_style("low_risk")
        else:
            return self._get_verdict_style("unknown", clean_verdict[:30] if clean_verdict else None)

    def _set_ai_button_verdict(self, analyze_btn, verdict: dict, full_response: str):
        def update_ui():
            try:
                self._reset_ai_state()

                if analyze_btn:
                    analyze_btn.setAlpha(1.0)
                
                if analyze_btn:
                    analyze_btn.setText(verdict["text"], True)
                    analyze_btn.setClickable(True)
                    analyze_btn.setEnabled(True)
                    
                    ThemeClass = find_class("org.telegram.ui.ActionBar.Theme")
                    AndroidUtilitiesClass = find_class("org.telegram.messenger.AndroidUtilities")

                    verdict_color = as_java_color(verdict["color"])
                    pressed_color = as_java_color(verdict["color"] - 0x00202020)
                    
                    new_bg = ThemeClass.createSimpleSelectorRoundRectDrawable(
                        AndroidUtilitiesClass.dp(8), verdict_color, pressed_color
                    )
                    analyze_btn.setBackground(new_bg)
                    
                    self._last_analysis_response = full_response
                    
                    class ShowReportClickListener(dynamic_proxy(View.OnClickListener)):
                        def onClick(self_inner, v):
                            self._show_styled_report_sheet()
                    
                    analyze_btn.setOnClickListener(ShowReportClickListener())
                    self._show_styled_report_sheet()

            except Exception as e:
                log(f"[Gemini] Ошибка обновления кнопки: {traceback.format_exc()}")
        
        run_on_ui_thread(update_ui)

    def _reset_ai_button(self, analyze_btn, text: Optional[str] = None):
        if text is None:
            text = texts.get("LOCAL_SCAN_AI_BUTTON")

        def reset_ui():
            self._reset_ai_state()

            if analyze_btn:
                try:
                    analyze_btn.setAlpha(1.0)
                except:
                    pass
            try:
                if analyze_btn:
                    analyze_btn.setText(text, True)
                    analyze_btn.setClickable(True)
                    analyze_btn.setEnabled(True)
            except Exception as e:
                log(f"[Gemini] Ошибка сброса кнопки: {e}")
        
        run_on_ui_thread(reset_ui)

    def _show_full_report(self, source_view=None):
        try:
            report_data = self._prepare_report_sheet_data()
            if not report_data:
                self._restore_report_preview_state(source_view)
                return

            fragment = get_last_fragment()
            if not fragment or not hasattr(fragment, "getParentActivity"):
                self._restore_report_preview_state(source_view)
                self._show_full_report_alert()
                return

            context = fragment.getParentActivity()
            if not context:
                self._restore_report_preview_state(source_view)
                self._show_full_report_alert()
                return

            self.alerts.dismiss_dialog()
            previous_sheet = None
            if source_view is None:
                self._dismiss_report_sheet()
            else:
                previous_sheet = self._current_report_sheet

            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            BottomSheetBuilder = None
            try:
                BottomSheetBuilder = jclass("org.telegram.ui.ActionBar.BottomSheet$Builder")
            except Exception:
                BottomSheetBuilder = None
            ThemeClass = jclass("org.telegram.ui.ActionBar.Theme")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            LinearLayoutClass = jclass("android.widget.LinearLayout")
            ScrollView = jclass("android.widget.ScrollView")
            TextView = jclass("android.widget.TextView")
            FrameLayout = jclass("android.widget.FrameLayout")
            TypedValue = jclass("android.util.TypedValue")
            Gravity = jclass("android.view.Gravity")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")

            sheet_ref = {"sheet": None}

            root = FrameLayout(context)
            try:
                root.setBackgroundColor(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                root.setBackgroundColor(as_java_color(0xFFFFFFFF))

            content = LinearLayoutClass(context)
            content.setOrientation(LinearLayoutClass.VERTICAL)
            content_top_padding = max(AndroidUtilities.dp(12), int(getattr(AndroidUtilities, "statusBarHeight", 0) or 0) + AndroidUtilities.dp(8))
            content.setPadding(
                AndroidUtilities.dp(18),
                content_top_padding,
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(16),
            )
            root.addView(content, LayoutHelper.createFrame(-1, -1))

            body_scroll = ScrollView(context)
            body_scroll.setVerticalScrollBarEnabled(False)
            try:
                body_scroll.setFillViewport(True)
            except Exception:
                pass
            body_scroll.setPadding(
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(26),
            )

            body_text_view = TextView(context)
            body_text_view.setText(report_data["report_text"])
            body_text_view.setTextIsSelectable(True)
            body_text_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            try:
                body_text_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
            except Exception:
                body_text_view.setTextColor(as_java_color(0xFF111111))
            try:
                body_text_view.setLineSpacing(AndroidUtilities.dp(4), 1.14)
            except Exception:
                pass

            body_scroll.addView(body_text_view)
            content.addView(body_scroll, LayoutHelper.createLinear(-1, 0, 1.0))

            sheet = None
            if BottomSheetBuilder is not None:
                try:
                    builder = BottomSheetBuilder(context, False)
                    builder.setApplyTopPadding(False)
                    builder.setApplyBottomPadding(False)
                    builder.setCustomView(root)
                    try:
                        builder.setUseFullWidth(True)
                    except Exception:
                        pass
                    try:
                        builder.setUseFullscreen(True)
                    except Exception:
                        pass
                    sheet = builder.create()
                except Exception:
                    sheet = None

            if sheet is None:
                sheet = BottomSheet(context, False)
                try:
                    sheet.setApplyTopPadding(False)
                    sheet.setApplyBottomPadding(False)
                except Exception:
                    pass
                sheet.setCustomView(root)

            try:
                sheet.setCanDismissWithSwipe(True)
            except Exception:
                pass
            try:
                sheet.setCanDismissWithTouchOutside(True)
            except Exception:
                pass
            try:
                sheet.fixNavigationBar(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                pass

            self._current_report_sheet = sheet
            sheet_ref["sheet"] = sheet
            sheet.show()
            self._animate_full_report_entry(root, content, source_view)

            if previous_sheet and previous_sheet != sheet:
                def dismiss_previous():
                    try:
                        previous_sheet.dismiss()
                    except Exception:
                        pass
                run_on_ui_thread(dismiss_previous, 90)
            elif source_view is not None:
                self._restore_report_preview_state(source_view)
        except Exception as e:
            self._restore_report_preview_state(source_view)
            log(f"[Gemini] Fullscreen report UI error: {traceback.format_exc()}")
            self._show_full_report_alert()

    def _show_styled_report_sheet(self):
        try:
            report_data = self._prepare_report_sheet_data()
            if not report_data:
                return

            fragment = get_last_fragment()
            if not fragment or not hasattr(fragment, "getParentActivity"):
                self._show_full_report()
                return

            context = fragment.getParentActivity()
            if not context:
                self._show_full_report()
                return

            self.alerts.dismiss_dialog()
            self._dismiss_report_sheet()
            report_text = report_data["report_text"]
            verdict = report_data["verdict"]
            preview_text = report_data["preview_text"]
            provider_name = report_data["provider_name"]
            model_name = report_data["model_name"]
            title_text = report_data["title_text"]
            preview_title = report_data["preview_title"]

            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            ThemeClass = jclass("org.telegram.ui.ActionBar.Theme")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            LinearLayoutClass = jclass("android.widget.LinearLayout")
            ScrollView = jclass("android.widget.ScrollView")
            TextView = jclass("android.widget.TextView")
            ImageView = jclass("android.widget.ImageView")
            FrameLayout = jclass("android.widget.FrameLayout")
            TypedValue = jclass("android.util.TypedValue")
            Gravity = jclass("android.view.Gravity")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            RClass = jclass("org.telegram.messenger.R")
            AndroidUtilitiesClass = jclass("org.telegram.messenger.AndroidUtilities")

            def resolve_drawable(*names: str) -> int:
                drawable_class = None
                resources = None
                package_name = None
                try:
                    drawable_class = getattr(RClass, "drawable", None)
                except Exception:
                    drawable_class = None
                try:
                    resources = context.getResources()
                except Exception:
                    resources = None
                try:
                    package_name = context.getPackageName()
                except Exception:
                    package_name = None

                seen = set()
                for name in names:
                    candidate = str(name or "").strip()
                    if not candidate or candidate in seen:
                        continue
                    seen.add(candidate)
                    if drawable_class is not None:
                        try:
                            res_id = int(getattr(drawable_class, candidate, 0) or 0)
                            if res_id:
                                return res_id
                        except Exception:
                            pass
                    if resources is not None and package_name:
                        try:
                            res_id = int(resources.getIdentifier(candidate, "drawable", package_name) or 0)
                            if res_id:
                                return res_id
                        except Exception:
                            pass
                return 0

            def create_chip(text: str, text_color: int, bg_color: int, icon_res: int = 0):
                chip_frame = FrameLayout(context)
                chip_bg = GradientDrawable()
                chip_bg.setCornerRadius(AndroidUtilitiesClass.dp(14))
                chip_bg.setColor(as_java_color(bg_color))
                chip_frame.setBackground(chip_bg)

                chip_layout = LinearLayoutClass(context)
                chip_layout.setOrientation(LinearLayoutClass.HORIZONTAL)
                chip_layout.setGravity(Gravity.CENTER)
                chip_layout.setPadding(
                    AndroidUtilitiesClass.dp(10),
                    AndroidUtilitiesClass.dp(5),
                    AndroidUtilitiesClass.dp(10),
                    AndroidUtilitiesClass.dp(5),
                )

                if icon_res:
                    chip_icon = ImageView(context)
                    chip_icon.setImageResource(icon_res)
                    chip_icon.setColorFilter(as_java_color(text_color))
                    chip_layout.addView(
                        chip_icon,
                        LayoutHelper.createLinear(14, 14, Gravity.CENTER_VERTICAL, 0, 0, 6, 0),
                    )

                chip_text = TextView(context)
                chip_text.setText(text)
                chip_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                chip_text.setTypeface(AndroidUtilitiesClass.bold())
                chip_text.setTextColor(as_java_color(text_color))
                chip_layout.addView(chip_text, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL))
                chip_frame.addView(chip_layout, LayoutHelper.createFrame(-2, -2, Gravity.CENTER))
                return chip_frame

            def create_text_card(title: str, description: str, accent_color: int):
                card_frame = FrameLayout(context)
                card_bg = GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilitiesClass.dp(16))
                card_bg.setColor(as_java_color(with_alpha(accent_color, 0x10)))
                try:
                    card_bg.setStroke(AndroidUtilitiesClass.dp(1), as_java_color(with_alpha(accent_color, 0x18)))
                except Exception:
                    pass
                card_frame.setBackground(card_bg)

                card_layout = LinearLayoutClass(context)
                card_layout.setOrientation(LinearLayoutClass.VERTICAL)
                card_layout.setPadding(
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                    AndroidUtilitiesClass.dp(14),
                    AndroidUtilitiesClass.dp(12),
                )

                header_view = TextView(context)
                header_view.setText(title)
                header_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                header_view.setTypeface(AndroidUtilitiesClass.bold())
                header_view.setTextColor(as_java_color(accent_color))
                card_layout.addView(header_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 8))

                body_view = TextView(context)
                body_view.setText(description)
                body_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                try:
                    body_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
                except Exception:
                    body_view.setTextColor(as_java_color(0xFF111111))
                try:
                    body_view.setLineSpacing(AndroidUtilitiesClass.dp(3), 1.1)
                except Exception:
                    pass
                card_layout.addView(body_view, LayoutHelper.createLinear(-1, -2))

                card_frame.addView(card_layout, LayoutHelper.createFrame(-1, -2))
                return card_frame

            def create_secondary_button(text: str, icon_res: int, on_click):
                button_frame = FrameLayout(context)
                button_bg = GradientDrawable()
                button_bg.setCornerRadius(AndroidUtilitiesClass.dp(18))
                try:
                    button_bg.setColor(ThemeClass.getColor(ThemeClass.key_listSelector))
                except Exception:
                    button_bg.setColor(as_java_color(0xFFF1F1F1))
                button_frame.setBackground(button_bg)
                button_frame.setClickable(True)
                button_frame.setFocusable(True)

                button_layout = LinearLayoutClass(context)
                button_layout.setOrientation(LinearLayoutClass.HORIZONTAL)
                button_layout.setGravity(Gravity.CENTER)
                button_layout.setPadding(
                    AndroidUtilitiesClass.dp(16),
                    AndroidUtilitiesClass.dp(10),
                    AndroidUtilitiesClass.dp(16),
                    AndroidUtilitiesClass.dp(10),
                )

                if icon_res:
                    button_icon = ImageView(context)
                    button_icon.setImageResource(icon_res)
                    try:
                        button_icon.setColorFilter(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
                    except Exception:
                        button_icon.setColorFilter(as_java_color(0xFF111111))
                    button_layout.addView(
                        button_icon,
                        LayoutHelper.createLinear(16, 16, Gravity.CENTER_VERTICAL, 0, 0, 6, 0),
                    )

                button_text = TextView(context)
                button_text.setText(text)
                button_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                button_text.setTypeface(AndroidUtilitiesClass.bold())
                try:
                    button_text.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
                except Exception:
                    button_text.setTextColor(as_java_color(0xFF111111))
                button_layout.addView(button_text, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL))

                button_frame.addView(button_layout, LayoutHelper.createFrame(-2, -2, Gravity.CENTER))
                button_frame.setOnClickListener(OnClickListener(on_click))
                return button_frame

            def create_primary_button(text: str, on_click):
                button_frame = FrameLayout(context)
                button_frame.setBackground(
                    self._make_button_bg(
                        ThemeClass,
                        AndroidUtilitiesClass,
                        0xFF3390EC,
                        0xFF2D7FCF,
                    )
                )
                button_frame.setClickable(True)
                button_frame.setFocusable(True)

                button_text = TextView(context)
                button_text.setText(text)
                button_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                button_text.setTypeface(AndroidUtilitiesClass.bold())
                button_text.setGravity(Gravity.CENTER)
                button_text.setTextColor(self._get_primary_button_text_color(ThemeClass))
                button_frame.addView(button_text, LayoutHelper.createFrame(-1, -1))
                button_frame.setOnClickListener(OnClickListener(on_click))
                return button_frame

            def close_report(_view=None):
                self._dismiss_report_sheet()

            sheet = BottomSheet(context, False)
            try:
                sheet.fixNavigationBar(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                pass

            root = LinearLayoutClass(context)
            root.setOrientation(LinearLayoutClass.VERTICAL)
            root.setPadding(
                AndroidUtilitiesClass.dp(18),
                AndroidUtilitiesClass.dp(18),
                AndroidUtilitiesClass.dp(18),
                AndroidUtilitiesClass.dp(16),
            )
            try:
                root.setBackgroundColor(ThemeClass.getColor(ThemeClass.key_dialogBackground))
            except Exception:
                pass

            top_icon_res = resolve_drawable("menu_feature_reliable", "menu_privacy_policy")
            verdict_icon_res = resolve_drawable(
                verdict.get("icon_name"),
                *(verdict.get("icon_fallbacks") or ()),
                "menu_privacy_policy",
            )
            copy_icon_res = resolve_drawable("msg_copy", "msg_select", "msg_message")

            icon_holder = FrameLayout(context)
            icon_bg = GradientDrawable()
            icon_bg.setShape(GradientDrawable.OVAL)
            icon_bg.setColor(as_java_color(with_alpha(verdict["color"], 0x18)))

            icon_view = ImageView(context)
            if top_icon_res:
                icon_view.setImageResource(top_icon_res)
            else:
                icon_view.setImageResource(RClass.drawable.menu_privacy_policy)
            icon_view.setColorFilter(as_java_color(verdict["color"]))
            icon_view.setBackground(icon_bg)
            icon_view.setPadding(
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
                AndroidUtilitiesClass.dp(14),
            )
            icon_holder.addView(icon_view, LayoutHelper.createFrame(64, 64, Gravity.CENTER))
            root.addView(icon_holder, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 14))

            title_view = TextView(context)
            title_view.setText(title_text)
            title_view.setGravity(Gravity.CENTER)
            title_view.setTypeface(AndroidUtilitiesClass.bold())
            title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
            try:
                title_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
            except Exception:
                title_view.setTextColor(as_java_color(0xFF111111))
            root.addView(title_view, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 8))

            tags_row = LinearLayoutClass(context)
            tags_row.setOrientation(LinearLayoutClass.HORIZONTAL)
            tags_row.setGravity(Gravity.CENTER)
            tags_row.addView(
                create_chip(provider_name, 0xFF3390EC, 0x163390EC),
                LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL, 0, 0, 8, 0),
            )
            tags_row.addView(
                create_chip(model_name, 0xFF7E57C2, 0x167E57C2),
                LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL),
            )
            root.addView(tags_row, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 8))

            verdict_chip = create_chip(
                verdict["text"],
                verdict["color"],
                with_alpha(verdict["color"], 0x18),
                verdict_icon_res,
            )
            root.addView(verdict_chip, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 8))

            preview_card = create_text_card(preview_title, preview_text, verdict["color"])
            root.addView(preview_card, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 8))

            body_frame = FrameLayout(context)
            body_bg = GradientDrawable()
            body_bg.setCornerRadius(AndroidUtilitiesClass.dp(16))
            try:
                body_bg.setColor(ThemeClass.getColor(ThemeClass.key_windowBackgroundWhite))
            except Exception:
                body_bg.setColor(as_java_color(0xFFF8F9FB))
            try:
                body_bg.setStroke(
                    AndroidUtilitiesClass.dp(1),
                    as_java_color(with_alpha(verdict["color"], 0x14)),
                )
            except Exception:
                pass
            body_frame.setBackground(body_bg)
            body_frame.setClickable(True)
            body_frame.setFocusable(True)
            try:
                body_frame.setForeground(
                    ThemeClass.createSimpleSelectorRoundRectDrawable(
                        AndroidUtilitiesClass.dp(16),
                        0,
                        as_java_color(with_alpha(verdict["color"], 0x08)),
                    )
                )
            except Exception:
                pass

            truncate_cls = None
            try:
                truncate_cls = jclass("android.text.TextUtils$TruncateAt")
            except Exception:
                truncate_cls = None

            body_text_view = TextView(context)
            body_text_view.setText(report_text)
            body_text_view.setTextIsSelectable(False)
            body_text_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            body_text_view.setPadding(
                AndroidUtilitiesClass.dp(16),
                AndroidUtilitiesClass.dp(10),
                AndroidUtilitiesClass.dp(16),
                AndroidUtilitiesClass.dp(10),
            )
            try:
                body_text_view.setTextColor(ThemeClass.getColor(ThemeClass.key_dialogTextBlack))
            except Exception:
                body_text_view.setTextColor(as_java_color(0xFF111111))
            try:
                body_text_view.setLineSpacing(AndroidUtilitiesClass.dp(4), 1.12)
            except Exception:
                pass
            try:
                body_text_view.setMaxLines(6)
            except Exception:
                pass
            if truncate_cls is not None:
                try:
                    body_text_view.setEllipsize(getattr(truncate_cls, "END"))
                except Exception:
                    pass

            body_frame.addView(body_text_view, LayoutHelper.createFrame(-1, -2, Gravity.TOP | Gravity.LEFT))
            body_frame.setOnClickListener(OnClickListener(lambda _view=None: self._open_full_report_from_preview(body_frame)))
            root.addView(body_frame, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 10))

            actions_row = LinearLayoutClass(context)
            actions_row.setOrientation(LinearLayoutClass.HORIZONTAL)
            actions_row.setGravity(Gravity.CENTER)
            copy_button = create_secondary_button(
                texts.get("COPY_BUTTON"),
                copy_icon_res,
                lambda _view=None: self._animate_press_then(
                    _view,
                    lambda: self._copy_text("REPORT_LABEL", report_text),
                ),
            )
            actions_row.addView(copy_button, LayoutHelper.createLinear(-2, -2))
            root.addView(actions_row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 8))

            close_button = create_primary_button(texts.get("ALERT_CLOSE_BUTTON"), close_report)
            root.addView(close_button, LayoutHelper.createLinear(-1, 50))

            self._current_report_sheet = sheet
            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            log(f"[Gemini] Styled report UI error: {traceback.format_exc()}")
            self._show_full_report()

    def _add_menu(self):
        try:
            menu_item_id = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                    text="Проверить плагин",
                    on_click=self._on_menu_check,
                    icon="menu_privacy_policy",
                    item_id="gemini_plugin_check",
                    condition="message != null && message.getDocument() != null && (message.getDocument().file_name_fixed.endsWith('.plugin') || message.getDocument().file_name_fixed.endsWith('.py'))"
                )
            )
            return menu_item_id

        except Exception as e:
            log(f"[Gemini] Error adding menu items: {str(e)}")
            log(f"[Gemini] Traceback: {traceback.format_exc()}")
            return None

    def _on_menu_check(self, context):
        try:
            self._log_context_keys(context)

            if not self._ensure_enabled():
                return

            message = self._get_message_from_context(context)
            if not message:
                self._show_error("NO_REPLY")
                return

            document = self._get_document_from_msg(message)
            if not document or not self._is_plugin_file(document.file_name_fixed):
                self._show_error("NOT_A_PLUGIN")
                return

            self._scan_document(document)

        except Exception as e:
            log(f"[Gemini] Error in menu plugin check: {str(e)}")
            log(f"[Gemini] Traceback: {traceback.format_exc()}")
            self._show_error("UNEXPECTED_ERROR", error=str(e))

    def _open_url(self, url: str):
        from android.content import Intent
        from android.net import Uri
        last_fragment = get_last_fragment()
        if not last_fragment: return
        context = last_fragment.getParentActivity()
        if not context: return
        intent = Intent(Intent.ACTION_VIEW, Uri.parse(url))
        context.startActivity(intent)

    def _copy_text(self, label_key, text):
        if AndroidUtilities.addToClipboard(text):
            self._show_copy_bulletin(label_key)

    def _build_copy_bulletin_text(self, label_key: str) -> Tuple[str, str, str]:
        label_text = texts.get(label_key)
        is_ru = texts.language == "ru"
        title = "Скопировано" if is_ru else "Copied"
        subtitle = (
            f"{label_text} добавлен в буфер обмена"
            if is_ru else
            f"{label_text} added to clipboard"
        )
        return label_text, title, subtitle

    def _get_copy_bulletin_icon(self) -> int:
        try:
            RClass = jclass("org.telegram.messenger.R")
            raw_class = getattr(RClass, "raw", None)
            return int(getattr(raw_class, "copy", 0) or 0) if raw_class is not None else 0
        except Exception:
            return 0

    def _get_report_bulletin_target(self) -> Tuple[Any, Any]:
        current_sheet = self._current_report_sheet
        if current_sheet is None:
            return None, None

        try:
            bulletin_container = getattr(current_sheet, "topBulletinContainer", None)
        except Exception:
            bulletin_container = None

        try:
            resources_provider = getattr(current_sheet, "resourcesProvider", None)
        except Exception:
            resources_provider = None

        if bulletin_container is None:
            try:
                bulletin_container = current_sheet.getContainer()
            except Exception:
                bulletin_container = None

        return bulletin_container, resources_provider

    def _show_copy_bulletin(self, label_key: str):
        label_text, title, subtitle = self._build_copy_bulletin_text(label_key)
        fragment = get_last_fragment()
        copy_icon = self._get_copy_bulletin_icon()

        try:
            bulletin_container, resources_provider = self._get_report_bulletin_target()

            if copy_icon and bulletin_container is not None:
                BulletinFactory = jclass("org.telegram.ui.Components.BulletinFactory")
                bulletin = BulletinFactory.of(bulletin_container, resources_provider).createSimpleBulletin(copy_icon, title, subtitle)
                bulletin.show(True)
            elif copy_icon:
                BulletinHelper.show_two_line(title, subtitle, copy_icon, fragment)
            else:
                BulletinHelper.show_success(texts.get("COPIED_TO_CLIPBOARD").format(label=label_text), fragment)
        except Exception:
            BulletinHelper.show_success(texts.get("COPIED_TO_CLIPBOARD").format(label=label_text), fragment)

    def _show_error(self, key: str, **kwargs):
        message = self._fmt_text(key, **kwargs)
        run_on_ui_thread(lambda: BulletinHelper.show_error(message))

    def _get_provider_type(self) -> int:
        provider_type = self.get_setting("provider_type", API_PROVIDER_GEMINI)
        try:
            return int(provider_type)
        except (ValueError, TypeError):
            return API_PROVIDER_GEMINI

    def _get_float_setting(self, key: str, default: str, fallback: float) -> float:
        try:
            return float(self.get_setting(key, default))
        except (ValueError, TypeError):
            return fallback

    def _get_int_setting(self, key: str, default: str, fallback: int) -> int:
        try:
            return int(self.get_setting(key, default))
        except (ValueError, TypeError):
            return fallback

    def _get_api_key(self, provider_type: int) -> str:
        if provider_type == API_PROVIDER_OPENAI_COMPATIBLE:
            return self.get_setting("openai_api_key", "").strip()
        return self.get_setting("gemini_api_key", "").strip()

    def _is_plugin_file(self, file_name: str) -> bool:
        return any(str(file_name).endswith(ext) for ext in [".plugin", ".py"])

    def _read_file_text(self, file_path: str) -> str:
        with open(file_path, "r", encoding="utf-8-sig", errors="ignore") as file:
            return file.read()

    def _load_plugin_source(self, file_path: str) -> Tuple[str, str, str]:
        plugin_code = self._read_file_text(file_path)
        plugin_name, plugin_version = self._parse_plugin_meta(plugin_code)
        return plugin_code, plugin_name, plugin_version

    def _get_prompt_template(self, use_blockquote: bool) -> str:
        key = "custom_prompt_plain" if use_blockquote else "custom_prompt_md"
        default = DEFAULT_PROMPT_PLAINTEXT if use_blockquote else DEFAULT_PROMPT_MARKDOWN
        return self.get_setting(key, default)

    def _build_prompt(self, masked_code: str, plugin_name: str, plugin_version: str, use_blockquote: bool) -> str:
        template = self._get_prompt_template(use_blockquote)
        return template.format(
            plugin_code=masked_code,
            plugin_name=plugin_name,
            plugin_version=plugin_version,
        )

    def _run_ai_request(
        self,
        provider_type: int,
        api_key: str,
        prompt: str,
        temperature: float,
        max_tokens: int,
        openai_default_model: str,
    ) -> Dict[str, Any]:
        if provider_type == API_PROVIDER_OPENAI_COMPATIBLE:
            base_url = self.get_setting("openai_base_url", "https://api.openai.com").strip() or "https://api.openai.com"
            model_name = self.get_setting("openai_model", openai_default_model).strip() or openai_default_model
            header_name = self.get_setting("openai_api_key_header", "Authorization").strip() or "Authorization"
            header_prefix = self.get_setting("openai_api_key_prefix", "Bearer").strip()
            return self.openai_client.analyze(
                base_url,
                api_key,
                model_name,
                prompt,
                temperature,
                max_tokens,
                header_name,
                header_prefix,
            )

        model_idx = self._get_int_setting("model_selection", "0", 0)
        if model_idx < 0 or model_idx >= len(GEMINI_MODEL_API_NAMES):
            model_idx = 0
        model_name = GEMINI_MODEL_API_NAMES[model_idx]
        return self.gemini_client.analyze(api_key, model_name, prompt, temperature, max_tokens)

    def _build_provider_settings(self, provider_type: int) -> List[Any]:
        if provider_type == API_PROVIDER_GEMINI:
            return [
                Header(text=texts.get("GEMINI_SECTION")),
                Input(key="gemini_api_key", text=texts.get("API_KEY_INPUT"), icon="msg_limit_links", default="", subtext=texts.get("API_KEY_SUBTEXT")),
                Text(
                    text=texts.get("GET_API_KEY_BUTTON"),
                    icon="msg_link",
                    accent=True,
                    on_click=lambda view: self._open_url("https://aistudio.google.com/app/apikey"),
                ),
                Selector(key="model_selection", text=texts.get("MODEL_SELECTOR"), icon="msg_media", default=0, items=GEMINI_MODEL_DISPLAY_NAMES),
                Divider(),
            ]

        return [
            Header(text=texts.get("OPENAI_SECTION")),
            Input(key="openai_api_key", text=texts.get("OPENAI_API_KEY_INPUT"), icon="msg_limit_links", default=""),
            Input(key="openai_base_url", text=texts.get("OPENAI_BASE_URL_INPUT"), icon="msg_link", default="https://api.openai.com", subtext=texts.get("OPENAI_BASE_URL_SUBTEXT")),
            Input(key="openai_model", text=texts.get("OPENAI_MODEL_INPUT"), icon="msg_media", default="gpt-5", subtext=texts.get("OPENAI_MODEL_SUBTEXT")),
            Input(key="openai_api_key_header", text=texts.get("OPENAI_HEADER_NAME_INPUT"), icon="msg_settings", default="Authorization", subtext=texts.get("OPENAI_HEADER_NAME_SUBTEXT")),
            Input(key="openai_api_key_prefix", text=texts.get("OPENAI_HEADER_PREFIX_INPUT"), icon="msg_settings", default="Bearer", subtext=texts.get("OPENAI_HEADER_PREFIX_SUBTEXT")),
            Divider(),
        ]

