    def _on_info_click(self, view):
        title = texts.get("USAGE_INFO_TITLE")
        text = texts.get("USAGE_INFO_TEXT")
        close_button = texts.get("ALERT_CLOSE_BUTTON")
        parsed_text = parse_markdown(text)
        self.alerts.show_info_alert(title, parsed_text.text, close_button)

    def create_settings(self) -> List[Any]:
        provider_type = self._get_provider_type()
        items = [
            Header(text=texts.get("SETTINGS_HEADER")),
            Switch(key="enabled", text=texts.get("ENABLE_SWITCH"), icon="menu_privacy_policy", default=True),
            Divider(),
            Selector(
                key="provider_type",
                text=texts.get("PROVIDER_SELECTOR"),
                icon="msg_bot",
                default=API_PROVIDER_GEMINI,
                items=API_PROVIDER_NAMES
            ),
            Divider(),
        ]
        items.extend(self._build_provider_settings(provider_type))
        items.extend(self._build_shared_settings())
        return items

    def _build_prompt_settings(self):
        return [
            Header(text=texts.get("PROMPT_INPUT_MD")),
            EditText(key="custom_prompt_md", hint=texts.get("PROMPT_INPUT_MD"), default=DEFAULT_PROMPT_MARKDOWN, multiline=True, max_length=50000),
            Divider(),
            Header(text=texts.get("PROMPT_INPUT_PLAIN")),
            EditText(key="custom_prompt_plain", hint=texts.get("PROMPT_INPUT_PLAIN"), default=DEFAULT_PROMPT_PLAINTEXT, multiline=True, max_length=50000)
        ]

    def _build_report_text(self, response_text: str, plugin_name: str, plugin_version: str, use_blockquote: bool) -> str:
        try:
            header_key = "SUCCESS_HEADER_PLAIN" if use_blockquote else "SUCCESS_HEADER_MD"
            header = texts.get(header_key).format(plugin_name=plugin_name, plugin_version=plugin_version)
            if self.get_setting("use_premium_emoji", False):
                return apply_premium_emoji(header) + apply_premium_emoji(response_text)
            return header + response_text
        except Exception as e:
            log(f"[Gemini] Error preparing report text: {e}")
            fallback_text = f"🛡️ Security Report: {plugin_name} v{plugin_version}\n\n{response_text}"
            if self.get_setting("use_premium_emoji", False):
                return apply_premium_emoji(fallback_text)
            return fallback_text

    def _build_message_payload(self, params: Any) -> Optional[Dict[str, Any]]:
        try:
            return {
                "peer": getattr(params, "peer", None),
                "replyToMsg": getattr(params, "replyToMsg", None),
                "replyToTopMsg": getattr(params, "replyToTopMsg", None),
            }
        except Exception as e:
            log(f"[Gemini] Error in simple peer approach: {e}")

        try:
            last_fragment = get_last_fragment()
            peer_id = last_fragment.getDialogId() if last_fragment and hasattr(last_fragment, "getDialogId") else 0
            return {
                "peer": peer_id,
                "message": "Fallback message",
            }
        except Exception as e:
            log(f"[Gemini] Fallback also failed: {e}")
            return None

    def _make_blockquote_entity(self, text: str):
        if not text or not text.strip():
            return None

        blockquote_entity = TLRPC.TL_messageEntityBlockquote()
        blockquote_entity.collapsed = True
        blockquote_entity.offset = 0
        try:
            blockquote_entity.length = len(text.encode("utf-16le")) // 2
        except Exception:
            blockquote_entity.length = len(text)
        return blockquote_entity

    def _build_entities(self, text: str, parsed_entities: Optional[List[Any]], use_blockquote: bool) -> List[Any]:
        entities = []
        if use_blockquote:
            blockquote = self._make_blockquote_entity(text)
            if blockquote:
                entities.append(blockquote)

        if not parsed_entities:
            return entities

        for entity in parsed_entities:
            try:
                tlrpc_entity = entity.to_tlrpc_object()
                if tlrpc_entity is not None:
                    entities.append(tlrpc_entity)
            except Exception as e:
                log(f"[Gemini] Entity error: {e}")
        return entities

    def _send_report_payload(self, message_payload: Dict[str, Any], text: str, entities: Optional[List[Any]] = None):
        message_payload["message"] = text
        message_payload["entities"] = entities if entities else None
        send_message(message_payload)

    def _show_report_bulletin(self, response_text: str):
        verdict_line = response_text.split('\n', 1)[0].strip()
        clean_verdict = verdict_line.replace("◈ Вердикт:", "").strip()
        bulletin_verdict = strip_premium_emoji(clean_verdict)

        def show_verdict_bulletin():
            if "✅" in verdict_line:
                BulletinHelper.show_success(bulletin_verdict)
            elif "❌" in verdict_line or "📛" in verdict_line:
                BulletinHelper.show_error(bulletin_verdict)
            else:
                BulletinHelper.show_info(bulletin_verdict)

        run_on_ui_thread(show_verdict_bulletin)

    def _parse_plugin_meta(self, code: str) -> Tuple[str, str]:
        name = "Unknown Plugin"; version = "Unknown Version"
        try:
            tree = ast.parse(code)
            for node in ast.walk(tree):
                if isinstance(node, ast.Assign):
                    for target in node.targets:
                        if isinstance(target, ast.Name):
                            if target.id == "__name__": name = ast.literal_eval(node.value)
                            elif target.id == "__version__": version = ast.literal_eval(node.value)
        except Exception:
            pass
        return name, version

    def _wait_file(self, file_path: str, document: Any) -> bool:
        if os.path.exists(file_path): return True
        get_file_loader().loadFile(document, "gemini_analyzer", FileLoader.PRIORITY_HIGH, 1)
        for _ in range(30):
            if os.path.exists(file_path): return True
            time.sleep(1)
        return False
    
    def _mask_code(self, code: str) -> str:
        lines = []
        for line in code.split('\n'):
            stripped_line = line.split('#', 1)[0]
            lines.append(stripped_line)
        clean_code = '\n'.join(lines)

        rename_vars = self.get_setting("rename_variables", True)
        rename_strings = self.get_setting("rename_strings", True)

        if not rename_vars and not rename_strings:
            return '\n'.join(line for line in clean_code.split('\n') if line.strip())

        try:
            tree = ast.parse(clean_code)
            transformer = CodeMasker(rename_vars, rename_strings)
            new_tree = transformer.visit(tree)
            ast.fix_missing_locations(new_tree)
            return ast.unparse(new_tree)
        except Exception:
            return '\n'.join(line for line in clean_code.split('\n') if line.strip())

    def _analyze_reply_task(self, params: Any, document: Any):
        try:
            file_path_obj = get_file_loader().getPathToAttach(document, True)
            file_path = file_path_obj.getAbsolutePath()
            if not self._wait_file(file_path, document):
                self._show_error("FILE_DOWNLOAD_ERROR")
                return

            try:
                plugin_code, plugin_name, plugin_version = self._load_plugin_source(file_path)
            except Exception as e:
                self._show_error("FILE_READ_ERROR", e=str(e))
                return

            provider_type = self._get_provider_type()
            api_key_error = "OPENAI_API_KEY_MISSING" if provider_type == API_PROVIDER_OPENAI_COMPATIBLE else "API_KEY_MISSING"
            api_key = self._get_api_key(provider_type)
            if not api_key:
                self._show_error(api_key_error)
                return

            masked_code = self._mask_code(plugin_code)
            use_blockquote = self.get_setting("use_blockquote", True)
            temperature = self._get_float_setting("gemini_temperature", "0.2", 0.5)
            max_tokens = self._get_int_setting("gemini_max_tokens", "200000", 8192)
            full_prompt = self._build_prompt(masked_code, plugin_name, plugin_version, use_blockquote)
            result = self._run_ai_request(
                provider_type,
                api_key,
                full_prompt,
                temperature,
                max_tokens,
                "gpt-5",
            )

            if result.get("success"):
                self._send_analysis(params, result["text"], plugin_name, plugin_version, use_blockquote)
            else: 
                self._show_error("API_ERROR", error=result.get("error", "Unknown"))

        except Exception as e:
            log(f"[Gemini] Traceback: {traceback.format_exc()}")
            self._show_error("UNEXPECTED_ERROR", error=str(e))

    def _send_analysis(self, params: Any, response_text: str, plugin_name: str, plugin_version: str, use_blockquote: bool):
        report_text = self._build_report_text(response_text, plugin_name, plugin_version, use_blockquote)
        message_payload = self._build_message_payload(params)
        if not message_payload:
            return

        try:
            parsed = parse_markdown(report_text)
            entities = self._build_entities(parsed.text, parsed.entities, use_blockquote)
            self._send_report_payload(message_payload, parsed.text, entities)

        except Exception as e:
            log(f"[Gemini] Send failed, using fallback: {e}")
            try:
                clean_text = report_text.replace('**', '').replace('__', '').replace('`', '')
                clean_text = strip_premium_emoji(clean_text)
                fallback_entities = self._build_entities(clean_text, None, use_blockquote)
                self._send_report_payload(message_payload, clean_text, fallback_entities)
            except Exception as e2:
                log(f"[Gemini] Fallback failed: {e2}")
                self._show_error("UNEXPECTED_ERROR", error="Failed to send report")
        self._show_report_bulletin(response_text)

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not hasattr(params, "message") or not isinstance(params.message, str): return HookResult()

        message_text = params.message.strip()
        if message_text.lower() != DEFAULT_COMMAND or not self.get_setting("enabled", True): return HookResult()

        provider_type = self._get_provider_type()
        api_key_error = "OPENAI_API_KEY_MISSING" if provider_type == API_PROVIDER_OPENAI_COMPATIBLE else "API_KEY_MISSING"
        if not self._get_api_key(provider_type):
            self._show_error(api_key_error)
            return HookResult(strategy=HookStrategy.CANCEL)

        if not hasattr(params, "replyToMsg") or not params.replyToMsg:
            self._show_error("NO_REPLY")
            return HookResult(strategy=HookStrategy.CANCEL)

        try:
            if not hasattr(params, 'replyToTopMsg') or not params.replyToTopMsg:
                topic_id = extract_topic_id(params.replyToMsg, params.peer)
                if topic_id > 0:
                    params.replyToTopMsg = build_reply_to_top(topic_id, params.peer)
        except Exception as e:
            log(f"[Gemini] Error setting up topic for command: {e}")

        document = MessageObject.getDocument(params.replyToMsg.messageOwner)
        if not document or not self._is_plugin_file(document.file_name_fixed):
            self._show_error("NOT_A_PLUGIN")
            return HookResult(strategy=HookStrategy.CANCEL)

        BulletinHelper.show_info(texts.get("ANALYZING_MESSAGE"))
        run_on_queue(lambda: self._analyze_reply_task(params, document))
        return HookResult(strategy=HookStrategy.CANCEL)
