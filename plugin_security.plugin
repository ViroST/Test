BOT_TOKEN_REGEX = re.compile(r"\b\d{8,10}:[A-Za-z0-9_-]{30,}\b")
DISCORD_WEBHOOK_REGEX = re.compile(
    r"https://(?:canary\.)?discord(?:app)?\.com/api/webhooks/[^\s\"']+",
    re.IGNORECASE,
)
DATA_PATH_REGEX = re.compile(r"/data/(?:user/0|data)/[^\s\"']+", re.IGNORECASE)
FIXED_ID_ASSIGNMENT_REGEX = re.compile(r"(?:target_user_id|your_chat_id)\s*=\s*\d{5,}", re.IGNORECASE)
HARD_CODED_ID_REGEX = re.compile(r"\b[A-Za-z_][A-Za-z0-9_]*\s*=\s*-?\d{5,}\b")

PREMIUM_EMOJI_MAP = {
    "❌": "[❌](5210952531676504517)",
    "📛": "[❗️](5834951734358707402)",
    "⚠️": "[⚠️](5447644880824181073)",
    "❔": "[❔](5467461928647399673)",
    "✅": "[✅](5219899949281453881)",
    "🛡️": "[ℹ️](5404366668635865453)",
    "◈": "[❌](5258453452631056344)",
    "☶": "[📝](5256230583717079814)",
    "❏": "[✍️](5337063551854999885)",
    "•": "[🟦](5404724576850573443)"
}

def apply_premium_emoji(text: str) -> str:
    result = text
    for regular_emoji, premium_emoji in PREMIUM_EMOJI_MAP.items():
        result = result.replace(regular_emoji, premium_emoji)
    return result

def strip_premium_emoji(text: str) -> str:
    result = text
    for regular_emoji, premium_emoji in PREMIUM_EMOJI_MAP.items():
        result = result.replace(premium_emoji, regular_emoji)
    return result

def as_java_color(color: int) -> int:
    value = int(color)
    if value > 0x7FFFFFFF:
        value -= 0x100000000
    return value

def with_alpha(color: int, alpha: int) -> int:
    return ((alpha & 0xFF) << 24) | (color & 0x00FFFFFF)

def mask_sensitive_text(text: str) -> str:
    redacted = BOT_TOKEN_REGEX.sub("<bot_token>", text)
    redacted = DISCORD_WEBHOOK_REGEX.sub("<discord_webhook>", redacted)
    return redacted

