    @classmethod
    def _is_russian(cls) -> bool:
        try:
            from java.util import Locale
            return Locale.getDefault().getLanguage() == 'ru'
        except:
            return False

    @classmethod
    def get(cls, key: str, **kwargs) -> str:
        strings = cls._ru if cls._is_russian() else cls._en
        text = strings.get(key, cls._ru.get(key, key))
        return text.format(**kwargs) if kwargs else text


class AchievementCategory(Enum):
    MESSAGES = "messages"
    MEDIA = "media"
    SOCIAL = "social"
    TIME = "time"
    STREAKS = "streaks"
    SPECIAL = "special"
    SECRET = "secret"
    REACTIONS = "reactions"
    EXPLORER = "explorer"
    COLLECTOR = "collector"
    VETERAN = "veteran"


@dataclass
class Achievement:
    id: str
    name_key: str
    desc_key: str
    category: AchievementCategory
    icon: str
    rarity: Rarity = Rarity.COMMON
    is_secret: bool = False
    target: int = 1
    requires_threshold: int = 0

    def get_name(self) -> str:
        return Strings.get(self.name_key)

    def get_description(self) -> str:
        return Strings.get(self.desc_key)

    def get_rarity_name(self) -> str:
        info = RARITY_INFO[self.rarity]
        return info['name_ru'] if Strings._is_russian() else info['name_en']

    def get_rarity_emoji(self) -> str:
        return RARITY_INFO[self.rarity]['emoji']


@dataclass
class UserStats:
    messages_sent: int = 0
    photos_sent: int = 0
    videos_sent: int = 0
    voice_sent: int = 0
    stickers_sent: int = 0
    gifs_sent: int = 0
    files_sent: int = 0
    audios_sent: int = 0
    video_notes_sent: int = 0
    edits_made: int = 0
    replies_made: int = 0
    forwards_made: int = 0
    reactions_made: int = 0
    unique_chats: int = 0
    private_chats_count: int = 0
    group_chats_count: int = 0
    channel_chats_count: int = 0
    bot_chats_count: int = 0
    days_active: Set[str] = field(default_factory=set)
    messages_timestamps: List[float] = field(default_factory=list)
    streak_restored_count: int = 0
    known_chat_ids: Set[int] = field(default_factory=set)

    def to_dict(self) -> dict:
        return {
            'messages_sent': self.messages_sent,
            'photos_sent': self.photos_sent,
            'videos_sent': self.videos_sent,
            'voice_sent': self.voice_sent,
            'stickers_sent': self.stickers_sent,
            'gifs_sent': self.gifs_sent,
            'files_sent': self.files_sent,
            'audios_sent': self.audios_sent,
            'video_notes_sent': self.video_notes_sent,
            'edits_made': self.edits_made,
            'replies_made': self.replies_made,
            'forwards_made': self.forwards_made,
            'reactions_made': self.reactions_made,
            'unique_chats': self.unique_chats,
            'private_chats_count': self.private_chats_count,
            'group_chats_count': self.group_chats_count,
            'channel_chats_count': self.channel_chats_count,
            'bot_chats_count': self.bot_chats_count,
            'days_active': list(self.days_active),
            'streak_restored_count': self.streak_restored_count,
            'known_chat_ids': list(self.known_chat_ids),
        }

    @classmethod
    def from_dict(cls, data: dict) -> 'UserStats':
        stats = cls()
        stats.messages_sent = data.get('messages_sent', 0)
        stats.photos_sent = data.get('photos_sent', 0)
        stats.videos_sent = data.get('videos_sent', 0)
        stats.voice_sent = data.get('voice_sent', 0)
        stats.stickers_sent = data.get('stickers_sent', 0)
        stats.gifs_sent = data.get('gifs_sent', 0)
        stats.files_sent = data.get('files_sent', 0)
        stats.audios_sent = data.get('audios_sent', 0)
        stats.video_notes_sent = data.get('video_notes_sent', 0)
        stats.edits_made = data.get('edits_made', 0)
        stats.replies_made = data.get('replies_made', 0)
        stats.forwards_made = data.get('forwards_made', 0)
        stats.reactions_made = data.get('reactions_made', 0)
        stats.unique_chats = data.get('unique_chats', 0)
        stats.private_chats_count = data.get('private_chats_count', 0)
        stats.group_chats_count = data.get('group_chats_count', 0)
        stats.channel_chats_count = data.get('channel_chats_count', 0)
        stats.bot_chats_count = data.get('bot_chats_count', 0)
        stats.days_active = set(data.get('days_active', []))
        stats.streak_restored_count = data.get('streak_restored_count', 0)
        stats.known_chat_ids = set(data.get('known_chat_ids', []))
        return stats


@dataclass
class FireStreak:
    partner_id: int = 0
    partner_name: str = ""
    is_active: bool = False
    is_pending: bool = True
    streak_days: int = 0
    started_at: str = ""
    last_interaction: str = ""
    my_message_dates: List[str] = field(default_factory=list)
    partner_message_dates: List[str] = field(default_factory=list)
    warned: bool = False
    expired_at: str = ""
    can_restore: bool = False
    restores_used_this_month: int = 0
    last_restore_month: str = ""
    expired_notification_sent: bool = False
    warning_sent_date: str = ""

    def to_dict(self) -> dict:
        return {
            'partner_id': self.partner_id,
            'partner_name': self.partner_name,
            'streak_days': self.streak_days,
            'started_at': self.started_at,
            'is_active': self.is_active,
            'is_pending': self.is_pending,
            'my_message_dates': self.my_message_dates[-30:],
            'partner_message_dates': self.partner_message_dates[-30:],
            'warned': self.warned,
            'expired_at': self.expired_at,
            'can_restore': self.can_restore,
            'restores_used_this_month': self.restores_used_this_month,
            'last_restore_month': self.last_restore_month,
            'expired_notification_sent': self.expired_notification_sent,
            'warning_sent_date': self.warning_sent_date,
        }

    @classmethod
    def from_dict(cls, data: dict) -> 'FireStreak':
        streak = cls(
            partner_id=data.get('partner_id', 0),
            partner_name=data.get('partner_name', ''),
        )
        streak.streak_days = data.get('streak_days', 0)
        streak.started_at = data.get('started_at', '')
        streak.is_active = data.get('is_active', False)
        streak.is_pending = data.get('is_pending', True)
        streak.my_message_dates = data.get('my_message_dates', [])
        streak.partner_message_dates = data.get('partner_message_dates', [])
        streak.warned = data.get('warned', False)
        streak.expired_at = data.get('expired_at', '')
        streak.can_restore = data.get('can_restore', False)
        streak.restores_used_this_month = data.get('restores_used_this_month', 0)
        streak.last_restore_month = data.get('last_restore_month', '')
        streak.expired_notification_sent = data.get('expired_notification_sent', False)
        streak.warning_sent_date = data.get('warning_sent_date', '')
        return streak

    def check_restore_limit(self) -> bool:
        current_month = datetime.now().strftime("%Y-%m")
        if self.last_restore_month != current_month:
            self.restores_used_this_month = 0
            self.last_restore_month = current_month
        return self.restores_used_this_month < Config.STREAK_MAX_RESTORES_PER_MONTH

    def use_restore(self) -> bool:
        if not self.check_restore_limit():
            return False
        current_month = datetime.now().strftime("%Y-%m")
        if self.last_restore_month != current_month:
            self.restores_used_this_month = 0
            self.last_restore_month = current_month
        self.restores_used_this_month += 1
        return True
    
    def reset_notification_flags(self):
        self.expired_notification_sent = False
        self.warning_sent_date = ""
        self.warned = False


def safe_int(v, default=0):
    try:
        s = str(v).strip()
        if not s:
            return default
        return int(s)
    except:
        return default


class SSLAdapter(HTTPAdapter):
    def __init__(self, *args, **kwargs):
        self._ssl_context = create_urllib3_context()
        self._ssl_context.minimum_version = ssl.TLSVersion.TLSv1_2
        self._ssl_context.verify_mode = ssl.CERT_REQUIRED
        self._ssl_context.check_hostname = True
        self._ssl_context.load_verify_locations(certifi.where())
        super().__init__(*args, **kwargs)

    def init_poolmanager(self, *args, **kwargs):
        kwargs["ssl_context"] = self._ssl_context
        return super().init_poolmanager(*args, **kwargs)


class BulletinHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def before_hooked_method(self, param):
        try:
            if len(param.args) < 4 or param.args[3] is None:
                return
            doc = param.args[0]
            if not doc or not hasattr(doc, 'id'):
                return
            doc_id = int(doc.id)
            
            for badge_data in self.p._server_badges.values():
                if safe_int(badge_data.get("emoji_doc_id", 0)) == doc_id:
                    args = list(param.args)
                    args[3] = None
                    param.args = tuple(args)
                    return
            
            if doc_id in STREAK_EMOJI_IDS:
                args = list(param.args)
                args[3] = None
                param.args = tuple(args)
        except:
            pass


