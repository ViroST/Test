class LocalizationManager:
    def __init__(self):
        self.language = "ru"
        
    def get_string(self, string_key):
        return self.strings["ru"].get(string_key, string_key)

    def _get_supported_languages(self):
        return ["ru"]
    
    strings = {
        "ru": {
