from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class
from android_utils import log

__id__ = "voice_blockquote"
__name__ = "Voice Blockquote"
__description__ = "Оборачивает текст расшифровки голосовых сообщений в сворачиваемую цитату."
__author__ = "@yzewe"
__icon__ = "nachoneko3/12"
__version__ = "1.0.0"
__min_version__ = "11.12.0"

class GetVoiceTranscriptionHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            text = param.getResult()
            if not text:
                return
            QuoteSpanClass = find_class("org.telegram.ui.Components.QuoteSpan")
            if hasattr(text, "getSpans") and QuoteSpanClass:
                if isinstance(text, str):
                    text_len = len(text.encode('utf-16-le')) // 2
                else:
                    text_len = text.length()
                    
                spans = text.getSpans(0, text_len, QuoteSpanClass)
                if spans and len(spans) > 0:
                    return
                    
            from android.text import SpannableStringBuilder
            from org.telegram.tgnet import TLRPC
            from org.telegram.messenger import MessageObject
            from java.util import ArrayList
            sb = SpannableStringBuilder(text)
            if isinstance(text, str):
                text_len = len(text.encode('utf-16-le')) // 2
            else:
                text_len = text.length()
                
            q = TLRPC.TL_messageEntityBlockquote()
            q.collapsed = True 
            q.offset = 0
            q.length = text_len
            
            entities = ArrayList()
            entities.add(q)
            
            msg = param.thisObject
            is_out = getattr(msg, "isOutOwner", lambda: False)()
            MessageObject.addEntitiesToText(sb, entities, is_out, False, False, False)
            param.setResult(sb)
            
        except Exception as e:
            log(f"[Voice Transcription] Error: {e}")

class VoiceTranscriptionPlugin(BasePlugin):
    def on_plugin_load(self):
        MessageObjectClass = find_class("org.telegram.messenger.MessageObject")
        if MessageObjectClass:
            self.hook_all_methods(MessageObjectClass, "getVoiceTranscription", GetVoiceTranscriptionHook())
        else:
            log("[Voice Transcription] MessageObject class not found!")