class AnimatorUpdateProxy(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
    def __init__(self, cb):
        super().__init__()
        self.cb = cb
    def onAnimationUpdate(self, animation):
        try: self.cb(float(animation.getAnimatedValue()))
        except: pass

class AnimatorListenerProxy(dynamic_proxy(Animator.AnimatorListener)):
    def __init__(self, end_cb, cleanup_cb):
        super().__init__()
        self.end_cb = end_cb
        self.cleanup_cb = cleanup_cb
    def onAnimationStart(self, *args): pass
    def onAnimationEnd(self, *args):
        if self.end_cb:
            try: self.end_cb()
            except: pass
        if self.cleanup_cb:
            try: self.cleanup_cb()
            except: pass
    def onAnimationCancel(self, *args): pass
    def onAnimationRepeat(self, *args): pass

class FloatAnimator:
    def __init__(self, start_val, end_val, duration, update_cb, end_cb=None):
        self.animator = ValueAnimator.ofFloat(start_val, end_val)
        self.animator.setDuration(duration)
        self.animator.setInterpolator(CubicBezierInterpolator.EASE_OUT_QUINT)
        
        self.update_proxy = AnimatorUpdateProxy(update_cb)
        self.listener_proxy = AnimatorListenerProxy(end_cb, self._cleanup)
        
        self.animator.addUpdateListener(self.update_proxy)
        self.animator.addListener(self.listener_proxy)
        
    def start(self): 
        self.animator.start()
        
    def cancel(self): 
        try: self.animator.cancel()
        except: pass
        self._cleanup()
        
    def _cleanup(self):
        try:
            self.animator.removeAllUpdateListeners()
            self.animator.removeAllListeners()
        except: pass

def safe_get_field(obj, field_name):
    if not obj: return None
    try:
        f = obj.getClass().getDeclaredField(field_name)
        f.setAccessible(True)
        return f.get(obj)
    except Exception:
        try:
            f = obj.getClass().getSuperclass().getDeclaredField(field_name)
            f.setAccessible(True)
            return f.get(obj)
        except Exception:
            pass
    return getattr(obj, field_name, None)

