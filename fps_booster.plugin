_OVER_SCROLL_NEVER = 2

_RUNTIME_SCHEMA_VERSION = 4

_MODULE_UI_NAMES = {
    "chat_hook": "оптимизация списка чата",
    "animator_scale": "ускорение анимаций",
    "ai_adaptation": "адаптация под нагрузку",
}


class _ChatCreateViewHook(MethodHook):
    def __init__(self, plugin: "FPSBoosterPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin._engine_initialized:
                return
            chat_list_view = self.plugin._resolve_chat_list_view(param.thisObject)
            if chat_list_view is None:
                return

            activity_id = id(param.thisObject)
            list_id = id(chat_list_view)
            surface = (activity_id, list_id)
            if surface != self.plugin._last_chat_surface:
                self.plugin._last_chat_surface = surface
                if self.plugin._compatibility_mode:
                    try:
                        chat_list_view.setOverScrollMode(_OVER_SCROLL_NEVER)
                    except Exception:
                        pass
                    item_animator = chat_list_view.getItemAnimator()
                    if item_animator is not None and self.plugin._is_default_item_animator(
                        item_animator
                    ):
                        chat_list_view.setItemAnimator(None)
                    if not chat_list_view.hasFixedSize():
                        chat_list_view.setHasFixedSize(True)

            effective_cache = self.plugin._effective_item_view_cache_target()
            current_cache = int(chat_list_view.getItemViewCacheSize())
            hyst = int(getattr(self.plugin, "_cache_resize_hysteresis", 0))
            if hyst > 0:
                if abs(current_cache - effective_cache) >= hyst:
                    chat_list_view.setItemViewCacheSize(effective_cache)
            elif current_cache != effective_cache:
                chat_list_view.setItemViewCacheSize(effective_cache)
            self.plugin._ai_adapt_for_chat(chat_list_view)
        except Exception as e:
            self.plugin.log(f"Chat list optimization skipped: {e}")


