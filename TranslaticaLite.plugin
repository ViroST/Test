def _ji(v):
    v = int(v) & 0xFFFFFFFF
    if v >= 0x80000000:
        v -= 0x100000000
    return int(v)


class TLLiteChatCreateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            fragment = param.thisObject
            run_on_ui_thread(lambda: self.plugin._attach_apple_button(fragment))
            run_on_ui_thread(lambda: self.plugin._schedule_apple_stabilize(fragment))
            run_on_ui_thread(self.plugin._maybe_show_first_install_welcome)
        except Exception as e:
            self.plugin._dlog(f"chat create hook fail: {e}")


class TLLiteChatResumeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            fragment = param.thisObject
            run_on_ui_thread(lambda: self.plugin._attach_apple_button(fragment))
            run_on_ui_thread(lambda: self.plugin._schedule_apple_stabilize(fragment))
            run_on_ui_thread(self.plugin._maybe_show_first_install_welcome)
        except Exception as e:
            self.plugin._dlog(f"chat resume hook fail: {e}")


class TLLiteChatPauseHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            run_on_ui_thread(self.plugin._detach_apple_button)
        except Exception as e:
            self.plugin._dlog(f"chat pause hook fail: {e}")


class TLLiteSettingsHeaderHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            activity = param.thisObject
            items = param.args[0] if param.args and len(param.args) > 0 else None
            if items is None:
                return
            self.plugin._inject_settings_header(activity, items)
        except Exception as e:
            self.plugin._dlog(f"settings header hook fail: {e}")


class TranslaticaLitePlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._translations = dict(STRINGS)
        self._hooks = []
        self._suppress_next_hook = False
        self._skip_next_translation_send = False
        self._chat_apple_btn = None
        self._chat_apple_icon = None
        self._chat_fragment_ref = None
        self._chat_dialog_id_ref = 0
        self._lang_dialog = None
        self._settings_header_hook = None
        self._chat_menu_item = None
        self._attach_retry_keys = set()
        self._telemetry_lock = threading.Lock()
        self._telemetry_sending = False
        self._telemetry_queue = []
        self._telemetry_last_flush_ts = 0
        self._telemetry_install_id = ""
    def _is_debug_on(self):
        try:
            return bool(self.get_setting("tlite_debug_logs", False))
        except Exception:
            return False

    def _dlog(self, message):
        try:
            if self._is_debug_on():
                log(f"[TranslaticaLite] {message}")
        except Exception:
            pass

    def _wlog(self, message):
        try:
            log(f"[TranslaticaLite][Welcome] {message}")
        except Exception:
            pass

    def _stats_enabled(self):
        try:
            v = self.get_setting("tlite_stats_enabled", True)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            return bool(v)
        except Exception:
            return True

    def _load_telemetry_queue(self):
        try:
            raw = self.get_setting("tlite_stats_queue_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            self._telemetry_queue = arr if isinstance(arr, list) else []
        except Exception:
            self._telemetry_queue = []

    def _save_telemetry_queue(self):
        try:
            self.set_setting("tlite_stats_queue_v1", json.dumps(list(self._telemetry_queue or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _telemetry_install_id_get(self):
        try:
            if self._telemetry_install_id:
                return str(self._telemetry_install_id)
            cached = str(self.get_setting("tlite_stats_install_id", "") or "").strip()
            if cached:
                self._telemetry_install_id = cached
                return cached
            sid = "tl_{0:x}{1:x}".format(int(time.time() * 1000), random.randint(0, 0xFFFFFF))
            self.set_setting("tlite_stats_install_id", sid)
            self._telemetry_install_id = sid
            return sid
        except Exception:
            return "tl_unknown"

    def _telemetry_app_snapshot(self):
        out = {
            "app_id": "unknown",
            "app_variant": "unknown",
            "app_version": "unknown",
            "plugin_version": str(__version__),
            "mode": "lite",
        }
        try:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return out
            pkg = str(ctx.getPackageName() or "unknown").strip() or "unknown"
            out["app_id"] = pkg
            l = pkg.lower()
            if "ayu" in l:
                out["app_variant"] = "ayugram"
            elif "extera" in l:
                out["app_variant"] = "exteragram"
            try:
                pm = ctx.getPackageManager()
                pi = pm.getPackageInfo(pkg, 0)
                out["app_version"] = str(getattr(pi, "versionName", "") or getattr(pi, "versionCode", "unknown"))
            except Exception:
                pass
        except Exception:
            pass
        return out

    def _telemetry_queue_event(self, event_name, feature=None, count=1, force_flush=False):
        try:
            if not self._stats_enabled():
                return
            name = str(event_name or "").strip()
            if not name:
                return
            ev = {
                "ts": int(time.time()),
                "event": name,
                "feature": str(feature or "").strip(),
                "count": int(count or 1),
            }
            with self._telemetry_lock:
                q = list(self._telemetry_queue or [])
                q.append(ev)
                if len(q) > 180:
                    q = q[-180:]
                self._telemetry_queue = q
            self._save_telemetry_queue()
            now_ts = int(time.time())
            if force_flush or (now_ts - int(self._telemetry_last_flush_ts or 0) >= 20):
                self._telemetry_flush_async()
        except Exception:
            pass

    def _telemetry_flush_async(self):
        try:
            if not self._stats_enabled():
                return
            with self._telemetry_lock:
                if self._telemetry_sending:
                    return
                queue = list(self._telemetry_queue or [])
                if not queue:
                    return
                self._telemetry_sending = True
            payload = {
                "plugin": "translatica_lite",
                "install_id": self._telemetry_install_id_get(),
                "sent_at": int(time.time()),
                "app": self._telemetry_app_snapshot(),
                "events": queue[:120],
            }

            def _worker():
                ok = False
                try:
                    ok = self._telemetry_post(payload)
                except Exception:
                    ok = False
                try:
                    with self._telemetry_lock:
                        if ok:
                            cur = list(self._telemetry_queue or [])
                            drop = min(len(cur), len(payload.get("events", []) or []))
                            self._telemetry_queue = cur[drop:]
                            self._telemetry_last_flush_ts = int(time.time())
                            self._save_telemetry_queue()
                        self._telemetry_sending = False
                except Exception:
                    self._telemetry_sending = False

            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            self._telemetry_sending = False

    def _telemetry_post(self, payload):
        try:
            raw = json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
            headers = {
                "User-Agent": "TranslaticaLiteStats/1.0",
                "Content-Type": "application/json",
                "Cache-Control": "no-cache",
            }
            token = str(GEEKSTATS_INGEST_TOKEN or "").strip()
            if token:
                headers["X-Ingest-Token"] = token
            req = Request(GEEKSTATS_INGEST_URL, data=raw, headers=headers, method="POST")
            with urlopen(req, timeout=6) as resp:
                code = int(getattr(resp, "status", 200) or 200)
                return 200 <= code < 300
        except Exception as e:
            self._dlog(f"stats post fail: {e}")
            return False

    def _current_ui_lang(self):
        try:
            pidx = int(self.get_setting("tlite_plugin_lang", 0) or 0)
            if pidx < 0 or pidx >= len(PLUGIN_LANG_OPTIONS):
                pidx = 0
            forced = str(PLUGIN_LANG_OPTIONS[pidx][1] or "system")
            if forced != "system":
                return forced
            from java.util import Locale
            return str(Locale.getDefault().getLanguage() or "en").strip().lower()[:2]
        except Exception:
            return "en"

    def _tr(self, key):
        try:
            table = self._translations.get(key) or {}
            lang = self._current_ui_lang()
            val = str(table.get(lang) or table.get("en") or "").strip()
            if val:
                return val
            return str(key)
        except Exception:
            return key

    def _get_user_first_name(self):
        try:
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            uc = UserConfig.getInstance(UserConfig.selectedAccount)
            u = uc.getCurrentUser() if uc else None
            if u:
                name = str(getattr(u, "first_name", "") or "").strip()
                if name:
                    return name
        except Exception:
            pass
        return "User"

    def _resolve_current_user(self):
        try:
            account = int(getattr(UserConfig, "selectedAccount", 0))
        except Exception:
            account = 0
        uc = None
        mc = None
        try:
            uc = UserConfig.getInstance(account)
        except Exception:
            uc = None
        try:
            mc = MessagesController.getInstance(account)
        except Exception:
            mc = None

        user = None
        try:
            if uc:
                user = uc.getCurrentUser()
        except Exception:
            user = None
        if user is None:
            try:
                if uc and mc:
                    user = mc.getUser(uc.getClientUserId())
            except Exception:
                user = None
        try:
            self._dlog(f"resolve user: {'ok' if user is not None else 'none'}")
        except Exception:
            pass
        try:
            if user is not None:
                uid = str(getattr(user, "id", "") or "")
                uname = str(getattr(user, "first_name", "") or getattr(user, "username", "") or "").strip()
                self._wlog(f"resolve_current_user=ok id={uid} name={uname}")
            else:
                self._wlog("resolve_current_user=none")
        except Exception:
            pass
        return user

    def _make_avatar_fallback_drawable(self, user=None):
        try:
            if user is not None:
                try:
                    return AvatarDrawable(user)
                except Exception:
                    pass
            d = AvatarDrawable()
            try:
                name = str(self._get_user_first_name() or "User").strip()
                try:
                    d.setInfo(0, name, "", False)
                except Exception:
                    try:
                        d.setInfo(0, name, "")
                    except Exception:
                        pass
            except Exception:
                pass
            return d
        except Exception:
            return AvatarDrawable()

    def _bind_logged_user_avatar(self, avatar_view, size_dp=108):
        try:
            if avatar_view is None:
                return False
            account = int(UserConfig.selectedAccount)
            mc = MessagesController.getInstance(account)
            uc = UserConfig.getInstance(account)
            user = None
            if mc and uc:
                user = mc.getUser(uc.getClientUserId())
            if user is None and uc:
                try:
                    user = uc.getCurrentUser()
                except Exception:
                    user = None
            if user is None:
                self._wlog("bind_avatar aborted: no user")
                return False

            avatar_drawable = None
            try:
                avatar_drawable = AvatarDrawable(user)
            except Exception:
                try:
                    avatar_drawable = AvatarDrawable()
                    avatar_drawable.setInfo(user)
                except Exception:
                    avatar_drawable = None

            # Always set a visible fallback first (never leave avatar invisible).
            try:
                if avatar_drawable is not None:
                    avatar_view.setImageDrawable(avatar_drawable)
            except Exception:
                pass

            try:
                if hasattr(avatar_view, "setForUserOrChat") and avatar_drawable is not None:
                    try:
                        avatar_view.setForUserOrChat(user, avatar_drawable)
                        self._wlog("bind_avatar setForUserOrChat(user, drawable)=ok")
                        return True
                    except Exception:
                        pass
                    try:
                        avatar_view.setForUserOrChat(user)
                        self._wlog("bind_avatar setForUserOrChat(user)=ok")
                        return True
                    except Exception:
                        pass
            except Exception:
                pass
            return avatar_drawable is not None
        except Exception as e:
            self._dlog(f"bind logged user avatar fail: {e}")
            self._wlog(f"bind_avatar fail: {e}")
        return False

    def _load_header_image_remote(self):
        try:
            os.makedirs(_CACHE_DIR, exist_ok=True)
            for url, path in (
                (HEADER_IMAGE_URL_DARK, HEADER_IMAGE_CACHE_FILE_DARK),
                (HEADER_IMAGE_URL_LIGHT, HEADER_IMAGE_CACHE_FILE_LIGHT),
            ):
                try:
                    req = Request(url, headers={"User-Agent": "TranslaticaLite/1.0"})
                    with urlopen(req, timeout=15) as resp:
                        data = resp.read()
                    if not data:
                        continue
                    with open(path, "wb") as f:
                        f.write(data)
                except Exception as ie:
                    self._dlog(f"header image load fail for {url}: {ie}")
            self._dlog("header images cached")
        except Exception as e:
            self._dlog(f"header image load fail: {e}")

