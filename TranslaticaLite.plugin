    def _sync_assets(self):
        try:
            self._load_header_image_remote()
            self._load_support_icon_remote()
            self._load_top_icon_remote()
            self._load_extended_icon_remote()
            self._load_about_avatar_remote()
            self._load_welcome_bg_remote()
            self._load_chat_icon_remote()
        except Exception as e:
            self._dlog(f"sync assets fail: {e}")

    def _open_dotted_chat(self):
        try:
            try:
                from client_utils import get_messages_controller, get_last_fragment
                get_messages_controller().openByUserName("DottedChat", get_last_fragment(), 1)
            except Exception:
                self.open_url("https://t.me/DottedChat")
        except Exception as e:
            self._dlog(f"open dotted fail: {e}")

    def _show_welcome_sheet(self, ctx_override=None):
        try:
            log("[TranslaticaLite][Welcome] show request")
            self._wlog("show begin")
            ctx = ctx_override
            if ctx is None:
                frag = self.get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else ApplicationLoader.applicationContext
            if not ctx:
                log("[TranslaticaLite][Welcome] no context")
                self._wlog("show abort: no ctx")
                return False
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass

            sheet = BottomSheet(ctx, False)
            try:
                sheet.setApplyTopPadding(False)
                sheet.setApplyBottomPadding(False)
                try:
                    sheet.setBackgroundColor(0x00000000)
                except Exception:
                    pass
            except Exception:
                pass
            root = FrameLayout(ctx)
            try:
                root.setBackgroundColor(0x00000000)
            except Exception:
                pass
            hero = FrameLayout(ctx)
            content = LinearLayout(ctx)
            content.setOrientation(LinearLayout.VERTICAL)
            content.setGravity(Gravity.CENTER_HORIZONTAL)
            hero_bg = None
            hero_radius = float(AndroidUtilities.dp(22))
            try:
                content.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(22), AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                hero_bg = GradientDrawable(GradientDrawable.Orientation.TOP_BOTTOM, jarray(jarray.int)([
                    0x00000000,
                    0x00000000,
                    0x00000000,
                ]))
                hero_bg.setCornerRadius(hero_radius)
                try:
                    hero_bg.setStroke(AndroidUtilities.dp(1), Color.parseColor("#2A3A58"))
                except Exception:
                    pass
                hero.setBackground(hero_bg)
                hero.setClipToOutline(True)
                hero.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass
            try:
                bg_wrap = FrameLayout(ctx)
                try:
                    wrap_bg = GradientDrawable()
                    wrap_bg.setColor(0x00000000)
                    wrap_bg.setCornerRadius(hero_radius)
                    bg_wrap.setBackground(wrap_bg)
                    bg_wrap.setClipToOutline(True)
                    bg_wrap.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                except Exception:
                    pass
                bg = ImageView(ctx)
                bg.setScaleType(ImageView.ScaleType.CENTER_CROP)
                if os.path.exists(WELCOME_BG_CACHE_FILE):
                    bmp_bg = BitmapFactory.decodeFile(WELCOME_BG_CACHE_FILE)
                    if bmp_bg:
                        bg.setImageBitmap(bmp_bg)
                bg_wrap.addView(bg, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
                hero.addView(bg_wrap, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
            except Exception:
                pass
            try:
                overlay = View(ctx)
                ov = GradientDrawable(
                    GradientDrawable.Orientation.TOP_BOTTOM,
                    jarray(jarray.int)([
                        0x55000000,
                        0x33000000,
                        0x99000000,
                    ]),
                )
                try:
                    ov.setCornerRadius(hero_radius)
                except Exception:
                    pass
                overlay.setBackground(ov)
                hero.addView(
                    overlay,
                    FrameLayout.LayoutParams(
                        FrameLayout.LayoutParams.MATCH_PARENT,
                        FrameLayout.LayoutParams.MATCH_PARENT,
                        Gravity.CENTER,
                    ),
                )
            except Exception:
                pass
            try:
                handle = View(ctx)
                hb = GradientDrawable()
                hb.setCornerRadius(float(AndroidUtilities.dp(2)))
                hb.setColor(Color.parseColor("#88FFFFFF"))
                handle.setBackground(hb)
                lp_handle = FrameLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(4), Gravity.TOP | Gravity.CENTER_HORIZONTAL)
                lp_handle.topMargin = AndroidUtilities.dp(10)
                hero.addView(handle, lp_handle)
            except Exception:
                pass
            try:
                from android.animation import ValueAnimator, ArgbEvaluator
                if hero_bg is not None:
                    evaluator = ArgbEvaluator()
                    anim = ValueAnimator.ofFloat(0.0, 1.0)
                    anim.setDuration(2600)
                    anim.setRepeatCount(-1)
                    anim.setRepeatMode(ValueAnimator.REVERSE)

                    class _Upd(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                        def onAnimationUpdate(self_obj, va):
                            try:
                                t = float(va.getAnimatedValue())
                                c1 = int(evaluator.evaluate(t, Color.parseColor("#0A0F16"), Color.parseColor("#0B1020")))
                                c2 = int(evaluator.evaluate(t, Color.parseColor("#101827"), Color.parseColor("#13203A")))
                                c3 = int(evaluator.evaluate(t, Color.parseColor("#0C1320"), Color.parseColor("#0E1524")))
                                try:
                                    hero_bg.setColors(jarray(jarray.int)([c1, c2, c3]))
                                except Exception:
                                    pass
                            except Exception:
                                pass
                    anim.addUpdateListener(_Upd())
                    anim.start()
            except Exception:
                pass
            try:
                grain_view = ImageView(ctx)
                try:
                    gw = 220
                    gh = 220
                    grain = Bitmap.createBitmap(gw, gh, Bitmap.Config.ARGB_8888)
                    import random
                    rnd = random.Random(73)
                    for yy in range(gh):
                        for xx in range(gw):
                            a = 8 + rnd.randint(0, 18)
                            c = (a << 24) | (255 << 16) | (255 << 8) | 255
                            grain.setPixel(xx, yy, c)
                    grain_view.setImageBitmap(grain)
                    grain_view.setScaleType(ImageView.ScaleType.FIT_XY)
                    grain_view.setAlpha(0.09)
                except Exception:
                    pass
                hero.addView(grain_view, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
            except Exception:
                pass

            avatar_shell = FrameLayout(ctx)
            try:
                sh = GradientDrawable()
                sh.setCornerRadius(float(AndroidUtilities.dp(18)))
                sh.setColor(0x00000000)
                avatar_shell.setBackground(sh)
                avatar_shell.setClipToOutline(True)
                avatar_shell.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass
            try:
                avatar_shell.setAlpha(1.0)
                avatar_shell.setScaleX(1.0)
                avatar_shell.setScaleY(1.0)
                avatar_shell.setTranslationY(0.0)
                avatar_shell.setRotation(0.0)
            except Exception:
                pass
            avatar_view = None
            try:
                avatar_view = BackupImageView(ctx)
                self._wlog("avatar_view created: BackupImageView")
            except Exception as e:
                self._wlog(f"avatar_view create fail: {e}")
                avatar_view = None
            if avatar_view is not None:
                try:
                    avatar_view.setRoundRadius(AndroidUtilities.dp(18))
                except Exception as e:
                    self._wlog(f"avatar_view setRoundRadius fail: {e}")
                try:
                    user = self._resolve_current_user()
                except Exception:
                    user = None
                try:
                    if user is not None:
                        drawable = AvatarDrawable(user)
                        avatar_view.setForUserOrChat(user, drawable)
                        self._wlog("avatar_view setForUserOrChat(user, AvatarDrawable(user))=ok")
                    else:
                        avatar_view.setImageDrawable(AvatarDrawable())
                        self._wlog("avatar_view fallback AvatarDrawable()=ok")
                except Exception as e:
                    self._wlog(f"avatar_view bind fail: {e}")
                    try:
                        avatar_view.setImageDrawable(AvatarDrawable())
                    except Exception:
                        pass
            if avatar_view is None:
                iv = ImageView(ctx)
                try:
                    iv.setScaleType(ImageView.ScaleType.CENTER_CROP)
                    try:
                        iv.setBackgroundColor(Color.TRANSPARENT)
                    except Exception:
                        pass
                    try:
                        iv.setImageDrawable(self._make_avatar_fallback_drawable(None))
                    except Exception:
                        pass
                except Exception:
                    pass
                avatar_view = iv
            avatar_shell.addView(avatar_view, FrameLayout.LayoutParams(AndroidUtilities.dp(108), AndroidUtilities.dp(108), Gravity.CENTER))
            self._wlog("avatar_view added to avatar_shell")
            try:
                avatar_view.setAlpha(1.0)
                avatar_view.setScaleX(1.0)
                avatar_view.setScaleY(1.0)
                avatar_view.setTranslationY(0.0)
                avatar_view.setRotationY(0.0)
            except Exception:
                pass
            try:
                class _RetryAvatar(dynamic_proxy("java.lang.Runnable")):
                    def run(self_obj):
                        try:
                            user = self._resolve_current_user()
                            if user is not None and hasattr(avatar_view, "setForUserOrChat"):
                                avatar_view.setForUserOrChat(user, AvatarDrawable(user))
                                self._wlog("avatar retry setForUserOrChat=ok")
                            elif hasattr(avatar_view, "setImageDrawable"):
                                avatar_view.setImageDrawable(AvatarDrawable())
                                self._wlog("avatar retry fallback drawable=ok")
                        except Exception:
                            pass
                avatar_view.postDelayed(_RetryAvatar(), 140)
            except Exception:
                pass
            lp_avatar = LinearLayout.LayoutParams(AndroidUtilities.dp(108), AndroidUtilities.dp(108))
            lp_avatar.topMargin = AndroidUtilities.dp(6)
            content.addView(avatar_shell, lp_avatar)
            self._wlog("avatar_shell added to content")

            name = self._get_user_first_name()
            pre_text = ""
            post_text = ""
            token = "__TLITE_NAME__"
            try:
                raw_tpl = str(self._tr("first_welcome_text") or "")
                marked = raw_tpl.replace("{name}", token).replace("{{name}}", token).replace("{ name }", token)
                if token in marked:
                    parts = marked.split(token, 1)
                    pre_text = str(parts[0] or "")
                    post_text = str(parts[1] or "")
                else:
                    txt = raw_tpl.format(name=name) if "{name}" in raw_tpl else raw_tpl
                    if name and name in txt:
                        parts = txt.split(name, 1)
                        pre_text = str(parts[0] or "")
                        post_text = str(parts[1] or "")
                    else:
                        pre_text = txt
            except Exception:
                pre_text = str(self._tr("first_welcome_text") or "")

            try:
                if post_text and len(post_text) > 0 and post_text[0] in "!,.:;?":
                    name = f"{name}{post_text[0]}"
                    post_text = post_text[1:]
            except Exception:
                pass

            title_wrap = LinearLayout(ctx)
            title_wrap.setOrientation(LinearLayout.VERTICAL)
            try:
                title_wrap.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(18), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
            except Exception:
                pass
            try:
                title_wrap.setGravity(Gravity.CENTER_HORIZONTAL)
            except Exception:
                pass

            prefix_block = ""
            prefix_inline = pre_text
            try:
                if "\n" in str(pre_text):
                    pparts = str(pre_text).split("\n")
                    prefix_block = "\n".join(pparts[:-1]).strip()
                    prefix_inline = str(pparts[-1] or "")
            except Exception:
                pass
            if prefix_block:
                pre_title = TextView(ctx)
                pre_title.setText(prefix_block)
                pre_title.setGravity(Gravity.CENTER)
                pre_title.setTextSize(30)
                try:
                    pre_title.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                    pre_title.setTextColor(Color.WHITE)
                    pre_title.setLineSpacing(0.0, 1.0)
                except Exception:
                    pass
                title_wrap.addView(pre_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            name_title = TextView(ctx)
            name_title.setText(str(name))
            name_title.setGravity(Gravity.CENTER_VERTICAL)
            name_title.setTextSize(32)
            try:
                name_title.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                name_title.setTextColor(Color.WHITE)
                name_title.setLineSpacing(0.0, 1.0)
            except Exception:
                pass

            suffix_inline = ""
            suffix_block = post_text
            try:
                if "\n" in str(post_text):
                    sparts = str(post_text).split("\n")
                    suffix_inline = str(sparts[0] or "")
                    suffix_block = "\n".join(sparts[1:]).strip()
                else:
                    suffix_inline = str(post_text or "")
                    suffix_block = ""
            except Exception:
                pass

            first_line = LinearLayout(ctx)
            first_line.setOrientation(LinearLayout.HORIZONTAL)
            try:
                first_line.setGravity(Gravity.CENTER_HORIZONTAL | Gravity.CENTER_VERTICAL)
            except Exception:
                pass

            if prefix_inline:
                pre_inline_view = TextView(ctx)
                pre_inline_view.setText(prefix_inline)
                pre_inline_view.setTextSize(30)
                try:
                    pre_inline_view.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                    pre_inline_view.setTextColor(Color.WHITE)
                except Exception:
                    pass
                first_line.addView(pre_inline_view, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            first_line.addView(name_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            if suffix_inline:
                post_inline_view = TextView(ctx)
                post_inline_view.setText(suffix_inline)
                post_inline_view.setTextSize(30)
                try:
                    post_inline_view.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                    post_inline_view.setTextColor(Color.WHITE)
                except Exception:
                    pass
                first_line.addView(post_inline_view, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            title_wrap.addView(first_line, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            if suffix_block:
                post_title = TextView(ctx)
                post_title.setText(suffix_block)
                post_title.setGravity(Gravity.CENTER)
                post_title.setTextSize(30)
                try:
                    post_title.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                    post_title.setTextColor(Color.WHITE)
                    post_title.setLineSpacing(0.0, 1.0)
                except Exception:
                    pass
                title_wrap.addView(post_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            lp_title = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_title.topMargin = AndroidUtilities.dp(10)
            content.addView(title_wrap, lp_title)

            desc = TextView(ctx)
            try:
                desc.setTextColor(Color.parseColor("#E3ECF8"))
                desc.setTextSize(15)
                desc.setGravity(Gravity.CENTER)
                desc.setText(self._tr("welcome_text"))
                desc.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(4), AndroidUtilities.dp(10), AndroidUtilities.dp(0))
            except Exception:
                pass
            content.addView(desc, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            open_btn = TextView(ctx)
            open_btn.setText(self._tr("first_welcome_button"))
            open_btn.setGravity(Gravity.CENTER)
            open_btn.setTextSize(18)
            try:
                open_btn.setTextColor(Color.BLACK)
                btn_bg = GradientDrawable()
                btn_bg.setColor(Color.parseColor("#F4FAFF"))
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(22)))
                open_btn.setBackground(btn_bg)
                open_btn.setPadding(AndroidUtilities.dp(22), AndroidUtilities.dp(14), AndroidUtilities.dp(22), AndroidUtilities.dp(14))
            except Exception:
                pass

            class _OpenSettings(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_plugin_settings(fragment or v)
                    except Exception:
                        pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            open_btn.setOnClickListener(_OpenSettings())
            hero.addView(open_btn, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL))
            try:
                blp = open_btn.getLayoutParams()
                blp.leftMargin = AndroidUtilities.dp(24)
                blp.rightMargin = AndroidUtilities.dp(24)
                blp.bottomMargin = AndroidUtilities.dp(22)
                open_btn.setLayoutParams(blp)
            except Exception:
                pass
            content_lp = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.TOP | Gravity.CENTER_HORIZONTAL)
            content_lp.topMargin = AndroidUtilities.dp(18)
            hero.addView(content, content_lp)
            self._wlog("content added to hero")

            lp_hero = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(458), Gravity.CENTER)
            lp_hero.leftMargin = AndroidUtilities.dp(16)
            lp_hero.rightMargin = AndroidUtilities.dp(16)
            lp_hero.topMargin = AndroidUtilities.dp(16)
            lp_hero.bottomMargin = AndroidUtilities.dp(18)
            root.addView(hero, lp_hero)
            sheet.setCustomView(root)
            try:
                self._style_welcome_sheet_surface(sheet)
            except Exception:
                pass
            run_on_ui_thread(sheet.show)
            try:
                class _AfterShow(dynamic_proxy("java.lang.Runnable")):
                    def run(self_obj):
                        try:
                            self._style_welcome_sheet_surface(sheet)
                        except Exception:
                            pass
                root.postDelayed(_AfterShow(), 32)
            except Exception:
                pass
            log("[TranslaticaLite][Welcome] show queued")
            try:
                class _InspectAvatar(dynamic_proxy("java.lang.Runnable")):
                    def run(self_obj):
                        try:
                            av_w = int(avatar_view.getWidth()) if avatar_view is not None else -1
                            av_h = int(avatar_view.getHeight()) if avatar_view is not None else -1
                            av_v = int(avatar_view.getVisibility()) if avatar_view is not None else -1
                            av_a = float(avatar_view.getAlpha()) if avatar_view is not None else -1.0
                            sh_w = int(avatar_shell.getWidth())
                            sh_h = int(avatar_shell.getHeight())
                            sh_v = int(avatar_shell.getVisibility())
                            self._wlog(f"inspect avatar w={av_w} h={av_h} vis={av_v} alpha={av_a} shell_w={sh_w} shell_h={sh_h} shell_vis={sh_v}")
                        except Exception as e:
                            self._wlog(f"inspect avatar fail: {e}")
                root.postDelayed(_InspectAvatar(), 260)
            except Exception:
                pass
            return True
        except Exception as e:
            log(f"[TranslaticaLite][Welcome] show fail: {e}")
            self._dlog(f"welcome sheet fail: {e}")
            return False

    def _style_welcome_sheet_surface(self, sheet):
        try:
            if not sheet:
                return
            targets = []
            try:
                c = sheet.getContainer()
                if c is not None and c not in targets:
                    targets.append(c)
            except Exception:
                pass
            try:
                c2 = getattr(sheet, "containerView", None)
                if c2 is not None and c2 not in targets:
                    targets.append(c2)
            except Exception:
                pass
            for fname in ("containerView", "container", "sheetContainer", "sheetView"):
                try:
                    v = _get_private_field_silent(sheet, fname)
                except Exception:
                    v = None
                if v is not None and v not in targets:
                    targets.append(v)
            for v in targets:
                try:
                    try:
                        v.setBackgroundColor(0x00000000)
                    except Exception:
                        pass
                    try:
                        v.setBackground(None)
                    except Exception:
                        pass
                    try:
                        v.setPadding(0, 0, 0, 0)
                    except Exception:
                        pass
                    try:
                        v.setAlpha(1.0)
                    except Exception:
                        pass
                    try:
                        v.setElevation(0.0)
                    except Exception:
                        pass
                except Exception:
                    pass
            try:
                w = sheet.getWindow()
            except Exception:
                w = None
            if w is None:
                return
            try:
                w.setBackgroundDrawable(None)
            except Exception:
                pass
            try:
                w.setDimAmount(0.0)
            except Exception:
                pass
            try:
                w.clearFlags(WindowManager.LayoutParams.FLAG_DIM_BEHIND)
            except Exception:
                pass
            try:
                if int(Build.VERSION.SDK_INT) >= 31:
                    w.setBackgroundBlurRadius(0)
            except Exception:
                pass
        except Exception as e:
            self._dlog(f"welcome sheet style fail: {e}")

    def _maybe_show_first_install_welcome(self):
        try:
            if bool(self.get_setting("tlite_first_welcome_done", False)):
                self._dlog("first welcome skip: already done")
                return
            if bool(getattr(self, "_tlite_welcome_launching", False)):
                self._dlog("first welcome skip: launching")
                return
            self._tlite_welcome_launching = True
            self._dlog("first welcome: start")

            def _worker():
                try:
                    target_ctx = None
                    for _ in range(40):
                        try:
                            from client_utils import get_last_fragment
                            frag = get_last_fragment()
                            if frag:
                                act = frag.getParentActivity()
                                if act:
                                    target_ctx = act
                                    break
                        except Exception:
                            pass
                        try:
                            time.sleep(0.25)
                        except Exception:
                            break
                    if target_ctx is None:
                        self._dlog("first welcome: no activity context")
                        return
                    try:
                        if not os.path.exists(WELCOME_BG_CACHE_FILE):
                            self._load_welcome_bg_remote()
                    except Exception:
                        pass

                    def _show():
                        try:
                            shown = bool(self._show_welcome_sheet(target_ctx))
                            self._dlog(f"first welcome: show={shown}")
                            if shown:
                                self.set_setting("tlite_first_welcome_done", True)
                        except Exception:
                            pass
                    run_on_ui_thread(_show)
                finally:
                    self._tlite_welcome_launching = False

            threading.Thread(target=_worker, daemon=True).start()
        except Exception as e:
            self._dlog(f"first welcome check fail: {e}")

    def _is_our_settings_activity(self, activity):
        try:
            if activity is None:
                return False
            p = None
            try:
                p = _get_private_field_silent(activity, "plugin")
            except Exception:
                p = None
            if not p:
                return False
            pid = ""
            try:
                pid = str(p.getId() or "").strip().lower()
            except Exception:
                pid = ""
            if pid == str(__id__).strip().lower():
                return True
            try:
                nm = str(p.getName() or "").strip().lower()
            except Exception:
                nm = ""
            return nm == str(__name__).strip().lower()
        except Exception:
            return False

    def _build_settings_header_view(self, ctx):
        try:
            from android.graphics.drawable import GradientDrawable
            compact_footer = False
            try:
                dm = ctx.getResources().getDisplayMetrics()
                screen_w_dp = float(dm.widthPixels) / float(dm.density or 1.0)
                font_scale = float(getattr(ctx.getResources().getConfiguration(), "fontScale", 1.0) or 1.0)
                compact_footer = bool(screen_w_dp < 380.0 or font_scale > 1.08)
            except Exception:
                compact_footer = False

            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            try:
                outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(6), AndroidUtilities.dp(16), AndroidUtilities.dp(6))
            except Exception:
                pass

            card = LinearLayout(ctx)
            card.setOrientation(LinearLayout.VERTICAL)
            try:
                card.setPadding(AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(10))
            except Exception:
                pass

            try:
                card.setBackgroundColor(0x00000000)
            except Exception:
                pass

            hero = FrameLayout(ctx)
            try:
                hero_bg = GradientDrawable()
                hero_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                hero_bg.setColor(0x00000000)
                hero.setBackground(hero_bg)
                hero.setClipToOutline(True)
                hero.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass
            banner = ImageView(ctx)
            try:
                banner.setScaleType(ImageView.ScaleType.CENTER_CROP)
            except Exception:
                pass
            try:
                is_dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark = True
            try:
                banner_path = HEADER_IMAGE_CACHE_FILE_DARK if is_dark else HEADER_IMAGE_CACHE_FILE_LIGHT
                if os.path.exists(banner_path):
                    bmp = BitmapFactory.decodeFile(banner_path)
                    if bmp:
                        banner.setImageBitmap(bmp)
            except Exception:
                pass
            hero.addView(
                banner,
                FrameLayout.LayoutParams(
                    FrameLayout.LayoutParams.MATCH_PARENT,
                    AndroidUtilities.dp(200),
                ),
            )

            top_icon = ImageView(ctx)
            try:
                top_icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                top_path = TOP_ICON_CACHE_FILE_DARK if is_dark else TOP_ICON_CACHE_FILE_LIGHT
                if os.path.exists(top_path):
                    bmp_t = BitmapFactory.decodeFile(top_path)
                    if bmp_t:
                        top_icon.setImageBitmap(bmp_t)
            except Exception:
                pass
            try:
                top_icon.setClickable(True)
                top_icon.setFocusable(True)
            except Exception:
                pass

            class _OpenExtera(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    self._dlog("header icon click -> exteraDevPlugins")
                    try:
                        from client_utils import get_messages_controller, get_last_fragment
                        get_messages_controller().openByUserName("exteraDevPlugins", get_last_fragment(), 1)
                    except Exception:
                        try:
                            self.open_url("https://t.me/exteraDevPlugins")
                        except Exception:
                            pass

            try:
                top_icon.setOnClickListener(_OpenExtera())
            except Exception:
                pass
            try:
                class _TopLong(dynamic_proxy(View.OnLongClickListener)):
                    def onLongClick(self_obj, v):
                        try:
                            self._show_debug_quick_popup(v)
                        except Exception as e:
                            self._dlog(f"header icon long press fail: {e}")
                        return True
                top_icon.setOnLongClickListener(_TopLong())
            except Exception:
                pass
            try:
                lp_top = FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.TOP | Gravity.END)
                lp_top.topMargin = AndroidUtilities.dp(10)
                lp_top.rightMargin = AndroidUtilities.dp(10)
                hero.addView(top_icon, lp_top)
            except Exception:
                hero.addView(top_icon)

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.VERTICAL if compact_footer else LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL if not compact_footer else Gravity.LEFT)
            try:
                row.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass
            try:
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                row_bg.setColor(Color.WHITE if is_dark else Color.BLACK)
                row.setBackground(row_bg)
            except Exception:
                pass

            btn = LinearLayout(ctx)
            btn.setOrientation(LinearLayout.HORIZONTAL)
            btn.setGravity(Gravity.CENTER_VERTICAL)
            try:
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(Color.parseColor("#6C4CFF"))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            btn_icon = ImageView(ctx)
            try:
                btn_icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                if os.path.exists(SUPPORT_ICON_CACHE_FILE):
                    bmp_i = BitmapFactory.decodeFile(SUPPORT_ICON_CACHE_FILE)
                    if bmp_i:
                        btn_icon.setImageBitmap(bmp_i)
                btn_icon.setColorFilter(Color.WHITE)
            except Exception:
                pass
            btn.addView(btn_icon, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))

            btn_text = TextView(ctx)
            btn_text.setText("Dotted Chat")
            btn_text.setTextSize(16)
            try:
                btn_text.setTextColor(Color.WHITE)
            except Exception:
                pass
            try:
                btn_text.setSingleLine(True)
                btn_text.setMaxLines(1)
            except Exception:
                pass
            try:
                lp_btn_text = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_btn_text.leftMargin = AndroidUtilities.dp(8)
                btn.addView(btn_text, lp_btn_text)
            except Exception:
                btn.addView(btn_text)

            class _OpenDotted(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_dotted_chat()
                    except Exception:
                        pass

            btn.setOnClickListener(_OpenDotted())
            try:
                btn.setClickable(True)
                btn.setFocusable(True)
                btn.setAlpha(1.0)
            except Exception:
                pass
            try:
                class _BtnPress(dynamic_proxy(View.OnTouchListener)):
                    def onTouch(self_obj, v, event):
                        try:
                            action = int(event.getActionMasked())
                        except Exception:
                            action = -1
                        try:
                            bg = v.getBackground()
                            if bg and isinstance(bg, GradientDrawable):
                                if action in (0, 2):
                                    bg.setColor(Color.parseColor("#5A3EF0"))
                                elif action in (1, 3):
                                    bg.setColor(Color.parseColor("#6C4CFF"))
                        except Exception:
                            pass
                        return False
                btn.setOnTouchListener(_BtnPress())
            except Exception:
                pass
            lp_btn_wrap = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            if compact_footer:
                lp_btn_wrap.bottomMargin = AndroidUtilities.dp(8)
            row.addView(btn, lp_btn_wrap)

            info = TextView(ctx)
            info.setText(self._tr("welcome_dotted_desc"))
            info.setTextSize(14)
            try:
                info.setTextColor(Color.BLACK if is_dark else Color.WHITE)
            except Exception:
                pass
            try:
                info.setMaxLines(3 if compact_footer else 2)
                info.setSingleLine(False)
            except Exception:
                pass
            try:
                lp_info = LinearLayout.LayoutParams(
                    0 if not compact_footer else LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    1.0 if not compact_footer else 0.0
                )
                if compact_footer:
                    lp_info.leftMargin = 0
                else:
                    lp_info.leftMargin = AndroidUtilities.dp(12)
                    lp_info.gravity = Gravity.CENTER_VERTICAL
                row.addView(info, lp_info)
            except Exception:
                row.addView(info)
            try:
                lp_row = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM | Gravity.START)
                lp_row.leftMargin = AndroidUtilities.dp(12)
                lp_row.rightMargin = AndroidUtilities.dp(12)
                lp_row.bottomMargin = AndroidUtilities.dp(12)
                hero.addView(row, lp_row)
            except Exception:
                hero.addView(row)
            card.addView(hero, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(200)))

            outer.addView(card, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            return outer
        except Exception as e:
            self._dlog(f"build settings header fail: {e}")
            return None

    def _build_settings_version_view(self, ctx):
        try:
            wrap = FrameLayout(ctx)
            wrap.setBackgroundColor(0x00000000)
            try:
                wrap.setPadding(0, AndroidUtilities.dp(2), 0, AndroidUtilities.dp(4))
            except Exception:
                pass
            tv = TextView(ctx)
            tv.setText(f"\nTranslatica Lite \u2022 v{__version__}")
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(13)
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2)))
            except Exception:
                pass
            wrap.addView(tv, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.CENTER))
            return wrap
        except Exception as e:
            self._dlog(f"build version view fail: {e}")
            return None

    def _inject_settings_header(self, activity, items):
        try:
            if not self._is_our_settings_activity(activity):
                return
            try:
                has_header = False
                has_version = False
                for i in range(items.size()):
                    it = items.get(i)
                    mk = str(getattr(it, "object2", "") or "")
                    if mk == "__tlite_settings_header__":
                        has_header = True
                    elif mk == "__tlite_settings_version__":
                        has_version = True
            except Exception:
                has_header = False
                has_version = False

            ctx = activity.getContext() if hasattr(activity, "getContext") else None
            if not ctx:
                return
            try:
                if (not bool(self.get_setting("tlite_first_welcome_done", False))) and (not bool(getattr(self, "_tlite_welcome_launching", False))):
                    self._tlite_welcome_launching = True
                    def _show_once():
                        try:
                            shown = bool(self._show_welcome_sheet(ctx))
                            if shown:
                                self.set_setting("tlite_first_welcome_done", True)
                        finally:
                            self._tlite_welcome_launching = False
                    run_on_ui_thread(_show_once)
            except Exception:
                pass
            UItem = find_class("org.telegram.ui.Components.UItem")
            if not UItem:
                return
            if not has_header:
                view = self._build_settings_header_view(ctx)
                if view:
                    hi = UItem.asCustom(view)
                    try:
                        hi.object2 = "__tlite_settings_header__"
                    except Exception:
                        pass
                    try:
                        hi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(0, hi)
                    try:
                        items.add(1, UItem.asShadow())
                    except Exception:
                        pass
            if not has_version:
                v = self._build_settings_version_view(ctx)
                if v:
                    vi = UItem.asCustom(v)
                    try:
                        vi.object2 = "__tlite_settings_version__"
                    except Exception:
                        pass
                    try:
                        vi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(vi)
        except Exception as e:
            self._dlog(f"inject settings header fail: {e}")

    def _show_debug_quick_popup(self, anchor_view):
        try:
            if anchor_view is None:
                return
            ctx = anchor_view.getContext()
            LinearLayoutCls = find_class("android.widget.LinearLayout")
            TextViewCls = find_class("android.widget.TextView")
            PopupWindow = find_class("android.widget.PopupWindow")
            GradientDrawable = find_class("android.graphics.drawable.GradientDrawable")
            TypedValue = find_class("android.util.TypedValue")
            if not LinearLayoutCls or not TextViewCls or not PopupWindow:
                return

            enabled = bool(self.get_setting("tlite_debug_logs", False))
            stats_enabled = bool(self._stats_enabled())
            root = LinearLayoutCls(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            try:
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                bg.setColor(int(Theme.getColor(Theme.key_actionBarDefaultSubmenuBackground)))
                root.setBackground(bg)
                root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            except Exception:
                pass

            row = LinearLayoutCls(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            try:
                row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            except Exception:
                pass

            tv = TextViewCls(ctx)
            tv.setText(self._tr("settings_debug_logs"))
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
                tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                tv.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
            except Exception:
                pass
            row.addView(tv, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            cb = LinearLayoutCls(ctx)
            cb.setGravity(Gravity.CENTER)
            try:
                cb_bg = GradientDrawable()
                cb_bg.setCornerRadius(float(AndroidUtilities.dp(6)))
                cb_bg.setColor(0x00000000)
                if enabled:
                    cb_bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_switchTrackChecked)))
                else:
                    cb_bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                cb.setBackground(cb_bg)
            except Exception:
                pass

            mark = TextViewCls(ctx)
            mark.setText("\u2713" if enabled else "")
            try:
                mark.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                mark.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                mark.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                pass
            try:
                cb.addView(mark, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                cb.addView(mark)
            lp_cb = LinearLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24))
            lp_cb.leftMargin = AndroidUtilities.dp(10)
            row.addView(cb, lp_cb)

            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            row_stats = LinearLayoutCls(ctx)
            row_stats.setOrientation(LinearLayout.HORIZONTAL)
            row_stats.setGravity(Gravity.CENTER_VERTICAL)
            try:
                row_stats.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            except Exception:
                pass

            tv_stats = TextViewCls(ctx)
            tv_stats.setText(self._tr("stats_enabled"))
            try:
                tv_stats.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
                tv_stats.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                tv_stats.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
            except Exception:
                pass
            row_stats.addView(tv_stats, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            cb_stats = LinearLayoutCls(ctx)
            cb_stats.setGravity(Gravity.CENTER)
            try:
                cb_stats_bg = GradientDrawable()
                cb_stats_bg.setCornerRadius(float(AndroidUtilities.dp(6)))
                cb_stats_bg.setColor(0x00000000)
                if stats_enabled:
                    cb_stats_bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_switchTrackChecked)))
                else:
                    cb_stats_bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                cb_stats.setBackground(cb_stats_bg)
            except Exception:
                pass

            mark_stats = TextViewCls(ctx)
            mark_stats.setText("\u2713" if stats_enabled else "")
            try:
                mark_stats.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                mark_stats.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                mark_stats.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                pass
            try:
                cb_stats.addView(mark_stats, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                cb_stats.addView(mark_stats)
            lp_cb_stats = LinearLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24))
            lp_cb_stats.leftMargin = AndroidUtilities.dp(10)
            row_stats.addView(cb_stats, lp_cb_stats)

            root.addView(row_stats, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            popup = PopupWindow(root, LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT, True)
            try:
                popup.setOutsideTouchable(True)
                popup.setFocusable(True)
            except Exception:
                pass

            def _toggle(_v=None):
                try:
                    nv = not bool(self.get_setting("tlite_debug_logs", False))
                    self.set_setting("tlite_debug_logs", nv)
                    if nv:
                        try:
                            BulletinHelper.show_success(";)")
                        except Exception:
                            pass
                    try:
                        self.reload_settings()
                    except Exception:
                        pass
                    try:
                        run_on_ui_thread(self._refresh_settings_screen)
                    except Exception:
                        pass
                except Exception as e:
                    self._dlog(f"debug toggle fail: {e}")
                try:
                    popup.dismiss()
                except Exception:
                    pass

            class _Click(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    _toggle()
            row.setOnClickListener(_Click())

            def _toggle_stats(_v=None):
                try:
                    nv = not bool(self._stats_enabled())
                    self.set_setting("tlite_stats_enabled", nv)
                    try:
                        BulletinHelper.show_info(self._tr("bulletin_stats_enabled") if nv else self._tr("bulletin_stats_disabled"))
                    except Exception:
                        pass
                    if nv:
                        try:
                            self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                            if not bool(self.get_setting("tlite_stats_install_event_sent_v1", False)):
                                self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                                self.set_setting("tlite_stats_install_event_sent_v1", True)
                        except Exception:
                            pass
                except Exception as e:
                    self._dlog(f"stats toggle fail: {e}")
                try:
                    popup.dismiss()
                except Exception:
                    pass

            class _StatsClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    _toggle_stats()
            row_stats.setOnClickListener(_StatsClick())

            try:
                popup.showAsDropDown(anchor_view, 0, AndroidUtilities.dp(8), Gravity.START)
            except Exception:
                try:
                    popup.showAsDropDown(anchor_view, 0, AndroidUtilities.dp(8))
                except Exception:
                    popup.showAsDropDown(anchor_view)
        except Exception as e:
            self._dlog(f"debug popup fail: {e}")

    def _refresh_settings_screen(self):
        try:
            activity = self.get_last_fragment()
            if not activity:
                return
            for name in ("rebuildAllItems", "updateRows", "updateVisibleRows", "notifyDataSetChanged"):
                try:
                    m = activity.getClass().getDeclaredMethod(name)
                    m.setAccessible(True)
                    m.invoke(activity)
                    self._dlog(f"settings refresh via {name}")
                    return
                except Exception:
                    pass
                try:
                    methods = activity.getClass().getDeclaredMethods()
                    for m in methods:
                        try:
                            if str(m.getName()) != name:
                                continue
                            ptypes = m.getParameterTypes()
                            if not ptypes or len(ptypes) != 1:
                                continue
                            m.setAccessible(True)
                            try:
                                m.invoke(activity, False)
                            except Exception:
                                m.invoke(activity, True)
                            self._dlog(f"settings refresh via {name}(bool)")
                            return
                        except Exception:
                            pass
                except Exception:
                    pass
            try:
                adapter = _get_private_field_silent(activity, "adapter")
                if adapter:
                    m = adapter.getClass().getMethod("notifyDataSetChanged")
                    m.invoke(adapter)
                    self._dlog("settings refresh via adapter.notifyDataSetChanged")
                    return
            except Exception:
                pass
        except Exception as e:
            self._dlog(f"settings refresh fail: {e}")

    def _setup_settings_header_hook(self):
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            if not PSA:
                return
            arr_cls = find_class("java.util.ArrayList")
            ua_cls = find_class("org.telegram.ui.Components.UniversalAdapter")
            if not arr_cls or not ua_cls:
                return
            m = PSA.getClass().getDeclaredMethod("fillItems", arr_cls, ua_cls)
            m.setAccessible(True)
            self._settings_header_hook = self.hook_method(m, TLLiteSettingsHeaderHook(self))
            self._dlog("settings header hook ok")
        except Exception as e:
            self._dlog(f"settings header hook fail: {e}")

    def _show_about_sheet(self, ctx_override=None):
        try:
            try:
                log("[TranslaticaLite] about sheet open requested")
            except Exception:
                pass
            ctx = ctx_override
            if ctx is None:
                frag = self.get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                ctx = ApplicationLoader.applicationContext
            if not ctx:
                try:
                    log("[TranslaticaLite] about sheet open aborted: no BottomSheet or context")
                except Exception:
                    pass
                return
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass

            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                root_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                root.setBackground(root_bg)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            try:
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                row_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                row.setBackground(row_bg)
            except Exception:
                pass

            avatar = ImageView(ctx)
            try:
                avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                av_bg = GradientDrawable()
                av_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                av_bg.setColor(0x00000000)
                avatar.setBackground(av_bg)
                avatar.setClipToOutline(True)
                avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                if os.path.exists(ABOUT_AVATAR_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(ABOUT_AVATAR_CACHE_FILE)
                    if bmp:
                        avatar.setImageBitmap(bmp)
                avatar.setCameraDistance(float(AndroidUtilities.dp(800)))
                avatar.setAlpha(0.0)
                avatar.setTranslationY(float(AndroidUtilities.dp(26)))
                avatar.setRotationY(-120.0)
            except Exception:
                pass
            row.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            try:
                desc.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_desc.leftMargin = AndroidUtilities.dp(10)
            row.addView(desc, lp_desc)
            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            btn = TextView(ctx)
            btn.setText(self._tr("about_button"))
            btn.setGravity(Gravity.CENTER)
            btn.setTextSize(16)
            try:
                btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            extended_btn = ImageView(ctx)
            try:
                extended_btn.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                is_dark = bool(Theme.isCurrentThemeDark())
                icon_path = EXTENDED_ICON_CACHE_FILE_DARK if is_dark else EXTENDED_ICON_CACHE_FILE_LIGHT
                if os.path.exists(icon_path):
                    bmp = BitmapFactory.decodeFile(icon_path)
                    if bmp:
                        extended_btn.setImageBitmap(bmp)
                extended_btn.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            except Exception:
                pass

            class _AboutOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        log("[TranslaticaLite] about button click -> AGeekApple")
                    except Exception:
                        pass
                    try:
                        from client_utils import get_messages_controller, get_last_fragment
                        get_messages_controller().openByUserName("AGeekApple", get_last_fragment(), 1)
                    except Exception:
                        try:
                            self.open_url("https://t.me/AGeekApple")
                        except Exception:
                            pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            btn.setOnClickListener(_AboutOpen())
            class _ExtendedOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self.open_url("tg://resolve?domain=ApplesBio&post=4")
                    except Exception:
                        try:
                            from client_utils import get_messages_controller, get_last_fragment
                            get_messages_controller().openByUserName("ApplesBio", get_last_fragment(), 1)
                        except Exception:
                            try:
                                self.open_url("https://t.me/ApplesBio/4")
                            except Exception:
                                pass

            extended_btn.setOnClickListener(_ExtendedOpen())

            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_actions.topMargin = AndroidUtilities.dp(10)

            lp_ext = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
            lp_ext.rightMargin = AndroidUtilities.dp(8)
            actions.addView(extended_btn, lp_ext)

            lp_btn = LinearLayout.LayoutParams(AndroidUtilities.dp(120), LinearLayout.LayoutParams.WRAP_CONTENT)
            actions.addView(btn, lp_btn)
            root.addView(actions, lp_actions)
            try:
                max_w = int(AndroidUtilities.displaySize.x) - AndroidUtilities.dp(36)
            except Exception:
                max_w = LinearLayout.LayoutParams.MATCH_PARENT
            lp_root = LinearLayout.LayoutParams(max_w, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_root.gravity = Gravity.CENTER_HORIZONTAL
            outer.addView(root, lp_root)

            sheet.setCustomView(outer)
            try:
                run_on_ui_thread(sheet.show)
            except Exception:
                sheet.show()
            try:
                avatar.post(lambda: avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start())
            except Exception:
                try:
                    avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start()
                except Exception:
                    pass
            try:
                log("[TranslaticaLite] about sheet shown")
            except Exception:
                pass
        except Exception as e:
            try:
                log(f"[TranslaticaLite] about sheet fail: {e}")
            except Exception:
                pass

    def _resolve_settings_fragment(self, source=None):
        try:
            if source is not None:
                try:
                    if hasattr(source, "presentFragment"):
                        return source
                except Exception:
                    pass
                for name in ("fragment", "parentFragment", "lastFragment"):
                    try:
                        cand = getattr(source, name, None)
                        if cand is not None and hasattr(cand, "presentFragment"):
                            return cand
                    except Exception:
                        pass
                for name in ("getFragment", "getParentFragment", "getLastFragment"):
                    try:
                        getter = getattr(source, name, None)
                        if getter is None:
                            continue
                        cand = getter()
                        if cand is not None and hasattr(cand, "presentFragment"):
                            return cand
                    except Exception:
                        pass
            try:
                from client_utils import get_last_fragment
                cand = get_last_fragment()
                if cand is not None and hasattr(cand, "presentFragment"):
                    return cand
            except Exception:
                pass
            try:
                cand = self.get_last_fragment()
                if cand is not None and hasattr(cand, "presentFragment"):
                    return cand
            except Exception:
                pass
        except Exception:
            pass
        return None

    def _open_plugin_settings(self, source=None):
        try:
            plugin = None
            fragment = self._resolve_settings_fragment(source)
            try:
                controller = PluginsController.getInstance()
                plugin = controller.plugins.get(self.id) if controller else None
            except Exception:
                plugin = None
            if plugin is None:
                plugin = self
            if plugin is None or fragment is None:
                self._dlog("open settings skipped: plugin/fragment unavailable")
                return
            fragment.presentFragment(PluginSettingsActivity(plugin))
            self._dlog("open settings ok")
        except Exception as e:
            self._dlog(f"open settings fail: {e}")

    def _add_menu_items(self):
        try:
            self._chat_menu_item = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Translatica Lite",
                    icon="msg_translate",
                    priority=5,
                    on_click=lambda _ctx: run_on_ui_thread(lambda: self._open_plugin_settings(_ctx)),
                )
            )
        except Exception as e:
            self._dlog(f"add menu item fail: {e}")

    def _on_about_click(self, _view=None):
        try:
            log("[TranslaticaLite] about item clicked")
        except Exception:
            pass
        ctx = None
        try:
            if _view is not None and hasattr(_view, "getContext"):
                ctx = _view.getContext()
        except Exception:
            ctx = None
        try:
            run_on_ui_thread(lambda: self._show_about_sheet(ctx))
        except Exception:
            self._show_about_sheet(ctx)

    def _global_target_lang(self):
        self._migrate_target_lang_index_order()
        try:
            raw = self.get_setting("tlite_target_lang", 0)
            idx = int(raw)
            if 0 <= idx < len(LANG_CODES):
                return LANG_CODES[idx]
        except Exception:
            pass
        return "en"

    def _extract_dialog_id(self, params=None, fragment=None):
        try:
            if fragment is None:
                try:
                    from client_utils import get_last_fragment
                    fragment = get_last_fragment()
                except Exception:
                    fragment = None
            if fragment is not None and hasattr(fragment, "getDialogId"):
                try:
                    return int(fragment.getDialogId() or 0)
                except Exception:
                    pass
            if params is not None:
                for key in ("dialog_id", "dialogId", "peer", "peer_id"):
                    try:
                        v = getattr(params, key, None)
                        if v is not None:
                            iv = int(v)
                            if iv != 0:
                                return iv
                    except Exception:
                        pass
                try:
                    if isinstance(params, dict):
                        for key in ("dialog_id", "dialogId", "peer", "peer_id"):
                            v = params.get(key)
                            if v is not None:
                                iv = int(v)
                                if iv != 0:
                                    return iv
                except Exception:
                    pass
        except Exception:
            pass
        try:
            if int(getattr(self, "_chat_dialog_id_ref", 0) or 0) != 0:
                return int(self._chat_dialog_id_ref)
        except Exception:
            pass
        return 0

    def _chat_prefs(self):
        try:
            raw = self.get_setting("tlite_chat_prefs", {}) or {}
            if isinstance(raw, dict):
                return raw
        except Exception:
            pass
        return {}

    def _save_chat_prefs(self, prefs):
        try:
            self.set_setting("tlite_chat_prefs", prefs if isinstance(prefs, dict) else {})
        except Exception:
            pass

    def _chat_config(self, dialog_id):
        prefs = self._chat_prefs()
        key = str(int(dialog_id or 0))
        cfg = prefs.get(key) or {}
        if not isinstance(cfg, dict):
            cfg = {}
        enabled = bool(cfg.get("enabled", False))
        lang = str(cfg.get("lang", self._global_target_lang()) or self._global_target_lang())
        if lang not in LANG_CODES:
            lang = self._global_target_lang()
        return {"enabled": enabled, "lang": lang}

    def _set_chat_config(self, dialog_id, enabled=None, lang=None):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                return
            prefs = self._chat_prefs()
            key = str(did)
            cfg = prefs.get(key) or {}
            if not isinstance(cfg, dict):
                cfg = {}
            if enabled is not None:
                cfg["enabled"] = bool(enabled)
            if lang is not None and str(lang or "") in LANG_CODES:
                cfg["lang"] = str(lang)
            prefs[key] = cfg
            self._save_chat_prefs(prefs)
        except Exception as e:
            self._dlog(f"set chat config fail: {e}")

    def _build_apple_icon(self, ctx):
        icon = ImageView(ctx)
        loaded_custom = False
        try:
            if os.path.exists(CHAT_ICON_CACHE_FILE):
                bmp = BitmapFactory.decodeFile(CHAT_ICON_CACHE_FILE)
                if bmp:
                    icon.setImageBitmap(bmp)
                    loaded_custom = True
        except Exception:
            pass
        if not loaded_custom:
            try:
                from client_utils import run_on_queue
                def _dl():
                    try:
                        self._load_chat_icon_remote()
                        if os.path.exists(CHAT_ICON_CACHE_FILE):
                            bmp2 = BitmapFactory.decodeFile(CHAT_ICON_CACHE_FILE)
                            if bmp2:
                                def _apply():
                                    try:
                                        icon.setImageBitmap(bmp2)
                                        self._refresh_apple_button()
                                    except Exception:
                                        pass
                                run_on_ui_thread(_apply)
                    except Exception as e:
                        self._dlog(f"chat icon async load fail: {e}")
                run_on_queue(_dl)
            except Exception:
                pass
            try:
                rid = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_translate", "drawable", ApplicationLoader.applicationContext.getPackageName())
                if rid:
                    icon.setImageResource(rid)
            except Exception:
                pass
        try:
            icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
        except Exception:
            pass
        return icon

    def _apply_apple_icon_state(self, fragment, icon_view):
        try:
            did = self._extract_dialog_id(fragment=fragment)
            cfg = self._chat_config(did)
            if cfg["enabled"]:
                try:
                    color = int(Theme.getColor(Theme.key_featuredStickers_addButton))
                except Exception:
                    color = 0xFF38A8FF
            else:
                try:
                    color = int(Theme.getColor(Theme.key_chat_messagePanelIcons))
                except Exception:
                    color = 0xFF8A8A8A
            icon_view.setColorFilter(color)
        except Exception:
            pass

    def _refresh_apple_button(self):
        try:
            if self._chat_apple_btn is None or self._chat_fragment_ref is None or self._chat_apple_icon is None:
                return
            self._apply_apple_icon_state(self._chat_fragment_ref, self._chat_apple_icon)
        except Exception:
            pass

    def _schedule_apple_attach_retry(self, fragment, reason="retry"):
        try:
            if fragment is None:
                return
            key = str(id(fragment))
            if key in self._attach_retry_keys:
                return
            self._attach_retry_keys.add(key)
            from client_utils import run_on_queue
            def _worker():
                try:
                    for _ in range(5):
                        time.sleep(0.22)
                        done = {"ok": False}
                        def _try():
                            try:
                                self._attach_apple_button(fragment, from_retry=True)
                                done["ok"] = self._chat_apple_btn is not None
                            except Exception:
                                pass
                        run_on_ui_thread(_try)
                        if done["ok"]:
                            break
                finally:
                    try:
                        self._attach_retry_keys.discard(key)
                    except Exception:
                        pass
            run_on_queue(_worker)
            self._dlog(f"attach retry scheduled: {reason}")
        except Exception as e:
            self._dlog(f"attach retry fail: {e}")

    def _schedule_apple_reorder(self, host, btn):
        try:
            if host is None or btn is None:
                return
            if not isinstance(host, LinearLayout):
                return
            def _once():
                try:
                    if btn.getParent() is not host:
                        return
                    lp = btn.getLayoutParams()
                    host.removeView(btn)
                    try:
                        host.addView(btn, lp)
                    except Exception:
                        host.addView(btn)
                    try:
                        btn.bringToFront()
                    except Exception:
                        pass
                except Exception:
                    pass
            run_on_ui_thread(_once)
            from client_utils import run_on_queue
            def _retry():
                for _ in range(4):
                    time.sleep(0.24)
                    run_on_ui_thread(_once)
            run_on_queue(_retry)
        except Exception as e:
            self._dlog(f"apple reorder fail: {e}")

    def _schedule_apple_stabilize(self, fragment):
        try:
            if fragment is None:
                return
            from client_utils import run_on_queue
            def _worker():
                for _ in range(5):
                    time.sleep(0.28)
                    run_on_ui_thread(lambda: self._attach_apple_button(fragment, from_retry=True))
            run_on_queue(_worker)
        except Exception as e:
            self._dlog(f"apple stabilize fail: {e}")

    def _show_language_dialog(self, fragment=None, dialog_id=0):
        try:
            ctx = fragment.getParentActivity() if fragment and fragment.getParentActivity() else ApplicationLoader.applicationContext
            if not ctx:
                return
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass
            did = int(dialog_id or 0)
            if did == 0:
                did = self._extract_dialog_id(fragment=fragment)
            if did == 0:
                return
            cfg = self._chat_config(did)
            current = str(cfg.get("lang", self._global_target_lang()))
            builder = AlertDialogBuilder(ctx)
            builder.set_title(self._tr("sheet_title_chat_language"))
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            try:
                root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            except Exception:
                pass

            for i, label in enumerate(LANG_LABELS):
                code = LANG_CODES[i]
                row = TextView(ctx)
                row.setText(f"{label}{'' if code != current else ' [x]'}")
                try:
                    row.setTextSize(16)
                    row.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                    row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
                except Exception:
                    pass

                class _Click(dynamic_proxy(View.OnClickListener)):
                    def __init__(self_obj, picked_code, picked_label):
                        super().__init__()
                        self_obj.picked_code = picked_code
                        self_obj.picked_label = picked_label
                    def onClick(self_obj, v):
                        try:
                            self._set_chat_config(did, lang=self_obj.picked_code)
                            self._refresh_apple_button()
                            try:
                                self._telemetry_queue_event("feature_use", feature=f"lang_select_{self_obj.picked_code}", count=1, force_flush=False)
                            except Exception:
                                pass
                            BulletinHelper.show_success(
                                (self._tr("bulletin_chat_lang_saved")).replace("%s", self_obj.picked_label.split(" (")[0])
                            )
                        except Exception:
                            pass
                        try:
                            if self._lang_dialog:
                                self._lang_dialog.dismiss()
                        except Exception:
                            pass

                row.setOnClickListener(_Click(code, label))
                root.addView(row)

            builder.set_view(root)
            builder.set_negative_button(self._tr("dialog_close"), lambda d, w: d.dismiss() if d else None)
            self._lang_dialog = builder.show()
        except Exception as e:
            self._dlog(f"language dialog fail: {e}")

    def _on_target_lang_changed(self, index):
        try:
            idx = int(index or 0)
        except Exception:
            idx = 0
        if idx < 0 or idx >= len(LANG_CODES):
            idx = 0
        try:
            self.set_setting("tlite_target_lang", idx)
        except Exception:
            pass
        try:
            self._telemetry_queue_event("feature_use", feature=f"lang_select_{LANG_CODES[idx]}", count=1, force_flush=False)
        except Exception:
            pass

    def _migrate_target_lang_index_order(self):
        try:
            if bool(self.get_setting("tlite_lang_order_v2_done", False)):
                return
        except Exception:
            pass
        try:
            raw = self.get_setting("tlite_target_lang", 0)
            idx = int(raw)
        except Exception:
            idx = 0
        new_idx = 0
        try:
            if 0 <= idx < len(OLD_LANG_CODES):
                code = str(OLD_LANG_CODES[idx] or "").strip()
                if code and code in LANG_CODES:
                    new_idx = int(LANG_CODES.index(code))
            elif 0 <= idx < len(LANG_CODES):
                new_idx = int(idx)
        except Exception:
            new_idx = 0
        try:
            self.set_setting("tlite_target_lang", int(new_idx))
            self.set_setting("tlite_lang_order_v2_done", True)
        except Exception:
            pass

    def _translate_service_mode(self):
        try:
            raw = self.get_setting("tlite_service", "appleai")
            if isinstance(raw, str):
                mode = str(raw or "").strip().lower()
                if mode == "native":
                    return "appleai"
                valid = [str(item[0] or "").strip().lower() for item in SERVICE_OPTIONS]
                if mode in valid:
                    return mode
            idx = int(raw or 0)
            if idx <= 0:
                return "appleai"
            if idx == 1:
                return "translatica"
            if idx == 2:
                return "alternative"
            if idx == 3:
                return "dynamic"
        except Exception:
            pass
        return "appleai"

    def _translate_service_index(self):
        mode = str(self._translate_service_mode() or "appleai").strip().lower()
        for idx, item in enumerate(SERVICE_OPTIONS):
            if str(item[0] or "").strip().lower() == mode:
                return int(idx)
        return 0

    def _translate_service_option_labels(self):
        return [
            "AppleAI",
            "Translatica",
            "Alternative",
            self._tr("settings_translate_service_dynamic"),
        ]

    def _on_plugin_lang_selector_changed(self, index):
        try:
            idx = int(index or 0)
        except Exception:
            idx = 0
        if idx < 0 or idx >= len(PLUGIN_LANG_OPTIONS):
            idx = 0
        try:
            self.set_setting("tlite_plugin_lang", idx)
        except Exception:
            pass
        try:
            code = str(PLUGIN_LANG_OPTIONS[idx][1] or "system")
            self._telemetry_queue_event("feature_use", feature=f"ui_lang_{code}", count=1, force_flush=False)
        except Exception:
            pass

    def _dismiss_keyboard_focus(self, ctx):
        try:
            if ctx is None:
                return
            try:
                focused = ctx.getCurrentFocus()
            except Exception:
                focused = None
            try:
                if focused is not None:
                    focused.clearFocus()
            except Exception:
                pass
            imm = None
            try:
                imm = ctx.getSystemService("input_method")
            except Exception:
                imm = None
            if imm is None:
                return
            token = None
            try:
                w = ctx.getWindow()
                dv = w.getDecorView() if w is not None else None
                token = dv.getWindowToken() if dv is not None else None
            except Exception:
                token = None
            if token is None:
                try:
                    focused = ctx.getCurrentFocus()
                    token = focused.getWindowToken() if focused is not None else None
                except Exception:
                    token = None
            if token is not None:
                try:
                    imm.hideSoftInputFromWindow(token, 0)
                except Exception:
                    pass
        except Exception as e:
            self._dlog(f"dismiss keyboard fail: {e}")

    def _attach_apple_button(self, fragment, from_retry=False):
        try:
            if not fragment:
                return
            enter_view = None
            try:
                enter_view = _get_private_field_silent(fragment, "chatActivityEnterView")
            except Exception:
                pass
            if enter_view is None:
                if not from_retry:
                    self._schedule_apple_attach_retry(fragment, "no_enter_view")
                return

            host = None
            try:
                host = _get_private_field_silent(enter_view, "attachLayout")
            except Exception:
                pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "sendButtonContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "textFieldContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "messageEditTextContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    for fname in ("attachLayout", "sendButtonContainer", "textFieldContainer", "messageEditTextContainer", "messageContainer", "topView", "parentView"):
                        try:
                            cand = _get_private_field_silent(enter_view, fname)
                            if cand is not None and isinstance(cand, ViewGroup):
                                host = cand
                                break
                        except Exception:
                            pass
                except Exception:
                    pass
            if host is None:
                if not from_retry:
                    self._schedule_apple_attach_retry(fragment, "no_host")
                return
            try:
                self._dlog(f"apple host={host.__class__.__name__} retry={from_retry}")
            except Exception:
                pass

            existing = None
            try:
                existing = host.findViewWithTag("__tlite_apple_btn__")
            except Exception:
                pass

            if existing is not None:
                self._chat_apple_btn = existing
                try:
                    self._chat_apple_icon = existing.getChildAt(0)
                except Exception:
                    self._chat_apple_icon = None
                self._chat_fragment_ref = fragment
                try:
                    self._chat_dialog_id_ref = int(self._extract_dialog_id(fragment=fragment) or 0)
                except Exception:
                    self._chat_dialog_id_ref = 0
                self._refresh_apple_button()
                return

            btn = FrameLayout(host.getContext())
            try:
                btn.setTag("__tlite_apple_btn__")
            except Exception:
                pass
            icon = self._build_apple_icon(host.getContext())
            try:
                btn.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.CENTER))
            except Exception:
                btn.addView(icon)

            try:
                if isinstance(host, LinearLayout):
                    lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
                    lp.gravity = Gravity.CENTER_VERTICAL
                    lp.leftMargin = AndroidUtilities.dp(2)
                    lp.rightMargin = AndroidUtilities.dp(2)
                    host.addView(btn, lp)
                else:
                    host.addView(btn)
            except Exception:
                host.addView(btn)

            class _Click(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        did = self._extract_dialog_id(fragment=fragment)
                        cfg = self._chat_config(did)
                        new_state = not bool(cfg["enabled"])
                        self._set_chat_config(did, enabled=new_state)
                        self._refresh_apple_button()
                        if new_state:
                            BulletinHelper.show_success(self._tr("bulletin_chat_enabled_saved"))
                        else:
                            BulletinHelper.show_success(self._tr("bulletin_chat_disabled_saved"))
                    except Exception as e:
                        self._dlog(f"apple click fail: {e}")

            class _Long(dynamic_proxy(View.OnLongClickListener)):
                def onLongClick(self_obj, v):
                    try:
                        self._show_language_dialog(fragment)
                    except Exception:
                        pass
                    return True

            btn.setOnClickListener(_Click())
            btn.setOnLongClickListener(_Long())
            self._chat_apple_btn = btn
            self._chat_apple_icon = icon
            self._chat_fragment_ref = fragment
            try:
                self._chat_dialog_id_ref = int(self._extract_dialog_id(fragment=fragment) or 0)
            except Exception:
                self._chat_dialog_id_ref = 0
            self._refresh_apple_button()
            self._schedule_apple_reorder(host, btn)
            self._dlog("apple button attached")
        except Exception as e:
            self._dlog(f"attach apple fail: {e}")

    def _detach_apple_button(self):
        try:
            if self._chat_apple_btn is not None and self._chat_apple_btn.getParent() is not None:
                self._chat_apple_btn.getParent().removeView(self._chat_apple_btn)
        except Exception:
            pass
        self._chat_apple_btn = None
        self._chat_apple_icon = None
        self._chat_fragment_ref = None
        self._chat_dialog_id_ref = 0

    def _has_entities(self, params):
        try:
            for key in ("entities", "messageEntities", "captionEntities"):
                ent = getattr(params, key, None)
                if ent is not None and len(ent) > 0:
                    return True
        except Exception:
            pass
        return False

    def _is_link_only(self, text):
        try:
            t = str(text or "").strip()
            if not t:
                return True
            no_urls = re.sub(r"(https?://\\S+|www\\.\\S+)", "", t, flags=re.IGNORECASE).strip()
            no_punct = re.sub(r"[\\s\\.,;:!?()\"'\\[\\]{}<>]+", "", no_urls)
            return no_punct == ""
        except Exception:
            return False

    def _is_emoji_only(self, text):
        try:
            t = str(text or "").strip()
            if not t:
                return True
            pat = re.compile(r"^[\\s\\U0001F300-\\U0001FAFF\\u2600-\\u27BF\\uFE0F\\u200D]+$")
            return bool(pat.match(t))
        except Exception:
            return False

    def _should_skip_text(self, text, params):
        t = str(text or "").strip()
        if not t:
            return True
        if t.startswith("/") or t.startswith("."):
            return True
        if self._is_link_only(t):
            self._dlog("skip: link-only")
            return True
        if self._is_emoji_only(t):
            self._dlog("skip: emoji-only")
            return True
        return False

    def _extract_entities_for_text(self, params, using_caption):
        keys = ("captionEntities", "entities", "messageEntities") if using_caption else ("entities", "messageEntities", "captionEntities")
        for k in keys:
            try:
                v = getattr(params, k, None)
                if v is not None and len(v) > 0:
                    return v
            except Exception:
                pass
        return None

    def _entities_to_markdown(self, text, entities):
        try:
            if not entities or not text:
                return text
            res = list(str(text))
            ents = list(entities)
            ents = sorted(ents, key=lambda e: int(getattr(e, "offset", 0)), reverse=True)
            for e in ents:
                try:
                    start = int(getattr(e, "offset", 0))
                    end = start + int(getattr(e, "length", 0))
                    if start < 0 or end < start or end > len(res):
                        continue
                    et = str(e.__class__.__name__)
                    if "Bold" in et:
                        res.insert(end, "*")
                        res.insert(start, "*")
                    elif "Italic" in et:
                        res.insert(end, "_")
                        res.insert(start, "_")
                    elif "Underline" in et:
                        res.insert(end, "__")
                        res.insert(start, "__")
                    elif "Strike" in et:
                        res.insert(end, "~")
                        res.insert(start, "~")
                    elif "Spoiler" in et:
                        res.insert(end, "||")
                        res.insert(start, "||")
                    elif "Code" in et and "Pre" not in et:
                        res.insert(end, "`")
                        res.insert(start, "`")
                    elif "Pre" in et:
                        lang = str(getattr(e, "language", "") or "")
                        res.insert(end, "```")
                        res.insert(start, f"```{lang}\n" if lang else "```")
                    elif "TextUrl" in et:
                        url = str(getattr(e, "url", "") or "")
                        res.insert(end, f"]({url})")
                        res.insert(start, "[")
                    elif "CustomEmoji" in et:
                        doc_id = str(getattr(e, "document_id", "") or "")
                        if doc_id:
                            res.insert(end, f"]({doc_id})")
                            res.insert(start, "[")
                except Exception:
                    pass
            return "".join(res)
        except Exception:
            return str(text or "")

    def _parse_markdown_to_entities(self, text):
        try:
            from markdown_utils import parse_markdown
            parsed = parse_markdown(str(text or ""))
            ents = []
            try:
                for raw in list(getattr(parsed, "entities", []) or []):
                    try:
                        ents.append(raw.to_tlrpc_object())
                    except Exception:
                        pass
            except Exception:
                pass
            return str(getattr(parsed, "text", "") or ""), ents
        except Exception as e:
            self._dlog(f"markdown parse unavailable/fail: {e}")
            return str(text or ""), []

    def _apply_outgoing_entities(self, params, using_caption, entities):
        try:
            j_ents = ArrayList()
            for ent in entities or []:
                try:
                    j_ents.add(ent)
                except Exception:
                    pass
            try:
                params.entities = j_ents
            except Exception:
                pass
            if using_caption:
                try:
                    params.captionEntities = j_ents
                except Exception:
                    pass
        except Exception as e:
            self._dlog(f"apply entities fail: {e}")

    def _mask_urls_for_translate(self, source_text):
        urls = []
        def _url_repl(match):
            idx = len(urls)
            urls.append(match.group(0))
            return f" __TL_URL_{idx}__ "
        masked = re.sub(r"(https?://\\S+|www\\.\\S+)", _url_repl, str(source_text or ""), flags=re.IGNORECASE)
        return masked, urls

    def _restore_masked_urls(self, translated_text, urls):
        out = str(translated_text or "")
        for i, u in enumerate(urls or []):
            out = out.replace(f"__TL_URL_{i}__", u)
        return out

    def _translate_text_google(self, text, dst):
        try:
            source_text = str(text or "")
            masked, urls = self._mask_urls_for_translate(source_text)
            url = (
                "https://translate.googleapis.com/translate_a/single"
                f"?client=gtx&sl=auto&tl={url_quote(dst)}"
                "&dt=t&ie=UTF-8&oe=UTF-8&otf=1&ssel=0&tsel=0&kc=7"
                "&dt=at&dt=bd&dt=ex&dt=ld&dt=md&dt=qca&dt=rw&dt=rm&dt=ss"
                f"&q={url_quote(masked)}"
            )
            req = Request(url, headers={"User-Agent": "TranslaticaLite/1.0"})
            with urlopen(req, timeout=15) as resp:
                raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(raw)
            blocks = data[0] if isinstance(data, list) and len(data) > 0 else []
            parts = []
            for b in blocks:
                try:
                    p = b[0]
                    if p is not None and str(p) != "null":
                        parts.append(str(p))
                except Exception:
                    pass
            out = "".join(parts).strip()
            out = self._restore_masked_urls(out, urls)
            self._dlog(f"translate google ok dst={dst} len_out={len(out)}")
            return out if out else None
        except Exception as e:
            self._dlog(f"translate google fail: {e}")
            return None

    def _translate_text_native(self, text, dst):
        try:
            source_text = str(text or "")
            if not source_text:
                return None
            masked, urls = self._mask_urls_for_translate(source_text)

            TLRPC = find_class("org.telegram.tgnet.TLRPC")
            ConnectionsManager = find_class("org.telegram.tgnet.ConnectionsManager")
            RequestDelegate = find_class("org.telegram.tgnet.RequestDelegate")
            if TLRPC is None or ConnectionsManager is None or RequestDelegate is None:
                self._dlog("translate native unavailable classes")
                return None

            req = TLRPC.TL_messages_translateText()
            req.flags |= 2
            req.to_lang = str(dst or "en")

            te = TLRPC.TL_textWithEntities()
            te.text = masked
            te.entities = ArrayList()
            req.text.add(te)

            state = {"out": None, "err": None}
            done = threading.Event()

            class _ReqDelegate(dynamic_proxy(RequestDelegate)):
                def run(self_obj, response, error):
                    try:
                        if error is not None:
                            state["err"] = str(getattr(error, "text", "") or "native_error")
                            return
                        if response is None:
                            state["err"] = "native_null_response"
                            return
                        result = getattr(response, "result", None)
                        if result is None or result.size() <= 0:
                            state["err"] = "native_empty_result"
                            return
                        first = result.get(0)
                        translated = str(getattr(first, "text", "") or "").strip()
                        if translated:
                            state["out"] = translated
                        else:
                            state["err"] = "native_empty_text"
                    except Exception as _e:
                        state["err"] = str(_e)
                    finally:
                        done.set()

            account = int(UserConfig.selectedAccount)
            ConnectionsManager.getInstance(account).sendRequest(req, _ReqDelegate())
            if not done.wait(12):
                self._dlog("translate native timeout")
                return None
            if not state["out"]:
                self._dlog(f"translate native fail: {state['err']}")
                return None

            out = self._restore_masked_urls(state["out"], urls)
            self._dlog(f"translate native ok dst={dst} len_out={len(out)}")
            return out if out else None
        except Exception as e:
            self._dlog(f"translate native error: {e}")
            return None

    def _translate_text(self, text, dst):
        mode = str(self._translate_service_mode() or "appleai").strip().lower()

        if mode == "translatica":
            return self._translate_text_google(text, dst)

        if mode == "alternative":
            return self._translate_text_google(text, dst)

        if mode == "appleai":
            native_res = self._translate_text_native(text, dst)
            if native_res:
                return native_res
            self._dlog(f"translate {mode} fallback -> google")
            return self._translate_text_google(text, dst)

        txt = str(text or "")
        if len(txt) <= 220:
            native_res = self._translate_text_native(txt, dst)
            if native_res:
                return native_res
            self._dlog("translate dynamic fallback native -> google")
            return self._translate_text_google(txt, dst)

        google_res = self._translate_text_google(txt, dst)
        if google_res:
            return google_res
        self._dlog("translate dynamic fallback google -> native")
        return self._translate_text_native(txt, dst)

    def create_settings(self):
        try:
            run_on_ui_thread(self._maybe_show_first_install_welcome)
        except Exception:
            pass
        try:
            self._migrate_target_lang_index_order()
        except Exception:
            pass
        idx = 0
        pidx = 0
        try:
            idx = int(self.get_setting("tlite_target_lang", 0) or 0)
        except Exception:
            idx = 0
        if idx < 0 or idx >= len(LANG_LABELS):
            idx = 0
        try:
            pidx = int(self.get_setting("tlite_plugin_lang", 0) or 0)
        except Exception:
            pidx = 0
        if pidx < 0 or pidx >= len(PLUGIN_LANG_OPTIONS):
            pidx = 0
        sidx = self._translate_service_index()
        name = self._get_user_first_name()
        welcome_template = str(self._tr("welcome_divider") or "welcome_divider")
        try:
            welcome_text = str(welcome_template).format(name=name)
        except Exception:
            welcome_text = str(welcome_template)
        welcome_text = (
            str(welcome_text)
            .replace("{name}", str(name))
            .replace("{{name}}", str(name))
            .replace("{ name }", str(name))
        )

        items = [
            Divider(text=welcome_text),
            Divider(),
            Switch(
                key="tlite_enabled",
                text=self._tr("settings_enable"),
                default=True,
                icon="msg_translate",
                on_change=lambda v: BulletinHelper.show_info(self._tr("bulletin_enabled") if bool(v) else self._tr("bulletin_disabled")),
            ),
            Selector(
                key="tlite_target_lang",
                text=self._tr("settings_target_lang"),
                items=LANG_LABELS,
                default=idx,
                icon="msg_language",
                on_change=lambda i: self._on_target_lang_changed(i),
            ),
            Selector(
                key="tlite_service",
                text=self._tr("settings_translate_service"),
                items=self._translate_service_option_labels(),
                default=sidx,
                icon="msg_arrow_avatar",
                on_change=lambda i: self.set_setting("tlite_service", str(SERVICE_OPTIONS[int(i)][0])),
            ),
            Divider(),
            Selector(
                key="tlite_plugin_lang",
                text=self._tr("settings_plugin_lang"),
                items=[x[0] for x in PLUGIN_LANG_OPTIONS],
                default=pidx,
                icon="msg_plugins_solar",
                on_change=lambda i: self._on_plugin_lang_selector_changed(i),
            ),
        ]
        items.append(
            Text(
                text=self._tr("settings_about"),
                icon="msg2_reactions2",
                on_click=self._on_about_click,
            )
        )
        return items

    def _setup_chat_hooks(self):
        try:
            cls = JClass.forName("org.telegram.ui.ChatActivity")
        except Exception as e:
            self._dlog(f"ChatActivity resolve fail: {e}")
            return
        try:
            ctx_cls = find_class("android.content.Context")
            m = cls.getDeclaredMethod("createView", ctx_cls)
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, TLLiteChatCreateHook(self)))
            self._dlog("hook chat createView ok")
        except Exception as e:
            self._dlog(f"hook chat createView fail: {e}")
        try:
            m = cls.getDeclaredMethod("onResume")
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, TLLiteChatResumeHook(self)))
            self._dlog("hook chat onResume ok")
        except Exception as e:
            self._dlog(f"hook chat onResume fail: {e}")
        try:
            m = cls.getDeclaredMethod("onPause")
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, TLLiteChatPauseHook(self)))
            self._dlog("hook chat onPause ok")
        except Exception as e:
            self._dlog(f"hook chat onPause fail: {e}")

    def on_plugin_load(self):
        self._dlog("plugin load")
        self._load_telemetry_queue()
        try:
            self.add_on_send_message_hook()
            self._dlog("send hook registered")
        except Exception as e:
            self._dlog(f"failed to register send hook: {e}")
        self._setup_chat_hooks()
        self._setup_settings_header_hook()
        self._add_menu_items()
        try:
            from client_utils import run_on_queue
            run_on_queue(lambda: self._sync_assets())
        except Exception:
            self._sync_assets()
        try:
            run_on_ui_thread(self._maybe_show_first_install_welcome)
        except Exception:
            pass
        try:
            self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
        except Exception:
            pass
        try:
            if not bool(self.get_setting("tlite_stats_install_event_sent_v1", False)):
                self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                self.set_setting("tlite_stats_install_event_sent_v1", True)
        except Exception:
            pass

    def on_plugin_unload(self):
        self._dlog("plugin unload")
        try:
            for h in list(self._hooks):
                try:
                    self.unhook_method(h)
                except Exception:
                    pass
            self._hooks = []
        except Exception:
            pass
        try:
            if self._settings_header_hook:
                self.unhook_method(self._settings_header_hook)
                self._settings_header_hook = None
        except Exception:
            pass
        try:
            if self._chat_menu_item:
                self.remove_menu_item(self._chat_menu_item)
                self._chat_menu_item = None
        except Exception:
            pass
        try:
            run_on_ui_thread(self._detach_apple_button)
        except Exception:
            pass
        try:
            self._telemetry_flush_async()
        except Exception:
            pass

    def on_send_message_hook(self, account, params):
        try:
            if self._suppress_next_hook:
                self._suppress_next_hook = False
                return HookResult(strategy=HookStrategy.DEFAULT)
            if self._skip_next_translation_send:
                self._skip_next_translation_send = False
                return HookResult(strategy=HookStrategy.DEFAULT)

            try:
                raw_msg = None
                if hasattr(params, "message") and isinstance(params.message, str):
                    raw_msg = params.message
                elif isinstance(params, dict):
                    mv = params.get("message", None)
                    if isinstance(mv, str):
                        raw_msg = mv
                if isinstance(raw_msg, str):
                    cmd = raw_msg.strip().lower()
                    first_token = (cmd.split(" ", 1)[0] if cmd else "")
                    if (
                        first_token == "!lite"
                        or first_token.startswith("!lite@")
                        or first_token == ".lite"
                        or first_token.startswith(".lite@")
                    ):
                        try:
                            params.message = ""
                        except Exception:
                            pass
                        try:
                            params["message"] = ""
                        except Exception:
                            pass
                        try:
                            run_on_ui_thread(self._open_plugin_settings)
                        except Exception:
                            self._open_plugin_settings()
                        return HookResult(strategy=HookStrategy.CANCEL)
            except Exception as e:
                self._dlog(f"command parse fail: {e}")

            if not bool(self.get_setting("tlite_enabled", True)):
                return HookResult()

            text = str(getattr(params, "caption", "") or "").strip()
            using_caption = bool(text)
            if not text:
                text = str(getattr(params, "message", "") or "")

            if self._should_skip_text(text, params):
                return HookResult()

            did = self._extract_dialog_id(params=params, fragment=self._chat_fragment_ref)
            if not did:
                try:
                    did = int(getattr(self, "_chat_dialog_id_ref", 0) or 0)
                except Exception:
                    did = 0
            cfg = self._chat_config(did) if did else {"enabled": False, "lang": self._global_target_lang()}
            if not bool(cfg.get("enabled", False)):
                return HookResult()

            dst = str(cfg.get("lang") or self._global_target_lang())
            self._dlog(f"resolved target={dst} did={did}")
            entities_orig = self._extract_entities_for_text(params, using_caption)

            try:
                from client_utils import run_on_queue, get_send_messages_helper
            except Exception as e:
                self._dlog(f"queue api unavailable, fallback sync: {e}")
                source_for_translate = self._entities_to_markdown(text, entities_orig) if entities_orig else text
                translated = self._translate_text(source_for_translate, dst)
                if not translated:
                    BulletinHelper.show_error(self._tr("bulletin_failed"))
                    return HookResult()
                try:
                    self._telemetry_queue_event("feature_use", feature="translate_send", count=1, force_flush=False)
                except Exception:
                    pass
                parsed_text, parsed_entities = self._parse_markdown_to_entities(translated) if entities_orig else (translated, [])
                if using_caption:
                    params.caption = parsed_text
                else:
                    params.message = parsed_text
                if entities_orig and parsed_entities:
                    self._apply_outgoing_entities(params, using_caption, parsed_entities)
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            def _translate_and_send():
                source_for_translate = self._entities_to_markdown(text, entities_orig) if entities_orig else text
                translated = self._translate_text(source_for_translate, dst)
                if translated:
                    try:
                        self._telemetry_queue_event("feature_use", feature="translate_send", count=1, force_flush=False)
                    except Exception:
                        pass
                    try:
                        parsed_text, parsed_entities = self._parse_markdown_to_entities(translated) if entities_orig else (translated, [])
                        if using_caption:
                            params.caption = parsed_text
                        else:
                            params.message = parsed_text
                        if entities_orig and parsed_entities:
                            self._apply_outgoing_entities(params, using_caption, parsed_entities)
                    except Exception as e:
                        self._dlog(f"apply translated text fail: {e}")
                else:
                    self._dlog("translation returned empty, sending original")
                try:
                    self._suppress_next_hook = True
                except Exception:
                    pass
                try:
                    run_on_ui_thread(lambda: get_send_messages_helper().sendMessage(params))
                except Exception as e:
                    self._dlog(f"sendMessage error: {e}")

            run_on_queue(_translate_and_send)
            return HookResult(strategy=HookStrategy.CANCEL)
        except Exception as e:
            self._dlog(f"hook error: {e}")
            return HookResult()
